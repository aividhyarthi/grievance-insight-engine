# Server
PORT=3001
DATABASE_PATH=./data/compliance.db

# JWT
JWT_SECRET=change-me-to-a-random-string

# Admin emails (comma-separated, auto-promoted to admin role)
ADMIN_EMAILS=admin@example.com

# Detection API Keys (add as you onboard providers)
HIVE_API_KEY=
SENSITY_API_KEY=
ARYA_API_KEY=
RESEMBLE_API_KEY=
OPENAI_API_KEY=

# File uploads
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
