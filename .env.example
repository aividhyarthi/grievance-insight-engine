# AEO Citation Tracker - Environment Configuration
# Copy this file to .env and fill in your API keys

# ─────────────────────────────────────────
# Perplexity API (Free credits on signup)
# Sign up at: https://www.perplexity.ai/api
# ─────────────────────────────────────────
PERPLEXITY_API_KEY=

# ─────────────────────────────────────────
# SerpAPI (100 free searches/month)
# Sign up at: https://serpapi.com
# Used for: Google AI Overviews scraping
# ─────────────────────────────────────────
SERPAPI_KEY=

# ─────────────────────────────────────────
# OpenAI API (Pay-as-you-go)
# Sign up at: https://platform.openai.com
# Used for: ChatGPT Search & Chat citations
# ─────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────
# App Config
# ─────────────────────────────────────────
# Set to "true" to force demo mode even with API keys
FORCE_DEMO_MODE=false

# Port to run the server on
PORT=8000
