# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real secrets

# Required for AI-generated captions (optional if entered in the UI)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Flask secret key (auto-generated in production via render.yaml)
SECRET_KEY=change-me-in-production

# Set to "true" during local development
FLASK_DEBUG=false
