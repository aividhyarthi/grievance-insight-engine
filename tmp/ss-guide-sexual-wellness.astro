---
import Layout from '../../layouts/Layout.astro';
import { webPageSchema, breadcrumbSchema } from '../../lib/schema';

const structuredData = [
  webPageSchema({
    name: 'Sexual Wellness & Intimacy in Perimenopause | The Second Spring',
    description: 'Changes in libido, vaginal dryness, and discomfort during sex are medical symptoms — not things to simply endure. A compassionate, clear guide for Indian women.',
    url: '/guide/sexual-wellness',
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Guide', url: '/guide' },
    { name: 'Sexual Wellness', url: '/guide/sexual-wellness' },
  ]),
];
---

<Layout
  title="Sexual Wellness & Intimacy in Perimenopause | The Second Spring"
  description="Changes in libido, vaginal dryness, and discomfort during sex are medical symptoms — not things to simply endure. A compassionate, clear guide for Indian women."
  structuredData={structuredData}
>

  <!-- HERO -->
  <section class="ig-hero">
    <div class="container">
      <div class="ig-hero-inner">
        <div class="ig-eyebrow">🌸 Topic Guide</div>
        <h1>Sexual Wellness in Perimenopause</h1>
        <p>Loss of desire, vaginal discomfort, and changes in intimacy during perimenopause are hormonal and medical — not signs of ageing or relationship failure.</p>
        <div class="ig-share-row">
          <span class="ig-share-label">Share this guide</span>
          <a href="https://wa.me/?text=Sexual wellness in perimenopause explained — https://thesecondspring.org/guide/sexual-wellness" target="_blank" class="ig-share-btn ig-wa">WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 01 — THE HORMONAL ROOT -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label">01 / Why This Happens</div>
      <h2 class="ig-section-title">The hormonal reasons intimacy changes during perimenopause</h2>

      <div class="mechanism-grid">
        <div class="mechanism-card">
          <div class="mechanism-icon">🌸</div>
          <h3 class="mechanism-title">Oestrogen decline → GSM</h3>
          <p class="mechanism-desc">Oestrogen maintains the elasticity, thickness, and lubrication of vaginal tissue. As it falls, tissue thins and dries — a condition called <strong>genitourinary syndrome of menopause (GSM)</strong>. This affects 50–70% of postmenopausal women but is massively undertreated.</p>
        </div>
        <div class="mechanism-card">
          <div class="mechanism-icon">⚡</div>
          <h3 class="mechanism-title">Testosterone decline</h3>
          <p class="mechanism-desc">Testosterone plays a key role in sexual desire in women. It also declines during perimenopause — reducing libido, energy, and physical sensitivity. This is a real, measurable hormonal change — not a psychological one.</p>
        </div>
        <div class="mechanism-card">
          <div class="mechanism-icon">🔄</div>
          <h3 class="mechanism-title">Indirect factors</h3>
          <p class="mechanism-desc">Fatigue, poor sleep, mood changes, body image shifts, and the psychological weight of multiple symptoms all further reduce desire. Addressing the physical symptoms often restores far more than expected.</p>
        </div>
      </div>

      <div class="ig-callout">
        <span class="ig-callout-icon">🇮🇳</span>
        <span>In India, women rarely discuss sexual symptoms with their doctor — and doctors rarely ask. This means GSM, which is both common and <strong>highly treatable</strong>, goes untreated for years. You are not alone in this, and you deserve to be asked.</span>
      </div>

      <div class="symptom-link-row">
        <a href="/guide/symptoms/low-libido" class="symptom-link">Read more: Low libido as a perimenopause symptom →</a>
      </div>
    </div>
  </section>

  <!-- SECTION 02 — GSM EXPLAINED -->
  <section class="ig-section bg-cream">
    <div class="container">
      <div class="ig-card-label center">02 / Understanding GSM</div>
      <h2 class="ig-section-title center">Genitourinary Syndrome of Menopause (GSM) — what it is and why it matters</h2>
      <p class="ig-section-sub center">GSM affects the vagina, vulva, urethra, and bladder. Unlike hot flashes, which often reduce over time, GSM tends to worsen if left untreated — making early treatment important.</p>

      <div class="gsm-clusters">
        <div class="gsm-card">
          <div class="gsm-icon">💧</div>
          <div class="gsm-cluster-title">Vaginal dryness</div>
          <p class="gsm-cluster-desc">Persistent dryness, itching, or burning in and around the vagina — present all the time, not only during sex. Often mistaken for infection.</p>
        </div>
        <div class="gsm-card">
          <div class="gsm-icon">🔴</div>
          <div class="gsm-cluster-title">Discomfort during sex</div>
          <p class="gsm-cluster-desc">Tightness, pain, or tearing sensation during intercourse. Caused by thinning, less elastic tissue and reduced natural lubrication. Fully treatable.</p>
        </div>
        <div class="gsm-card">
          <div class="gsm-icon">⚡</div>
          <div class="gsm-cluster-title">Urinary urgency</div>
          <p class="gsm-cluster-desc">Sudden, strong urge to urinate. Oestrogen maintains bladder and urethral tissue — as it falls, urgency, frequency, and mild leakage increase.</p>
        </div>
        <div class="gsm-card">
          <div class="gsm-icon">🔁</div>
          <div class="gsm-cluster-title">Recurrent UTIs</div>
          <p class="gsm-cluster-desc">Women who never had frequent UTIs find them increasing in perimenopause. This is a GSM symptom — treating GSM often reduces UTI frequency significantly.</p>
        </div>
      </div>

      <div class="treatment-box">
        <div class="treatment-box-title">Treatments available in India</div>
        <div class="treatment-grid">
          <div class="treatment-item">
            <div class="treatment-label">Vaginal oestrogen cream</div>
            <div class="treatment-note">Ovestin, Premarin cream — prescription. Local application with minimal systemic absorption. Safe for most women, including those who cannot take systemic HRT.</div>
          </div>
          <div class="treatment-item">
            <div class="treatment-label">Mirena IUD</div>
            <div class="treatment-note">Can help with uterine-related symptoms. Discuss with your gynaecologist as part of an overall perimenopause plan.</div>
          </div>
          <div class="treatment-item">
            <div class="treatment-label">Non-hormonal vaginal moisturisers</div>
            <div class="treatment-note">RepHresh, hyaluronic acid products — available without prescription. Used regularly (not just during sex) for ongoing moisture restoration.</div>
          </div>
          <div class="treatment-item">
            <div class="treatment-label">Hyaluronic acid products</div>
            <div class="treatment-note">Increasingly available in Indian pharmacies and online. Effective for mild to moderate dryness. Can be used alongside vaginal oestrogen.</div>
          </div>
        </div>
        <div class="ig-callout ig-callout--peach" style="margin-top:1.5rem;">
          <span class="ig-callout-icon">💡</span>
          <span><strong>Vaginal oestrogen is local — not systemic.</strong> It acts directly on vaginal tissue with minimal absorption into the bloodstream. This makes it appropriate for the vast majority of women, including many who are advised against systemic HRT. Women with a history of breast cancer or other hormone-sensitive cancers should discuss vaginal oestrogen specifically with their oncologist before use — guidance varies and individual risk must be assessed. Ask your gynaecologist specifically about this.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 03 — LIBIDO -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label">03 / Changes in Desire</div>
      <h2 class="ig-section-title">Changes in sexual desire are common, hormonal, and addressable</h2>

      <div class="libido-grid">
        <div class="libido-main">
          <p class="libido-lead">Loss of desire affects the majority of perimenopausal women — and is often the symptom women feel most alone with. It is not a sign of not loving your partner. It is physiological.</p>

          <div class="libido-points">
            <div class="libido-point">
              <div class="lp-icon">🧪</div>
              <div class="lp-content">
                <div class="lp-title">Testosterone therapy</div>
                <div class="lp-desc">Available and appropriate for some women experiencing significant loss of desire. Discuss with a menopause-specialist gynaecologist — not all are familiar with this option, but it is evidence-based and used internationally.</div>
              </div>
            </div>
            <div class="libido-point">
              <div class="lp-icon">🔗</div>
              <div class="lp-content">
                <div class="lp-title">Fix the foundation first</div>
                <div class="lp-desc">Addressing the other symptoms often restores desire: treat the vaginal dryness, the pain during sex, the fatigue, the mood disruption. Many women find that desire returns once sex is no longer associated with discomfort.</div>
              </div>
            </div>
            <div class="libido-point">
              <div class="lp-icon">💬</div>
              <div class="lp-content">
                <div class="lp-title">Communication with your partner</div>
                <div class="lp-desc">Simple, honest conversation reduces pressure and improves intimacy. Most partners are relieved to understand what is happening medically — and to know this is not about them. Consider couples counselling if intimacy has become a source of tension.</div>
              </div>
            </div>
            <div class="libido-point">
              <div class="lp-icon">🌿</div>
              <div class="lp-content">
                <div class="lp-title">Non-penetrative intimacy</div>
                <div class="lp-desc">This is a valid, important option while you are addressing physical symptoms. Redefining intimacy during this period can actually strengthen a relationship — it removes the pressure that makes symptoms worse.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="libido-sidebar">
          <div class="sidebar-box">
            <div class="sidebar-box-title">You are not alone</div>
            <div class="sidebar-stat"><span class="sidebar-stat-num">~70%</span><span class="sidebar-stat-label">of perimenopausal women report reduced sexual desire</span></div>
            <div class="sidebar-stat"><span class="sidebar-stat-num">50–70%</span><span class="sidebar-stat-label">experience GSM symptoms — most go untreated</span></div>
            <div class="sidebar-note">These are medical statistics. This is not a personal failing.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 04 — PRACTICAL GUIDE -->
  <section class="ig-section bg-cream">
    <div class="container">
      <div class="ig-card-label center">04 / Practical Steps</div>
      <h2 class="ig-section-title center">What you can do — practical options at every stage</h2>

      <div class="helps-grid">
        <div class="helps-col">
          <div class="helps-head helps-head--otc">🛒 Immediate (over the counter)</div>
          <ul class="helps-list">
            <li><strong>Water-based lubricant</strong> — use during sex; available at Indian pharmacies without prescription</li>
            <li><strong>Regular vaginal moisturiser</strong> — use 2–3 times a week, not just during sex; RepHresh and hyaluronic acid products work well</li>
            <li><strong>Vitamin E suppositories</strong> — available online; mild benefit for vaginal tissue</li>
            <li><strong>Avoid harsh soaps</strong> — the vulvar area is sensitive; use plain water or a gentle, unperfumed wash</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--prescription">💊 Prescription options</div>
          <ul class="helps-list">
            <li><strong>Vaginal oestrogen cream or pessary</strong> — ask your gynaecologist specifically; it is local and safe</li>
            <li><strong>Systemic HRT</strong> — addresses systemic oestrogen deficiency including libido, mood, sleep, and skin</li>
            <li><strong>Testosterone therapy</strong> — discuss with a menopause-specialist gynaecologist if low desire is a primary concern</li>
            <li><strong>Pelvic floor physiotherapy</strong> — referral available; addresses pain, tightness, and urinary urgency</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--relationship">💬 Relationship & communication</div>
          <ul class="helps-list">
            <li><strong>Have the conversation</strong> — most partners are relieved to understand what is happening medically rather than guessing</li>
            <li><strong>Reframe intimacy</strong> — non-penetrative intimacy can maintain closeness while physical symptoms are treated</li>
            <li><strong>Reduce performance pressure</strong> — scheduling intimacy during times of lower fatigue helps</li>
            <li><strong>Couples counselling</strong> — consider if intimacy has become a consistent source of tension or distance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 05 — TALKING TO YOUR DOCTOR -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label">05 / Advocating for Yourself</div>
      <h2 class="ig-section-title">How to talk to your gynaecologist about sexual symptoms</h2>

      <div class="advocate-grid">
        <div class="advocate-main">
          <div class="script-box">
            <div class="script-box-label">What to say — a direct script</div>
            <blockquote class="script-quote">
              "I've noticed significant changes in my libido and vaginal comfort. I know this can be related to perimenopause. Can we discuss what options exist, including vaginal oestrogen?"
            </blockquote>
            <p class="script-note">You do not need to soften this or frame it as embarrassing. It is a medical symptom. A good gynaecologist will treat it as one.</p>
          </div>

          <div class="advocate-points">
            <div class="advocate-point advocate-point--good">
              <div class="ap-label">What to expect from a good gynaecologist</div>
              <ul class="ap-list">
                <li>They should ask about your symptoms — and listen to your answers</li>
                <li>They should not dismiss symptoms as "normal ageing" without offering treatment</li>
                <li>They should offer treatment options, explain the evidence, and let you decide</li>
                <li>They should know about vaginal oestrogen and GSM</li>
              </ul>
            </div>
            <div class="advocate-point advocate-point--warning">
              <div class="ap-label">If you are dismissed</div>
              <ul class="ap-list">
                <li>You are entitled to a second opinion — always</li>
                <li>"This is normal at your age" is not a diagnosis — it is a dismissal</li>
                <li>Seek a gynaecologist with a specific interest in menopause or women's health</li>
                <li>The Second Spring can help you find the right questions to ask</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="advocate-sidebar">
          <div class="sidebar-box sidebar-box--green">
            <div class="sidebar-box-title">Remember</div>
            <p class="sidebar-reminder">Sexual health is health. It affects quality of life, relationships, mental health, and self-image. It is not a luxury concern — it is a legitimate medical issue that deserves proper treatment.</p>
            <p class="sidebar-reminder" style="margin-top:.75rem;">You are not being dramatic. You are not being difficult. You are describing real symptoms caused by measurable hormonal changes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ig-cta-section">
    <div class="container">
      <div class="ig-cta-inner">
        <div class="ig-cta-left">
          <h2>Talk privately about what you're experiencing</h2>
          <p>No judgement, no login needed. Whether it's vaginal dryness, low libido, or not knowing where to start — we're here to help you find your way forward.</p>
          <div class="ig-cta-btns">
            <a href="/chat" class="btn btn-peach btn-lg">Talk Privately →</a>
            <a href="/quiz" class="btn btn-outline-white">Check My Symptoms</a>
          </div>
        </div>
        <div class="ig-cta-stat-col">
          <div class="ig-stat"><span class="ig-stat-num">50–70%</span><span class="ig-stat-label">of postmenopausal women experience GSM — most never seek treatment</span></div>
          <div class="ig-stat"><span class="ig-stat-num">~70%</span><span class="ig-stat-label">of perimenopausal women report reduced sexual desire</span></div>
          <div class="ig-stat"><span class="ig-stat-num">Highly treatable</span><span class="ig-stat-label">GSM and libido changes respond well to the right treatment</span></div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .ig-hero {
    background: linear-gradient(135deg, #0F2A1A 0%, #1A3D2B 60%, #2A5C45 100%);
    color: #fff;
    padding: 6rem 0 5rem;
    text-align: center;
  }
  .ig-hero-inner { max-width: 680px; margin: 0 auto; }
  .ig-eyebrow { display: inline-block; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.85); font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .4rem 1rem; border-radius: 100px; margin-bottom: 1.25rem; }
  .ig-hero h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 900; letter-spacing: -.03em; color: #fff; margin-bottom: 1rem; }
  .ig-hero p { font-size: 1.1rem; color: rgba(255,255,255,.75); margin-bottom: 2rem; }
  .ig-share-row { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .ig-share-label { font-size: .85rem; color: rgba(255,255,255,.55); }
  .ig-share-btn { font-size: .82rem; font-weight: 700; padding: .45rem 1rem; border-radius: 99px; text-decoration: none; }
  .ig-wa { background: #25D366; color: #fff; }

  /* SECTIONS */
  .ig-section { padding: 5rem 0; }
  .bg-white { background: #fff; }
  .bg-cream { background: var(--cream, #F9F5F0); }
  .ig-card-label { font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--green, #1A3D2B); background: var(--green-light, #E8F0EB); display: inline-block; padding: .3rem .9rem; border-radius: 99px; margin-bottom: 1rem; }
  .ig-card-label.center { display: block; text-align: center; }
  .ig-section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 900; letter-spacing: -.025em; color: var(--text, #1a1a1a); margin-bottom: .75rem; }
  .ig-section-title.center { text-align: center; }
  .ig-section-sub { font-size: 1rem; color: var(--text-secondary, #555); line-height: 1.7; text-align: center; max-width: 640px; margin: 0 auto 3rem; }

  /* CALLOUT */
  .ig-callout { display: flex; gap: 1rem; align-items: flex-start; background: var(--green-light, #E8F0EB); border-left: 4px solid var(--green, #1A3D2B); border-radius: 0 12px 12px 0; padding: 1.1rem 1.25rem; margin-top: 2rem; font-size: .9rem; color: var(--text, #1a1a1a); line-height: 1.65; }
  .ig-callout--peach { background: #FEF3EC; border-color: #D4845A; }
  .ig-callout-icon { font-size: 1.3rem; flex-shrink: 0; }

  /* MECHANISM GRID */
  .mechanism-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .mechanism-card { background: var(--cream, #F9F5F0); border-radius: 16px; padding: 1.75rem; border: 1.5px solid var(--border-light, #eee); }
  .mechanism-icon { font-size: 2rem; margin-bottom: .75rem; }
  .mechanism-title { font-size: 1rem; font-weight: 800; color: var(--text, #1a1a1a); margin-bottom: .6rem; }
  .mechanism-desc { font-size: .87rem; color: var(--text-secondary, #555); line-height: 1.7; }

  /* SYMPTOM LINK */
  .symptom-link-row { margin-top: 2rem; }
  .symptom-link { display: inline-block; font-size: .88rem; font-weight: 700; color: var(--green, #1A3D2B); text-decoration: none; border-bottom: 2px solid var(--green-light, #E8F0EB); padding-bottom: .1rem; transition: border-color .15s; }
  .symptom-link:hover { border-color: var(--green, #1A3D2B); }

  /* GSM CLUSTERS */
  .gsm-clusters { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; margin-top: 2rem; }
  .gsm-card { background: #fff; border-radius: 16px; padding: 1.5rem; border: 1.5px solid var(--border-light, #eee); }
  .gsm-icon { font-size: 1.75rem; margin-bottom: .6rem; }
  .gsm-cluster-title { font-size: .95rem; font-weight: 800; color: var(--text, #1a1a1a); margin-bottom: .5rem; }
  .gsm-cluster-desc { font-size: .83rem; color: var(--text-secondary, #555); line-height: 1.65; }

  /* TREATMENT BOX */
  .treatment-box { background: #fff; border-radius: 20px; padding: 2rem; margin-top: 2.5rem; border: 1.5px solid var(--border-light, #eee); }
  .treatment-box-title { font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--green, #1A3D2B); margin-bottom: 1.25rem; }
  .treatment-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  .treatment-item { background: var(--cream, #F9F5F0); border-radius: 12px; padding: 1.1rem 1.25rem; }
  .treatment-label { font-size: .9rem; font-weight: 800; color: var(--text, #1a1a1a); margin-bottom: .4rem; }
  .treatment-note { font-size: .83rem; color: var(--text-secondary, #555); line-height: 1.6; }

  /* LIBIDO */
  .libido-grid { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; margin-top: 2rem; align-items: start; }
  .libido-lead { font-size: 1.05rem; color: var(--text, #1a1a1a); line-height: 1.75; margin-bottom: 2rem; border-left: 4px solid #D4845A; padding-left: 1.25rem; }
  .libido-points { display: flex; flex-direction: column; gap: 1.25rem; }
  .libido-point { display: flex; gap: 1.25rem; align-items: flex-start; background: var(--cream, #F9F5F0); border-radius: 14px; padding: 1.25rem; }
  .lp-icon { font-size: 1.5rem; flex-shrink: 0; }
  .lp-title { font-size: .95rem; font-weight: 800; color: var(--text, #1a1a1a); margin-bottom: .3rem; }
  .lp-desc { font-size: .85rem; color: var(--text-secondary, #555); line-height: 1.65; }
  .libido-sidebar {}
  .sidebar-box { background: var(--cream, #F9F5F0); border-radius: 16px; padding: 1.75rem; border: 1.5px solid var(--border-light, #eee); }
  .sidebar-box--green { background: #E8F0EB; border-color: #C8DDD0; }
  .sidebar-box-title { font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--green, #1A3D2B); margin-bottom: 1.25rem; }
  .sidebar-stat { display: flex; flex-direction: column; gap: .2rem; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(0,0,0,.06); }
  .sidebar-stat:last-of-type { border-bottom: none; }
  .sidebar-stat-num { font-size: 1.6rem; font-weight: 900; color: #D4845A; letter-spacing: -.03em; }
  .sidebar-stat-label { font-size: .8rem; color: var(--text-secondary, #555); line-height: 1.5; }
  .sidebar-note { font-size: .8rem; color: var(--text-secondary, #555); font-style: italic; margin-top: .5rem; }
  .sidebar-reminder { font-size: .87rem; color: var(--text, #1a1a1a); line-height: 1.65; }

  /* HELPS (reuse template pattern) */
  .helps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .helps-col { background: #fff; border-radius: 16px; padding: 1.5rem; border: 1.5px solid var(--border-light, #eee); }
  .helps-head { font-size: .9rem; font-weight: 800; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 2px solid; }
  .helps-head--otc { border-color: #7FB89A; color: #2A5C45; }
  .helps-head--prescription { border-color: #D4845A; color: #9D4E1E; }
  .helps-head--relationship { border-color: var(--green, #1A3D2B); color: var(--green, #1A3D2B); }
  .helps-list { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
  .helps-list li { font-size: .85rem; color: var(--text, #1a1a1a); line-height: 1.55; padding-left: 1rem; position: relative; }
  .helps-list li::before { content: '→'; position: absolute; left: 0; color: var(--green, #1A3D2B); font-size: .75rem; }

  /* ADVOCATE */
