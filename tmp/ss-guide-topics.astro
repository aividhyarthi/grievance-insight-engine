---
import Layout from '../../layouts/Layout.astro';

const topics = [
  {
    icon: '⚖️',
    title: 'Weight & Belly Fat',
    desc: 'Why perimenopause rewires how your body stores fat — and what actually works for Indian women.',
    time: '7 min read',
    tag: 'Popular',
    href: '/guide/weight',
    live: true,
  },
  {
    icon: '🌙',
    title: 'Sleep',
    desc: 'The three hormonal mechanisms that disrupt sleep — and evidence-based approaches to fix them.',
    time: '6 min read',
    tag: '',
    href: '/guide/sleep',
    live: true,
  },
  {
    icon: '🧠',
    title: 'Mood & Memory',
    desc: 'Anxiety, brain fog, and mood swings are hormonal — not stress or personality. Here is the science.',
    time: '7 min read',
    tag: '',
    href: '/guide/mood-memory',
    live: true,
  },
  {
    icon: '🌸',
    title: 'Sexual Wellness',
    desc: 'Low libido, vaginal dryness, and discomfort during sex are medical symptoms with medical solutions.',
    time: '7 min read',
    tag: 'India-focused',
    href: '/guide/sexual-wellness',
    live: true,
  },
  {
    icon: '✨',
    title: 'Hair & Skin',
    desc: 'Why oestrogen shapes your appearance — and practical steps for Indian women experiencing changes.',
    time: '7 min read',
    tag: '',
    href: '/guide/hair-skin',
    live: true,
  },
  {
    icon: '🌿',
    title: 'What Is Menopause?',
    desc: 'What comes after perimenopause — what changes, what to protect long-term, and what to expect.',
    time: '7 min read',
    tag: '',
    href: '/menopause',
    live: true,
  },
  {
    icon: '💊',
    title: 'HRT & Treatments',
    desc: 'A calm, balanced guide to hormone therapy — what the research actually says, and what is available in India.',
    time: '9 min read',
    tag: 'Important',
    href: '/blog/hormonal-symptom-treatments-perimenopause',
    live: true,
  },
  {
    icon: '🔬',
    title: 'Hormones Explained',
    desc: 'Oestrogen vs progesterone — what they do, how they differ, and why both matter in perimenopause.',
    time: '8 min read',
    tag: 'Start here',
    href: '/blog/oestrogen-vs-progesterone-perimenopause',
    live: true,
  },
  {
    icon: '🥗',
    title: 'Nutrition & Lifestyle',
    desc: 'How diet, exercise, and daily habits can meaningfully support your body — with Indian dietary context.',
    time: '11 min read',
    tag: '',
    href: '/blog/lifestyle-changes-perimenopause-symptoms',
    live: true,
  },
  {
    icon: '🌿',
    title: 'Natural Remedies',
    desc: 'Which alternative remedies have evidence behind them — and which are myths. Honest assessment.',
    time: '8 min read',
    tag: '',
    href: '/blog/natural-remedies-perimenopause',
    live: true,
  },
];
---

<Layout
  title="Topic Guides — The Second Spring"
  description="Deep-dive guides on weight, sleep, mood, sexual wellness, hair, skin, hormones, and HRT during perimenopause — written for Indian women."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <div class="page-eyebrow">📚 Guide</div>
        <h1>Topic Guides</h1>
        <p>In-depth guides on the subjects that matter most during perimenopause — written in plain language, with the Indian woman in mind.</p>
      </div>
    </div>
  </section>

  <!-- Topics grid -->
  <section class="section bg-cream">
    <div class="container">
      <div class="topics-grid">
        {topics.map(t => (
          <a href={t.href} class="topic-card">
            <div class="topic-card-top">
              <span class="topic-icon">{t.icon}</span>
              {t.tag && <span class="topic-tag">{t.tag}</span>}
            </div>
            <h3 class="topic-title">{t.title}</h3>
            <p class="topic-desc">{t.desc}</p>
            <div class="topic-footer">
              <span class="topic-time">⏱ {t.time}</span>
              <span class="topic-cta">Read guide →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Symptom library CTA -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="two-cta-row">
        <div class="two-cta-card two-cta-card--green">
          <div class="tcc-icon">🔍</div>
          <div>
            <h3>Symptom Library</h3>
            <p>Every perimenopause symptom explained clearly — what it feels like, why it happens, and what helps.</p>
          </div>
          <a href="/guide/symptoms" class="btn btn-primary">Explore symptoms →</a>
        </div>
        <div class="two-cta-card two-cta-card--peach">
          <div class="tcc-icon">💬</div>
          <div>
            <h3>Ask our companion</h3>
            <p>Questions on any topic answered privately, any time. No login, no judgement.</p>
          </div>
          <a href="/chat" class="btn btn-peach">Talk privately →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm bg-green">
    <div class="container">
      <div class="cta-block">
        <div>
          <h2 class="section-title">Not sure where to start?</h2>
          <p class="section-sub">Our free 3-minute symptom check will tell you which topics are most relevant for you.</p>
        </div>
        <a href="/quiz" class="btn btn-primary btn-lg">Check my symptoms →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .topic-card {
    background: #fff;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: .75rem;
    transition: box-shadow .22s, border-color .22s, transform .18s;
    cursor: pointer;
  }

  .topic-card:hover {
    box-shadow: 0 8px 32px rgba(61,122,95,.12);
    border-color: var(--green);
    transform: translateY(-2px);
  }

  .topic-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
  }

  .topic-icon { font-size: 2rem; }

  .topic-tag {
    font-size: .68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .08em;
    background: var(--green-light);
    color: var(--green);
    padding: .2rem .65rem;
    border-radius: 99px;
  }

  .topic-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.02em;
    line-height: 1.3;
  }

  .topic-desc {
    font-size: .88rem;
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
  }

  .topic-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: .75rem;
    border-top: 1.5px solid var(--border-light);
    margin-top: auto;
  }

  .topic-time {
    font-size: .78rem;
    color: var(--text-muted);
  }

  .topic-cta {
    font-size: .82rem;
    font-weight: 700;
    color: var(--green);
  }

  .two-cta-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .two-cta-card {
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .two-cta-card--green {
    background: var(--green-light);
    border: 1.5px solid var(--green);
  }

  .two-cta-card--peach {
    background: #FEF3EC;
    border: 1.5px solid #D4845A;
  }

  .tcc-icon { font-size: 1.75rem; }

  .two-cta-card h3 {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: .3rem;
  }

  .two-cta-card p {
    font-size: .88rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .cta-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .topics-grid { grid-template-columns: 1fr; }
    .two-cta-row { grid-template-columns: 1fr; }
    .cta-block { flex-direction: column; }
  }
</style>
