---
import Layout from '../../layouts/Layout.astro';

const topics = [
  {
    icon: '🌙',
    title: 'Sleep & perimenopause',
    desc: 'Why perimenopause disrupts sleep, what\'s happening in your brain, and practical strategies for better rest — from sleep hygiene to medical options.',
    time: '8 min read',
    tag: 'Popular',
  },
  {
    icon: '🌊',
    title: 'Managing mood changes',
    desc: 'Understanding the hormonal roots of irritability, anxiety, and low mood during perimenopause — and evidence-based approaches to feeling more like yourself.',
    time: '9 min read',
    tag: '',
  },
  {
    icon: '🔬',
    title: 'Hormones explained simply',
    desc: 'A clear, jargon-free explanation of oestrogen, progesterone, and testosterone — what they do, what happens when they fall, and why this matters for how you feel.',
    time: '10 min read',
    tag: 'Start here',
  },
  {
    icon: '🥗',
    title: 'Nutrition & lifestyle',
    desc: 'How what you eat and how you live can meaningfully support your body during perimenopause — including Indian dietary considerations and practical tips.',
    time: '11 min read',
    tag: '',
  },
  {
    icon: '💞',
    title: 'Relationships & intimacy',
    desc: 'How perimenopause affects your relationships — with partners, family, and yourself. Navigating libido changes, communication, and emotional shifts together.',
    time: '8 min read',
    tag: '',
  },
  {
    icon: '🏃‍♀️',
    title: 'Exercise & movement',
    desc: 'The right kind of movement can profoundly ease perimenopausal symptoms. This guide covers what the evidence says and how to build a sustainable routine.',
    time: '7 min read',
    tag: '',
  },
  {
    icon: '🌿',
    title: 'Ayurveda & traditional remedies',
    desc: 'What traditional Indian medicine says about this transition, which remedies have evidence behind them, and how to integrate Ayurvedic support safely.',
    time: '9 min read',
    tag: 'India-focused',
  },
  {
    icon: '💊',
    title: 'Understanding HRT/MHT',
    desc: 'A calm, balanced guide to hormone replacement therapy — what it is, what the research actually says about safety, and how to have an informed conversation with your doctor.',
    time: '12 min read',
    tag: 'Important',
  },
];
---

<Layout
  title="Topic Guides – The Second Spring"
  description="Deep-dive guides on sleep, mood, hormones, nutrition, relationships, exercise, Ayurveda, and HRT during perimenopause — written for Indian women."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <div class="page-eyebrow">📚 Guide</div>
        <h1>Topic Guides</h1>
        <p>Deep dives on the subjects that matter most during perimenopause — written in plain language, with the Indian woman in mind.</p>
      </div>
    </div>
  </section>

  <!-- Coming soon notice -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="notice-banner">
        <span class="notice-icon">✍️</span>
        <div>
          <strong>These guides are being written now.</strong>
          <p>We're crafting each one carefully — with real information, Indian context, and the warmth you deserve. In the meantime, our AI companion can answer your questions on any of these topics right now, privately and without waiting.</p>
        </div>
        <a href="/chat" class="btn btn-primary" style="flex-shrink:0;">Ask our companion →</a>
      </div>
    </div>
  </section>

  <!-- Topics grid -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="section-label">All topics</span>
        <h2 class="section-title">Explore what's coming</h2>
        <p class="section-sub">Eight comprehensive guides covering everything you need to navigate perimenopause with confidence.</p>
      </div>
      <div class="topics-grid">
        {topics.map(t => (
          <a href="/chat" class="topic-card">
            <div class="topic-card-top">
              <span class="topic-icon">{t.icon}</span>
              {t.tag && <span class="topic-tag">{t.tag}</span>}
            </div>
            <h3 class="topic-title">{t.title}</h3>
            <p class="topic-desc">{t.desc}</p>
            <div class="topic-footer">
              <span class="topic-time">⏱ {t.time}</span>
              <span class="topic-cta">Chat about this →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Expanding notice -->
  <section class="section-sm bg-white">
    <div class="container">
      <div class="expand-block">
        <div class="expand-icon">🌱</div>
        <div>
          <h2 class="expand-title">This guide is growing</h2>
          <p class="expand-text">We're publishing new topic guides regularly. Each one is reviewed for accuracy and written with Indian women's lives in mind — our food, our families, our healthcare system, and the cultural context that shapes our experience of this transition.</p>
          <p class="expand-text">To be notified when new guides go live, reach out at <a href="mailto:hello@thesecondspring.com">hello@thesecondspring.com</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm bg-green">
    <div class="container">
      <div class="cta-block">
        <div>
          <h2 class="section-title">Don't want to wait for the guides?</h2>
          <p class="section-sub">Our companion can answer questions on any of these topics right now — personally and privately.</p>
        </div>
        <a href="/chat" class="btn btn-primary btn-lg">Start a conversation →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .notice-banner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: var(--green-light);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    flex-wrap: wrap;
  }
  .notice-icon { font-size: 1.5rem; flex-shrink: 0; }
  .notice-banner strong { display: block; font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: .3rem; }
  .notice-banner p { font-size: .9rem; color: var(--text-secondary); line-height: 1.65; }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .topic-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-decoration: none;
    color: var(--text);
    transition: all .22s;
  }

  .topic-card:hover {
    border-color: var(--green);
    box-shadow: 0 8px 28px rgba(61,122,95,.12);
    transform: translateY(-2px);
  }

  .topic-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .topic-icon { font-size: 1.75rem; }

  .topic-tag {
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    background: var(--peach-light);
    color: var(--peach-dark);
    padding: .2rem .6rem;
    border-radius: 100px;
  }

  .topic-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: .6rem;
    line-height: 1.3;
  }

  .topic-desc {
    font-size: .88rem;
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .topic-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border-light);
    padding-top: .85rem;
    margin-top: auto;
  }

  .topic-time {
    font-size: .78rem;
    color: var(--text-muted);
  }

  .topic-cta {
    font-size: .83rem;
    font-weight: 600;
    color: var(--green);
  }

  .topic-card:hover .topic-cta { color: var(--green-dark); }

  .expand-block {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 760px;
  }

  .expand-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .expand-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: .6rem;
  }

  .expand-text {
    font-size: .93rem;
    color: var(--text-secondary);
    line-height: 1.72;
    margin-bottom: .75rem;
  }

  .cta-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .topics-grid { grid-template-columns: 1fr; }
    .notice-banner { flex-direction: column; }
    .cta-block { flex-direction: column; }
  }
</style>
