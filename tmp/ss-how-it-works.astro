---
import Layout from '../layouts/Layout.astro';

const steps = [
  {
    num: '01',
    icon: '💬',
    title: 'Start a private conversation',
    desc: 'Open the chat — no sign-up, no login, no name required. Type exactly what\'s on your mind. You can describe your symptoms, ask about a specific experience, or simply say "I don\'t know where to start" — the companion will meet you there.',
    detail: 'Your conversation is private by design. We do not share, sell, or expose your data. You can chat from your phone in 5 minutes of privacy — no one else needs to know.',
  },
  {
    num: '02',
    icon: '🌿',
    title: 'Receive personalised, empathetic information',
    desc: 'The Second Spring companion draws on up-to-date medical information and an understanding of the Indian woman\'s context — our bodies, our families, our healthcare system, and our cultural relationship with this transition.',
    detail: 'Every response is designed to feel like a conversation with a knowledgeable, warm friend — not a medical textbook. You\'ll receive clear explanations, validated information, and practical suggestions tailored to what you\'ve shared.',
  },
  {
    num: '03',
    icon: '🩺',
    title: 'Find your next step',
    desc: 'The Second Spring helps you understand when something warrants a doctor\'s visit, what to say when you get there, and what specialist support might look like. We help you bridge the gap between feeling confused and getting real care.',
    detail: 'When appropriate, we can connect you with verified gynaecologists and menopause specialists. We also provide guides on preparing for appointments, advocating for yourself, and understanding your treatment options.',
  },
];

const differentiators = [
  {
    icon: '🔒',
    title: 'Completely private',
    desc: 'No account required. No personal data collected. Chat from wherever you feel safe — a quiet moment at work, from your bedroom, from anywhere. Your questions stay yours.',
  },
  {
    icon: '🌸',
    title: 'Indian context, always',
    desc: 'Most perimenopause resources are written for Western women. The Second Spring understands India-specific onset ages, dietary context, joint family dynamics, cultural taboos, and the Indian healthcare system.',
  },
  {
    icon: '💛',
    title: 'Empathy before information',
    desc: 'We know how it feels to be dismissed, confused, and alone in this. The companion is designed to listen first, validate your experience, and then provide information — never the other way around.',
  },
  {
    icon: '🏥',
    title: 'Bridges to real care',
    desc: 'We are not a replacement for medical care — we\'re a bridge to it. We help you understand when to seek help, what to ask, and, where relevant, connect you with qualified specialists.',
  },
];

const faqs = [
  {
    q: 'Is The Second Spring actually a doctor?',
    a: 'No. The Second Spring is an AI-powered companion that provides general health information. It is not a substitute for professional medical advice, diagnosis, or treatment. We always encourage users to speak with a qualified GP or gynaecologist for personal medical decisions.',
  },
  {
    q: 'How private is my conversation really?',
    a: 'Your conversations are private. We do not require you to create an account or provide your name, and we do not sell or share personal data. You can read more in our Privacy Policy.',
  },
  {
    q: 'Can The Second Spring help me find a doctor in my city?',
    a: 'We are working on a verified specialist directory. In the meantime, our companion can provide guidance on what type of specialist to look for and what questions to ask when evaluating one.',
  },
  {
    q: 'Is this service only for women already in perimenopause?',
    a: 'Not at all. Many women come to us wondering whether they might be in perimenopause — that\'s a perfectly valid place to start. The service is useful at any stage of your journey, from early questions to navigating symptoms to managing postmenopause.',
  },
  {
    q: 'What languages is The Second Spring available in?',
    a: 'Currently in English, with Hindi support in development. If you have a language request, please reach out to us at hello@thesecondspring.com.',
  },
];
---

<Layout
  title="How It Works – The Second Spring"
  description="Learn how The Second Spring provides private, empathetic perimenopause support for Indian women — including our 3-step process, what makes us different, and what's free."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <div class="page-eyebrow">✦ The Second Spring</div>
        <h1>How The Second Spring works</h1>
        <p>A private, empathetic companion for every Indian woman navigating perimenopause — from first questions to finding the right care.</p>
      </div>
    </div>
  </section>

  <!-- 3-step process -->
  <section class="section bg-white">
    <div class="container">
      <div class="section-header">
        <span class="section-label">The process</span>
        <h2 class="section-title">Three steps to clarity</h2>
        <p class="section-sub">From your first confused question to confident, informed action — here's how it works.</p>
      </div>

      <div class="steps">
        {steps.map((step, i) => (
          <div class="step">
            <div class="step-left">
              <div class="step-num">{step.num}</div>
              <div class="step-icon">{step.icon}</div>
              {i < steps.length - 1 && <div class="step-line" />}
            </div>
            <div class="step-content">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.desc}</p>
              <div class="step-detail">{step.detail}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="step-cta">
        <a href="/chat" class="btn btn-peach btn-lg">Try it now — it's free →</a>
      </div>
    </div>
  </section>

  <!-- What makes us different -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header center">
        <span class="section-label">Why us</span>
        <h2 class="section-title">What makes us different</h2>
        <p class="section-sub">There are many health chatbots. There is only one designed specifically for Indian women navigating perimenopause.</p>
      </div>

      <div class="diff-grid">
        {differentiators.map(d => (
          <div class="diff-card">
            <div class="diff-icon">{d.icon}</div>
            <h3 class="diff-title">{d.title}</h3>
            <p class="diff-desc">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section bg-white">
    <div class="container">
      <div class="pricing-layout">
        <div>
          <span class="section-label">Pricing</span>
          <h2 class="section-title">Completely free to use</h2>
          <p class="body-text">
            The Second Spring companion — including unlimited private conversations, the full guide library, symptom information, and doctor preparation resources — is completely free. No subscription, no hidden fees, no credit card.
          </p>
          <p class="body-text">
            We believe access to good information about your own body should not be gated behind ability to pay. Every Indian woman deserves this.
          </p>
          <p class="body-text">
            In the future, we will offer optional paid connections to verified specialists — gynaecologists, menopause specialists, and therapists experienced in this transition. These will be clearly labelled and always optional.
          </p>
          <a href="/chat" class="btn btn-primary btn-lg" style="margin-top:1rem;">Start chatting — it's free →</a>
        </div>
        <div class="pricing-card">
          <div class="pricing-label">What's included — always free</div>
          <ul class="pricing-features">
            {[
              'Unlimited private conversations',
              'Symptom library & explanations',
              'Personalised information',
              'Doctor preparation guides',
              'Full guide library',
              'No account required',
              'No ads, ever',
            ].map(f => (
              <li class="pricing-feature">
                <span class="pf-check">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <div class="pricing-price">
            <span class="price-free">Free</span>
            <span class="price-forever">— always</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Questions</span>
        <h2 class="section-title">About the product</h2>
      </div>

      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{faq.q}</span>
              <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm bg-green">
    <div class="container">
      <div class="cta-block">
        <div>
          <h2 class="section-title">Ready to start?</h2>
          <p class="section-sub">No sign-up needed. Just open the chat and ask whatever's on your mind.</p>
        </div>
        <a href="/chat" class="btn btn-peach btn-lg">Start a private conversation →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 820px;
  }

  .step {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding-bottom: 2.5rem;
  }

  .step-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    flex-shrink: 0;
    width: 60px;
  }

  .step-num {
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .06em;
    color: var(--green);
    background: var(--green-light);
    border: 2px solid var(--green);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-icon { font-size: 1.5rem; }

  .step-line {
    width: 2px;
    flex: 1;
    min-height: 3rem;
    background: var(--border);
    margin: .25rem 0;
  }

  .step-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: .6rem;
    letter-spacing: -.02em;
  }

  .step-desc {
    font-size: .95rem;
    color: var(--text-secondary);
    line-height: 1.72;
    margin-bottom: .75rem;
  }

  .step-detail {
    font-size: .88rem;
    color: var(--text-muted);
    line-height: 1.7;
    background: var(--green-light);
    border-radius: var(--radius-sm);
    padding: .85rem 1rem;
    border-left: 3px solid var(--green);
  }

  .step-cta { margin-top: 1.5rem; }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .diff-card {
    background: #fff;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }

  .diff-icon { font-size: 2rem; margin-bottom: 1rem; }
  .diff-title { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: .5rem; }
  .diff-desc { font-size: .9rem; color: var(--text-secondary); line-height: 1.7; }

  .pricing-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .pricing-card {
    background: var(--green-dark);
    border-radius: var(--radius-lg);
    padding: 2rem;
    color: #fff;
  }

  .pricing-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.6);
    margin-bottom: 1.5rem;
  }

  .pricing-features { list-style: none; display: flex; flex-direction: column; gap: .75rem; margin-bottom: 2rem; }

  .pricing-feature {
    display: flex;
    align-items: center;
    gap: .85rem;
    font-size: .93rem;
    color: rgba(255,255,255,.9);
  }

  .pf-check {
    width: 22px;
    height: 22px;
    background: rgba(255,255,255,.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .78rem;
    font-weight: 700;
    flex-shrink: 0;
    color: #7FB89A;
  }

  .pricing-price {
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,.15);
    display: flex;
    align-items: baseline;
    gap: .5rem;
  }

  .price-free { font-size: 2.5rem; font-weight: 900; color: #fff; letter-spacing: -.04em; }
  .price-forever { font-size: 1rem; color: rgba(255,255,255,.6); }

  .faq-list { display: flex; flex-direction: column; gap: .75rem; max-width: 760px; }

  .faq-item {
    background: #fff;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-item[open] { border-color: var(--green); }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    font-size: .97rem;
    font-weight: 600;
    color: var(--text);
    transition: background .18s;
  }

  .faq-question::-webkit-details-marker { display: none; }
  .faq-question:hover { background: var(--green-light); }
  .faq-item[open] .faq-question { background: var(--green-light); border-bottom: 1.5px solid var(--border); }

  .faq-chevron { flex-shrink: 0; color: var(--green); transition: transform .22s; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }

  .faq-answer { padding: 1.1rem 1.25rem 1.25rem; font-size: .92rem; color: var(--text-secondary); line-height: 1.75; }

  .cta-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .diff-grid { grid-template-columns: 1fr; }
    .pricing-layout { grid-template-columns: 1fr; }
    .cta-block { flex-direction: column; }
  }
</style>
