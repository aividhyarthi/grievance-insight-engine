---
import Layout from '../layouts/Layout.astro';

// Each hotspot maps to a body zone. x/y are percentages over the figure box.
// `q` is the symptom question; `blog` links to the matching journal article.
const spots = [
  { id: 'mind',    label: 'Mind',     x: 50, y: 9,  color: '#2D5F7A',
    q: 'Brain fog, forgetting words mid-sentence, or trouble concentrating?',
    sign: 'Brain fog & memory changes', blog: '/blog/natural-remedies-perimenopause-brain-fog' },
  { id: 'mood',    label: 'Mood',     x: 27, y: 15, color: '#3D7A5F',
    q: 'New anxiety, mood swings, irritability, or low mood?',
    sign: 'Mood & anxiety changes', blog: '/blog/perimenopause-anxiety-triggers-easily' },
  { id: 'sleep',   label: 'Sleep',    x: 73, y: 15, color: '#1A2D4A',
    q: 'Waking at 3am, broken sleep, or night sweats?',
    sign: 'Sleep disruption & night sweats', blog: '/blog/natural-remedies-perimenopause-hot-flashes' },
  { id: 'face',    label: 'Skin',     x: 50, y: 20, color: '#B84A2E',
    q: 'Hot flashes, flushed cheeks, or suddenly drier skin?',
    sign: 'Hot flashes & skin changes', blog: '/blog/perimenopause-flushed-cheeks' },
  { id: 'chest',   label: 'Chest',    x: 50, y: 33, color: '#8A5230',
    q: 'Breast tenderness, or a fluttering / pounding heart?',
    sign: 'Breast tenderness & palpitations', blog: '/blog/perimenopause-breast-tenderness' },
  { id: 'belly',   label: 'Cycle',    x: 50, y: 50, color: '#A23E5C',
    q: 'Irregular periods, heavier bleeding, or large clots?',
    sign: 'Cycle & bleeding changes', blog: '/blog/are-blood-clots-during-period-normal' },
  { id: 'pelvis',  label: 'Intimate', x: 50, y: 60, color: '#7A4A8A',
    q: 'Vaginal dryness, discomfort during sex, or needing the toilet more?',
    sign: 'Vaginal dryness & urinary changes', blog: '/blog/why-am-i-suddenly-dry-down-there' },
  { id: 'joints',  label: 'Joints',   x: 24, y: 64, color: '#5A6B4E',
    q: 'New joint aches, stiffness, or hip and muscle pain?',
    sign: 'Joint & muscle aches', blog: '/blog/perimenopause-joint-pain' },
  { id: 'energy',  label: 'Energy',   x: 76, y: 50, color: '#C8862E',
    q: 'Deep fatigue that sleep does not fix, or sudden weight changes?',
    sign: 'Fatigue & weight changes', blog: '/blog/perimenopause-weight-gain-belly-fat' },
];
---
<Layout
  title="Am I in Perimenopause? — Interactive Body Check — The Second Spring"
  description="Tap where your body feels different and see whether your pattern points to perimenopause. An interactive, visual symptom check — no buttons, just your body."
>

<main class="ck-page">

  <section class="ck-hero">
    <p class="ck-eyebrow">Interactive Check</p>
    <h1 class="ck-title">Where does your body feel different?</h1>
    <p class="ck-sub">Tap each area where something has changed. As you go, we will show you whether your pattern points to perimenopause — and exactly what is happening in your body.</p>
  </section>

  <section class="ck-stage">

    <!-- The figure + hotspots -->
    <div class="ck-figure-wrap">
      <div class="ck-figure" id="ck-figure">
        <svg viewBox="0 0 200 440" class="ck-silhouette" aria-hidden="true">
          <!-- simple feminine silhouette -->
          <path d="M100 18
                   c-13 0 -23 10 -23 23 c0 9 4 16 10 20
                   c-10 4 -16 12 -18 24 l-9 52 c-1 7 9 9 11 2 l7 -34
                   l-3 46 c-2 14 -4 28 -2 42 l4 70 c1 8 -1 16 -3 24 l-7 56
                   c-1 9 12 11 14 2 l9 -64 l5 0 l9 64 c2 9 15 7 14 -2 l-7 -56
                   c-2 -8 -4 -16 -3 -24 l4 -70 c2 -14 0 -28 -2 -42 l-3 -46 l7 34
                   c2 7 12 5 11 -2 l-9 -52 c-2 -12 -8 -20 -18 -24
                   c6 -4 10 -11 10 -20 c0 -13 -10 -23 -23 -23 z"
                fill="#E8D9C8" stroke="#D8C4AE" stroke-width="1.5"/>
        </svg>

        {spots.map((s) => (
          <button class="ck-spot" data-id={s.id} style={`left:${s.x}%; top:${s.y}%; --c:${s.color};`} aria-label={s.label}>
            <span class="ck-spot-dot"></span>
            <span class="ck-spot-label">{s.label}</span>
          </button>
        ))}
      </div>

      <div class="ck-meter">
        <div class="ck-meter-track"><div class="ck-meter-fill" id="ck-fill"></div></div>
        <p class="ck-meter-text" id="ck-meter-text">Tap an area to begin</p>
      </div>
    </div>

    <!-- Question card (slides in when a spot is tapped) -->
    <div class="ck-card" id="ck-card" hidden>
      <p class="ck-card-zone" id="ck-card-zone"></p>
      <p class="ck-card-q" id="ck-card-q"></p>
      <div class="ck-card-actions">
        <button class="ck-btn ck-btn-yes" id="ck-yes">Yes, that's me</button>
        <button class="ck-btn ck-btn-no" id="ck-no">Not really</button>
      </div>
    </div>

    <button class="ck-result-trigger" id="ck-see-result" hidden>See my result →</button>

  </section>

  <!-- Result -->
  <section class="ck-result" id="ck-result" hidden>
    <div class="ck-result-inner">
      <p class="ck-result-eyebrow" id="ck-result-eyebrow"></p>
      <h2 class="ck-result-title" id="ck-result-title"></h2>
      <p class="ck-result-body" id="ck-result-body"></p>

      <div class="ck-result-list" id="ck-result-list"></div>

      <div class="ck-disclaimer">
        <strong>This is not a diagnosis.</strong> Only a doctor can confirm perimenopause, using your symptoms and cycle history. This check is here to help you recognise a pattern and have a more confident conversation with your gynaecologist.
      </div>

      <div class="ck-result-cta">
        <a href="/blog/when-to-see-doctor-perimenopause" class="ck-cta-primary">When should I see a doctor?</a>
        <button class="ck-cta-secondary" id="ck-restart">Start again</button>
      </div>
    </div>
  </section>

</main>

<script define:vars={{ spots }}>
  const state = {};           // id -> true/false
  const order = spots.map(s => s.id);
  let current = null;

  const figure   = document.getElementById('ck-figure');
  const card     = document.getElementById('ck-card');
  const cardZone = document.getElementById('ck-card-zone');
  const cardQ    = document.getElementById('ck-card-q');
  const fill     = document.getElementById('ck-fill');
  const meterTxt = document.getElementById('ck-meter-text');
  const seeBtn   = document.getElementById('ck-see-result');

  function spotById(id) { return spots.find(s => s.id === id); }

  function openCard(id) {
    current = id;
    const s = spotById(id);
    cardZone.textContent = s.label;
    cardZone.style.color = s.color;
    cardQ.textContent = s.q;
    card.hidden = false;
    card.classList.remove('ck-card-in');
    void card.offsetWidth;            // restart animation
    card.classList.add('ck-card-in');
    card.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function answer(yes) {
    if (!current) return;
    state[current] = yes;
    const btn = document.querySelector(`.ck-spot[data-id="${current}"]`);
    btn.classList.remove('ck-spot-yes', 'ck-spot-no');
    btn.classList.add(yes ? 'ck-spot-yes' : 'ck-spot-no');
    btn.classList.add('ck-spot-done');
    card.hidden = true;
    current = null;
    updateMeter();
  }

  function updateMeter() {
    const answered = Object.keys(state).length;
    const yesCount = Object.values(state).filter(Boolean).length;
    const pct = Math.round((answered / order.length) * 100);
    fill.style.width = pct + '%';
    if (yesCount === 0 && answered === 0) {
      meterTxt.textContent = 'Tap an area to begin';
    } else {
      meterTxt.textContent = `${yesCount} symptom${yesCount === 1 ? '' : 's'} marked · ${answered} of ${order.length} areas checked`;
    }
    seeBtn.hidden = answered < 1;
  }

  figure.addEventListener('click', (e) => {
    const btn = e.target.closest('.ck-spot');
    if (btn) openCard(btn.dataset.id);
  });

  document.getElementById('ck-yes').addEventListener('click', () => answer(true));
  document.getElementById('ck-no').addEventListener('click', () => answer(false));

  seeBtn.addEventListener('click', showResult);

  function showResult() {
    const yes = spots.filter(s => state[s.id] === true);
    const n = yes.length;

    const eyebrow = document.getElementById('ck-result-eyebrow');
    const title   = document.getElementById('ck-result-title');
    const body    = document.getElementById('ck-result-body');
    const list    = document.getElementById('ck-result-list');

    let head, msg;
    if (n >= 5) {
      head = 'Your pattern strongly points to perimenopause';
      msg  = `You marked ${n} areas of change. Together, these are a classic perimenopause pattern — the kind of cluster that points clearly to fluctuating hormones rather than several unrelated problems. This is worth a conversation with a gynaecologist.`;
    } else if (n >= 3) {
      head = 'Several signs point toward perimenopause';
      msg  = `You marked ${n} areas of change. A cluster like this often reflects shifting oestrogen and progesterone. It is worth tracking your symptoms and raising them with a gynaecologist.`;
    } else if (n >= 1) {
      head = 'A few early signs to keep an eye on';
      msg  = `You marked ${n} area${n === 1 ? '' : 's'}. On its own this could be many things, but if more changes appear — especially shifts in your periods — it may be early perimenopause. Worth watching, and worth mentioning at your next check-up.`;
    } else {
      head = 'No clear pattern yet';
      msg  = `You did not mark any changes. If something does shift later, come back to this check — and remember the areas below are the common places perimenopause shows up.`;
    }

    eyebrow.textContent = n >= 3 ? 'Your result' : 'Your result';
    title.textContent = head;
    body.textContent = msg;

    const show = n >= 1 ? yes : spots;
    list.innerHTML = '';
    show.forEach(s => {
      const a = document.createElement('a');
      a.href = s.blog;
      a.className = 'ck-result-item';
      a.style.setProperty('--c', s.color);
      a.innerHTML = `<span class="ck-ri-dot"></span><span class="ck-ri-text"><span class="ck-ri-sign">${s.sign}</span><span class="ck-ri-read">Read what's happening →</span></span>`;
      list.appendChild(a);
    });

    document.getElementById('ck-result').hidden = false;
    document.getElementById('ck-result').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  document.getElementById('ck-restart').addEventListener('click', () => {
    for (const k in state) delete state[k];
    document.querySelectorAll('.ck-spot').forEach(b => b.classList.remove('ck-spot-yes','ck-spot-no','ck-spot-done'));
    document.getElementById('ck-result').hidden = true;
    card.hidden = true;
    current = null;
    updateMeter();
    document.getElementById('ck-figure').scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>

<style>
  .ck-page { background: #F5F2EE; min-height: 100vh; }

  .ck-hero { text-align: center; padding: 3.5rem 1.25rem 1rem; max-width: 640px; margin: 0 auto; }
  .ck-eyebrow { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .16em; color: #B84A2E; margin-bottom: .6rem; }
  .ck-title { font-size: clamp(1.7rem, 5vw, 2.6rem); font-weight: 900; color: #2D2010; font-style: italic; line-height: 1.15; margin-bottom: .9rem; }
  .ck-sub { font-size: 1rem; color: #6A5A48; line-height: 1.7; }

  .ck-stage { max-width: 560px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem; }

  .ck-figure-wrap { background: #fff; border-radius: 22px; padding: 1.5rem 1rem 1.25rem; box-shadow: 0 4px 24px rgba(0,0,0,.07); }
  .ck-figure { position: relative; width: 100%; max-width: 260px; margin: 0 auto; aspect-ratio: 200 / 440; }
  .ck-silhouette { width: 100%; height: 100%; display: block; }

  .ck-spot {
    position: absolute; transform: translate(-50%, -50%);
    background: none; border: none; cursor: pointer; padding: 0;
    display: flex; flex-direction: column; align-items: center; gap: 2px;
  }
  .ck-spot-dot {
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--c); opacity: .55;
    box-shadow: 0 0 0 0 var(--c);
    animation: ck-pulse 2.4s infinite; transition: opacity .2s, transform .2s;
  }
  .ck-spot-label {
    font-size: .6rem; font-weight: 700; color: #fff; background: var(--c);
    padding: 1px 7px; border-radius: 99px; white-space: nowrap; opacity: .9;
  }
  .ck-spot:hover .ck-spot-dot { opacity: .85; transform: scale(1.1); }
  .ck-spot-done .ck-spot-dot { animation: none; }
  .ck-spot-yes .ck-spot-dot { opacity: 1; box-shadow: 0 0 0 5px color-mix(in srgb, var(--c) 28%, transparent); }
  .ck-spot-yes .ck-spot-dot::after { content: '✓'; color: #fff; font-size: .8rem; font-weight: 900; display: grid; place-items: center; height: 100%; }
  .ck-spot-no .ck-spot-dot { opacity: .18; }
  .ck-spot-no .ck-spot-label { opacity: .35; }

  @keyframes ck-pulse {
    0%   { box-shadow: 0 0 0 0 color-mix(in srgb, var(--c) 45%, transparent); }
    70%  { box-shadow: 0 0 0 12px color-mix(in srgb, var(--c) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--c) 0%, transparent); }
  }

  .ck-meter { margin-top: 1.25rem; }
  .ck-meter-track { height: 8px; background: #EDE4D8; border-radius: 99px; overflow: hidden; }
  .ck-meter-fill { height: 100%; width: 0; background: linear-gradient(90deg, #B84A2E, #C8862E); border-radius: 99px; transition: width .4s ease; }
  .ck-meter-text { text-align: center; font-size: .8rem; color: #8A7A60; margin-top: .6rem; font-weight: 600; }

  .ck-card {
    background: #2D2010; color: #FFF8F0; border-radius: 18px;
    padding: 1.5rem 1.4rem; margin-top: 1.25rem; text-align: center;
  }
  .ck-card-in { animation: ck-slidein .35s ease; }
  @keyframes ck-slidein { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .ck-card-zone { font-size: .72rem; font-weight: 800; text-transform: uppercase; letter-spacing: .12em; margin-bottom: .5rem; }
  .ck-card-q { font-size: 1.08rem; font-weight: 600; line-height: 1.5; margin-bottom: 1.25rem; }
  .ck-card-actions { display: flex; gap: .7rem; justify-content: center; flex-wrap: wrap; }
  .ck-btn { border: none; cursor: pointer; font-weight: 700; font-size: .9rem; padding: .7rem 1.4rem; border-radius: 99px; transition: transform .15s; }
  .ck-btn:hover { transform: translateY(-2px); }
  .ck-btn-yes { background: #C8A87A; color: #2D2010; }
  .ck-btn-no { background: rgba(255,255,255,.12); color: #FFF8F0; }

  .ck-result-trigger {
    display: block; margin: 1.5rem auto 0; background: #B84A2E; color: #fff;
    border: none; cursor: pointer; font-weight: 700; font-size: .98rem;
    padding: .85rem 2rem; border-radius: 99px; transition: transform .15s, box-shadow .15s;
  }
  .ck-result-trigger:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(184,74,46,.3); }

  .ck-result { background: linear-gradient(160deg, #2D2010, #1A1208); padding: 3.5rem 1.25rem 4rem; }
  .ck-result-inner { max-width: 560px; margin: 0 auto; }
  .ck-result-eyebrow { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .16em; color: #C8A87A; margin-bottom: .7rem; text-align: center; }
  .ck-result-title { font-size: clamp(1.5rem, 4.5vw, 2.1rem); font-weight: 900; color: #FFF8F0; font-style: italic; line-height: 1.2; margin-bottom: 1rem; text-align: center; }
  .ck-result-body { font-size: 1rem; color: rgba(255,248,240,.78); line-height: 1.75; margin-bottom: 1.75rem; text-align: center; }

  .ck-result-list { display: flex; flex-direction: column; gap: .65rem; margin-bottom: 1.75rem; }
  .ck-result-item {
    display: flex; align-items: center; gap: .85rem; text-decoration: none;
    background: rgba(255,255,255,.06); border-radius: 13px; padding: .9rem 1.1rem;
    border-left: 4px solid var(--c); transition: background .2s, transform .2s;
  }
  .ck-result-item:hover { background: rgba(255,255,255,.11); transform: translateX(3px); }
  .ck-ri-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--c); flex-shrink: 0; }
  .ck-ri-text { display: flex; flex-direction: column; }
  .ck-ri-sign { color: #FFF8F0; font-weight: 700; font-size: .92rem; }
  .ck-ri-read { color: #C8A87A; font-size: .76rem; font-weight: 600; margin-top: 1px; }

  .ck-disclaimer { background: rgba(200,168,122,.1); border: 1px solid rgba(200,168,122,.25); border-radius: 12px; padding: 1rem 1.1rem; font-size: .82rem; color: rgba(255,248,240,.7); line-height: 1.6; margin-bottom: 1.75rem; }
  .ck-disclaimer strong { color: #FFF8F0; }

  .ck-result-cta { display: flex; gap: .8rem; justify-content: center; flex-wrap: wrap; }
  .ck-cta-primary { background: #C8A87A; color: #2D2010; font-weight: 700; font-size: .92rem; padding: .8rem 1.6rem; border-radius: 99px; text-decoration: none; transition: transform .15s; }
  .ck-cta-primary:hover { transform: translateY(-2px); }
  .ck-cta-secondary { background: rgba(255,255,255,.1); color: #FFF8F0; border: none; cursor: pointer; font-weight: 700; font-size: .92rem; padding: .8rem 1.6rem; border-radius: 99px; transition: background .2s; }
  .ck-cta-secondary:hover { background: rgba(255,255,255,.18); }
</style>

</Layout>
