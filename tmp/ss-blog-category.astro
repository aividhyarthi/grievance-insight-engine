---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getCategory, postsForCategory, POSTS_PER_PAGE, CATEGORIES } from '../../../lib/blog-categories';
import { breadcrumbSchema, collectionPageSchema, itemListSchema, abs } from '../../../lib/schema';

const { category } = Astro.params;
const cat = category ? getCategory(category) : undefined;
if (!cat) return Astro.redirect('/blog');

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const catPosts = postsForCategory(allPosts, cat);

// ─── Pagination ───
const totalPages = Math.max(1, Math.ceil(catPosts.length / POSTS_PER_PAGE));
const rawPage = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const page = Number.isNaN(rawPage) ? 1 : Math.min(Math.max(rawPage, 1), totalPages);
const start = (page - 1) * POSTS_PER_PAGE;
const pagePosts = catPosts.slice(start, start + POSTS_PER_PAGE);
const showPagination = totalPages > 1;

const base = `/blog/category/${cat.slug}`;
const pageHref = (p: number) => (p <= 1 ? base : `${base}?page=${p}`);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
}

const TAG_COLORS: Record<string, string> = {
  perimenopause: '#3D7A5F', anxiety: '#7B4F3A', 'mood swings': '#7B4F3A',
  hormones: '#2A5C45', 'weight gain': '#C06030', basics: '#3D7A5F',
  'mental health': '#7B4F3A', metabolism: '#C06030', symptoms: '#2A5C45',
  lifestyle: '#3D7A5F', supplements: '#5A8A6A', 'hair loss': '#C06030',
  'hot flashes': '#C06030', fatigue: '#7B4F3A', 'brain fog': '#7B4F3A',
};
function tagColor(tag: string) { return TAG_COLORS[tag.toLowerCase()] || '#3D7A5F'; }

const pageTitle = page > 1
  ? `${cat.label} (Page ${page}) — The Second Spring Journal`
  : `${cat.label} — The Second Spring Journal`;

// ─── Structured data ───
const structuredData = [
  collectionPageSchema({
    name: `${cat.label} — The Second Spring Journal`,
    description: cat.desc,
    url: pageHref(page),
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Journal', url: '/blog' },
    { name: cat.label, url: base },
  ]),
  itemListSchema(pagePosts.map(p => ({ name: p.data.title, url: `/blog/${p.slug}` }))),
];
---

<Layout title={pageTitle} description={cat.desc} structuredData={structuredData} canonical={abs(pageHref(page))}>

  <!-- Hero -->
  <section class="cat-hero">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <a href="/blog">Journal</a>
        <span class="crumb-sep">/</span>
        <span class="crumb-current">{cat.label}</span>
      </nav>
      <div class="cat-hero-head">
        <span class="cat-hero-icon">{cat.icon}</span>
        <div>
          <h1>{cat.label}</h1>
          <p class="cat-hero-desc">{cat.desc}</p>
        </div>
      </div>
      <p class="cat-count">
        {catPosts.length} {catPosts.length === 1 ? 'article' : 'articles'}
        {showPagination && <span class="cat-count-page"> · Page {page} of {totalPages}</span>}
      </p>
    </div>
  </section>

  <!-- Article grid -->
  <section class="section bg-cream">
    <div class="container">
      {pagePosts.length > 0 ? (
        <div class="posts-grid">
          {pagePosts.map(post => (
            <a href={`/blog/${post.slug}`} class="post-card">
              <div class="post-image">
                {post.data.image
                  ? <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
                  : <div class="post-image-fallback" style="background: linear-gradient(135deg, #1A3D2B, #4E9070)"></div>
                }
              </div>
              <div class="post-body">
                <div class="post-tags">
                  {post.data.tags.slice(0, 2).map((t: string) => (
                    <span class="ptag" style={`color:${tagColor(t)};background:${tagColor(t)}18`}>{t}</span>
                  ))}
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-footer">
                  <div class="post-meta">
                    <span>{post.data.author}</span>
                    <span>·</span>
                    <span>{formatDate(post.data.pubDate)}</span>
                    <span>·</span>
                    <span>{post.data.readTime}</span>
                  </div>
                  <span class="post-read-link">Read →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty">No articles in this category yet — check back soon.</p>
      )}

      <!-- Pagination -->
      {showPagination && (
        <nav class="pagination" aria-label="Pagination">
          {page > 1
            ? <a href={pageHref(page - 1)} class="page-btn page-arrow">← Previous</a>
            : <span class="page-btn page-arrow disabled">← Previous</span>}

          <div class="page-numbers">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
              p === page
                ? <span class="page-num active" aria-current="page">{p}</span>
                : <a href={pageHref(p)} class="page-num">{p}</a>
            ))}
          </div>

          {page < totalPages
            ? <a href={pageHref(page + 1)} class="page-btn page-arrow">Next →</a>
            : <span class="page-btn page-arrow disabled">Next →</span>}
        </nav>
      )}

      <!-- Other categories -->
      <div class="other-cats">
        <p class="oc-label">Browse other topics</p>
        <div class="oc-chips">
          {CATEGORIES.filter(c => c.slug !== cat.slug).map(c => (
            <a href={`/blog/category/${c.slug}`} class="oc-chip">{c.icon} {c.label}</a>
          ))}
          <a href="/blog" class="oc-chip oc-chip-all">View all journals →</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ─── Hero ─── */
  .cat-hero {
    background: linear-gradient(150deg, #0F2A1A 0%, #1A3D2B 100%);
    padding: 3rem 0 3.25rem;
  }
  .crumbs {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .82rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }
  .crumbs a { color: rgba(255,255,255,.6); text-decoration: none; transition: color .15s; }
  .crumbs a:hover { color: #fff; }
  .crumb-sep { color: rgba(255,255,255,.3); }
  .crumb-current { color: rgba(255,255,255,.95); font-weight: 600; }

  .cat-hero-head {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
  }
  .cat-hero-icon {
    flex-shrink: 0;
    font-size: 2rem;
    width: 62px;
    height: 62px;
    border-radius: 16px;
    background: rgba(255,255,255,.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cat-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -.04em;
    color: #fff;
    line-height: 1.1;
    margin-bottom: .5rem;
  }
  .cat-hero-desc {
    font-size: 1rem;
    color: rgba(255,255,255,.68);
    line-height: 1.65;
    max-width: 560px;
  }
  .cat-count {
    margin-top: 1.5rem;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: rgba(255,255,255,.5);
  }
  .cat-count-page { color: rgba(255,255,255,.4); text-transform: none; letter-spacing: 0; }

  /* ─── Section ─── */
  .section { padding: 3.5rem 0 4.5rem; }
  .bg-cream { background: var(--cream-mid, #F7F3EE); }
  .empty { text-align: center; color: var(--text-muted, #888); padding: 3rem 0; }

  /* ─── Post cards grid ─── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.35rem;
  }
  .post-card {
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    border: 1.5px solid var(--border, #E0DDD8);
    text-decoration: none;
    color: var(--text, #1A1A1A);
    display: flex;
    flex-direction: column;
    background: #fff;
    transition: all .18s;
  }
  .post-card:hover {
    box-shadow: 0 12px 36px rgba(61,122,95,.13);
    transform: translateY(-3px);
    border-color: var(--green, #3D7A5F);
  }
  .post-image {
    height: 180px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--cream-mid, #F7F3EE);
  }
  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform .4s ease;
    display: block;
  }
  .post-card:hover .post-image img { transform: scale(1.04); }
  .post-image-fallback { width: 100%; height: 100%; }
  .post-body {
    padding: 1.2rem 1.25rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    flex: 1;
  }
  .post-tags { display: flex; gap: .4rem; flex-wrap: wrap; }
  .ptag {
    font-size: .67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    padding: .2rem .6rem;
    border-radius: 100px;
  }
  .post-title {
    font-size: .97rem;
    font-weight: 700;
    color: var(--text, #1A1A1A);
    line-height: 1.37;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-desc {
    font-size: .83rem;
    color: var(--text-secondary, #555);
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: .3rem;
    flex-wrap: wrap;
    gap: .35rem;
  }
  .post-meta {
    font-size: .74rem;
    color: var(--text-muted, #888);
    display: flex;
    gap: .35rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .post-read-link {
    font-size: .8rem;
    font-weight: 700;
    color: var(--green, #3D7A5F);
    white-space: nowrap;
  }

  /* ─── Pagination ─── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }
  .page-btn {
    font-size: .85rem;
    font-weight: 700;
    padding: .55rem 1.1rem;
    border-radius: 100px;
    border: 1.5px solid var(--green, #3D7A5F);
    color: var(--green, #3D7A5F);
    text-decoration: none;
    transition: all .18s;
    white-space: nowrap;
  }
  .page-btn:hover:not(.disabled) { background: var(--green, #3D7A5F); color: #fff; }
  .page-btn.disabled { opacity: .35; cursor: not-allowed; border-color: var(--border, #E0DDD8); color: var(--text-muted, #999); }
  .page-numbers { display: flex; gap: .4rem; align-items: center; }
  .page-num {
    min-width: 38px;
    height: 38px;
    padding: 0 .4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    font-size: .88rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--text-secondary, #555);
    background: #fff;
    border: 1.5px solid var(--border, #E0DDD8);
    transition: all .15s;
  }
  .page-num:hover { border-color: var(--green, #3D7A5F); color: var(--green, #3D7A5F); }
  .page-num.active {
    background: var(--green, #3D7A5F);
    color: #fff;
    border-color: var(--green, #3D7A5F);
  }

  /* ─── Other categories ─── */
  .other-cats {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border, #E0DDD8);
  }
  .oc-label {
    font-size: .74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-muted, #888);
    margin-bottom: 1rem;
  }
  .oc-chips { display: flex; gap: .65rem; flex-wrap: wrap; }
  .oc-chip {
    font-size: .85rem;
    font-weight: 600;
    padding: .5rem 1rem;
    border-radius: 100px;
    background: #fff;
    border: 1.5px solid var(--border, #E0DDD8);
    color: var(--text-secondary, #555);
    text-decoration: none;
    transition: all .18s;
  }
  .oc-chip:hover { border-color: var(--green, #3D7A5F); color: var(--green, #3D7A5F); }
  .oc-chip-all { color: var(--green, #3D7A5F); border-color: var(--green, #3D7A5F); }
  .oc-chip-all:hover { background: var(--green, #3D7A5F); color: #fff; }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; }
    .cat-hero-icon { width: 52px; height: 52px; font-size: 1.6rem; }
  }
</style>
