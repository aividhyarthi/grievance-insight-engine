---
import Layout from '../layouts/Layout.astro';
import { webPageSchema, breadcrumbSchema } from '../lib/schema';

const structuredData = [
  webPageSchema({
    name: 'Perimenopause Explained — A Visual Guide for Indian Women',
    description: 'What is perimenopause? What hormones change, why symptoms happen, and what your body is going through — explained visually so anyone can understand.',
    url: '/perimenopause-explained',
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Perimenopause Explained', url: '/perimenopause-explained' },
  ]),
];
---

<Layout
  title="Perimenopause Explained — A Visual Guide for Indian Women"
  description="What is perimenopause? What hormones change, why symptoms happen, and what your body is going through — explained visually so anyone can understand."
  structuredData={structuredData}
>

  <!-- HERO -->
  <section class="ig-hero">
    <div class="container">
      <div class="ig-hero-inner">
        <div class="ig-eyebrow">📊 Visual Guide</div>
        <h1>Perimenopause, Explained</h1>
        <p>What's happening in your body — and why — in simple visuals anyone can understand.</p>
        <div class="ig-share-row">
          <span class="ig-share-label">Share this guide</span>
          <a href="https://wa.me/?text=Perimenopause explained simply — https://thesecondspring.org/perimenopause-explained" target="_blank" class="ig-share-btn ig-wa">WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 1. WHAT IS PERIMENOPAUSE -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card ig-card--full">
        <div class="ig-card-label">01 / What Is It?</div>
        <h2 class="ig-card-title">Perimenopause is the transition <em>before</em> menopause</h2>

        <div class="timeline-wrap">
          <div class="tl-item tl-item--past">
            <div class="tl-dot tl-dot--green"></div>
            <div class="tl-body">
              <div class="tl-age">20s – early 40s</div>
              <div class="tl-label">Reproductive Years</div>
              <div class="tl-desc">Regular cycles. Stable oestrogen &amp; progesterone. Ovulation most months.</div>
            </div>
          </div>
          <div class="tl-line"></div>
          <div class="tl-item tl-item--now">
            <div class="tl-dot tl-dot--peach tl-dot--pulse"></div>
            <div class="tl-body">
              <div class="tl-age">Late 30s – mid 40s</div>
              <div class="tl-label tl-label--highlight">← Perimenopause (You may be here)</div>
              <div class="tl-desc">Hormones begin to fluctuate. Cycles change. Symptoms begin. Can last 4–10 years.</div>
            </div>
          </div>
          <div class="tl-line"></div>
          <div class="tl-item tl-item--future">
            <div class="tl-dot tl-dot--muted"></div>
            <div class="tl-body">
              <div class="tl-age">~46–47 (India avg)</div>
              <div class="tl-label">Menopause</div>
              <div class="tl-desc">12 months with no period. A single point in time — not a phase.</div>
            </div>
          </div>
          <div class="tl-line"></div>
          <div class="tl-item">
            <div class="tl-dot tl-dot--light"></div>
            <div class="tl-body">
              <div class="tl-age">50s onwards</div>
              <div class="tl-label">Postmenopause</div>
              <div class="tl-desc">Hormones settle at a lower level. Many women feel more stable than during the transition.</div>
            </div>
          </div>
        </div>

        <div class="ig-callout">
          <span class="ig-callout-icon">🇮🇳</span>
          <span>Indian women reach menopause at an average age of <strong>46–47</strong> — 4–5 years earlier than Western women. Perimenopause often begins in the <strong>early 40s or late 30s</strong>.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. THE TWO KEY HORMONES -->
  <section class="ig-section bg-cream">
    <div class="container">
      <div class="ig-card-label center">02 / The Hormones</div>
      <h2 class="ig-section-title center">Two hormones drive everything</h2>

      <div class="hormone-grid">
        <div class="hormone-card hormone-card--oestrogen">
          <div class="hormone-icon">🌸</div>
          <h3 class="hormone-name">Oestrogen</h3>
          <div class="hormone-subtitle">The master messenger</div>
          <ul class="hormone-list">
            <li>Controls your mood, memory, sleep</li>
            <li>Keeps bones strong</li>
            <li>Protects your heart</li>
            <li>Keeps skin hydrated</li>
            <li>Regulates your cycle</li>
          </ul>
          <div class="hormone-what-happens">
            <div class="hwh-label">What happens in perimenopause</div>
            <div class="hwh-desc">Oestrogen doesn't just decline — it <strong>surges and crashes erratically</strong>. This instability is what drives most symptoms.</div>
          </div>
        </div>

        <div class="hormone-card hormone-card--progesterone">
          <div class="hormone-icon">🌿</div>
          <h3 class="hormone-name">Progesterone</h3>
          <div class="hormone-subtitle">The calming counterbalance</div>
          <ul class="hormone-list">
            <li>Calms the nervous system</li>
            <li>Supports deep sleep</li>
            <li>Balances oestrogen's effects</li>
            <li>Stabilises the uterine lining</li>
            <li>Reduces anxiety</li>
          </ul>
          <div class="hormone-what-happens">
            <div class="hwh-label">What happens in perimenopause</div>
            <div class="hwh-desc">Progesterone declines <strong>earlier and faster</strong> than oestrogen. Its loss removes the calming effect on mood and sleep.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. THE HORMONE GRAPH -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label center">03 / The Pattern</div>
      <h2 class="ig-section-title center">It's not a smooth decline — it's a rollercoaster</h2>
      <p class="ig-section-sub center">This is why symptoms feel so unpredictable. Good days and bad days happen because oestrogen swings wildly before settling low.</p>

      <div class="graph-wrap">
        <div class="graph-y-label">Oestrogen level</div>
        <div class="graph-area">
          <!-- Stable phase -->
          <div class="graph-phase graph-phase--stable">
            <div class="graph-line-stable"></div>
            <div class="graph-phase-label">Reproductive years<br/><span>Stable cycles</span></div>
          </div>
          <!-- Perimenopause wavy -->
          <div class="graph-phase graph-phase--peri">
            <svg class="graph-wave" viewBox="0 0 260 80" preserveAspectRatio="none">
              <polyline points="0,35 20,15 40,50 60,10 80,55 100,20 120,60 140,15 160,45 180,25 200,55 220,30 240,50 260,20" fill="none" stroke="#D4845A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="graph-phase-label">Perimenopause<br/><span>Erratic surges &amp; drops</span></div>
          </div>
          <!-- Post menopause low -->
          <div class="graph-phase graph-phase--post">
            <div class="graph-line-low"></div>
            <div class="graph-phase-label">Postmenopause<br/><span>Low but stable</span></div>
          </div>
        </div>
        <div class="graph-x-label">Time →</div>
      </div>

      <div class="ig-callout ig-callout--peach">
        <span class="ig-callout-icon">💡</span>
        <span>A single blood test during perimenopause can look completely normal — because it may catch oestrogen on a high day. <strong>Symptoms over time matter more than one result.</strong></span>
      </div>
    </div>
  </section>

  <!-- 4. WHY SYMPTOMS HAPPEN -->
  <section class="ig-section bg-cream">
    <div class="container">
      <div class="ig-card-label center">04 / Why Symptoms Happen</div>
      <h2 class="ig-section-title center">Oestrogen doesn't just affect your periods</h2>
      <p class="ig-section-sub center">It is a messenger that works across every organ system. When it fluctuates, everything feels it.</p>

      <div class="body-map-wrap">
        <div class="body-map-items body-map-items--left">
          <div class="bm-item">
            <div class="bm-organ">🧠 Brain</div>
            <div class="bm-effect">Oestrogen regulates serotonin &amp; dopamine</div>
            <div class="bm-symptom">→ Mood swings, anxiety, brain fog, low mood</div>
          </div>
          <div class="bm-item">
            <div class="bm-organ">❤️ Heart</div>
            <div class="bm-effect">Oestrogen keeps blood vessels flexible</div>
            <div class="bm-symptom">→ Palpitations, rising cardiovascular risk</div>
          </div>
          <div class="bm-item">
            <div class="bm-organ">🦴 Bones</div>
            <div class="bm-effect">Oestrogen slows bone breakdown</div>
            <div class="bm-symptom">→ Bone density loss, joint pain, fracture risk</div>
          </div>
          <div class="bm-item">
            <div class="bm-organ">😴 Sleep</div>
            <div class="bm-effect">Oestrogen + progesterone regulate sleep cycles</div>
            <div class="bm-symptom">→ Waking at 3am, light sleep, night sweats</div>
          </div>
        </div>

        <div class="body-silhouette">
          <svg viewBox="0 0 120 260" xmlns="http://www.w3.org/2000/svg" class="silhouette-svg">
            <!-- Head -->
            <ellipse cx="60" cy="28" rx="22" ry="26" fill="#D4845A" opacity=".18"/>
            <!-- Neck -->
            <rect x="52" y="52" width="16" height="14" rx="4" fill="#D4845A" opacity=".15"/>
            <!-- Body -->
            <path d="M30 66 Q20 90 22 130 Q24 160 30 180 Q40 200 60 200 Q80 200 90 180 Q96 160 98 130 Q100 90 90 66 Q75 58 60 58 Q45 58 30 66Z" fill="#1A3D2B" opacity=".08"/>
            <!-- Glow dots for organs -->
            <circle cx="60" cy="28" r="5" fill="#D4845A" opacity=".5"/>
            <circle cx="60" cy="90" r="5" fill="#D4845A" opacity=".4"/>
            <circle cx="60" cy="115" r="5" fill="#D4845A" opacity=".4"/>
            <circle cx="60" cy="145" r="5" fill="#D4845A" opacity=".35"/>
          </svg>
        </div>

        <div class="body-map-items body-map-items--right">
          <div class="bm-item bm-item--right">
            <div class="bm-organ">🌡️ Temperature</div>
            <div class="bm-effect">Oestrogen regulates the hypothalamus thermostat</div>
            <div class="bm-symptom">→ Hot flashes, night sweats, chills</div>
          </div>
          <div class="bm-item bm-item--right">
            <div class="bm-organ">⚖️ Metabolism</div>
            <div class="bm-effect">Oestrogen influences insulin sensitivity &amp; fat storage</div>
            <div class="bm-symptom">→ Belly fat, weight gain, blood sugar changes</div>
          </div>
          <div class="bm-item bm-item--right">
            <div class="bm-organ">💧 Skin &amp; Hair</div>
            <div class="bm-effect">Oestrogen drives collagen &amp; moisture</div>
            <div class="bm-symptom">→ Dry skin, thinning hair, adult acne</div>
          </div>
          <div class="bm-item bm-item--right">
            <div class="bm-organ">🔵 Urinary</div>
            <div class="bm-effect">Oestrogen maintains bladder &amp; urethral tissue</div>
            <div class="bm-symptom">→ Urgency, leakage, recurrent UTIs</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. THE 3 STAGES -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label center">05 / The Stages</div>
      <h2 class="ig-section-title center">Perimenopause has two distinct phases</h2>

      <div class="stages-grid">
        <div class="stage-card stage-card--early">
          <div class="stage-badge">Early Perimenopause</div>
          <div class="stage-duration">Lasts 2–5 years · Often starts late 30s</div>
          <div class="stage-hormones">
            <div class="sh-row"><span class="sh-name">Oestrogen</span><div class="sh-bar"><div class="sh-fill sh-fill--erratic"></div></div><span class="sh-note">Erratic — can spike HIGH</span></div>
            <div class="sh-row"><span class="sh-name">Progesterone</span><div class="sh-bar"><div class="sh-fill sh-fill--low" style="width:45%"></div></div><span class="sh-note">Starting to fall</span></div>
          </div>
          <div class="stage-symptoms">
            <div class="ss-title">What you notice:</div>
            <ul>
              <li>Periods slightly heavier or shorter</li>
              <li>Worsening PMS</li>
              <li>Sleep becoming lighter</li>
              <li>Mood shifts, more irritable</li>
              <li>Blood tests may look "normal"</li>
            </ul>
          </div>
        </div>

        <div class="stage-card stage-card--late">
          <div class="stage-badge stage-badge--late">Late Perimenopause</div>
          <div class="stage-duration">Lasts 1–3 years · Cycles become very irregular</div>
          <div class="stage-hormones">
            <div class="sh-row"><span class="sh-name">Oestrogen</span><div class="sh-bar"><div class="sh-fill sh-fill--declining" style="width:35%"></div></div><span class="sh-note">Overall declining</span></div>
            <div class="sh-row"><span class="sh-name">Progesterone</span><div class="sh-bar"><div class="sh-fill sh-fill--verylow" style="width:20%"></div></div><span class="sh-note">Very low</span></div>
          </div>
          <div class="stage-symptoms">
            <div class="ss-title">What you notice:</div>
            <ul>
              <li>Skipping periods — gaps of 60+ days</li>
              <li>Hot flashes more frequent</li>
              <li>Significant sleep disruption</li>
              <li>Vaginal dryness begins</li>
              <li>FSH elevated on blood tests</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. WHAT WOMEN IN INDIA EXPERIENCE -->
  <section class="ig-section bg-cream">
    <div class="container">
      <div class="ig-card-label center">06 / The Indian Picture</div>
      <h2 class="ig-section-title center">Why perimenopause is especially hard to navigate in India</h2>

      <div class="india-grid">
        {[
          { icon: '🔇', title: 'No word for it', desc: 'Most Indian languages have no specific word for perimenopause. The experience is invisible in daily conversation.' },
          { icon: '🏥', title: 'Dismissed by doctors', desc: '"You\'re too young for menopause." "It\'s just stress." Women often hear this for years before getting answers.' },
          { icon: '👨‍👩‍👧', title: 'Joint family pressure', desc: 'Mood changes and fatigue during perimenopause are often attributed to character or relationship failures — not hormones.' },
          { icon: '📉', title: 'Earlier onset', desc: 'Indian women reach menopause 4–5 years earlier than Western women — but guidelines and resources are largely Western.' },
          { icon: '🧪', title: 'Low testing culture', desc: 'Vitamin D, B12, and ferritin deficiencies are extremely common in Indian women and dramatically worsen symptoms when untreated.' },
          { icon: '💊', title: 'HRT stigma', desc: 'Persistent myths about HRT keep many Indian women from accessing treatments that could significantly improve their quality of life.' },
        ].map(item => (
          <div class="india-card">
            <div class="india-icon">{item.icon}</div>
            <h3 class="india-title">{item.title}</h3>
            <p class="india-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. WHAT HELPS -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label center">07 / What Helps</div>
      <h2 class="ig-section-title center">You have options — more than you may have been told</h2>

      <div class="helps-grid">
        <div class="helps-col">
          <div class="helps-head helps-head--medical">🩺 Medical</div>
          <ul class="helps-list">
            <li><strong>HRT</strong> — most effective for hot flashes, sleep, mood, bone health</li>
            <li><strong>Progesterone therapy</strong> — for heavy bleeding and sleep</li>
            <li><strong>Mirena IUD</strong> — for heavy periods</li>
            <li><strong>Vaginal oestrogen</strong> — for dryness and urinary symptoms</li>
            <li><strong>Non-hormonal options</strong> — SSRIs, clonidine, gabapentin</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--lifestyle">🌿 Lifestyle</div>
          <ul class="helps-list">
            <li><strong>Strength training</strong> — best exercise for bones &amp; metabolism</li>
            <li><strong>Protein at every meal</strong> — preserves muscle mass</li>
            <li><strong>Phytoestrogens</strong> — til, flaxseed, soy, lentils, rajma</li>
            <li><strong>Magnesium + Vitamin D</strong> — sleep, mood, bone density</li>
            <li><strong>Reduce alcohol</strong> — worsens every symptom</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--support">💬 Support</div>
          <ul class="helps-list">
            <li><strong>A menopause-aware gynaecologist</strong> — not all are</li>
            <li><strong>Test properly</strong> — FSH, LH, E2, AMH, thyroid, ferritin, D, B12</li>
            <li><strong>Don't suffer alone</strong> — connection reduces symptom severity</li>
            <li><strong>The Second Spring</strong> — private, India-specific support any time</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ig-cta-section">
    <div class="container">
      <div class="ig-cta-inner">
        <div class="ig-cta-left">
          <h2>Not sure if you're in perimenopause?</h2>
          <p>Our free 3-minute symptom check is built specifically for Indian women. No login, no judgement.</p>
          <div class="ig-cta-btns">
            <a href="/quiz" class="btn btn-peach btn-lg">Check My Symptoms →</a>
            <a href="/chat" class="btn btn-outline-white">Talk Privately</a>
          </div>
        </div>
        <div class="ig-cta-stat-col">
          <div class="ig-stat"><span class="ig-stat-num">30M+</span><span class="ig-stat-label">Indian women currently navigating perimenopause</span></div>
          <div class="ig-stat"><span class="ig-stat-num">4–10</span><span class="ig-stat-label">years perimenopause typically lasts</span></div>
          <div class="ig-stat"><span class="ig-stat-num">46–47</span><span class="ig-stat-label">average age of menopause in India</span></div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .ig-hero {
    background: linear-gradient(135deg, #0F2A1A 0%, #1A3D2B 60%, #2A5C45 100%);
    color: #fff;
    padding: 6rem 0 5rem;
    text-align: center;
  }
  .ig-hero-inner { max-width: 680px; margin: 0 auto; }
  .ig-eyebrow { display: inline-block; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.85); font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .4rem 1rem; border-radius: 100px; margin-bottom: 1.25rem; }
  .ig-hero h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 900; letter-spacing: -.03em; color: #fff; margin-bottom: 1rem; }
  .ig-hero p { font-size: 1.1rem; color: rgba(255,255,255,.75); margin-bottom: 2rem; }
  .ig-share-row { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .ig-share-label { font-size: .85rem; color: rgba(255,255,255,.55); }
  .ig-share-btn { font-size: .82rem; font-weight: 700; padding: .45rem 1rem; border-radius: 99px; text-decoration: none; }
  .ig-wa { background: #25D366; color: #fff; }

  /* SECTIONS */
  .ig-section { padding: 5rem 0; }
  .bg-white { background: #fff; }
  .bg-cream { background: var(--cream, #F9F5F0); }
  .ig-card-label { font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--green, #1A3D2B); background: var(--green-light, #E8F0EB); display: inline-block; padding: .3rem .9rem; border-radius: 99px; margin-bottom: 1rem; }
  .ig-card-label.center { display: block; text-align: center; }
  .ig-section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 900; letter-spacing: -.025em; color: var(--text, #1a1a1a); margin-bottom: .75rem; text-align: center; }
  .ig-section-sub { font-size: 1rem; color: var(--text-secondary, #555); line-height: 1.7; text-align: center; max-width: 600px; margin: 0 auto 3rem; }
  .ig-card--full { background: var(--cream, #F9F5F0); border-radius: 20px; padding: 2.5rem; }
  .ig-card-title { font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 900; color: var(--text, #1a1a1a); letter-spacing: -.02em; margin-bottom: 2rem; }
  .ig-card-title em { font-style: normal; color: var(--green, #1A3D2B); }

  /* TIMELINE */
  .timeline-wrap { display: flex; flex-direction: column; gap: 0; max-width: 640px; }
  .tl-item { display: flex; gap: 1.5rem; align-items: flex-start; padding-bottom: .5rem; }
  .tl-line { width: 2px; background: var(--border, #e0e0e0); height: 2rem; margin-left: 11px; }
  .tl-dot { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; margin-top: .2rem; }
  .tl-dot--green { background: var(--green, #1A3D2B); }
  .tl-dot--peach { background: #D4845A; box-shadow: 0 0 0 6px rgba(212,132,90,.2); }
  .tl-dot--pulse { animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100% { box-shadow: 0 0 0 4px rgba(212,132,90,.2); } 50% { box-shadow: 0 0 0 10px rgba(212,132,90,.08); } }
  .tl-dot--muted { background: var(--border, #ccc); }
  .tl-dot--light { background: #ddd; }
  .tl-age { font-size: .75rem; font-weight: 700; color: var(--text-muted, #888); text-transform: uppercase; letter-spacing: .06em; margin-bottom: .2rem; }
  .tl-label { font-size: 1rem; font-weight: 800; color: var(--text, #1a1a1a); margin-bottom: .3rem; }
  .tl-label--highlight { color: #D4845A; }
  .tl-desc { font-size: .88rem; color: var(--text-secondary, #555); line-height: 1.6; }

  /* CALLOUT */
  .ig-callout { display: flex; gap: 1rem; align-items: flex-start; background: var(--green-light, #E8F0EB); border-left: 4px solid var(--green, #1A3D2B); border-radius: 0 12px 12px 0; padding: 1.1rem 1.25rem; margin-top: 2rem; font-size: .9rem; color: var(--text, #1a1a1a); line-height: 1.65; }
  .ig-callout--peach { background: #FEF3EC; border-color: #D4845A; }
  .ig-callout-icon { font-size: 1.3rem; flex-shrink: 0; }

  /* HORMONES */
  .hormone-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2rem; }
  .hormone-card { border-radius: 20px; padding: 2rem; }
  .hormone-card--oestrogen { background: linear-gradient(135deg, #FEF3EC, #FDDCC8); border: 2px solid #D4845A; }
  .hormone-card--progesterone { background: linear-gradient(135deg, #E8F0EB, #C8DDD0); border: 2px solid var(--green, #1A3D2B); }
  .hormone-icon { font-size: 2.5rem; margin-bottom: .75rem; }
  .hormone-name { font-size: 1.4rem; font-weight: 900; letter-spacing: -.02em; margin-bottom: .2rem; }
  .hormone-card--oestrogen .hormone-name { color: #9D4E1E; }
  .hormone-card--progesterone .hormone-name { color: #1A3D2B; }
  .hormone-subtitle { font-size: .83rem; font-weight: 600; opacity: .65; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: .06em; }
  .hormone-list { list-style: none; display: flex; flex-direction: column; gap: .4rem; margin-bottom: 1.5rem; }
