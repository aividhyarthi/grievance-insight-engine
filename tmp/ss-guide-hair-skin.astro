---
import Layout from '../../layouts/Layout.astro';
import { webPageSchema, breadcrumbSchema } from '../../lib/schema';

const structuredData = [
  webPageSchema({
    name: 'Hair & Skin Changes in Perimenopause | The Second Spring',
    description: "Drier skin, thinning hair, adult acne, and facial hair — oestrogen's decline changes how you look. Here is why it happens and what Indian women can do.",
    url: '/guide/hair-skin',
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Guide', url: '/guide' },
    { name: 'Hair & Skin', url: '/guide/hair-skin' },
  ]),
];
---

<Layout
  title="Hair & Skin Changes in Perimenopause | The Second Spring"
  description="Drier skin, thinning hair, adult acne, and facial hair — oestrogen's decline changes how you look. Here is why it happens and what Indian women can do."
  structuredData={structuredData}
>

  <!-- HERO -->
  <section class="ig-hero">
    <div class="container">
      <div class="ig-hero-inner">
        <div class="ig-eyebrow">✨ Topic Guide</div>
        <h1>Hair & Skin in Perimenopause</h1>
        <p>Changes in your hair and skin during perimenopause are hormonal — understanding why they happen is the first step toward doing something about them.</p>
        <div class="ig-share-row">
          <span class="ig-share-label">Share this guide</span>
          <a href="https://wa.me/?text=Hair and skin changes in perimenopause explained — https://thesecondspring.org/guide/hair-skin" target="_blank" class="ig-share-btn ig-wa">WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 01 — THE SCIENCE -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label">01 / Why Hormones Affect Appearance</div>
      <h2 class="ig-section-title">How oestrogen shapes your skin and hair — and what changes when it falls</h2>

      <div class="science-grid">
        <div class="science-card science-card--skin">
          <div class="science-icon">✨</div>
          <h3 class="science-title">Skin</h3>
          <ul class="science-list">
            <li>Oestrogen stimulates <strong>collagen and elastin production</strong> — the proteins that give skin thickness, firmness, and bounce</li>
            <li>Oestrogen also supports <strong>sebum production</strong> and moisture retention</li>
            <li>Women lose approximately <strong>30% of skin collagen in the first 5 years postmenopause</strong> (2% per year thereafter)</li>
            <li>Result: skin becomes thinner, drier, less elastic — prone to fine lines and reduced glow</li>
          </ul>
        </div>
        <div class="science-card science-card--hair">
          <div class="science-icon">💆</div>
          <h3 class="science-title">Hair</h3>
          <ul class="science-list">
            <li>Hair follicles are <strong>oestrogen-sensitive</strong> — oestrogen keeps more follicles in the growth (anagen) phase</li>
            <li>As oestrogen falls, more follicles simultaneously enter the resting/shedding <strong>(telogen) phase</strong></li>
            <li>Result: <strong>diffuse thinning</strong> — overall density loss, not bald patches — similar pattern to PCOS hair loss</li>
          </ul>
        </div>
        <div class="science-card science-card--androgens">
          <div class="science-icon">⚖️</div>
          <h3 class="science-title">Androgens</h3>
          <ul class="science-list">
            <li>As oestrogen falls, the <strong>ratio of androgens (male hormones) to oestrogen shifts</strong></li>
            <li>Androgens stimulate <strong>facial hair growth</strong> — chin, upper lip, jaw — same mechanism as PCOS</li>
            <li>Androgens also drive <strong>adult acne</strong> along the jaw and lower face</li>
          </ul>
        </div>
      </div>

      <div class="ig-callout">
        <span class="ig-callout-icon">💡</span>
        <span>These changes are hormonal — switching products alone won't fully address them. Treating the underlying hormonal cause produces the most significant improvement. Skincare helps; hormonal treatment helps more.</span>
      </div>

      <div class="symptom-link-row">
        <a href="/guide/symptoms/skin-hair" class="symptom-link">Read more: Skin and hair changes as perimenopause symptoms →</a>
      </div>
    </div>
  </section>

  <!-- SECTION 02 — WHAT INDIAN WOMEN NOTICE -->
  <section class="ig-section bg-cream">
    <div class="container">
      <div class="ig-card-label center">02 / Common Experiences</div>
      <h2 class="ig-section-title center">The specific changes Indian women report most</h2>
      <p class="ig-section-sub center">These changes can feel sudden and distressing. They are real, they are hormonal, and they are addressable.</p>

      <div class="india-grid">
        <div class="india-card">
          <div class="india-icon">💧</div>
          <h3 class="india-title">Skin dryness</h3>
          <p class="india-desc">Especially noticeable in air conditioning or winter. Skin that used to be normal or oily becomes dry and flaky — requiring a completely different skincare approach.</p>
        </div>
        <div class="india-card">
          <div class="india-icon">🚿</div>
          <h3 class="india-title">Hair shedding</h3>
          <p class="india-desc">More hair in the shower drain and on the pillow. Ponytails feel thinner. This is diffuse thinning — overall density loss — not patchy baldness. It is caused by the telogen shift.</p>
        </div>
        <div class="india-card">
          <div class="india-icon">🌙</div>
          <h3 class="india-title">Dull, uneven skin tone</h3>
          <p class="india-desc">Loss of the luminosity Indian skin is known for. Uneven tone, dullness, and pigmentation changes become more pronounced as collagen and cell turnover slow.</p>
        </div>
        <div class="india-card">
          <div class="india-icon">🌱</div>
          <h3 class="india-title">New facial hair</h3>
          <p class="india-desc">Often on the chin, jaw, or upper lip — coarser than before. This is androgen-driven as the oestrogen-to-androgen ratio shifts. The same mechanism as PCOS-related hirsutism.</p>
        </div>
        <div class="india-card">
          <div class="india-icon">🔴</div>
          <h3 class="india-title">Adult acne</h3>
          <p class="india-desc">Particularly along the jaw and lower face — appearing in women who never had acne, or returning after decades. Hormonal, not hygiene-related. Requires a hormonal approach to treat properly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 03 — SKIN CARE -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label center">03 / Caring for Perimenopausal Skin</div>
      <h2 class="ig-section-title center">Evidence-based skincare for perimenopausal skin</h2>

      <div class="helps-grid">
        <div class="helps-col">
          <div class="helps-head helps-head--actives">🧪 Actives that work</div>
          <ul class="helps-list">
            <li><strong>Retinoids (tretinoin — prescription; retinol — OTC)</strong> — stimulate collagen production; the most evidence-backed anti-ageing ingredient</li>
            <li><strong>Vitamin C</strong> — brightening, antioxidant, supports collagen synthesis; use in the morning</li>
            <li><strong>Hyaluronic acid</strong> — draws moisture into skin; use on damp skin before moisturiser</li>
            <li><strong>Peptides</strong> — support collagen structure; well tolerated, can be layered with other actives</li>
            <li><strong>Niacinamide</strong> — reduces pore appearance and pigmentation; calms androgenic acne</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--habits">🌿 Daily habits</div>
          <ul class="helps-list">
            <li><strong>SPF every morning</strong> — UV breaks down collagen faster than any other factor; non-negotiable</li>
            <li><strong>Richer moisturiser than before</strong> — your skin's barrier function has changed; it needs more support</li>
            <li><strong>Gentle cleansers</strong> — avoid stripping foaming cleansers that damage the skin barrier</li>
            <li><strong>2 litres of water daily</strong> — hydration from within supports skin moisture and texture</li>
            <li><strong>Sleep and stress management</strong> — cortisol accelerates collagen loss and worsens acne</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--medical">🩺 Medical options</div>
          <ul class="helps-list">
            <li><strong>HRT (oestrogen)</strong> — direct skin benefit: improves skin collagen content within 6 months of starting</li>
            <li><strong>Topical oestrogen cream for face</strong> — off-label use, but practised by some dermatologists for facial skin thinning</li>
            <li><strong>Dermatologist referral</strong> — for persistent acne, significant pigmentation, or specific skin concerns</li>
            <li><strong>Prescription tretinoin</strong> — available in India; significantly more effective than OTC retinol</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 04 — HAIR CARE -->
  <section class="ig-section bg-cream">
    <div class="container">
      <div class="ig-card-label center">04 / Addressing Hair Changes</div>
      <h2 class="ig-section-title center">Managing perimenopause-related hair thinning</h2>

      <div class="helps-grid">
        <div class="helps-col">
          <div class="helps-head helps-head--test">🧪 Check deficiencies first</div>
          <ul class="helps-list">
            <li><strong>Ferritin (iron stores)</strong> — the most common cause of hair loss in Indian women; test ferritin specifically, not just haemoglobin</li>
            <li><strong>Thyroid (TSH)</strong> — hypothyroidism causes significant hair loss and is very common in Indian women</li>
            <li><strong>Vitamin D</strong> — deficiency directly impacts hair follicle cycling; extremely common in India</li>
            <li><strong>B12</strong> — deficiency causes hair loss and is common, especially in vegetarians</li>
            <li><strong>Zinc</strong> — low zinc impairs hair follicle function; test if hair loss is significant</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--scalp">💆 Scalp care</div>
          <ul class="helps-list">
            <li><strong>Scalp massage</strong> — Regular scalp massage may improve blood flow to follicles — some evidence suggests it can support hair thickness over time.</li>
            <li><strong>Mild sulphate-free shampoos</strong> — harsh detergents strip the scalp and worsen shedding</li>
            <li><strong>Avoid tight hairstyles</strong> — traction alopecia compounds hormonal thinning; give follicles space</li>
            <li><strong>Reduce heat styling</strong> — heat damage breaks already-weakened hair shafts</li>
            <li><strong>What to avoid</strong> — aggressive chemical treatments, bleaching, and tight braids during active thinning</li>
          </ul>
        </div>
        <div class="helps-col">
          <div class="helps-head helps-head--medical">🩺 Medical options</div>
          <ul class="helps-list">
            <li><strong>Minoxidil (topical)</strong> — available OTC in India; the most evidence-backed treatment for female pattern hair thinning. Speak to your doctor before starting minoxidil — it is not suitable during pregnancy (which remains possible during perimenopause until confirmed menopause) and is best used under medical guidance.</li>
            <li><strong>HRT (oestrogen)</strong> — addresses the hormonal root cause; many women report hair improvement within 6–12 months</li>
            <li><strong>Platelet-rich plasma (PRP)</strong> — dermatologist referral; available in Indian cities; stimulates follicle activity</li>
            <li><strong>Dermatologist referral</strong> — for significant or rapid hair loss; a trichologist can assess pattern and cause</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 05 — NUTRITION -->
  <section class="ig-section bg-white">
    <div class="container">
      <div class="ig-card-label">05 / Nutrition for Skin & Hair</div>
      <h2 class="ig-section-title">What you eat matters — especially for Indian women</h2>

      <div class="nutrition-grid">
        <div class="nutrition-card">
          <div class="nutrition-icon">🥚</div>
          <h3 class="nutrition-title">Protein at every meal</h3>
          <p class="nutrition-desc">Skin and hair are made of protein — keratin and collagen. Indian sources: dal, eggs, paneer, curd, chicken, fish, rajma, chana. Aim for at least 20–30g of protein per meal.</p>
        </div>
        <div class="nutrition-card">
          <div class="nutrition-icon">🫘</div>
          <h3 class="nutrition-title">Iron (ferritin)</h3>
          <p class="nutrition-desc">Critical for hair growth. Indian women are at high risk of deficiency — test ferritin specifically, not just haemoglobin. Sources: methi, rajma, sesame (til), dates, red meat, dark leafy greens with Vitamin C to improve absorption.</p>
        </div>
        <div class="nutrition-card">
          <div class="nutrition-icon">🫐</div>
          <h3 class="nutrition-title">Vitamin C</h3>
          <p class="nutrition-desc">Essential for collagen synthesis — the body cannot make collagen without it. <strong>Amla (Indian gooseberry) is one of the richest natural sources of Vitamin C in the world.</strong> Also: guava, bell peppers, citrus fruits.</p>
        </div>
        <div class="nutrition-card">
          <div class="nutrition-icon">🌱</div>
          <h3 class="nutrition-title">Zinc</h3>
          <p class="nutrition-desc">Supports hair follicle health and sebum regulation. Indian sources: pumpkin seeds (kaddu ke beej), til (sesame), lentils, chickpeas, eggs. Zinc deficiency directly causes hair shedding.</p>
        </div>
        <div class="nutrition-card">
          <div class="nutrition-icon">🐟</div>
          <h3 class="nutrition-title">Omega-3 fatty acids</h3>
          <p class="nutrition-desc">Anti-inflammatory; supports skin hydration and reduces the inflammatory component of hormonal acne. Indian sources: alsi (flaxseed), walnuts, chia seeds, sardines, mackerel.</p>
        </div>
        <div class="nutrition-card">
          <div class="nutrition-icon">☀️</div>
          <h3 class="nutrition-title">Vitamin D</h3>
          <p class="nutrition-desc">Deficiency is extremely common in Indian women despite sun exposure (due to melanin, indoor work, sunscreen). Vitamin D deficiency causes hair loss and poor skin healing. Test your level and supplement if low.</p>
        </div>
      </div>

      <div class="ig-callout ig-callout--peach">
        <span class="ig-callout-icon">🇮🇳</span>
        <span>Indian women following vegetarian or vegan diets are at particularly high risk of iron, B12, zinc, and Vitamin D deficiency — all of which directly impact hair and skin. If you're experiencing significant changes, ask your doctor to test all four before starting supplements.</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ig-cta-section">
    <div class="container">
      <div class="ig-cta-inner">
        <div class="ig-cta-left">
          <h2>Find out what's driving your hair and skin changes</h2>
          <p>Our free symptom check is built for Indian women and covers the full picture — including hair, skin, and the hormonal changes underneath. Private, free, no login needed.</p>
          <div class="ig-cta-btns">
            <a href="/quiz" class="btn btn-peach btn-lg">Check My Symptoms →</a>
            <a href="/chat" class="btn btn-outline-white">Talk Privately</a>
          </div>
        </div>
        <div class="ig-cta-stat-col">
          <div class="ig-stat"><span class="ig-stat-num">30%</span><span class="ig-stat-label">of skin collagen lost in the first 5 years after menopause</span></div>
          <div class="ig-stat"><span class="ig-stat-num">6 months</span><span class="ig-stat-label">for HRT to produce measurable improvement in skin collagen content</span></div>
          <div class="ig-stat"><span class="ig-stat-num">Treatable</span><span class="ig-stat-label">hair thinning and skin changes respond to the right interventions</span></div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .ig-hero {
    background: linear-gradient(135deg, #0F2A1A 0%, #1A3D2B 60%, #2A5C45 100%);
    color: #fff;
    padding: 6rem 0 5rem;
    text-align: center;
  }
  .ig-hero-inner { max-width: 680px; margin: 0 auto; }
  .ig-eyebrow { display: inline-block; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.85); font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .4rem 1rem; border-radius: 100px; margin-bottom: 1.25rem; }
  .ig-hero h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 900; letter-spacing: -.03em; color: #fff; margin-bottom: 1rem; }
  .ig-hero p { font-size: 1.1rem; color: rgba(255,255,255,.75); margin-bottom: 2rem; }
  .ig-share-row { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .ig-share-label { font-size: .85rem; color: rgba(255,255,255,.55); }
  .ig-share-btn { font-size: .82rem; font-weight: 700; padding: .45rem 1rem; border-radius: 99px; text-decoration: none; }
  .ig-wa { background: #25D366; color: #fff; }

  /* SECTIONS */
  .ig-section { padding: 5rem 0; }
  .bg-white { background: #fff; }
  .bg-cream { background: var(--cream, #F9F5F0); }
  .ig-card-label { font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--green, #1A3D2B); background: var(--green-light, #E8F0EB); display: inline-block; padding: .3rem .9rem; border-radius: 99px; margin-bottom: 1rem; }
  .ig-card-label.center { display: block; text-align: center; }
  .ig-section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 900; letter-spacing: -.025em; color: var(--text, #1a1a1a); margin-bottom: .75rem; }
  .ig-section-title.center { text-align: center; }
  .ig-section-sub { font-size: 1rem; color: var(--text-secondary, #555); line-height: 1.7; text-align: center; max-width: 640px; margin: 0 auto 3rem; }

  /* CALLOUT */
  .ig-callout { display: flex; gap: 1rem; align-items: flex-start; background: var(--green-light, #E8F0EB); border-left: 4px solid var(--green, #1A3D2B); border-radius: 0 12px 12px 0; padding: 1.1rem 1.25rem; margin-top: 2rem; font-size: .9rem; color: var(--text, #1a1a1a); line-height: 1.65; }
  .ig-callout--peach { background: #FEF3EC; border-color: #D4845A; }
  .ig-callout-icon { font-size: 1.3rem; flex-shrink: 0; }

  /* SCIENCE GRID */
  .science-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .science-card { border-radius: 20px; padding: 2rem; }
  .science-card--skin { background: linear-gradient(135deg, #FEF3EC, #FDDCC8); border: 2px solid #D4845A; }
  .science-card--hair { background: linear-gradient(135deg, #E8F0EB, #C8DDD0); border: 2px solid var(--green, #1A3D2B); }
  .science-card--androgens { background: linear-gradient(135deg, #F5F0F8, #E8DFF0); border: 2px solid #9B7BB8; }
  .science-icon { font-size: 2rem; margin-bottom: .75rem; }
  .science-title { font-size: 1.1rem; font-weight: 900; margin-bottom: 1rem; }
  .science-card--skin .science-title { color: #9D4E1E; }
  .science-card--hair .science-title { color: #1A3D2B; }
  .science-card--androgens .science-title { color: #6B4D8A; }
  .science-list { list-style: none; display: flex; flex-direction: column; gap: .5rem; }
  .science-list li { font-size: .86rem; color: var(--text, #1a1a1a); padding-left: 1.2rem; position: relative; line-height: 1.65; }
  .science-list li::before { content: '✓'; position: absolute; left: 0; font-size: .75rem; font-weight: 700; }
  .science-card--skin .science-list li::before { color: #D4845A; }
  .science-card--hair .science-list li::before { color: var(--green, #1A3D2B); }
  .science-card--androgens .science-list li::before { color: #9B7BB8; }

  /* SYMPTOM LINK */
  .symptom-link-row { margin-top: 2rem; }
  .symptom-link { display: inline-block; font-size: .88rem; font-weight: 700; color: var(--green, #1A3D2B); text-decoration: none; border-bottom: 2px solid var(--green-light, #E8F0EB); padding-bottom: .1rem; transition: border-color .15s; }
  .symptom-link:hover { border-color: var(--green, #1A3D2B); }

  /* INDIA GRID (5-card version) */
  .india-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2rem; }
  .india-card { background: #fff; border-radius: 16px; padding: 1.5rem; border: 1.5px solid var(--border-light, #eee); }
  .india-icon { font-size: 2rem; margin-bottom: .75rem; }
  .india-title { font-size: .97rem; font-weight: 800; color: var(--text, #1a1a1a); margin-bottom: .4rem; }
  .india-desc { font-size: .85rem; color: var(--text-secondary, #555); line-height: 1.65; }

  /* HELPS (reuse template pattern) */
  .helps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .helps-col { background: var(--cream, #F9F5F0); border-radius: 16px; padding: 1.5rem; }
  .helps-head { font-size: .9rem; font-weight: 800; margin-bottom: 1rem; padding-bottom: .75rem; border-bottom: 2px solid; }
  .helps-head--actives { border-color: #9B7BB8; color: #6B4D8A; }
  .helps-head--habits { border-color: #7FB89A; color: #2A5C45; }
  .helps-head--medical { border-color: #D4845A; color: #9D4E1E; }
  .helps-head--test { border-color: #D4845A; color: #9D4E1E; }
  .helps-head--scalp { border-color: var(--green, #1A3D2B); color: var(--green, #1A3D2B); }
  .helps-list { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
  .helps-list li { font-size: .85rem; color: var(--text, #1a1a1a); line-height: 1.55; padding-left: 1rem; position: relative; }
  .helps-list li::before { content: '→'; position: absolute; left: 0; color: var(--green, #1A3D2B); font-size: .75rem; }

  /* NUTRITION GRID */
  .nutrition-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2rem; }
  .nutrition-card { background: var(--cream, #F9F5F0); border-radius: 16px; padding: 1.5rem; border: 1.5px solid var(--border-light, #eee); }
  .nutrition-icon { font-size: 1.75rem; margin-bottom: .6rem; }
  .nutrition-title { font-size: .95rem; font-weight: 800; color: var(--text, #1a1a1a); margin-bottom: .5rem; }
  .nutrition-desc { font-size: .83rem; color: var(--text-secondary, #555); line-height: 1.65; }

  /* CTA */
  .ig-cta-section { background: linear-gradient(135deg, #0F2A1A, #1A3D2B); padding: 5rem 0; color: #fff; }
  .ig-cta-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .ig-cta-left h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 900; letter-spacing: -.03em; color: #fff; margin-bottom: .75rem; }
  .ig-cta-left p { font-size: 1rem; color: rgba(255,255,255,.75); margin-bottom: 1.75rem; line-height: 1.65; }
  .ig-cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-peach { display: inline-flex; align-items: center; padding: .75rem 1.5rem; background: #D4845A; color: #fff; border-radius: 99px; font-weight: 700; font-size: .9rem; text-decoration: none; transition: background .18s; }
  .btn-peach:hover { background: #C07040; }
  .btn-lg { padding: .85rem 2rem; font-size: 1rem; }
  .btn-outline-white { display: inline-flex; align-items: center; padding: .75rem 1.5rem; border: 2px solid rgba(255,255,255,.4); color: #fff; border-radius: 99px; font-weight: 700; font-size: .9rem; text-decoration: none; transition: all .18s; }
  .btn-outline-white:hover { background: rgba(255,255,255,.1); }
  .ig-cta-stat-col { display: flex; flex-direction: column; gap: 1rem; }
  .ig-stat { background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12); border-radius: 14px; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: .25rem; }
  .ig-stat-num { font-size: 1.75rem; font-weight: 900; color: #FBBF81; letter-spacing: -.03em; }
  .ig-stat-label { font-size: .83rem; color: rgba(255,255,255,.7); line-height: 1.4; }

