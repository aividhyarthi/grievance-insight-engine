---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Free Perimenopause Quiz — Check Your Symptoms | The Second Spring"
  description="Take our free perimenopause quiz designed for Indian women. 12 questions, 2 minutes, instant results. Understand if your symptoms — irregular periods, mood changes, sleep problems, hot flashes — could be perimenopause."
>
  <div class="quiz-page">

    <!-- INTRO -->
    <section class="qs-screen" id="screen-intro">
      <div class="qc">
        <span class="q-eyebrow">🌸 Free · 2 minutes · Anonymous</span>
        <h1>Could it be perimenopause?</h1>
        <p class="qi-desc">
          12 clinically-informed questions. Instant personalised results.<br/>
          Nothing is saved, stored, or shared.
        </p>
        <div class="qi-stats">
          <div class="qi-stat"><span class="qs-n">12</span><span class="qs-l">Questions</span></div>
          <div class="qi-div"></div>
          <div class="qi-stat"><span class="qs-n">2 min</span><span class="qs-l">Duration</span></div>
          <div class="qi-div"></div>
          <div class="qi-stat"><span class="qs-n">Free</span><span class="qs-l">Always</span></div>
        </div>
        <button class="btn btn-peach btn-lg qi-start-btn" id="start-btn">Begin symptom check →</button>
        <p class="qi-note">🔒 Anonymous · No login required · Not medical advice</p>
        <div class="qi-credibility">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Questions developed with guidance from menopause-aware gynaecologists, informed by the Greene Climacteric Scale — the most widely used validated tool for assessing menopausal symptoms in clinical practice.
        </div>
      </div>
    </section>

    <!-- LEAD CAPTURE -->
    <section class="qs-screen" id="screen-lead" style="display:none">
      <div class="qc">
        <button class="qq-back" id="lead-back-btn">← Back</button>
        <div class="lead-card">
          <div class="lead-icon">📩</div>
          <h2 class="lead-title">Where should we send your result?</h2>
          <p class="lead-desc">We'll send your personalised perimenopause result to your WhatsApp or email — along with resources matched to your symptoms. You can also take the quiz anonymously if you prefer.</p>
          <form id="lead-form" novalidate>
            <div class="lead-field">
              <label class="lead-label" for="lead-phone">WhatsApp / Mobile number <span class="lead-optional">(India +91)</span></label>
              <input class="lead-input" type="tel" id="lead-phone" name="phone" placeholder="e.g. 9876543210" inputmode="numeric" maxlength="10" />
            </div>
            <div class="lead-field">
              <label class="lead-label" for="lead-email">Email address</label>
              <input class="lead-input" type="email" id="lead-email" name="email" placeholder="you@example.com" />
            </div>
            <p class="lead-privacy">🔒 We never share your details. You can unsubscribe any time.</p>
            <button type="submit" class="btn btn-peach btn-lg lead-submit-btn">Start symptom check →</button>
          </form>
          <button class="lead-skip" id="lead-skip-btn">Skip — take quiz anonymously</button>
        </div>
      </div>
    </section>

    <!-- QUESTIONS -->
    <section class="qs-screen" id="screen-questions" style="display:none">
      <div class="qc">
        <div class="qq-header">
          <button class="qq-back" id="back-btn">← Back</button>
          <span class="qq-counter" id="q-counter">1 of 12</span>
        </div>
        <div class="qq-bar-wrap">
          <div class="qq-bar" id="q-bar"></div>
          <span class="qq-pct" id="q-pct">0%</span>
        </div>
        <div class="qq-card">
          <div class="qq-num" id="q-num"></div>
          <h2 class="qq-text" id="q-text"></h2>
          <div class="qq-opts" id="q-opts"></div>
        </div>
        <p class="qq-privacy">🔒 Your answers are not stored or shared</p>
      </div>
    </section>

    <!-- RESULT -->
    <section class="qs-screen" id="screen-result" style="display:none">
      <div class="qc" id="result-content"></div>
    </section>

  </div>

  <!-- SEO content -->
  <section class="quiz-seo-section">
    <div class="container">

      <div class="qseo-intro">
        <h2>What Is This Perimenopause Quiz?</h2>
        <p>This free perimenopause symptom quiz helps Indian women in their late 30s and 40s understand whether the changes they are experiencing — irregular periods, sleep disruption, mood swings, brain fog, weight gain, hot flashes — could be signs of perimenopause.</p>
        <p>The quiz takes 2 minutes, asks 12 questions, and gives you an instant personalised result. It is private, anonymous, and free. No login, no data stored.</p>
      </div>

      <div class="qseo-grid">
        <div class="qseo-card">
          <div class="qseo-icon">🌸</div>
          <h3>Designed for Indian Women</h3>
          <p>Indian women reach menopause 2–3 years earlier than Western averages — typically around age 46–47. This quiz accounts for the Indian context, including different symptom patterns and cultural factors.</p>
        </div>
        <div class="qseo-card">
          <div class="qseo-icon">🔬</div>
          <h3>Clinically Informed</h3>
          <p>Questions are informed by the Greene Climacteric Scale, the most widely validated tool for assessing menopausal symptoms, developed with guidance from menopause-aware gynaecologists.</p>
        </div>
        <div class="qseo-card">
          <div class="qseo-icon">🔒</div>
          <h3>Completely Private</h3>
          <p>Nothing is saved, shared, or stored. You do not need to create an account. Your answers disappear when you close the tab. Designed for women who want to understand their bodies without judgment.</p>
        </div>
      </div>

      <div class="qseo-symptoms">
        <h2>Which Symptoms Does the Quiz Cover?</h2>
        <p>The perimenopause symptom check covers the most common signs of perimenopause in Indian women:</p>
        <div class="qseo-sym-grid">
          <a href="/guide/symptoms/irregular-periods" class="qseo-sym">📅 Irregular periods</a>
          <a href="/guide/symptoms/hot-flashes" class="qseo-sym">🌡️ Hot flashes & night sweats</a>
          <a href="/guide/symptoms/sleep-problems" class="qseo-sym">🌙 Sleep problems</a>
          <a href="/guide/symptoms/mood-swings" class="qseo-sym">😤 Mood swings & irritability</a>
          <a href="/guide/symptoms/anxiety" class="qseo-sym">💭 Anxiety & low mood</a>
          <a href="/guide/symptoms/brain-fog" class="qseo-sym">🧠 Brain fog & memory</a>
          <a href="/guide/symptoms/joint-pain" class="qseo-sym">🦴 Joint & muscle pain</a>
          <a href="/guide/symptoms/joint-pain" class="qseo-sym">😴 Fatigue & low energy</a>
          <a href="/guide/symptoms/low-libido" class="qseo-sym">🌸 Low libido</a>
          <a href="/guide/symptoms/skin-hair" class="qseo-sym">✨ Hair & skin changes</a>
          <a href="/guide/symptoms/heart-palpitations" class="qseo-sym">💓 Heart palpitations</a>
        </div>
      </div>

      <div class="qseo-faq">
        <h2>Perimenopause Quiz — Common Questions</h2>
        <div class="qseo-faq-item">
          <h3>Is this perimenopause quiz accurate?</h3>
          <p>This quiz is a symptom awareness tool, not a medical diagnosis. It identifies patterns that commonly align with perimenopause based on current clinical evidence. A definitive assessment requires a consultation with a gynaecologist — but the quiz gives you a clear starting point and language to use with your doctor.</p>
        </div>
        <div class="qseo-faq-item">
          <h3>What age should I take a perimenopause quiz?</h3>
          <p>If you are 38 or older and noticing changes in your periods, sleep, mood, or energy, it is worth checking. In India, perimenopause typically begins between ages 41–46, though it can start in the late 30s. There is no age that is "too young" to understand your symptoms.</p>
        </div>
        <div class="qseo-faq-item">
          <h3>Can I have perimenopause symptoms with regular periods?</h3>
          <p>Yes. Perimenopause often begins while periods are still regular. The earliest signs are frequently mood changes, sleep disruption, anxiety, or subtle cycle length changes — not necessarily missed periods. The quiz covers this early pattern.</p>
        </div>
        <div class="qseo-faq-item">
          <h3>What should I do after taking the quiz?</h3>
          <p>Read the journals most relevant to your result, use our private <a href="/chat">chat companion</a> to ask questions without judgment, and if your symptoms are affecting your quality of life, speak to a gynaecologist. Our <a href="/guide/talk-to-doctor">Talk to Your Doctor guide</a> helps you prepare for that conversation.</p>
        </div>
        <div class="qseo-faq-item">
          <h3>Is perimenopause different for Indian women?</h3>
          <p>Yes. Indian women on average reach menopause 2–3 years earlier than Western women. Vitamin D deficiency is more prevalent, affecting bone and mood symptoms. Dietary patterns, body composition, and cultural factors around discussing menopause all influence the experience. This quiz and website are built specifically for the Indian context.</p>
        </div>
      </div>

      <div class="qseo-links">
        <h2>Learn More</h2>
        <div class="qseo-link-row">
          <a href="/guide/symptoms" class="qseo-link-card">🔍 Symptom Library — every symptom explained</a>
          <a href="/blog/seven-signs-of-perimenopause" class="qseo-link-card">📋 Seven Signs of Perimenopause</a>
          <a href="/blog/how-to-test-for-perimenopause" class="qseo-link-card">🧪 How to Test for Perimenopause</a>
          <a href="/blog/how-long-does-perimenopause-last" class="qseo-link-card">⏱ How Long Does Perimenopause Last?</a>
          <a href="/myths" class="qseo-link-card">🚫 Perimenopause Myths Debunked</a>
          <a href="/chat" class="qseo-link-card">💬 Ask Our Private Companion</a>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
const QUESTIONS = [
  {
    q: "How old are you?",
    hint: "Age is one of the strongest indicators of where you are in the hormonal transition.",
    opts: [
      { t: "Under 35",    s: 0 },
      { t: "35 – 39",     s: 2 },
      { t: "40 – 44",     s: 5 },
      { t: "45 – 49",     s: 7 },
      { t: "50 or older", s: 5 },
    ]
  },
  {
    q: "Have your periods changed in the last 12 months?",
    hint: "Cycle changes are often the clearest early signal of perimenopause.",
    opts: [
      { t: "No — still regular and predictable",                  s: 0 },
      { t: "Slightly different — lighter, heavier, or a few days off", s: 3 },
      { t: "Noticeably irregular or skipping months",             s: 6 },
      { t: "No period in over 12 months",                         s: 8 },
    ]
  },
  {
    q: "Do you experience hot flashes or night sweats?",
    hint: "A sudden wave of heat, flushing, or waking drenched in sweat — even occasionally.",
    opts: [
      { t: "No, not at all",                                       s: 0 },
      { t: "Occasionally — mild and manageable",                   s: 2 },
      { t: "Regularly — a few times a week",                       s: 4 },
      { t: "Often — disruptive to sleep or daily life",            s: 6 },
    ]
  },
  {
    q: "How is your sleep?",
    hint: "Progesterone — the first hormone to decline — has natural sleep-promoting properties.",
    opts: [
      { t: "I sleep well and wake refreshed",                      s: 0 },
      { t: "Occasionally restless or unrefreshed",                 s: 2 },
      { t: "I regularly wake at night or struggle to fall asleep", s: 4 },
      { t: "Sleep is a constant struggle affecting my days",       s: 5 },
    ]
  },
  {
    q: "Are you experiencing mood swings or feeling emotionally unlike yourself?",
    hint: "Oestrogen directly influences serotonin. Its fluctuation can cause sudden, disproportionate emotional reactions.",
    opts: [
      { t: "Not really — emotions feel normal for me",             s: 0 },
      { t: "Occasionally more irritable or tearful than usual",    s: 2 },
      { t: "Often — swings that feel out of character",            s: 4 },
      { t: "My moods feel very unpredictable and distressing",     s: 5 },
    ]
  },
  {
    q: "Have you noticed more anxiety or persistent low mood?",
    hint: "New-onset anxiety in your 40s with no prior history is one of the most commonly missed signs of perimenopause.",
    opts: [
      { t: "No more than usual",                                   s: 0 },
      { t: "A little more worried or flat lately",                 s: 2 },
      { t: "Yes — anxiety or low mood I haven't felt before",      s: 4 },
      { t: "It's significantly affecting my daily life",           s: 5 },
    ]
  },
  {
    q: "Do you have trouble concentrating or remembering things?",
    hint: "Oestrogen supports memory and cognitive function. Brain fog is one of the most distressing but least talked-about symptoms.",
    opts: [
      { t: "No — memory and focus are fine",                       s: 0 },
      { t: "Occasionally forgetful or lose my train of thought",   s: 2 },
      { t: "Often — affecting work or daily tasks",                s: 4 },
      { t: "Severe — I feel I've lost my mental sharpness",        s: 5 },
    ]
  },
  {
    q: "How are your energy levels?",
    hint: "Hormonal disruption, poor sleep, and thyroid changes all contribute to perimenopausal fatigue.",
    opts: [
      { t: "Good — I feel energetic most days",                    s: 0 },
      { t: "I tire more easily than I used to",                    s: 2 },
      { t: "I feel exhausted most days",                           s: 4 },
      { t: "My fatigue is severe and hard to explain",             s: 5 },
    ]
  },
  {
    q: "Do you have unexplained joint pain, stiffness, or muscle aches?",
    hint: "Oestrogen has anti-inflammatory properties. Its decline often causes joint pain — an underrecognised perimenopause symptom.",
    opts: [
      { t: "No joint pain or stiffness",                           s: 0 },
      { t: "Mild stiffness, especially in the morning",            s: 2 },
      { t: "Regular joint or muscle pain without obvious cause",   s: 4 },
      { t: "Significant pain affecting movement or daily life",    s: 5 },
    ]
  },
  {
    q: "Have you noticed unexplained weight gain, especially around the belly?",
    hint: "Declining oestrogen shifts fat storage toward the abdomen — even without changes to diet or exercise.",
    opts: [
      { t: "No change in weight or shape",                         s: 0 },
      { t: "A little weight gain — not sure if hormonal",          s: 2 },
      { t: "Yes, gaining around my belly despite no diet changes", s: 4 },
      { t: "Yes — significant and very hard to manage",            s: 5 },
    ]
  },
  {
    q: "Have you noticed changes in your hair or skin?",
    hint: "Oestrogen stimulates collagen and supports the hair growth cycle. Its decline causes dryness, thinning, and reduced elasticity.",
    opts: [
      { t: "No noticeable changes",                                s: 0 },
      { t: "Mild dryness or slightly more hair shedding",          s: 2 },
      { t: "Noticeable thinning or skin changes that concern me",  s: 4 },
      { t: "Significant changes in both hair and skin",            s: 5 },
    ]
  },
  {
    q: "Has your interest in sex or physical intimacy changed?",
    hint: "Declining oestrogen and testosterone both reduce libido. Vaginal dryness and discomfort are also common.",
    opts: [
      { t: "No change",                                            s: 0 },
      { t: "Slightly lower interest than before",                  s: 1 },
      { t: "Noticeably lower, or intimacy is uncomfortable",       s: 3 },
      { t: "Very low, or with significant physical discomfort",    s: 4 },
    ]
  },
];

const RESULTS = [
  {
    max: 15,
    emoji: '🌱',
    level: 'Low likelihood right now',
    topBg: 'linear-gradient(135deg,#EEF7F2 0%,#C8E6D4 100%)',
    color: '#3D7A5F',
    title: 'Your symptoms are mild at this stage',
    body: "Your answers suggest a low likelihood of perimenopause right now — but symptoms can evolve over months, and some changes may relate to hormonal shifts, thyroid function, or stress. It is worth staying aware.",
    steps: [
      { icon: '💬', text: 'Chat with our companion about any symptoms that concern you' },
      { icon: '📚', text: 'Read our guide on early signs to watch for' },
      { icon: '🩺', text: 'Mention any new changes to your doctor at your next visit' },
    ],
    cta: 'Talk to your companion', href: '/chat',
  },
  {
    max: 33,
    emoji: '🌸',
    level: 'Possible early perimenopause',
    topBg: 'linear-gradient(135deg,#FDF2EC 0%,#F5D4BA 100%)',
    color: '#C06030',
    title: 'You may be in early perimenopause',
    body: "Your symptoms align with early perimenopause — the transition that typically begins 4–10 years before menopause. In India, this often starts between ages 38–44. This is completely normal, but it deserves proper understanding and support.",
    steps: [
      { icon: '💬', text: 'Start a private conversation — get answers specific to your symptoms' },
      { icon: '🩺', text: 'Speak to a gynaecologist who understands perimenopause' },
      { icon: '📖', text: 'Read our Symptom Library to understand each symptom in detail' },
    ],
    cta: 'Start a private conversation', href: '/chat',
  },
  {
    max: Infinity,
    emoji: '🌺',
    level: 'Likely perimenopause or menopause transition',
    topBg: 'linear-gradient(135deg,#FFF5F5 0%,#F9D0D0 100%)',
    color: '#9B2C2C',
    title: 'Your symptoms strongly suggest perimenopause',
    body: "Based on your answers, you are likely in perimenopause or approaching menopause. This is well understood and very manageable with the right care. The women who do best are those who sought support early — you are doing that right now.",
    steps: [
      { icon: '💬', text: 'Talk to our companion now — personalised information, no judgement' },
      { icon: '🩺', text: 'Consult a menopause-aware gynaecologist as soon as possible' },
      { icon: '🩸', text: 'Ask your doctor for a hormone panel: FSH, LH, oestradiol, and thyroid' },
    ],
    cta: 'Get support now', href: '/chat',
  },
];

// Track per-question scores to enable proper back navigation
let answers: number[] = [];
let cur = 0;
let ageAnswer = '';

const $intro     = document.getElementById('screen-intro')!;
const $lead      = document.getElementById('screen-lead')!;
const $questions = document.getElementById('screen-questions')!;
const $result    = document.getElementById('screen-result')!;

function totalScore() {
  return answers.reduce((sum, s) => sum + s, 0);
}

function startQuiz() {
  $lead.style.display = 'none';
  $questions.style.display = 'flex';
  render();
}

// Intro → Lead capture
document.getElementById('start-btn')!.addEventListener('click', () => {
  $intro.style.display = 'none';
  $lead.style.display = 'flex';
});

// Lead capture back → Intro
document.getElementById('lead-back-btn')!.addEventListener('click', () => {
  $lead.style.display = 'none';
  $intro.style.display = 'flex';
});

// Lead form submit
document.getElementById('lead-form')!.addEventListener('submit', (e) => {
  e.preventDefault();
  const phone = (document.getElementById('lead-phone') as HTMLInputElement).value.trim();
  const email = (document.getElementById('lead-email') as HTMLInputElement).value.trim();
  if (!phone && !email) {
    const err = document.querySelector('.lead-error') as HTMLElement || (() => {
      const el = document.createElement('p');
      el.className = 'lead-error';
      el.textContent = 'Please enter at least a phone number or email to continue.';
      document.getElementById('lead-form')!.insertBefore(el, document.querySelector('.lead-privacy'));
      return el;
    })();
    err.style.display = 'block';
    return;
  }
  try {
    sessionStorage.setItem('tss_lead', JSON.stringify({ phone, email }));
    fetch('/api/collect-lead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone, email, stage: 'quiz_start' }),
    }).catch(() => {});
  } catch (_) {}
  startQuiz();
});

// Skip → start anonymously
document.getElementById('lead-skip-btn')!.addEventListener('click', () => {
  startQuiz();
});

document.getElementById('back-btn')!.addEventListener('click', () => {
  if (cur > 0) {
    cur--;
    answers = answers.slice(0, cur);
    render();
  } else {
    $questions.style.display = 'none';
    $lead.style.display = 'flex';
  }
});

function render() {
  const q = QUESTIONS[cur];
  const pct = Math.round((cur / QUESTIONS.length) * 100);
  (document.getElementById('q-counter') as HTMLElement).textContent = `${cur + 1} of ${QUESTIONS.length}`;
  (document.getElementById('q-bar') as HTMLElement).style.width = `${pct}%`;
  (document.getElementById('q-pct') as HTMLElement).textContent = `${pct}%`;
  (document.getElementById('q-num') as HTMLElement).textContent = `Question ${cur + 1}`;
  (document.getElementById('q-text') as HTMLElement).textContent = q.q;

  const el = document.getElementById('q-opts')!;
  el.innerHTML = '';

  // Show hint if exists
  const hintId = 'q-hint';
  let hintEl = document.getElementById(hintId);
  if (!hintEl) {
    hintEl = document.createElement('p');
    hintEl.id = hintId;
    hintEl.className = 'qq-hint';
    (document.getElementById('q-text') as HTMLElement).insertAdjacentElement('afterend', hintEl);
  }
  hintEl.textContent = q.hint || '';

  q.opts.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'q-opt';
    btn.innerHTML = `<span class="qo-radio"></span><span class="qo-text">${opt.t}</span>`;
    btn.addEventListener('click', () => {
      el.querySelectorAll('.q-opt').forEach(b => (b as HTMLButtonElement).disabled = true);
      btn.classList.add('selected');
      if (cur === 0) ageAnswer = opt.t;
      answers[cur] = opt.s;
      cur++;
      setTimeout(() => cur < QUESTIONS.length ? render() : showResult(), 380);
    });
    el.appendChild(btn);
  });
}

function showResult() {
  $questions.style.display = 'none';
  $result.style.display = 'flex';
  const score = totalScore();
  const r = RESULTS.find(x => score < x.max)!;

  try {
    const lead = JSON.parse(sessionStorage.getItem('tss_lead') || '{}');
    fetch('/api/collect-lead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: lead.email || '', phone: lead.phone || '', age: ageAnswer, score, level: r.level }),
    }).catch(() => {});
    sessionStorage.removeItem('tss_lead');
  } catch (_) {}

  document.getElementById('result-content')!.innerHTML = `
    <div class="result-card">
      <div class="result-top" style="background:${r.topBg}">
        <div class="rt-emoji">${r.emoji}</div>
        <div class="rt-tag" style="background:${r.color};color:#fff">${r.level}</div>
        <h2 class="rt-title">${r.title}</h2>
      </div>
      <div class="result-body">
        <p class="rb-lead">${r.body}</p>
        <div class="rb-steps">
          <p class="rbs-label">Your personalised next steps</p>
          ${r.steps.map(s => `
            <div class="rbs-item">
              <span class="rbs-icon">${s.icon}</span>
              <span>${s.text}</span>
            </div>
          `).join('')}
        </div>
        <div class="rb-cta-wrap">
          <a href="${r.href}" class="btn btn-peach btn-lg">${r.cta} →</a>
          <p class="rb-private">🔒 Private · Confidential · Judgment-free</p>
        </div>
        <div class="rb-footer">
          <button id="retake" class="rb-retake">← Retake the quiz</button>
          <p class="rb-disc">This quiz is a symptom awareness tool, not a medical diagnosis. Always consult a qualified gynaecologist for personal medical advice.</p>
        </div>
      </div>
    </div>
  `;
  document.getElementById('retake')!.addEventListener('click', () => {
    cur = 0; answers = [];
    $result.style.display = 'none';
    $intro.style.display = 'flex';
  });
}
</script>

<style>
  .quiz-page { background: var(--cream); min-height: calc(100vh - var(--nav-h)); }

  .qs-screen {
    min-height: calc(100vh - var(--nav-h));
    display: flex; align-items: center; justify-content: center;
    padding: 3rem 1.5rem;
  }
  .qc { width: 100%; max-width: 620px; }

  /* ── INTRO ── */
  .q-eyebrow {
    display: inline-flex; font-size: .76rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--green); background: var(--green-light); padding: .35rem .9rem; border-radius: 100px; margin-bottom: 1.5rem;
  }
  #screen-intro h1 { font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 900; letter-spacing: -.03em; color: var(--text); line-height: 1.15; margin-bottom: 1rem; }
  .qi-desc { font-size: 1.05rem; color: var(--text-secondary); line-height: 1.72; margin-bottom: 2rem; }
  .qi-stats {
    display: flex; align-items: center; gap: 1.75rem;
    background: var(--green-light); border-radius: var(--radius);
