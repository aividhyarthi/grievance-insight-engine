---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Free Perimenopause Symptom Check — The Second Spring"
  description="Take our free perimenopause quiz designed for Indian women. 12 questions, 2 minutes, instant results. Understand if your symptoms could be perimenopause."
>

<div class="quiz-shell">

  <!-- ── INTRO ── -->
  <div class="q-screen active" id="s-intro">
    <div class="q-wrap">
      <div class="intro-badge">🌸 Free · 2 min · Private</div>
      <h1 class="intro-h1">Could your symptoms<br/>be perimenopause?</h1>
      <p class="intro-sub">12 clinically-informed questions. Instant personalised result. Nothing stored or shared.</p>
      <div class="intro-pills">
        <span>😤 Mood swings</span>
        <span>🌙 Poor sleep</span>
        <span>🧠 Brain fog</span>
        <span>🔥 Hot flashes</span>
        <span>😰 Anxiety</span>
        <span>⚖️ Weight gain</span>
      </div>
      <button class="btn-main" id="btn-start">Begin symptom check →</button>
      <p class="intro-lock">🔒 Anonymous · No login · Not medical advice</p>
      <div class="intro-trust">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Informed by the Greene Climacteric Scale, developed with guidance from menopause-aware gynaecologists
      </div>
    </div>
  </div>

  <!-- ── PRIVACY ── -->
  <div class="q-screen" id="s-privacy">
    <div class="q-wrap">
      <button class="btn-back" id="btn-privacy-back">← Back</button>
      <div class="prv-top">
        <div class="prv-icon">🔒</div>
        <h2 class="prv-h2">Your data, your control</h2>
        <p class="prv-sub">This quiz is completely private. Here is exactly what we do — and do not — do with any information you share.</p>
      </div>
      <div class="prv-cards">
        <div class="prv-card">
          <span class="prv-card-icon">✅</span>
          <div class="prv-card-body">
            <p class="prv-card-title">What you choose to share</p>
            <p class="prv-card-text">If you enter your phone or email, we use it only to send you your personalised result. Nothing else, ever.</p>
          </div>
        </div>
        <div class="prv-card">
          <span class="prv-card-icon">🚫</span>
          <div class="prv-card-body">
            <p class="prv-card-title">What we never collect</p>
            <p class="prv-card-text">Your quiz answers are never stored or linked to your identity. We cannot see which options you chose.</p>
          </div>
        </div>
        <div class="prv-card">
          <span class="prv-card-icon">🤝</span>
          <div class="prv-card-body">
            <p class="prv-card-title">We never sell your data</p>
            <p class="prv-card-text">Your information is never sold, rented, or shared with third parties. You can unsubscribe from any message instantly.</p>
          </div>
        </div>
        <div class="prv-card">
          <span class="prv-card-icon">📧</span>
          <div class="prv-card-body">
            <p class="prv-card-title">Questions about your data?</p>
            <p class="prv-card-text">Write to us at <strong>thesecondspringofficial@gmail.com</strong> and we will respond within 48 hours.</p>
          </div>
        </div>
      </div>
      <button class="btn-main" id="btn-privacy-ok">I understand — continue →</button>
      <button class="btn-ghost" id="btn-privacy-anon">Skip — take quiz without sharing data</button>
    </div>
  </div>

  <!-- ── LEAD CAPTURE ── -->
  <div class="q-screen" id="s-lead">
    <div class="q-wrap">
      <button class="btn-back" id="btn-lead-back">← Back</button>
      <div class="lead-top">
        <div class="lead-icon">📩</div>
        <h2 class="lead-h2">Where should we send your result?</h2>
        <p class="lead-sub">Get your personalised report on WhatsApp or email — matched to your symptoms.</p>
      </div>
      <form id="lead-form" novalidate>
        <div class="field">
          <label class="field-label" for="f-phone">WhatsApp / Mobile <span class="field-opt">India +91</span></label>
          <input class="field-input" type="tel" id="f-phone" placeholder="9876543210" inputmode="numeric" maxlength="10" />
        </div>
        <div class="field">
          <label class="field-label" for="f-email">Email address</label>
          <input class="field-input" type="email" id="f-email" placeholder="you@example.com" />
        </div>
        <p class="lead-err" id="lead-err" style="display:none">Please enter at least your phone or email.</p>
        <p class="field-note">🔒 We never sell or share your details. Unsubscribe any time.</p>
        <button type="submit" class="btn-main">Continue to quiz →</button>
      </form>
      <button class="btn-ghost" id="btn-skip">Skip — take quiz anonymously</button>
    </div>
  </div>

  <!-- ── QUESTION ── -->
  <div class="q-screen" id="s-question">
    <div class="q-wrap">
      <div class="qhdr">
        <button class="btn-back" id="btn-back">← Back</button>
        <span class="q-count" id="q-count">1 / 12</span>
      </div>
      <div class="prog-bar"><div class="prog-fill" id="prog-fill"></div></div>
      <div class="q-card" id="q-card">
        <p class="q-label" id="q-label">Question 1</p>
        <h2 class="q-text" id="q-text"></h2>
        <p class="q-hint" id="q-hint"></p>
        <div class="q-opts" id="q-opts"></div>
      </div>
      <p class="q-foot">🔒 Your answers are private and not stored</p>
    </div>
  </div>

  <!-- ── RESULT ── -->
  <div class="q-screen" id="s-result">
    <div class="q-wrap q-wrap--result">

      <div class="res-hero" id="res-hero">
        <div class="res-emoji" id="res-emoji"></div>
        <div class="res-badge" id="res-badge"></div>
        <h2 class="res-title" id="res-title"></h2>
        <div class="res-meter" id="res-meter">
          <div class="rm-track">
            <div class="rm-fill" id="rm-fill"></div>
          </div>
          <div class="rm-labels">
            <span>Mild</span><span>Moderate</span><span>Likely</span>
          </div>
        </div>
      </div>

      <div class="res-body">
        <p class="res-desc" id="res-desc"></p>

        <div class="res-steps" id="res-steps">
          <p class="res-steps-label">Your personalised next steps</p>
        </div>

        <a class="btn-main res-cta" id="res-cta" href="/chat">Talk to our companion →</a>
        <p class="res-lock">🔒 Private · Confidential · No login needed</p>

        <div class="res-foot">
          <button class="btn-ghost" id="btn-retake">← Retake quiz</button>
          <p class="res-disc">This is a symptom awareness tool, not a medical diagnosis. Always consult a qualified gynaecologist.</p>
        </div>
      </div>

    </div>
  </div>

</div>

<!-- SEO section -->
<section class="seo-wrap">
  <div class="container">
    <div class="seo-intro">
      <h2>What Is This Perimenopause Quiz?</h2>
      <p>This free perimenopause symptom quiz helps Indian women in their late 30s and 40s understand whether the changes they are experiencing could be signs of perimenopause. The quiz takes 2 minutes, asks 12 questions, and gives an instant personalised result.</p>
    </div>
    <div class="seo-cards">
      <div class="seo-card"><div class="seo-icon">🌸</div><h3>For Indian Women</h3><p>Indian women reach menopause 2–3 years earlier than Western averages. This quiz accounts for the Indian context including age of onset, symptoms, and cultural factors.</p></div>
      <div class="seo-card"><div class="seo-icon">🔬</div><h3>Clinically Informed</h3><p>Questions are informed by the Greene Climacteric Scale, developed with guidance from menopause-aware gynaecologists.</p></div>
      <div class="seo-card"><div class="seo-icon">🔒</div><h3>Completely Private</h3><p>Nothing is saved or shared. No account needed. Answers disappear when you close the tab.</p></div>
    </div>
    <div class="seo-faqs">
      <h2>Common Questions</h2>
      <div class="seo-faq"><h3>Is this quiz accurate?</h3><p>It is a symptom awareness tool, not a medical diagnosis. It identifies patterns that align with perimenopause based on clinical evidence. A definitive assessment requires a gynaecologist consultation.</p></div>
      <div class="seo-faq"><h3>What age should I take this quiz?</h3><p>If you are 38 or older and noticing changes in your periods, sleep, mood, or energy — it is worth checking. In India, perimenopause typically begins between ages 41–46.</p></div>
      <div class="seo-faq"><h3>Can I have symptoms with regular periods?</h3><p>Yes. Perimenopause often begins while periods are still regular. The earliest signs are mood changes, sleep disruption, and anxiety — not necessarily missed periods.</p></div>
      <div class="seo-faq"><h3>What do I do after the quiz?</h3><p>Use our private <a href="/chat">chat companion</a> to ask questions, read the <a href="/guide/symptoms">Symptom Library</a>, and speak to a gynaecologist if symptoms affect your quality of life.</p></div>
    </div>
  </div>
</section>

</Layout>

<script>
const Q = [
  { q:'How old are you?', hint:'Age is the strongest single indicator of where you are in the hormonal transition.', opts:[{t:'Under 35',s:0},{t:'35–39',s:2},{t:'40–44',s:5},{t:'45–49',s:7},{t:'50 or older',s:5}] },
  { q:'Have your periods changed in the last 12 months?', hint:'Cycle changes are often the clearest early signal of perimenopause.', opts:[{t:'No — still regular and predictable',s:0},{t:'Slightly different — heavier, lighter, or a few days off',s:3},{t:'Noticeably irregular or skipping months',s:6},{t:'No period in over 12 months',s:8}] },
  { q:'Do you experience hot flashes or night sweats?', hint:'A sudden wave of heat or waking drenched in sweat — even occasionally — is a hallmark hormonal symptom.', opts:[{t:'No, not at all',s:0},{t:'Occasionally — mild',s:2},{t:'Regularly — a few times a week',s:4},{t:'Often — disruptive to sleep or daily life',s:6}] },
  { q:'How is your sleep?', hint:'Progesterone — the first hormone to decline — has natural sleep-promoting properties. Its fall disrupts sleep significantly.', opts:[{t:'I sleep well and wake refreshed',s:0},{t:'Occasionally restless or unrefreshed',s:2},{t:'I regularly wake at night or struggle to fall asleep',s:4},{t:'Sleep is a constant struggle affecting my days',s:5}] },
  { q:'Are you experiencing mood swings or feeling emotionally unlike yourself?', hint:'Oestrogen directly influences serotonin. Its fluctuation can cause sudden, disproportionate emotional reactions.', opts:[{t:'Not really — emotions feel normal for me',s:0},{t:'Occasionally more irritable or tearful',s:2},{t:'Often — swings that feel out of character',s:4},{t:'Very unpredictable and distressing',s:5}] },
  { q:'Have you noticed more anxiety or persistent low mood?', hint:'New-onset anxiety in your 40s with no prior history is one of the most commonly missed signs of perimenopause.', opts:[{t:'No more than usual',s:0},{t:'A little more worried or flat lately',s:2},{t:'Yes — anxiety or low mood I haven\'t felt before',s:4},{t:'It\'s significantly affecting my daily life',s:5}] },
  { q:'Do you have trouble concentrating or remembering things?', hint:'Oestrogen supports memory and cognitive function. Brain fog is one of the most distressing but least-discussed symptoms.', opts:[{t:'No — memory and focus are fine',s:0},{t:'Occasionally forget things or lose my train of thought',s:2},{t:'Often — affecting work or daily tasks',s:4},{t:'Severe — I feel I\'ve lost my mental sharpness',s:5}] },
  { q:'How are your energy levels?', hint:'Hormonal disruption, poor sleep, and thyroid changes all contribute to perimenopausal fatigue.', opts:[{t:'Good — energetic most days',s:0},{t:'I tire more easily than I used to',s:2},{t:'I feel exhausted most days',s:4},{t:'Severe fatigue, hard to explain',s:5}] },
  { q:'Do you have unexplained joint pain, stiffness, or muscle aches?', hint:'Oestrogen has anti-inflammatory properties. Its decline causes joint pain — an underrecognised but very common perimenopause symptom.', opts:[{t:'No joint pain or stiffness',s:0},{t:'Mild stiffness, especially in the morning',s:2},{t:'Regular joint or muscle pain without obvious cause',s:4},{t:'Significant pain affecting daily life',s:5}] },
  { q:'Have you noticed unexplained weight gain, especially around the belly?', hint:'Declining oestrogen shifts fat storage toward the abdomen — even without changes to diet or exercise.', opts:[{t:'No change',s:0},{t:'A little — not sure if hormonal',s:2},{t:'Yes, gaining around belly despite no diet changes',s:4},{t:'Significant and very hard to manage',s:5}] },
  { q:'Have you noticed changes in your hair or skin?', hint:'Oestrogen stimulates collagen and supports the hair growth cycle. Its decline causes dryness, thinning, and reduced elasticity.', opts:[{t:'No noticeable changes',s:0},{t:'Mild dryness or slightly more hair shedding',s:2},{t:'Noticeable thinning or skin changes',s:4},{t:'Significant changes in both hair and skin',s:5}] },
  { q:'Has your interest in sex or physical intimacy changed?', hint:'Declining oestrogen and testosterone both reduce libido. Vaginal dryness and discomfort are also common.', opts:[{t:'No change',s:0},{t:'Slightly lower interest',s:1},{t:'Noticeably lower, or intimacy is uncomfortable',s:3},{t:'Very low or significant physical discomfort',s:4}] },
];

const RESULTS = [
  { max:15, emoji:'🌱', level:'Low likelihood right now', meterPct:15, heroGrad:'linear-gradient(135deg,#E8F5EE,#C3DFC9)', badgeColor:'#3D7A5F', title:'Your symptoms are mild right now', desc:'Your answers suggest a low likelihood of perimenopause at this stage — but symptoms can evolve, and some changes may still relate to hormonal shifts, thyroid function, or stress. It\'s worth staying aware.', steps:[{i:'💬',t:'Chat privately about any symptoms that concern you'},{i:'📖',t:'Read our guide on early signs to watch for'},{i:'🩺',t:'Mention any new changes to your doctor at your next visit'}], cta:'Ask our companion', href:'/chat' },
  { max:33, emoji:'🌸', level:'Possible early perimenopause', meterPct:50, heroGrad:'linear-gradient(135deg,#FDF2EC,#F5D0A9)', badgeColor:'#C06030', title:'You may be in early perimenopause', desc:'Your symptoms align with early perimenopause — the transition that typically begins 4–10 years before menopause. In India, this often starts between ages 38–44. This is completely normal, but it deserves proper understanding and support.', steps:[{i:'💬',t:'Start a private conversation — get answers for your specific symptoms'},{i:'🩺',t:'Speak to a gynaecologist who understands perimenopause'},{i:'📖',t:'Explore our Symptom Library to understand each symptom in detail'}], cta:'Start a private conversation', href:'/chat' },
  { max:Infinity, emoji:'🌺', level:'Likely perimenopause', meterPct:90, heroGrad:'linear-gradient(135deg,#FDF0F0,#F5BABA)', badgeColor:'#9B2C2C', title:'Your symptoms strongly suggest perimenopause', desc:'Based on your answers, you are likely in perimenopause or approaching menopause. The good news: this is well understood and very manageable with the right support. Women who seek help early do significantly better.', steps:[{i:'💬',t:'Talk to our companion — personalised guidance, no judgement'},{i:'🩺',t:'Consult a menopause-aware gynaecologist as soon as possible'},{i:'🩸',t:'Ask your doctor for a hormone panel: FSH, oestradiol, and thyroid'}], cta:'Get support now', href:'/chat' },
];

let answers: number[] = [];
let cur = 0;
let ageAnswer = '';

const sIntro    = document.getElementById('s-intro')!;
const sPrivacy  = document.getElementById('s-privacy')!;
const sLead     = document.getElementById('s-lead')!;
const sQuestion = document.getElementById('s-question')!;
const sResult   = document.getElementById('s-result')!;

function show(el: HTMLElement) {
  [sIntro, sPrivacy, sLead, sQuestion, sResult].forEach(s => s.classList.remove('active'));
  el.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}

// Intro → Privacy
document.getElementById('btn-start')!.onclick = () => show(sPrivacy);

// Privacy → Intro (back)
document.getElementById('btn-privacy-back')!.onclick = () => show(sIntro);

// Privacy → Lead
document.getElementById('btn-privacy-ok')!.onclick = () => show(sLead);

// Privacy → Quiz (anonymous, skip lead)
document.getElementById('btn-privacy-anon')!.onclick = () => startQuiz();

// Lead → Privacy (back)
document.getElementById('btn-lead-back')!.onclick = () => show(sPrivacy);

// Lead form submit
document.getElementById('lead-form')!.addEventListener('submit', e => {
  e.preventDefault();
  const phone = (document.getElementById('f-phone') as HTMLInputElement).value.trim();
  const email = (document.getElementById('f-email') as HTMLInputElement).value.trim();
  const err = document.getElementById('lead-err')!;
  if (!phone && !email) { err.style.display = 'block'; return; }
  err.style.display = 'none';
  try {
    sessionStorage.setItem('tss_lead', JSON.stringify({phone, email}));
    fetch('/api/collect-lead', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({phone,email,stage:'quiz_start'}) }).catch(()=>{});
  } catch(_) {}
  startQuiz();
});

// Skip → start anonymously
document.getElementById('btn-skip')!.onclick = () => startQuiz();

function startQuiz() {
  cur = 0; answers = [];
  renderQ();
  show(sQuestion);
}

// Back in question screen
document.getElementById('btn-back')!.onclick = () => {
  if (cur > 0) { cur--; answers = answers.slice(0, cur); renderQ(); }
  else { show(sLead); }
};

function renderQ() {
  const q = Q[cur];
  const pct = Math.round((cur / Q.length) * 100);
  (document.getElementById('prog-fill') as HTMLElement).style.width = pct + '%';
  (document.getElementById('q-count') as HTMLElement).textContent = `${cur + 1} / ${Q.length}`;
  (document.getElementById('q-label') as HTMLElement).textContent = `Question ${cur + 1} of ${Q.length}`;
  (document.getElementById('q-text') as HTMLElement).textContent = q.q;
  (document.getElementById('q-hint') as HTMLElement).textContent = q.hint;

  const opts = document.getElementById('q-opts')!;
  opts.innerHTML = '';

  // Animate card in
  const card = document.getElementById('q-card')!;
  card.classList.remove('q-in');
  void card.offsetWidth;
  card.classList.add('q-in');

  q.opts.forEach(opt => {
    const b = document.createElement('button');
    b.className = 'q-opt';
    b.innerHTML = `<span class="q-opt-radio"></span><span>${opt.t}</span>`;
    b.onclick = () => {
      opts.querySelectorAll('.q-opt').forEach((x:any) => x.disabled = true);
      b.classList.add('sel');
      if (cur === 0) ageAnswer = opt.t;
      answers[cur] = opt.s;
      cur++;
      setTimeout(() => cur < Q.length ? renderQ() : showResult(), 420);
    };
    opts.appendChild(b);
  });
}

function showResult() {
  const score = answers.reduce((a,b) => a+b, 0);
  const r = RESULTS.find(x => score < x.max)!;

  (document.getElementById('res-emoji') as HTMLElement).textContent = r.emoji;
  const badge = document.getElementById('res-badge')!;
  badge.textContent = r.level;
  badge.style.background = r.badgeColor;
  (document.getElementById('res-title') as HTMLElement).textContent = r.title;
  (document.getElementById('res-hero') as HTMLElement).style.background = r.heroGrad;
  (document.getElementById('res-desc') as HTMLElement).textContent = r.desc;
  (document.getElementById('rm-fill') as HTMLElement).style.width = r.meterPct + '%';

  const stepsEl = document.getElementById('res-steps')!;
  stepsEl.innerHTML = '<p class="res-steps-label">Your personalised next steps</p>';
  r.steps.forEach(s => {
    const d = document.createElement('div');
    d.className = 'res-step';
    d.innerHTML = `<span class="res-step-icon">${s.i}</span><span class="res-step-text">${s.t}</span>`;
    stepsEl.appendChild(d);
  });

  const cta = document.getElementById('res-cta')!;
  cta.textContent = r.cta + ' →';
  (cta as HTMLAnchorElement).href = r.href;

  document.getElementById('btn-retake')!.onclick = () => {
    cur = 0; answers = [];
    show(sIntro);
  };

  try {
    const lead = JSON.parse(sessionStorage.getItem('tss_lead') || '{}');
    fetch('/api/collect-lead', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({email:lead.email||'',phone:lead.phone||'',age:ageAnswer,score,level:r.level}) }).catch(()=>{});
    sessionStorage.removeItem('tss_lead');
  } catch(_) {}

  show(sResult);
}
</script>

<style>
  /* ── SHELL ── */
  .quiz-shell {
    background: var(--cream);
    min-height: calc(100vh - var(--nav-h, 64px));
  }
  .q-screen { display: none; }
  .q-screen.active { display: flex; flex-direction: column; align-items: center; padding: 2.5rem 1.25rem 3rem; }
  .q-wrap { width: 100%; max-width: 560px; }
  .q-wrap--result { max-width: 580px; }

  /* ── INTRO ── */
  .intro-badge {
    display: inline-flex; align-items: center; gap: .4rem;
    font-size: .74rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--green); background: var(--green-light);
    padding: .35rem .9rem; border-radius: 100px; margin-bottom: 1.5rem;
  }
  .intro-h1 {
    font-size: clamp(2rem, 6vw, 2.8rem); font-weight: 900;
    letter-spacing: -.035em; line-height: 1.12;
    color: var(--text); margin-bottom: 1rem;
  }
  .intro-sub { font-size: 1rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.75rem; }
  .intro-pills {
    display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 2rem;
  }
  .intro-pills span {
    font-size: .8rem; font-weight: 600;
    background: #fff; border: 1.5px solid var(--border);
    border-radius: 99px; padding: .3rem .85rem; color: var(--text-secondary);
  }
  .intro-lock { font-size: .78rem; color: var(--text-muted); margin-top: .75rem; margin-bottom: 1.25rem; }
  .intro-trust {
    display: flex; align-items: flex-start; gap: .6rem;
    font-size: .76rem; color: #2D5A42; line-height: 1.6;
    background: #EEF7F2; border: 1.5px solid #C5DFD0;
    border-radius: 10px; padding: .85rem 1rem;
  }
  .intro-trust svg { flex-shrink: 0; margin-top: .15rem; color: var(--green); }

  /* ── PRIVACY ── */
  .prv-top { margin-bottom: 1.75rem; }
  .prv-icon { font-size: 2.5rem; margin-bottom: .75rem; }
  .prv-h2 { font-size: 1.5rem; font-weight: 900; letter-spacing: -.02em; color: var(--text); margin-bottom: .5rem; }
  .prv-sub { font-size: .92rem; color: var(--text-secondary); line-height: 1.65; }
  .prv-cards { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 1.75rem; }
  .prv-card {
    display: flex; align-items: flex-start; gap: 1rem;
    background: #fff; border: 1.5px solid var(--border-light);
    border-radius: 14px; padding: 1rem 1.1rem;
  }
  .prv-card-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: .05rem; }
  .prv-card-body { display: flex; flex-direction: column; gap: .2rem; }
  .prv-card-title { font-size: .84rem; font-weight: 800; color: var(--text); }
  .prv-card-text { font-size: .81rem; color: var(--text-secondary); line-height: 1.6; }
  .prv-card-text strong { color: var(--text); font-weight: 700; }

  /* ── LEAD ── */
  .lead-top { margin-bottom: 1.75rem; }
  .lead-icon { font-size: 2.5rem; margin-bottom: .75rem; }
  .lead-h2 { font-size: 1.5rem; font-weight: 900; letter-spacing: -.02em; color: var(--text); margin-bottom: .5rem; }
  .lead-sub { font-size: .92rem; color: var(--text-secondary); line-height: 1.65; }
  .field { display: flex; flex-direction: column; gap: .35rem; margin-bottom: 1rem; }
  .field-label { font-size: .82rem; font-weight: 700; color: var(--text); }
  .field-opt { font-weight: 400; color: var(--text-muted); }
  .field-input {
    padding: .9rem 1rem; font-size: 1rem;
    border: 1.5px solid var(--border); border-radius: 12px;
    background: #fff; color: var(--text); outline: none;
    transition: border-color .15s; width: 100%;
  }
