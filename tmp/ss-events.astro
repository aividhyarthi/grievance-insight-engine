---
import Layout from '../layouts/Layout.astro';

const eventTypes = [
  {
    icon: '🎙️',
    title: 'Expert webinars',
    desc: 'Live online sessions with gynaecologists, therapists, nutritionists, and other specialists — covering specific aspects of perimenopause in depth. Time for Q&A included.',
  },
  {
    icon: '💬',
    title: 'Live Q&A sessions',
    desc: 'Smaller, more intimate online sessions where you can ask questions directly — to a doctor, to our team, or to a panel of women sharing their experiences.',
  },
  {
    icon: '🌿',
    title: 'Specialist talks',
    desc: 'Deep dives on specific topics: Ayurveda and perimenopause, bone health, navigating HRT conversations, managing the workplace during perimenopause, and more.',
  },
  {
    icon: '🤝',
    title: 'Community circles',
    desc: 'Small, facilitated peer conversations for women to share experiences, ask questions, and realise they are not alone. Hosted with care, warmth, and clear ground rules.',
  },
];
---

<Layout
  title="Events & Community – The Second Spring"
  description="Upcoming webinars, live Q&A sessions, and community events for Indian women navigating perimenopause — from The Second Spring."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <div class="page-eyebrow">
          🌸 Events &amp; community
          <span class="eyebrow-badge">New</span>
        </div>
        <h1>Events &amp; community</h1>
        <p>Live sessions, expert talks, and community conversations — a space to learn, ask questions, and realise you're not alone in this.</p>
      </div>
    </div>
  </section>

  <!-- Coming soon -->
  <section class="section bg-white">
    <div class="container">
      <div class="coming-soon-layout">
        <div class="coming-soon-badge">✦ Coming soon</div>
        <h2 class="section-title">Our first event is on its way</h2>
        <p class="body-text">
          We are planning The Second Spring's first live event — a webinar for Indian women on understanding perimenopause, navigating the healthcare system, and building a support strategy that actually works.
        </p>
        <p class="body-text">
          The event will be free to attend, hosted online, and designed to be practical, warm, and genuinely useful — not a medical lecture, but a real conversation.
        </p>

        <div class="event-preview-card">
          <div class="event-preview-top">
            <span class="event-type-badge">Webinar</span>
            <span class="event-status">Registration opening soon</span>
          </div>
          <h3 class="event-preview-title">"Understanding Perimenopause: What Indian Women Need to Know"</h3>
          <p class="event-preview-desc">
            A comprehensive, compassionate introduction to perimenopause — covering symptoms, hormonal changes, the Indian context, and how to find the right support. With a live Q&A at the end.
          </p>
          <div class="event-preview-details">
            <div class="event-detail">
              <span class="event-detail-icon">📅</span>
              <span>Date to be announced</span>
            </div>
            <div class="event-detail">
              <span class="event-detail-icon">💻</span>
              <span>Online — attend from anywhere in India</span>
            </div>
            <div class="event-detail">
              <span class="event-detail-icon">🆓</span>
              <span>Free to attend</span>
            </div>
            <div class="event-detail">
              <span class="event-detail-icon">🌐</span>
              <span>In English (Hindi session to follow)</span>
            </div>
          </div>
          <a href="mailto:thesecondspringofficial@gmail.com?subject=Events%20notification&body=Please%20add%20me%20to%20the%20events%20notification%20list." class="btn btn-primary">
            Notify me when registration opens →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Email signup -->
  <section class="section-sm bg-green">
    <div class="container">
      <div class="signup-block">
        <div>
          <h2 class="signup-title">Be the first to know</h2>
          <p class="signup-sub">Send us your email and we'll let you know as soon as registration opens for our first event — and for everything that follows.</p>
        </div>
        <div class="signup-actions">
          <a href="mailto:thesecondspringofficial@gmail.com?subject=Events%20notification&body=Please%20add%20me%20to%20the%20events%20notification%20list.%20My%20name%20is%3A%20" class="btn btn-peach btn-lg">
            📬 Add me to the events list →
          </a>
          <span class="signup-email-note">Or email us at <a href="mailto:thesecondspringofficial@gmail.com">thesecondspringofficial@gmail.com</a></span>
        </div>
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header center">
        <span class="section-label">What's coming</span>
        <h2 class="section-title">Types of events we're planning</h2>
        <p class="section-sub">A growing calendar of events designed around what Indian women actually need — not generic health content, but something built for us.</p>
      </div>

      <div class="event-types-grid">
        {eventTypes.map(t => (
          <div class="event-type-card">
            <div class="event-type-icon">{t.icon}</div>
            <h3 class="event-type-title">{t.title}</h3>
            <p class="event-type-desc">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Community vision -->
  <section class="section bg-white">
    <div class="container">
      <div class="vision-layout">
        <div class="vision-text">
          <span class="section-label">Our vision</span>
          <h2 class="section-title">Building something bigger than information</h2>
          <p class="body-text">
            Information matters enormously — and that's where we start. But we know that the loneliness of perimenopause in India is not just about a lack of facts. It's about isolation. About feeling like no one around you understands. About carrying this alone.
          </p>
          <p class="body-text">
            The Second Spring's community vision is to create spaces — online and eventually offline — where Indian women can share this experience with each other. Not to complain or commiserate, but to be genuinely useful to each other: sharing what's worked, asking what hasn't, finding out that someone else's body is doing exactly the same strange thing yours is doing.
          </p>
          <p class="body-text">
            That's what events are the beginning of. We're building slowly and carefully, because we want it to be real.
          </p>
        </div>
        <div class="vision-stats">
          {[
            { num: '77%', text: 'Of Indian women feel they had no support during their menopausal transition' },
            { num: '1 in 3', text: 'Women say they wish they had known more before symptoms began' },
            { num: '0', text: 'Major community events for Indian women on perimenopause — until now' },
          ].map(s => (
            <div class="vision-stat">
              <div class="vision-stat-num">{s.num}</div>
              <div class="vision-stat-text">{s.text}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm bg-green">
    <div class="container">
      <div class="cta-block">
        <div>
          <h2 class="section-title">Don't wait for the events</h2>
          <p class="section-sub">Our companion is available right now — completely private, completely free.</p>
        </div>
        <a href="/chat" class="btn btn-peach btn-lg">Start a private conversation →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .eyebrow-badge {
    display: inline-block;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .05em;
    background: var(--peach);
    color: #fff;
    padding: .15rem .45rem;
    border-radius: 100px;
    text-transform: uppercase;
    margin-left: .35rem;
    vertical-align: middle;
  }

  .coming-soon-layout {
    max-width: 760px;
  }

  .coming-soon-badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .76rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--green);
    background: var(--green-light);
    padding: .35rem .9rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .event-preview-card {
    background: var(--green-light);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-top: 2rem;
  }

  .event-preview-top {
    display: flex;
    align-items: center;
    gap: .85rem;
    margin-bottom: 1rem;
  }

  .event-type-badge {
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    background: var(--green);
    color: #fff;
    padding: .25rem .75rem;
    border-radius: 100px;
  }

  .event-status {
    font-size: .82rem;
    color: var(--text-muted);
  }

  .event-preview-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.02em;
    margin-bottom: .75rem;
    line-height: 1.3;
  }

  .event-preview-desc {
    font-size: .93rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .event-preview-details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .65rem;
    margin-bottom: 1.75rem;
  }

  .event-detail {
    display: flex;
    align-items: center;
    gap: .65rem;
    font-size: .88rem;
    color: var(--text-secondary);
  }

  .event-detail-icon { font-size: 1rem; }

  .signup-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .signup-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: .35rem;
  }

  .signup-sub {
    font-size: .95rem;
    color: var(--text-secondary);
    max-width: 460px;
  }

  .signup-actions {
    display: flex;
    flex-direction: column;
    gap: .6rem;
    align-items: flex-end;
  }

  .signup-email-note {
    font-size: .82rem;
    color: var(--text-muted);
  }

  .signup-email-note a { color: var(--green); }

  .event-types-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .event-type-card {
    background: #fff;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }

  .event-type-icon { font-size: 2rem; margin-bottom: 1rem; }
  .event-type-title { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: .5rem; }
  .event-type-desc { font-size: .9rem; color: var(--text-secondary); line-height: 1.7; }

  .vision-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .vision-stats {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .vision-stat {
    background: var(--cream-mid);
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .vision-stat-num {
    font-size: 2rem;
    font-weight: 900;
    color: var(--green-dark);
    letter-spacing: -.03em;
    margin-bottom: .35rem;
  }

  .vision-stat-text {
    font-size: .87rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .cta-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .event-preview-details { grid-template-columns: 1fr; }
    .event-types-grid { grid-template-columns: 1fr; }
    .vision-layout { grid-template-columns: 1fr; }
    .signup-block { flex-direction: column; }
    .signup-actions { align-items: flex-start; }
    .cta-block { flex-direction: column; }
  }
</style>
