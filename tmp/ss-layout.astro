      const iconClose = document.getElementById('icon-close')!;

      function closeMenu() {
        links.classList.remove('open');
        iconMenu.style.display  = 'block';
        iconClose.style.display = 'none';
      }

      toggle.addEventListener('click', () => {
        const open = links.classList.toggle('open');
        iconMenu.style.display  = open ? 'none'  : 'block';
        iconClose.style.display = open ? 'block' : 'none';
      });

      document.addEventListener('click', (e) => {
        if (!toggle.contains(e.target as Node) && !links.contains(e.target as Node)) {
          closeMenu();
        }
      });

      // Mobile: Guide dropdown toggles on tap
      document.querySelectorAll('.has-dropdown > a').forEach(link => {
        link.addEventListener('click', (e) => {
          if (window.innerWidth <= 768) {
            e.preventDefault();
            const li = link.parentElement as HTMLElement;
            li.classList.toggle('mob-open');
          }
        });
      });

      // "More" tab opens hamburger menu
      const moreBtn = document.getElementById('mbn-more-btn');
      if (moreBtn) {
        moreBtn.addEventListener('click', () => {
          const open = links.classList.toggle('open');
          iconMenu.style.display  = open ? 'none'  : 'block';
          iconClose.style.display = open ? 'block' : 'none';
        });
      }

      // Highlight active bottom nav tab
      const path = window.location.pathname;
      document.querySelectorAll('.mbn-tab[data-path]').forEach(tab => {
        const tp = tab.getAttribute('data-path');
        if (tp === '/' ? path === '/' : path.startsWith(tp!)) {
          tab.classList.add('mbn-active');
        }
      });
    </script>

    <script>
      (() => {
        const STORAGE_KEY = 'tss_popup_dismissed';
        const overlay = document.getElementById('popup-overlay')!;
        const closeBtn = document.getElementById('popup-close')!;
        const form = document.getElementById('popup-form')!;

        // Don't show on quiz or chat pages, or if already dismissed
        const pg = window.location.pathname;
        if (pg.startsWith('/quiz') || pg.startsWith('/chat') || sessionStorage.getItem(STORAGE_KEY)) return;

        function showPopup() {
          overlay.classList.add('popup-visible');
          document.body.classList.add('popup-open');
        }
        function hidePopup() {
          overlay.classList.remove('popup-visible');
          document.body.classList.remove('popup-open');
          sessionStorage.setItem(STORAGE_KEY, '1');
        }

        // Trigger: 8s timer OR 50% scroll, whichever comes first
        let triggered = false;
        function trigger() {
          if (triggered) return;
          triggered = true;
          showPopup();
        }

        const timer = setTimeout(trigger, 8000);

        const scrollHandler = () => {
          const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
          if (pct >= 0.45) {
            clearTimeout(timer);
            trigger();
            window.removeEventListener('scroll', scrollHandler);
          }
        };
        window.addEventListener('scroll', scrollHandler, { passive: true });

        // Close on X button
        closeBtn.addEventListener('click', hidePopup);

        // Close on overlay backdrop click
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) hidePopup();
        });

        // Escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') hidePopup();
        });

        // Validate + submit
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const emailEl = document.getElementById('popup-email') as HTMLInputElement;
          const phoneEl = document.getElementById('popup-phone') as HTMLInputElement;
          const errEmail = document.getElementById('err-email')!;
          const errPhone = document.getElementById('err-phone')!;

          const email = emailEl.value.trim();
          const phone = phoneEl.value.trim();
          let valid = true;

          // Validate email
          if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            errEmail.textContent = 'Please enter a valid email address';
            emailEl.classList.add('popup-input-err');
            valid = false;
          } else {
            errEmail.textContent = '';
            emailEl.classList.remove('popup-input-err');
          }

          // Validate phone — at least 7 digits
          const digits = phone.replace(/\D/g, '');
          if (!phone || digits.length < 7) {
            errPhone.textContent = 'Please enter a valid phone number';
            phoneEl.classList.add('popup-input-err');
            valid = false;
          } else {
            errPhone.textContent = '';
            phoneEl.classList.remove('popup-input-err');
          }

          if (!valid) return;

          // Save for quiz to use
          sessionStorage.setItem('tss_lead', JSON.stringify({ email, phone }));

          // Send lead immediately — captures even if user never finishes the quiz
          fetch('/api/collect-lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, phone, age: '', score: '', level: 'Popup only — quiz not completed' }),
          }).catch(() => {});

          hidePopup();
          window.location.href = '/quiz';
        });
      })();
    </script>

