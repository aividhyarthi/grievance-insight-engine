---
import Layout from '../layouts/Layout.astro';

const RAW = 'https://raw.githubusercontent.com/aividhyarthi/thesecondspring/main';
---

<Layout
  title="The Second Spring – Perimenopause Support for Indian Women"
  description="India's first private companion for women navigating perimenopause. Ask anything, understand what's happening, and find real support."
>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-shapes">
      <div class="hs hs-1"></div>
      <div class="hs hs-2"></div>
    </div>
    <div class="container">
      <div class="hero-inner">
        <div class="eyebrow">🌸 India's perimenopause companion</div>
        <h1>
          You're not going mad.<br/>
          <em>Your body is changing.</em>
        </h1>
        <p class="hero-desc">
          Mood swings, sleepless nights, brain fog, hot flashes — and everyone says
          "it's just stress." You deserve more than that.
          The Second Spring is a safe, private space to finally understand what's happening.
        </p>
        <div class="hero-actions">
          <a href="/chat" class="btn btn-peach btn-lg">Start a private conversation →</a>
          <a href="/guide" class="btn btn-outline-white">Read the guide</a>
        </div>
        <div class="hero-trust">
          <span>✦ Anonymous &amp; private</span>
          <span>✦ No login required</span>
          <span>✦ Built for Indian women</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WOMEN PHOTOS ── -->
  <section class="women-section">
    <div class="container">
      <div class="women-inner">
        <div class="women-text">
          <span class="w-label">Real women. Real experiences.</span>
          <h2>They thought it was stress.<br/>It wasn't.</h2>
          <p>
            Millions of Indian women are navigating perimenopause right now —
            silently, alone, and often misunderstood. This is for all of them.
          </p>
          <a href="/chat" class="btn btn-peach">Talk to someone who gets it →</a>
        </div>
        <div class="women-cards">
          {[
            { src: `${RAW}/women1.jpg`, name: 'Priya, 44', city: 'Bengaluru', quote: '"I finally have a name for what I\'ve been going through."', color: '#C94B4B', init: 'P' },
            { src: `${RAW}/women2.jpg`, name: 'Meena, 47', city: 'Mumbai',    quote: '"My husband finally understands why I\'ve been so different."', color: '#2A5C45', init: 'M' },
            { src: `${RAW}/women3.jpg`, name: 'Sunita, 41', city: 'Delhi',   quote: '"I stopped blaming myself the day I understood this was hormonal."', color: '#7B4F3A', init: 'S' },
          ].map((w, i) => (
            <div class={`wc wc-${i + 1}`}>
              <div class="wc-photo">
                <img src={w.src} alt={w.name} onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`} />
                <div class="wc-fallback" style={`background:${w.color};display:none`}>{w.init}</div>
              </div>
              <div class="wc-info">
                <div class="wc-meta"><strong>{w.name}</strong><span>{w.city}</span></div>
                <p class="wc-quote">{w.quote}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── STATS STRIP ── -->
  <div class="stats-strip">
    <div class="container">
      <div class="stats-row">
        {[
          { num: '46.2', unit: 'yrs', label: 'Average menopause age for Indian women — earlier than most expect' },
          { num: '30M+', unit: '',    label: 'Indian women entering this transition every year' },
          { num: '8–10', unit: 'yrs', label: 'How long perimenopause can last before menopause arrives' },
          { num: '<30%', unit: '',    label: 'Of Indian women who can name even one perimenopause symptom' },
        ].map(s => (
          <div class="stat-block">
            <div class="stat-big">
              <span class="stat-n">{s.num}</span>
              {s.unit && <span class="stat-u">{s.unit}</span>}
            </div>
            <div class="stat-l">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── THE SILENCE IN INDIA ── -->
  <section class="silence-section">
    <div class="container">
      <div class="silence-inner">
        <div class="silence-quote-block">
          <div class="quote-mark">"</div>
          <blockquote>
            Beta, it's just your age. Everyone goes through it. Don't make it a big deal.
          </blockquote>
          <cite>— What too many Indian women are told</cite>
        </div>
        <div class="silence-content">
          <span class="label-dark">The reality in India</span>
          <h2>We don't talk about this.<br/>And that has a cost.</h2>
          <p>
            In India, perimenopause is invisible. There's barely a word for it in most of our languages.
            Women suffer through it — often for <strong>5 to 10 years</strong> — thinking they are depressed,
            "difficult," or simply falling apart.
          </p>
          <p>
            Doctors dismiss it. Families don't understand it. Women feel too ashamed to even name it.
          </p>
          <p class="silence-call">
            <strong>The Second Spring exists to break that silence.</strong>
          </p>
          <a href="/perimenopause" class="silence-link">Learn what perimenopause actually is →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── QUICK SYMPTOMS ── -->
  <section class="section bg-cream" id="symptoms">
    <div class="container">
      <div class="section-header center">
        <span class="section-label">Does this feel familiar?</span>
        <h2 class="section-title">These are not personality flaws.<br/>They are symptoms.</h2>
      </div>
      <div class="symptom-4">
        {[
          { emoji: '😤', label: 'Anger & irritability',  desc: 'Snapping at people you love. Feeling completely unlike yourself.' },
          { emoji: '🌙', label: 'Sleepless nights',      desc: 'Waking at 2, 3, 4am — mind racing, exhausted all day.' },
          { emoji: '🧠', label: 'Brain fog',             desc: 'Forgetting words mid-sentence. Struggling to focus.' },
          { emoji: '💔', label: 'Anxiety & low mood',   desc: 'A heaviness with no clear cause. Worrying more. Feeling disconnected.' },
        ].map(s => (
          <a href="/guide/symptoms" class="s4-card">
            <span class="s4-emoji">{s.emoji}</span>
            <span class="s4-label">{s.label}</span>
            <span class="s4-desc">{s.desc}</span>
          </a>
        ))}
      </div>
      <div class="symptom-cta">
        <a href="/guide/symptoms" class="btn btn-outline">See all 10 symptoms in detail →</a>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ── -->
  <section class="section how-section">
    <div class="container">
      <div class="section-header center light">
        <span class="label-light">Simple. Private. Warm.</span>
        <h2 class="section-title" style="color:#fff;">How The Second Spring works</h2>
        <p class="section-sub" style="color:rgba(255,255,255,.72);">No forms. No login. No judgement.</p>
      </div>
      <div class="steps-3">
        {[
          { n: '01', icon: '💬', title: 'You share what\'s on your mind', desc: 'Choose a topic or just type what you\'re feeling. No wrong way to begin.' },
          { n: '02', icon: '🌿', title: 'Your companion listens first',   desc: 'Acknowledged before anything is explained. Warm, real, no jargon.' },
          { n: '03', icon: '🌸', title: 'You get clarity and a next step', desc: 'Understand what\'s happening — and connect with a specialist when ready.' },
        ].map(s => (
          <div class="step-box">
            <div class="step-top">
              <span class="step-n">{s.n}</span>
              <span class="step-icon">{s.icon}</span>
            </div>
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="how-cta">
        <a href="/chat" class="btn btn-peach btn-lg">Open your companion →</a>
        <a href="/how-it-works" class="btn btn-outline-white">Learn more</a>
      </div>
    </div>
  </section>

  <!-- ── FOUNDER ── -->
  <section class="section founder-strip bg-white" id="about">
    <div class="container">
      <div class="founder-inner">
        <div class="founder-photo-wrap">
          <img src="/rudra.jpg" alt="Rudra Kasturi — Founder, The Second Spring" />
        </div>
        <div class="founder-text-wrap">
          <span class="section-label">The person behind this</span>
          <h2 class="section-title">Rudra Kasturi</h2>
          <p class="body-text">
            Watching the women closest to him navigate perimenopause with no language, no support,
            and no recognition of what they were experiencing — that became the reason The Second Spring exists.
          </p>
          <p class="body-text">
            Rudra leads product, engineering, and AI strategy — building technology that makes healthcare
            more human, not less.
          </p>
          <div class="founder-links">
            <a href="https://linkedin.com/in/rudrakasturi" target="_blank" rel="noopener" class="founder-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a href="https://www.rudrakasturi.com" target="_blank" rel="noopener" class="founder-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              Website
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-leaf">🌿</div>
        <h2 class="cta-title">You don't have to figure this out alone.</h2>
        <p class="cta-desc">Start a private conversation — no login, no judgement, no cost.</p>
        <a href="/chat" class="btn btn-primary btn-lg">Begin your Second Spring →</a>
        <p class="cta-fine">Information only — not medical advice. Always consult your doctor.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    background: linear-gradient(150deg, #0F2A1A 0%, #1A3D2B 40%, #2A5C45 100%);
    color: #fff; padding: 7rem 0 6rem; position: relative; overflow: hidden;
  }
  .hero-shapes { position: absolute; inset: 0; pointer-events: none; }
  .hs { position: absolute; border-radius: 50%; opacity: .12; }
  .hs-1 { width: 600px; height: 600px; background: radial-gradient(circle, #D4845A, transparent); right: -150px; top: -150px; }
  .hs-2 { width: 400px; height: 400px; background: radial-gradient(circle, #7FB89A, transparent); left: -100px; bottom: -100px; }
  .hero-inner { position: relative; z-index: 1; max-width: 680px; }
  .eyebrow { display: inline-flex; align-items: center; gap: .5rem; font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.8); background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); padding: .4rem 1rem; border-radius: 100px; margin-bottom: 1.75rem; }
  .hero h1 { font-size: clamp(2.6rem, 5.5vw, 4rem); font-weight: 900; line-height: 1.12; letter-spacing: -.035em; color: #fff; margin-bottom: 1.75rem; }
  .hero h1 em { font-style: normal; color: #FBBF81; }
  .hero-desc { font-size: 1.1rem; color: rgba(255,255,255,.82); line-height: 1.78; max-width: 560px; margin-bottom: 2.5rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.25rem; }
  .hero-trust { display: flex; flex-wrap: wrap; gap: 1.75rem; font-size: .86rem; color: rgba(255,255,255,.6); }

  /* WOMEN SECTION */
  .women-section { background: #fff; padding: 5.5rem 0; border-bottom: 1.5px solid var(--border-light); }
  .women-inner { display: grid; grid-template-columns: 340px 1fr; gap: 4.5rem; align-items: center; }
  .w-label { display: inline-flex; font-size: .76rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--peach); background: var(--peach-light); padding: .3rem .85rem; border-radius: 100px; margin-bottom: 1rem; }
  .women-text h2 { font-size: clamp(1.7rem, 2.8vw, 2.2rem); font-weight: 900; letter-spacing: -.025em; color: var(--text); line-height: 1.2; margin-bottom: 1rem; }
  .women-text p { font-size: .97rem; color: var(--text-secondary); line-height: 1.75; margin-bottom: 1.75rem; }
  .women-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .wc { border-radius: var(--radius-lg); overflow: hidden; border: 1.5px solid var(--border); transition: transform .2s, box-shadow .2s; }
  .wc:hover { transform: translateY(-5px); box-shadow: 0 14px 36px rgba(61,122,95,.15); }
  .wc-1 { margin-top: 0; }
  .wc-2 { margin-top: 1.75rem; }
  .wc-3 { margin-top: -.75rem; }
  .wc-photo { height: 200px; position: relative; overflow: hidden; }
  .wc-photo img { width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; }
  .wc-fallback { width: 100%; height: 100%; align-items: center; justify-content: center; font-size: 4rem; font-weight: 900; color: rgba(255,255,255,.35); font-family: Georgia, serif; }
  .wc-info { background: #fff; padding: 1rem 1.2rem 1.25rem; }
  .wc-meta { display: flex; align-items: baseline; gap: .5rem; margin-bottom: .4rem; }
  .wc-meta strong { font-size: .9rem; color: var(--text); }
  .wc-meta span { font-size: .76rem; color: var(--text-muted); }
  .wc-quote { font-size: .82rem; color: var(--text-secondary); line-height: 1.6; font-style: italic; }

  /* STATS */
  .stats-strip { background: #0F2A1A; border-bottom: 1px solid rgba(255,255,255,.06); padding: 2.5rem 0; }
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat-block { padding: 1.25rem 2rem; border-right: 1px solid rgba(255,255,255,.1); text-align: center; }
  .stat-block:last-child { border-right: none; }
  .stat-big { display: flex; align-items: baseline; justify-content: center; gap: .2rem; margin-bottom: .4rem; }
  .stat-n { font-size: 2.4rem; font-weight: 900; color: var(--peach); letter-spacing: -.03em; line-height: 1; }
  .stat-u { font-size: 1rem; font-weight: 700; color: var(--peach); opacity: .8; }
  .stat-l { font-size: .78rem; color: rgba(255,255,255,.55); line-height: 1.5; max-width: 160px; margin: 0 auto; }

  /* SILENCE */
  .silence-section { background: #0F2A1A; padding: 5rem 0; }
  .silence-inner { display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; align-items: center; }
  .silence-quote-block { padding: 2.5rem; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: var(--radius-lg); }
  .quote-mark { font-size: 5rem; line-height: 1; color: var(--peach); font-family: Georgia, serif; margin-bottom: -.5rem; opacity: .7; }
  blockquote { font-size: 1.3rem; font-style: italic; color: rgba(255,255,255,.88); line-height: 1.65; margin-bottom: 1rem; }
  cite { font-size: .85rem; color: rgba(255,255,255,.45); font-style: normal; }
  .label-dark { display: inline-flex; font-size: .76rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--peach); background: rgba(212,132,90,.15); padding: .3rem .85rem; border-radius: 100px; margin-bottom: .85rem; }
  .silence-content h2 { font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 900; letter-spacing: -.025em; color: #fff; line-height: 1.2; margin-bottom: 1.5rem; }
  .silence-content p { font-size: .97rem; line-height: 1.78; color: rgba(255,255,255,.7); margin-bottom: 1rem; }
  .silence-call { color: rgba(255,255,255,.9) !important; font-size: 1.05rem !important; }
  .silence-link { display: inline-flex; margin-top: 1rem; color: #FBBF81; font-size: .9rem; font-weight: 600; transition: gap .2s; gap: .25rem; }
  .silence-link:hover { color: #fff; }

  /* QUICK SYMPTOMS */
  .symptom-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; margin-bottom: 2rem; }
  .s4-card { background: #fff; border: 1.5px solid var(--border); border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; gap: .35rem; text-decoration: none; color: var(--text); transition: all .2s; }
  .s4-card:hover { border-color: var(--peach); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(212,132,90,.13); }
  .s4-emoji { font-size: 1.8rem; margin-bottom: .15rem; }
  .s4-label { font-weight: 700; font-size: .92rem; }
  .s4-desc  { font-size: .81rem; color: var(--text-secondary); line-height: 1.55; }
  .symptom-cta { text-align: center; }

  /* HOW IT WORKS */
  .how-section { background: linear-gradient(150deg, #1A3D2B 0%, #2A5C45 100%); padding: 5.5rem 0; }
  .label-light { display: inline-flex; font-size: .76rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.7); background: rgba(255,255,255,.1); padding: .3rem .85rem; border-radius: 100px; margin-bottom: .85rem; }
  .section-header.light .section-sub { color: rgba(255,255,255,.7); }
  .steps-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; margin-bottom: 3rem; }
  .step-box { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius-lg); padding: 2rem; }
  .step-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
  .step-n { font-size: .78rem; font-weight: 800; color: var(--peach); letter-spacing: .05em; }
  .step-icon { font-size: 1.75rem; }
  .step-title { font-weight: 700; font-size: 1rem; color: #fff; line-height: 1.35; margin-bottom: .6rem; }
  .step-desc  { font-size: .87rem; color: rgba(255,255,255,.7); line-height: 1.7; }
  .how-cta { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }

  /* FOUNDER STRIP */
  .founder-strip { padding: 5rem 0; }
  .founder-inner { display: grid; grid-template-columns: 280px 1fr; gap: 5rem; align-items: center; }
  .founder-photo-wrap { width: 220px; height: 260px; border-radius: 20px; overflow: hidden; border: 3px solid var(--border); box-shadow: 0 12px 40px rgba(61,122,95,.15); flex-shrink: 0; }
  .founder-photo-wrap img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
  .founder-links { display: flex; gap: .75rem; margin-top: 1.5rem; }
  .founder-link { display: inline-flex; align-items: center; gap: .4rem; font-size: .82rem; font-weight: 600; color: var(--green); background: var(--green-light); border: 1.5px solid var(--border); padding: .4rem .85rem; border-radius: 100px; transition: all .18s; }
  .founder-link:hover { background: var(--green); color: #fff; border-color: var(--green); }

  /* CTA */
  .cta-section { background: var(--peach-light); border-top: 2px solid #F0C9B0; padding: 6rem 0; text-align: center; }
  .cta-inner { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; max-width: 640px; margin: 0 auto; }
  .cta-leaf  { font-size: 3rem; }
  .cta-title { font-size: clamp(1.9rem, 4vw, 2.6rem); font-weight: 900; letter-spacing: -.03em; color: var(--text); line-height: 1.2; }
  .cta-desc  { font-size: 1.05rem; color: var(--text-secondary); line-height: 1.72; }
  .cta-fine  { font-size: .78rem; color: var(--text-muted); }

  /* SHARED */
  .section { padding: 5.5rem 0; }
  .bg-white  { background: #fff; }
  .bg-cream  { background: var(--cream-mid); }
  .section-header { margin-bottom: 3rem; }
  .section-header.center { text-align: center; }
  .section-header.center .section-sub { margin: 0 auto; }
  .section-label { display: inline-flex; font-size: .76rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--green); background: var(--green-light); padding: .3rem .85rem; border-radius: 100px; margin-bottom: .85rem; }
  .section-title { font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 900; letter-spacing: -.025em; color: var(--text); line-height: 1.18; margin-bottom: .75rem; }
  .body-text { font-size: .97rem; color: var(--text-secondary); line-height: 1.78; margin-bottom: 1rem; }

  /* RESPONSIVE */
  @media (max-width: 1000px) {
    .women-inner  { grid-template-columns: 1fr; }
    .women-cards  { grid-template-columns: repeat(3, 1fr); }
    .wc-2, .wc-3  { margin-top: 0; }
    .silence-inner { grid-template-columns: 1fr; gap: 3rem; }
    .steps-3      { grid-template-columns: 1fr; }
    .founder-inner { grid-template-columns: 1fr; }
    .stats-row    { grid-template-columns: 1fr 1fr; }
    .stat-block:nth-child(2) { border-right: none; }
    .symptom-4    { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .hero { padding: 4.5rem 0 4rem; }
    .section { padding: 3.5rem 0; }
    .women-cards  { grid-template-columns: 1fr; }
    .stats-row    { grid-template-columns: 1fr 1fr; }
    .symptom-4    { grid-template-columns: 1fr 1fr; }
    .hero-trust   { gap: 1rem; }
  }
  @media (max-width: 420px) {
    .symptom-4 { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: 1fr; }
  }
</style>
