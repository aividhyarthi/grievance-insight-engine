---
import Layout from '../layouts/Layout.astro';

const quickFaqs = [
  {
    q: 'How quickly will you respond?',
    a: 'We aim to respond to all enquiries within 2 business days. For urgent health concerns, please consult a doctor or gynaecologist directly — our companion is also available 24/7 for information and support.',
  },
  {
    q: 'Can I report an issue with the AI companion?',
    a: 'Yes — if you received inaccurate, harmful, or unhelpful information from our companion, please email us at hello@thesecondspring.com with as much detail as you can. We take this very seriously and review all reports.',
  },
  {
    q: 'I\'m a journalist/researcher/healthcare professional — who should I contact?',
    a: 'Please email hello@thesecondspring.com with a brief description of your enquiry. We welcome collaboration with journalists covering women\'s health in India, researchers in this space, and healthcare professionals interested in partnering with us.',
  },
];
---

<Layout
  title="Contact – The Second Spring"
  description="Get in touch with The Second Spring — for general enquiries, employer partnerships, media, or feedback."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <div class="page-eyebrow">✉️ Contact</div>
        <h1>Get in touch</h1>
        <p>We'd love to hear from you — whether you have a question, a partnership idea, feedback, or just want to say hello.</p>
      </div>
    </div>
  </section>

  <!-- Two-column layout -->
  <section class="section bg-white">
    <div class="container">
      <div class="contact-layout">

        <!-- Contact info -->
        <div class="contact-info">
          <div class="section-header">
            <span class="section-label">Reach us</span>
            <h2 class="section-title">Contact information</h2>
          </div>

          <div class="contact-cards">
            <div class="contact-card">
              <div class="contact-card-icon">✉️</div>
              <div>
                <div class="contact-card-label">Email</div>
                <a href="mailto:hello@thesecondspring.com" class="contact-card-value">hello@thesecondspring.com</a>
                <p class="contact-card-note">General enquiries, feedback, partnerships</p>
              </div>
            </div>

            <div class="contact-card">
              <div class="contact-card-icon">💼</div>
              <div>
                <div class="contact-card-label">LinkedIn</div>
                <a href="https://linkedin.com/in/rudrakasturi" class="contact-card-value" target="_blank" rel="noopener noreferrer">linkedin.com/in/rudrakasturi</a>
                <p class="contact-card-note">Professional enquiries &amp; partnerships</p>
              </div>
            </div>

            <div class="contact-card">
              <div class="contact-card-icon">🏢</div>
              <div>
                <div class="contact-card-label">For employers</div>
                <a href="mailto:hello@thesecondspring.com?subject=Employer%20partnership%20enquiry" class="contact-card-value">hello@thesecondspring.com</a>
                <p class="contact-card-note">Employee access, wellness programs, partnerships</p>
              </div>
            </div>
          </div>

          <div class="contact-notice">
            <span>🌸</span>
            <p><strong>Need health support now?</strong> Our companion is available immediately — private, free, and no sign-up required.</p>
            <a href="/chat" class="btn btn-outline" style="margin-top:.75rem; width:fit-content;">Chat now →</a>
          </div>
        </div>

        <!-- Contact form -->
        <div class="contact-form-wrap">
          <div class="section-header">
            <span class="section-label">Send a message</span>
            <h2 class="section-title">Write to us</h2>
          </div>

          <form
            class="contact-form"
            action="mailto:hello@thesecondspring.com"
            method="get"
            enctype="text/plain"
          >
            <div class="form-row">
              <div class="form-group">
                <label for="name" class="form-label">Your name</label>
                <input type="text" id="name" name="name" class="form-input" placeholder="Priya Sharma" />
              </div>
              <div class="form-group">
                <label for="email" class="form-label">Email address</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="priya@example.com" />
              </div>
            </div>

            <div class="form-group">
              <label for="subject" class="form-label">What's this about?</label>
              <select id="subject" name="subject" class="form-input form-select">
                <option value="">Select a topic</option>
                <option value="General enquiry">General enquiry</option>
                <option value="Feedback on the companion">Feedback on the companion</option>
                <option value="Employer partnership">Employer partnership</option>
                <option value="Media or press">Media or press</option>
                <option value="Report an issue">Report an issue</option>
                <option value="Healthcare professional enquiry">Healthcare professional enquiry</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Your message</label>
              <textarea
                id="message"
                name="body"
                class="form-input form-textarea"
                placeholder="Tell us how we can help…"
                rows="6"
              ></textarea>
            </div>

            <div class="form-footer">
              <button type="submit" class="btn btn-primary btn-lg">Send message →</button>
              <p class="form-note">This form opens your email client. Alternatively, email us directly at <a href="mailto:hello@thesecondspring.com">hello@thesecondspring.com</a></p>
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Quick FAQs -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Quick answers</span>
        <h2 class="section-title">Common questions</h2>
      </div>

      <div class="quick-faqs">
        {quickFaqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{faq.q}</span>
              <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-answer">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm bg-green">
    <div class="container">
      <div class="cta-block">
        <div>
          <h2 class="section-title">Looking for immediate support?</h2>
          <p class="section-sub">Our companion is available right now — no waiting, no sign-up, completely private.</p>
        </div>
        <a href="/chat" class="btn btn-peach btn-lg">Chat with our companion →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: .5rem;
  }

  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--cream-mid);
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .contact-card-icon { font-size: 1.5rem; flex-shrink: 0; }

  .contact-card-label {
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .09em;
    color: var(--text-muted);
    margin-bottom: .3rem;
  }

  .contact-card-value {
    display: block;
    font-size: .97rem;
    font-weight: 600;
    color: var(--green);
    text-decoration: none;
    margin-bottom: .2rem;
  }

  .contact-card-value:hover { color: var(--green-dark); text-decoration: underline; }

  .contact-card-note {
    font-size: .82rem;
    color: var(--text-muted);
    line-height: 1.45;
  }

  .contact-notice {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    background: var(--green-light);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-top: 1.5rem;
    font-size: .9rem;
    color: var(--text-secondary);
  }

  .contact-notice span { font-size: 1.3rem; }
  .contact-notice strong { color: var(--text); }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }

  .form-label {
    font-size: .85rem;
    font-weight: 600;
    color: var(--text);
  }

  .form-input {
    font-family: inherit;
    font-size: .93rem;
    color: var(--text);
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: .75rem 1rem;
    transition: border-color .18s, box-shadow .18s;
    width: 100%;
    outline: none;
  }

  .form-input:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(61,122,95,.12);
  }

  .form-input::placeholder { color: var(--text-muted); }

  .form-select { cursor: pointer; }

  .form-textarea {
    resize: vertical;
    min-height: 150px;
    line-height: 1.6;
  }

  .form-footer {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .form-note {
    font-size: .82rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 340px;
  }

  .form-note a { color: var(--green); }

  .quick-faqs {
    display: flex;
    flex-direction: column;
    gap: .75rem;
    max-width: 760px;
  }

  .faq-item {
    background: #fff;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-item[open] { border-color: var(--green); }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    font-size: .97rem;
    font-weight: 600;
    color: var(--text);
    transition: background .18s;
  }

  .faq-question::-webkit-details-marker { display: none; }
  .faq-question:hover { background: var(--green-light); }
  .faq-item[open] .faq-question { background: var(--green-light); border-bottom: 1.5px solid var(--border); }

  .faq-chevron { flex-shrink: 0; color: var(--green); transition: transform .22s; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }

  .faq-answer { padding: 1.1rem 1.25rem 1.25rem; font-size: .92rem; color: var(--text-secondary); line-height: 1.75; }

  .cta-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-row { grid-template-columns: 1fr; }
    .cta-block { flex-direction: column; }
  }
</style>
