const { slug } = Astro.params;
const story = stories[slug];

const allSlugs = Object.keys(stories);
const currentIndex = allSlugs.indexOf(slug as string);
const prevSlug = currentIndex > 0 ? allSlugs[currentIndex - 1] : null;
const nextSlug = currentIndex < allSlugs.length - 1 ? allSlugs[currentIndex + 1] : null;
const prev = prevSlug ? stories[prevSlug] : null;
const next = nextSlug ? stories[nextSlug] : null;
---
<Layout
  title={`${story.title} — Voices — The Second Spring`}
  description={`${story.name}, ${story.age}, ${story.city}. A personal account of perimenopause.`}
>

<main class="vs-page">

  <div class="vs-breadcrumb">
    <a href="/voices">← All Voices</a>
  </div>

  <div class="vs-header" style={`border-top: 5px solid ${story.color};`}>
    <div class="vs-who">
      <span class="vs-name">{story.name}</span>
      <span class="vs-sep">·</span>
      <span>{story.age}</span>
      <span class="vs-sep">·</span>
      <span>{story.city}</span>
      <span class="vs-sep">·</span>
      <span>{story.occupation}</span>
    </div>
    <h1 class="vs-title">{story.title}</h1>
  </div>

  <article class="vs-body">
    {story.sections.map((section: any) => (
      section.text
        ? <p class="vs-para">{section.text}</p>
        : <div class="vs-ig">
            <div class="vs-ig-head">{section.ig.head}</div>
            <div class="vs-ig-body">
              {section.ig.rows.map((row: any) => (
                <div class="vs-ig-row">
                  <span class={`vs-ig-label vs-ig-label--${row.color}`}>{row.label}</span>
                  <span class="vs-ig-text">{row.text}</span>
                </div>
              ))}
            </div>
          </div>
    ))}
  </article>

  <nav class="vs-nav">
    {prev && prevSlug ? (
      <a href={`/voices/${prevSlug}`} class="vs-nav-link">
        <span class="vs-nav-dir">← Previous</span>
        <span class="vs-nav-name">{prev.name}: {prev.title}</span>
      </a>
    ) : <span />}
    {next && nextSlug ? (
      <a href={`/voices/${nextSlug}`} class="vs-nav-link vs-nav-next">
        <span class="vs-nav-dir">Next →</span>
        <span class="vs-nav-name">{next.name}: {next.title}</span>
      </a>
    ) : <span />}
  </nav>

  <div class="vs-share">
    <div class="vs-share-inner">
      <h2>Have a story of your own?</h2>
      <p>Write to us at <a href="mailto:thesecondspringofficial@gmail.com">thesecondspringofficial@gmail.com</a> — your name, your city, what happened, what you wish someone had told you. With your permission, we may share it here.</p>
      <div class="vs-share-btns">
        <a href="mailto:thesecondspringofficial@gmail.com?subject=My Story" class="vs-btn-primary">Share Your Story</a>
        <a href="/voices" class="vs-btn-outline">Read More Stories</a>
      </div>
    </div>
  </div>

</main>

</Layout>

