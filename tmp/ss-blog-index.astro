---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, postsForCategory as postsInCategory } from '../../lib/blog-categories';
import { breadcrumbSchema, collectionPageSchema, itemListSchema } from '../../lib/schema';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Featured slider: up to 3 posts with featured:true, fall back to 3 most-recent
const featuredPosts = (() => {
  const f = posts.filter(p => p.data.featured);
  return (f.length >= 3 ? f : posts).slice(0, 3);
})();

function postsForCategory(cat: typeof CATEGORIES[number]) {
  return postsInCategory(posts, cat).slice(0, 4);
}

function formatDate(d: Date) {
  return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
}

// ─── Structured data ───
const structuredData = [
  collectionPageSchema({
    name: 'The Second Spring Journal',
    description: 'Honest, science-backed writing on perimenopause, hormones, and thriving through midlife — for Indian women.',
    url: '/blog',
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Journal', url: '/blog' },
  ]),
  itemListSchema(
    posts.slice(0, 20).map(p => ({ name: p.data.title, url: `/blog/${p.slug}` }))
  ),
];

const TAG_COLORS: Record<string, string> = {
  perimenopause: '#3D7A5F', anxiety: '#7B4F3A', 'mood swings': '#7B4F3A',
  hormones: '#2A5C45', 'weight gain': '#C06030', basics: '#3D7A5F',
  'mental health': '#7B4F3A', metabolism: '#C06030', symptoms: '#2A5C45',
  lifestyle: '#3D7A5F', supplements: '#5A8A6A', 'hair loss': '#C06030',
  'hot flashes': '#C06030', fatigue: '#7B4F3A', 'brain fog': '#7B4F3A',
};
function tagColor(tag: string) { return TAG_COLORS[tag.toLowerCase()] || '#3D7A5F'; }
---

<Layout
  title="The Second Spring Journal — Perimenopause Insights for Indian Women"
  description="Honest, science-backed writing on perimenopause, hormones, and thriving through midlife. Journals written for Indian women."
  structuredData={structuredData}
>

  <!-- Hero -->
  <section class="journal-hero">
    <div class="container">
      <span class="jh-label">🌸 The Second Spring</span>
      <h1>Journal</h1>
      <p class="jh-sub">Honest, science-backed writing on perimenopause, hormones, and thriving through midlife — for Indian women.</p>
    </div>
  </section>

  <!-- Featured Slider -->
  {featuredPosts.length > 0 && (
    <section class="section featured-section bg-white">
      <div class="container">
        <div class="featured-header">
          <p class="grid-label">✦ Featured journals</p>
          <div class="slider-controls" id="sliderControls">
            <button class="slider-btn" id="prevBtn" aria-label="Previous" disabled>
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 4L6 9L11 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="slider-dots" id="sliderDots">
              {featuredPosts.map((_, i) => (
                <button class={`dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
              ))}
            </div>
            <button class="slider-btn" id="nextBtn" aria-label="Next">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>

        <div class="slider-viewport" id="sliderViewport">
          <div class="slider-track" id="sliderTrack">
            {featuredPosts.map(post => (
              <a href={`/blog/${post.slug}`} class="slider-card">
                <div class="sc-image">
                  {post.data.image
                    ? <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
                    : <div class="sc-image-fallback" style="background: linear-gradient(135deg, #1A3D2B, #3D7A5F)"></div>
                  }
                  <div class="sc-image-overlay"></div>
                  <div class="sc-image-tags">
                    {post.data.tags.slice(0, 2).map((t: string) => (
                      <span class="stag">{t}</span>
                    ))}
                  </div>
                </div>
                <div class="sc-body">
                  <h2 class="sc-title">{post.data.title}</h2>
                  <p class="sc-desc">{post.data.description}</p>
                  <div class="sc-footer">
                    <div class="sc-meta">
                      <span class="sc-author">{post.data.author}</span>
                      <span class="sc-sep">·</span>
                      <span>{formatDate(post.data.pubDate)}</span>
                      <span class="sc-sep">·</span>
                      <span>{post.data.readTime}</span>
                    </div>
                    <span class="sc-read">Read →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Category sections -->
  {CATEGORIES.map((cat, catIdx) => {
    const catPosts = postsForCategory(cat);
    if (catPosts.length === 0) return null;
    return (
      <section class={`section cat-section ${catIdx % 2 === 0 ? 'bg-cream' : 'bg-white'}`}>
        <div class="container">
          <!-- Category header -->
          <div class="cat-header">
            <div class="cat-header-left">
              <div class="cat-icon-wrap">
                <span class="cat-icon">{cat.icon}</span>
              </div>
              <div class="cat-title-block">
                <h2 class="cat-label">{cat.label}</h2>
                <p class="cat-desc">{cat.desc}</p>
              </div>
            </div>
            <a href={`/blog/category/${cat.slug}`} class="cat-see-all">
              See all <span class="see-all-arrow">→</span>
            </a>
          </div>

          <!-- Post cards grid -->
          <div class="posts-grid">
            {catPosts.map(post => (
              <a href={`/blog/${post.slug}`} class="post-card">
                <div class="post-image">
                  {post.data.image
                    ? <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
                    : <div class="post-image-fallback" style={`background: linear-gradient(135deg, #1A3D2B, #4E9070)`}></div>
                  }
                </div>
                <div class="post-body">
                  <div class="post-tags">
                    {post.data.tags.slice(0, 2).map((t: string) => (
                      <span class="ptag" style={`color:${tagColor(t)};background:${tagColor(t)}18`}>{t}</span>
                    ))}
                  </div>
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-desc">{post.data.description}</p>
                  <div class="post-footer">
                    <div class="post-meta">
                      <span>{post.data.author}</span>
                      <span>·</span>
                      <span>{post.data.readTime}</span>
                    </div>
                    <span class="post-read-link">Read →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- CTA -->
  <section class="journal-cta">
    <div class="container">
      <div class="cta-inner">
        <h2>Have a question you don't see answered here?</h2>
        <p>Ask our private companion — any time, no login needed.</p>
        <a href="/chat" class="btn btn-peach btn-lg">Start a private conversation →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ─── Hero ─── */
  .journal-hero {
    background: linear-gradient(150deg, #0F2A1A 0%, #1A3D2B 100%);
    padding: 5rem 0 4rem;
    text-align: center;
  }
  .jh-label {
    display: inline-flex;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.65);
    background: rgba(255,255,255,.1);
    padding: .3rem .9rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }
  .journal-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -.04em;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .jh-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,.68);
    line-height: 1.72;
    max-width: 520px;
    margin: 0 auto;
  }

  /* ─── Section helpers ─── */
  .section { padding: 4.5rem 0; }
  .bg-white { background: #fff; }
  .bg-cream { background: var(--cream-mid, #F7F3EE); }
  .grid-label {
    font-size: .74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-muted, #888);
    margin-bottom: 0;
  }

  /* ─── Featured Slider ─── */
  .featured-section { overflow: hidden; }

  .featured-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
    gap: .75rem;
  }

  .slider-controls {
    display: flex;
    align-items: center;
    gap: .75rem;
  }

  .slider-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid var(--border, #E0DDD8);
    background: #fff;
    color: var(--green, #3D7A5F);
    cursor: pointer;
    transition: all .18s;
    flex-shrink: 0;
  }
  .slider-btn:hover:not(:disabled) {
    background: var(--green, #3D7A5F);
    color: #fff;
    border-color: var(--green, #3D7A5F);
  }
  .slider-btn:disabled {
    opacity: .35;
    cursor: not-allowed;
  }

  .slider-dots {
    display: flex;
    gap: .4rem;
    align-items: center;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--border, #E0DDD8);
    cursor: pointer;
    padding: 0;
    transition: all .2s;
  }
  .dot.active {
    background: var(--green, #3D7A5F);
    width: 22px;
    border-radius: 100px;
  }

  .slider-viewport {
    overflow: hidden;
    /* allow the track to peek on the right edge */
    margin-right: -1.25rem;
    padding-right: 1.25rem;
  }

  .slider-track {
    display: flex;
    gap: 1.5rem;
    transition: transform .4s cubic-bezier(.4,0,.2,1);
    will-change: transform;
  }

  /* ─── Slider cards ─── */
  .slider-card {
    flex: 0 0 min(calc(100% - 2rem), 460px);
    min-width: 320px;
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    border: 1.5px solid var(--border, #E0DDD8);
    text-decoration: none;
    color: var(--text, #1A1A1A);
    display: flex;
    flex-direction: column;
    background: #fff;
    transition: all .2s;
    box-shadow: 0 2px 12px rgba(0,0,0,.04);
  }
  .slider-card:hover {
    box-shadow: 0 16px 48px rgba(61,122,95,.15);
    transform: translateY(-4px);
    border-color: var(--green, #3D7A5F);
  }

  .sc-image {
    position: relative;
    height: 260px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .sc-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform .4s ease;
    display: block;
  }
  .slider-card:hover .sc-image img { transform: scale(1.04); }
  .sc-image-fallback { width: 100%; height: 100%; }
  .sc-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.5) 0%, transparent 60%);
  }
  .sc-image-tags {
    position: absolute;
    bottom: .9rem;
    left: 1.1rem;
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
  }
  .stag {
    font-size: .67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #fff;
    background: rgba(0,0,0,.35);
    backdrop-filter: blur(6px);
    padding: .22rem .65rem;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,.25);
  }

  .sc-body {
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    flex: 1;
  }
  .sc-title {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -.02em;
    color: var(--text, #1A1A1A);
    line-height: 1.32;
  }
  .sc-desc {
    font-size: .89rem;
    color: var(--text-secondary, #555);
    line-height: 1.7;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sc-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: .15rem;
    flex-wrap: wrap;
    gap: .5rem;
  }
  .sc-meta {
    font-size: .76rem;
    color: var(--text-muted, #888);
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .sc-sep { opacity: .5; }
  .sc-author { font-weight: 600; color: var(--text-secondary, #555); }
  .sc-read {
    font-size: .85rem;
    font-weight: 700;
    color: var(--green, #3D7A5F);
    white-space: nowrap;
    letter-spacing: .01em;
  }

  /* ─── Category sections ─── */
  .cat-section { border-top: 1px solid var(--border, #E0DDD8); }

  .cat-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.25rem;
    flex-wrap: wrap;
  }

  .cat-header-left {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    flex: 1;
    min-width: 0;
  }

  .cat-icon-wrap {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--green-tint, rgba(61,122,95,.1));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: .1rem;
  }
  .cat-icon { font-size: 1.55rem; line-height: 1; }

  .cat-title-block { min-width: 0; }
  .cat-label {
    font-size: 1.45rem;
    font-weight: 800;
    letter-spacing: -.03em;
    color: var(--text, #1A1A1A);
    line-height: 1.2;
    margin-bottom: .3rem;
  }
  .cat-desc {
    font-size: .88rem;
    color: var(--text-secondary, #555);
    line-height: 1.65;
    max-width: 520px;
  }

  .cat-see-all {
    flex-shrink: 0;
    font-size: .88rem;
    font-weight: 700;
    color: var(--green, #3D7A5F);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    padding: .5rem 1rem;
    border-radius: 100px;
    border: 1.5px solid var(--green, #3D7A5F);
    transition: all .18s;
    white-space: nowrap;
    align-self: center;
  }
  .cat-see-all:hover {
    background: var(--green, #3D7A5F);
    color: #fff;
  }
  .see-all-arrow { transition: transform .18s; }
  .cat-see-all:hover .see-all-arrow { transform: translateX(3px); }

  /* ─── Post cards grid ─── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.35rem;
  }
  /* If only 4 posts, use 4-col layout */
  .posts-grid:has(> :nth-child(4)):not(:has(> :nth-child(5))) {
    grid-template-columns: repeat(4, 1fr);
  }

  .post-card {
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    border: 1.5px solid var(--border, #E0DDD8);
    text-decoration: none;
    color: var(--text, #1A1A1A);
    display: flex;
    flex-direction: column;
    background: #fff;
    transition: all .18s;
  }
  .post-card:hover {
    box-shadow: 0 12px 36px rgba(61,122,95,.13);
    transform: translateY(-3px);
    border-color: var(--green, #3D7A5F);
  }

  .post-image {
    height: 180px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--cream-mid, #F7F3EE);
  }
  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform .4s ease;
    display: block;
  }
  .post-card:hover .post-image img { transform: scale(1.04); }
  .post-image-fallback { width: 100%; height: 100%; }

  .post-body {
    padding: 1.2rem 1.25rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    flex: 1;
  }
  .post-tags { display: flex; gap: .4rem; flex-wrap: wrap; }
  .ptag {
    font-size: .67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    padding: .2rem .6rem;
    border-radius: 100px;
  }
  .post-title {
    font-size: .97rem;
    font-weight: 700;
    color: var(--text, #1A1A1A);
    line-height: 1.37;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-desc {
    font-size: .83rem;
    color: var(--text-secondary, #555);
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: .3rem;
    flex-wrap: wrap;
    gap: .35rem;
  }
  .post-meta {
    font-size: .74rem;
    color: var(--text-muted, #888);
    display: flex;
    gap: .35rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .post-read-link {
    font-size: .8rem;
    font-weight: 700;
    color: var(--green, #3D7A5F);
    white-space: nowrap;
  }

  /* ─── CTA ─── */
  .journal-cta {
    background: var(--green-dark, #1A3D2B);
    padding: 4rem 0;
    text-align: center;
  }
  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 540px;
    margin: 0 auto;
  }
  .journal-cta h2 {
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -.02em;
    line-height: 1.25;
  }
  .journal-cta p { color: rgba(255,255,255,.68); font-size: .97rem; }

  /* ─── Responsive ─── */
  @media (max-width: 1100px) {
    .posts-grid:has(> :nth-child(4)):not(:has(> :nth-child(5))) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 900px) {
    .slider-card { flex-basis: min(calc(100% - 1.5rem), 380px); }
    .posts-grid  { grid-template-columns: repeat(2, 1fr); }
    .posts-grid:has(> :nth-child(4)):not(:has(> :nth-child(5))) {
      grid-template-columns: repeat(2, 1fr);
    }
    .cat-label { font-size: 1.25rem; }
  }
  @media (max-width: 600px) {
    .slider-card { flex-basis: calc(100% - .5rem); min-width: 0; }
    .slider-viewport { margin-right: 0; padding-right: 0; }
    .posts-grid { grid-template-columns: 1fr; }
    .cat-header { flex-direction: column; gap: 1rem; }
    .cat-see-all { align-self: flex-start; }
    .cat-icon-wrap { width: 44px; height: 44px; border-radius: 12px; }
    .cat-icon { font-size: 1.25rem; }
    .featured-header { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  // ─── Featured Slider ───────────────────────────────────────────────────────
  const track    = document.getElementById('sliderTrack') as HTMLElement | null;
  const viewport = document.getElementById('sliderViewport') as HTMLElement | null;
  const prevBtn  = document.getElementById('prevBtn') as HTMLButtonElement | null;
  const nextBtn  = document.getElementById('nextBtn') as HTMLButtonElement | null;
  const dotsContainer = document.getElementById('sliderDots') as HTMLElement | null;

  if (track && viewport && prevBtn && nextBtn && dotsContainer) {
    const cards = Array.from(track.children) as HTMLElement[];
    const total = cards.length;
    let current = 0;

    function getCardWidth(): number {
      if (cards[0]) {
        return cards[0].offsetWidth + 24; // card + gap (1.5rem = 24px)
      }
      return 0;
    }

    function goTo(index: number) {
      current = Math.max(0, Math.min(index, total - 1));
      const offset = current * getCardWidth();
      track.style.transform = `translateX(-${offset}px)`;

      // Update buttons
      prevBtn!.disabled = current === 0;
      nextBtn!.disabled = current === total - 1;

      // Update dots
      const dots = dotsContainer!.querySelectorAll('.dot');
      dots.forEach((dot, i) => dot.classList.toggle('active', i === current));
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    const dots = dotsContainer.querySelectorAll('.dot');
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });

    // Touch/swipe support
    let touchStartX = 0;
    let touchStartY = 0;
    let isDragging = false;

    viewport.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      isDragging = false;
    }, { passive: true });

    viewport.addEventListener('touchmove', (e: TouchEvent) => {
      const dx = Math.abs(e.touches[0].clientX - touchStartX);
      const dy = Math.abs(e.touches[0].clientY - touchStartY);
      if (dx > dy) isDragging = true;
    }, { passive: true });

    viewport.addEventListener('touchend', (e: TouchEvent) => {
      if (!isDragging) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) {
        goTo(dx < 0 ? current + 1 : current - 1);
      }
    });

    // Recalculate on resize
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(current), 150);
    });

    // Initial state
    goTo(0);
  }
</script>
