---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.filter(p => p.data.featured);
const rest     = posts.filter(p => !p.data.featured);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout
  title="Blog — The Second Spring"
  description="Honest, science-backed articles on perimenopause, menopause, hormones, and women's health. Written for Indian women."
>
  <!-- Hero -->
  <section class="blog-hero">
    <div class="container">
      <span class="bh-label">Knowledge is power</span>
      <h1>The Second Spring Journal</h1>
      <p class="bh-sub">Honest, science-backed writing on perimenopause, hormones, and thriving through midlife — for Indian women.</p>
    </div>
  </section>

  <!-- Featured posts -->
  {featured.length > 0 && (
    <section class="section bg-white">
      <div class="container">
        <p class="grid-label">Featured reads</p>
        <div class="featured-grid">
          {featured.map(post => (
            <a href={`/blog/${post.slug}`} class="feat-card">
              <div class="feat-tags">
                {post.data.tags.slice(0,2).map(t => <span class="tag">{t}</span>)}
              </div>
              <h2 class="feat-title">{post.data.title}</h2>
              <p class="feat-desc">{post.data.description}</p>
              <div class="feat-meta">
                <span>{formatDate(post.data.pubDate)}</span>
                <span>·</span>
                <span>{post.data.readTime}</span>
              </div>
              <span class="feat-read">Read article →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All posts -->
  {rest.length > 0 && (
    <section class="section bg-cream">
      <div class="container">
        <p class="grid-label">All articles</p>
        <div class="posts-grid">
          {rest.map(post => (
            <a href={`/blog/${post.slug}`} class="post-card">
              <div class="post-tags">
                {post.data.tags.slice(0,2).map(t => <span class="tag">{t}</span>)}
              </div>
              <h3 class="post-title">{post.data.title}</h3>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-meta">
                <span>{formatDate(post.data.pubDate)}</span>
                <span>·</span>
                <span>{post.data.readTime}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="blog-cta">
    <div class="container">
      <div class="cta-inner">
        <h2>Have a question you don't see answered here?</h2>
        <p>Ask our private companion — any time, no login needed.</p>
        <a href="/chat" class="btn btn-peach btn-lg">Start a private conversation →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-hero {
    background: linear-gradient(150deg, #0F2A1A 0%, #1A3D2B 100%);
    padding: 5rem 0 4rem; text-align: center;
  }
  .bh-label {
    display: inline-flex; font-size: .76rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: rgba(255,255,255,.7); background: rgba(255,255,255,.1);
    padding: .3rem .85rem; border-radius: 100px; margin-bottom: 1rem;
  }
  .blog-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; letter-spacing: -.03em;
    color: #fff; line-height: 1.15; margin-bottom: 1rem;
  }
  .bh-sub { font-size: 1.05rem; color: rgba(255,255,255,.72); line-height: 1.72; max-width: 560px; margin: 0 auto; }

  .section { padding: 4rem 0; }
  .bg-white { background: #fff; }
  .bg-cream { background: var(--cream-mid); }

  .grid-label { font-size: .76rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--text-muted); margin-bottom: 1.5rem; }

  .featured-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .feat-card {
    background: var(--cream-mid); border: 1.5px solid var(--border); border-radius: var(--radius-lg);
    padding: 2rem; display: flex; flex-direction: column; gap: .75rem;
    text-decoration: none; color: var(--text); transition: all .2s;
  }
  .feat-card:hover { border-color: var(--green); box-shadow: 0 8px 32px rgba(61,122,95,.12); transform: translateY(-3px); }
  .feat-tags { display: flex; gap: .5rem; flex-wrap: wrap; }
  .tag { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--green); background: var(--green-light); padding: .2rem .65rem; border-radius: 100px; }
  .feat-title { font-size: 1.25rem; font-weight: 800; letter-spacing: -.02em; color: var(--text); line-height: 1.3; }
  .feat-desc  { font-size: .9rem; color: var(--text-secondary); line-height: 1.7; flex: 1; }
  .feat-meta  { font-size: .78rem; color: var(--text-muted); display: flex; gap: .4rem; }
  .feat-read  { font-size: .85rem; font-weight: 700; color: var(--green); margin-top: .25rem; }

  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .post-card {
    background: #fff; border: 1.5px solid var(--border); border-radius: var(--radius);
    padding: 1.5rem; display: flex; flex-direction: column; gap: .6rem;
    text-decoration: none; color: var(--text); transition: all .18s;
  }
  .post-card:hover { border-color: var(--green); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(61,122,95,.1); }
  .post-tags { display: flex; gap: .4rem; flex-wrap: wrap; }
  .post-title { font-size: 1rem; font-weight: 700; color: var(--text); line-height: 1.35; }
  .post-desc  { font-size: .84rem; color: var(--text-secondary); line-height: 1.65; flex: 1; }
  .post-meta  { font-size: .76rem; color: var(--text-muted); display: flex; gap: .4rem; }

  .blog-cta { background: var(--green-dark); padding: 4rem 0; text-align: center; }
  .blog-cta .cta-inner { display: flex; flex-direction: column; align-items: center; gap: 1rem; max-width: 540px; margin: 0 auto; }
  .blog-cta h2 { font-size: 1.6rem; font-weight: 800; color: #fff; letter-spacing: -.02em; line-height: 1.25; }
  .blog-cta p  { color: rgba(255,255,255,.72); font-size: .97rem; }

  @media (max-width: 768px) {
    .featured-grid { grid-template-columns: 1fr; }
    .posts-grid    { grid-template-columns: 1fr; }
  }
</style>
