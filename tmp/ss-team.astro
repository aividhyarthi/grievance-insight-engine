---
import Layout from '../layouts/Layout.astro';

const experts = [
  {
    icon: '🩺',
    role: 'Gynaecologist & Menopause Specialist',
    tagline: 'Your primary clinical guide through perimenopause',
    desc: 'A gynaecologist with menopause training is the cornerstone of your care during perimenopause. They assess hormonal symptoms, investigate irregular or heavy bleeding, discuss HRT (hormone replacement therapy), and manage conditions like fibroids, PCOS, and endometriosis that can worsen during this transition. Not all gynaecologists are menopause-trained — ours are.',
    handles: ['Heavy or irregular periods', 'HRT assessment and prescription', 'Fibroids and uterine conditions', 'Vaginal dryness and urinary symptoms', 'Bone density concerns'],
  },
  {
    icon: '👩‍⚕️',
    role: 'Nurse Practitioner',
    tagline: 'Your first point of contact — expert, warm, and thorough',
    desc: 'Our nurse practitioners are trained in women\'s health and perimenopause. They conduct your first consultation, take a detailed history of your symptoms, order initial investigations, and help you understand your results. They work closely with our doctors and gynaecologists, and often provide the kind of unhurried, empathetic conversation that is hard to find in a busy clinic.',
    handles: ['Initial symptom assessment', 'Reviewing your blood test results', 'Ongoing monitoring and follow-up', 'Medication management support', 'Guidance on when to escalate to a specialist'],
  },
  {
    icon: '🏥',
    role: 'General Physician',
    tagline: 'Treating the whole picture, not just the hormones',
    desc: 'Many perimenopausal symptoms — fatigue, weight gain, palpitations, brain fog — overlap with conditions like thyroid dysfunction, anaemia, diabetes, and high blood pressure. A general physician rules these out, manages existing conditions that interact with hormonal changes, and ensures your overall health is seen as a whole. In India, this is often the first doctor a woman sees — ours are perimenopause-aware.',
    handles: ['Thyroid and metabolic conditions', 'Anaemia and iron deficiency', 'Blood pressure and cardiovascular health', 'Blood sugar and insulin resistance', 'Vitamin and mineral deficiencies (D, B12, iron)'],
  },
  {
    icon: '🔬',
    role: 'Endocrinologist',
    tagline: 'For hormonal complexity beyond the basics',
    desc: 'An endocrinologist specialises in the body\'s hormone systems — including thyroid, adrenal, and insulin-related conditions. During perimenopause, the hormonal landscape becomes more complex, and conditions like hypothyroidism, PCOS, or metabolic syndrome can interact with oestrogen decline in ways that need specialist understanding. Our endocrinologist handles the cases where the picture is more complicated.',
    handles: ['Thyroid disorders (hypothyroid, hyperthyroid, Hashimoto\'s)', 'PCOS in perimenopause', 'Insulin resistance and metabolic syndrome', 'Osteoporosis and bone density management', 'Complex HRT cases with metabolic conditions'],
  },
  {
    icon: '🧠',
    role: 'Psychologist',
    tagline: 'Because mood, mind, and identity matter just as much',
    desc: 'Perimenopause affects the brain directly — oestrogen regulates the chemicals that control mood, anxiety, and emotional resilience. Many women experience anxiety, depression, rage, or a loss of sense of self for the first time in their 40s. Our psychologist provides evidence-based support specifically for hormonal mental health: this is not just stress management — it is clinical care for a neurological transition.',
    handles: ['Perimenopause-related anxiety and depression', 'Sudden onset panic attacks', 'Rage and emotional dysregulation', 'Identity and self-esteem changes', 'Cognitive behavioural therapy (CBT) for perimenopausal symptoms'],
  },
  {
    icon: '🥗',
    role: 'Registered Dietician',
    tagline: 'Clinical nutrition for a body that is changing',
    desc: 'A registered dietician (RD) holds a formal clinical qualification and works with medical conditions — not just general wellness. During perimenopause, diet directly affects insulin resistance, bone density, cardiovascular risk, and weight. Our dietician creates personalised, evidence-based plans that account for Indian food culture, regional cuisines, and the specific metabolic changes of this transition. This is not generic diet advice.',
    handles: ['Weight management and belly fat', 'Insulin resistance and blood sugar control', 'Bone health and calcium/vitamin D', 'Managing cholesterol and cardiovascular risk', 'Managing symptoms through food (bloating, hot flashes, sleep)'],
  },
  {
    icon: '🌿',
    role: 'Nutritionist & Wellness Coach',
    tagline: 'Practical, day-to-day guidance for sustainable lifestyle change',
    desc: 'Where the dietician works on clinical nutrition, our nutritionist and wellness coach work on the daily realities of making change — habits, routines, supplement guidance, and sustainable choices within the context of an Indian household. They provide guidance on adapting traditional diets, managing stress through lifestyle, sleep hygiene, and the small daily shifts that add up to significant change over time.',
    handles: ['Daily eating habits and meal planning', 'Supplement guidance (vitamin D, magnesium, omega-3)', 'Sleep hygiene and routine', 'Stress reduction and lifestyle design', 'Exercise guidance for perimenopause'],
  },
  {
    icon: '🤸',
    role: 'Pelvic Floor Physiotherapist',
    tagline: 'For symptoms nobody talks about — but almost every woman experiences',
    desc: 'As oestrogen declines, the muscles and tissues of the pelvic floor weaken. This causes bladder leakage (urinary incontinence), pelvic heaviness or prolapse, pain during intimacy, and reduced bladder control. These symptoms affect the majority of perimenopausal women and are almost never discussed. A pelvic floor physiotherapist provides targeted exercises and treatment that can dramatically improve quality of life — without surgery.',
    handles: ['Urinary leakage and urgency', 'Pelvic organ prolapse (early stages)', 'Pelvic pain and discomfort', 'Pain during sex', 'Post-surgical pelvic rehabilitation'],
  },
  {
    icon: '💛',
    role: 'Sexual Health Counsellor',
    tagline: 'For the part of perimenopause that nobody talks about',
    desc: 'Loss of libido, vaginal dryness, discomfort during sex, and changes in intimacy are among the most common — and most silently suffered — symptoms of perimenopause. They have real physical causes. And they are treatable. Our sexual health counsellor provides a confidential, judgement-free space to address these changes — whether the need is clinical information, communication support, or simply being heard without shame.',
    handles: ['Low libido and loss of desire', 'Vaginal dryness and pain during sex', 'Relationship and intimacy changes', 'Body image during midlife transition', 'Genitourinary syndrome of menopause (GSM)'],
  },
  {
    icon: '🌸',
    role: 'Health Coach',
    tagline: 'Your guide from confusion to confident, consistent action',
    desc: 'A health coach works with you on the journey between understanding and action. They help you identify your goals, build sustainable habits, navigate the emotional complexity of this transition, and stay consistent — especially when motivation is low. They are not clinicians, but they are trained in behaviour change, motivational interviewing, and the specific challenges of perimenopause. Think of them as the person who walks this road with you.',
    handles: ['Goal setting and habit building', 'Navigating doctor appointments and advocating for yourself', 'Managing the emotional weight of this transition', 'Accountability and ongoing support', 'Coordinating your care across different specialists'],
  },
];
---

<Layout
  title="Our Team – The Second Spring"
  description="Meet the people behind The Second Spring — India's first private perimenopause companion for Indian women."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <div class="page-eyebrow">✦ Our team</div>
        <h1>The people behind The Second Spring</h1>
        <p>Built with care, purpose, and a belief that every Indian woman deserves access to information about her own body.</p>
      </div>
    </div>
  </section>

  <!-- Founder -->
  <section class="section bg-white">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Founding team</span>
        <h2 class="section-title">Who we are</h2>
      </div>

      <div class="founder-card">
        <div class="founder-photo-wrap">
          <img
            src="https://raw.githubusercontent.com/aividhyarthi/thesecondspring/main/Rudra%20Kasturi%20Photo.jpg"
            alt="Rudra Kasturi, Founder & CEO of The Second Spring"
            class="founder-photo"
          />
        </div>
        <div class="founder-info">
          <div class="founder-meta">
            <h2 class="founder-name">Rudra Kasturi</h2>
            <div class="founder-title">Founder &amp; CEO</div>
          </div>

          <p class="founder-bio">
            Rudra is a technology leader with deep experience across product, engineering, and AI strategy. He has spent his career building products that solve real human problems — and The Second Spring represents his most personal mission yet: using technology to make healthcare more human, more accessible, and more empathetic.
          </p>
          <p class="founder-bio">
            The Second Spring was born from witnessing women in his life navigate perimenopause without information, language, or support — and from a conviction that this was a solvable problem. The combination of AI capability, genuine empathy, and India-specific context creates something that hasn't existed before.
          </p>
          <p class="founder-bio">
            Rudra believes that the best products are built when deep technical capability meets a genuine understanding of the human experience. The Second Spring is his attempt to do exactly that — for millions of Indian women who deserve better.
          </p>

          <div class="founder-links">
            <a href="https://linkedin.com/in/rudrakasturi" class="founder-link" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a href="https://www.rudrakasturi.com" class="founder-link" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 014-10z"/></svg>
              rudrakasturi.com
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Clinical Experts -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header center">
        <span class="section-label">Clinical team</span>
        <h2 class="section-title">Our experts — and what they do</h2>
        <p class="section-sub">Perimenopause touches every system in your body. Our team is built to match that — each specialist addressing a specific dimension of what you're going through.</p>
      </div>

      <div class="experts-grid">
        {experts.map(e => (
          <div class="expert-card">
            <div class="expert-header">
              <div class="expert-icon">{e.icon}</div>
              <div>
                <h3 class="expert-role">{e.role}</h3>
                <div class="expert-tagline">{e.tagline}</div>
              </div>
            </div>
            <p class="expert-desc">{e.desc}</p>
            <div class="expert-handles">
              <div class="handles-label">They help with:</div>
              <ul class="handles-list">
                {e.handles.map(h => (
                  <li class="handle-item">
                    <span class="handle-dot" />
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="experts-note">
        <div class="experts-note-inner">
          <div class="note-icon">💬</div>
          <div>
            <strong>Not sure which specialist you need?</strong>
            <p>Start with The Second Spring chat — our companion will help you understand your symptoms and point you to the right person. No appointment needed.</p>
            <a href="/chat" class="btn btn-peach" style="margin-top:.85rem; display:inline-block;">Talk to The Second Spring →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission section -->
  <section class="section bg-white">
    <div class="container">
      <div class="mission-layout">
        <div>
          <span class="section-label">Our mission</span>
          <h2 class="section-title">Why we built this</h2>
        </div>
        <div>
          <p class="body-text">
            The Second Spring exists because perimenopause has been invisible for too long in India. Millions of women go through this transition without knowing what's happening to them, without language to describe their experience, and without finding healthcare providers who take them seriously.
          </p>
          <p class="body-text">
            We believe that accurate, empathetic information — available privately, on your own terms — can be transformative. Not as a replacement for medical care, but as the bridge that gets you there. The bridge that helps you understand your body, find your voice, and walk into the doctor's office prepared.
          </p>
          <div class="mission-quote">
            <blockquote>
              "Every Indian woman navigating perimenopause deserves to feel seen, informed, and supported. The Second Spring is our small contribution to making that a reality."
            </blockquote>
            <cite>— Rudra Kasturi</cite>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-cream">
    <div class="container">
      <div class="section-header center">
        <span class="section-label">What we stand for</span>
        <h2 class="section-title">Our values</h2>
      </div>
      <div class="values-grid">
        {[
          { icon: '🔒', title: 'Privacy first', desc: 'Your questions, your conversations, your body — entirely your own. We will never compromise on privacy.' },
          { icon: '🌸', title: 'Indian women, always', desc: 'Everything we build is shaped by the realities of Indian women\'s lives, bodies, and healthcare contexts.' },
          { icon: '💛', title: 'Empathy before everything', desc: 'We lead with warmth, validation, and care — because that\'s what this transition demands.' },
          { icon: '🔬', title: 'Evidence, not fear', desc: 'We provide accurate, evidence-based information — cutting through the outdated fears and myths that have silenced women for decades.' },
        ].map(v => (
          <div class="value-card">
            <div class="value-icon">{v.icon}</div>
            <h3 class="value-title">{v.title}</h3>
            <p class="value-desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Join us -->
  <section class="section bg-green">
    <div class="container">
      <div class="join-layout">
        <div>
          <span class="section-label">Join us</span>
          <h2 class="section-title">We're growing</h2>
          <p class="body-text">
            The Second Spring is in its early stages — and we're looking for clinicians who care deeply about women's health and want to be part of India's first perimenopause platform built specifically for Indian women.
          </p>
          <p class="body-text">
            We're particularly interested in connecting with:
          </p>
          <ul class="join-list">
            <li>Gynaecologists and menopause specialists for clinical advisory and tele-consult roles</li>
            <li>Psychologists and mental health professionals with women's health experience</li>
            <li>Registered dieticians and pelvic floor physiotherapists</li>
            <li>Investors and strategic partners aligned with our mission</li>
          </ul>
          <a href="mailto:hello@thesecondspring.com" class="btn btn-primary btn-lg" style="margin-top:1.5rem;">Reach out to us →</a>
        </div>
        <div class="join-image-block">
          <div class="join-stat">
            <div class="join-stat-num">30M+</div>
            <div class="join-stat-label">Indian women entering perimenopause every year</div>
          </div>
          <div class="join-stat">
            <div class="join-stat-num">1</div>
            <div class="join-stat-label">Platform built specifically for them</div>
          </div>
          <div class="join-stat join-stat--highlight">
            <div class="join-stat-num">You?</div>
            <div class="join-stat-label">Join us in building something that matters</div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .founder-card {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3.5rem;
    align-items: start;
    background: var(--cream-mid);
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
  }

  .founder-photo-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/5;
    background: var(--green-light);
  }

  .founder-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .founder-meta {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1.5px solid var(--border-light);
  }

  .founder-name {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text);
    letter-spacing: -.03em;
    margin-bottom: .35rem;
  }

  .founder-title {
    font-size: .88rem;
    font-weight: 600;
    color: var(--green);
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .founder-bio {
    font-size: .95rem;
    color: var(--text-secondary);
    line-height: 1.78;
    margin-bottom: 1rem;
  }

  .founder-links {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .founder-link {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .88rem;
    font-weight: 600;
    color: var(--green);
    padding: .55rem 1.1rem;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all .18s;
    background: #fff;
  }

  .founder-link:hover {
    background: var(--green);
    color: #fff;
    border-color: var(--green);
  }

  /* Experts */
  .experts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .expert-card {
    background: #fff;
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .expert-header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .expert-icon {
    font-size: 2rem;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--green-light);
    border-radius: var(--radius);
  }

  .expert-role {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: .2rem;
    letter-spacing: -.01em;
  }

  .expert-tagline {
    font-size: .82rem;
    color: var(--green);
    font-weight: 600;
    font-style: italic;
  }

  .expert-desc {
    font-size: .88rem;
    color: var(--text-secondary);
    line-height: 1.72;
  }

  .expert-handles {
    background: var(--green-light);
    border-radius: var(--radius-sm);
    padding: 1rem;
    border-left: 3px solid var(--green);
  }

  .handles-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--green);
    margin-bottom: .6rem;
  }

  .handles-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .handle-item {
    display: flex;
    align-items: flex-start;
    gap: .6rem;
    font-size: .83rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .handle-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    margin-top: .45rem;
  }

  .experts-note {
    background: var(--green-dark);
    border-radius: var(--radius-lg);
    padding: 2rem;
    color: #fff;
  }

  .experts-note-inner {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .note-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .experts-note strong {
    font-size: 1.05rem;
    font-weight: 700;
    display: block;
    margin-bottom: .4rem;
  }

  .experts-note p {
    font-size: .9rem;
    color: rgba(255,255,255,.8);
    line-height: 1.65;
  }

  /* Mission */
  .mission-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .mission-quote {
    margin-top: 1.75rem;
    border-left: 3px solid var(--green);
    padding-left: 1.25rem;
  }

  .mission-quote blockquote {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: .5rem;
  }

  .mission-quote cite {
    font-size: .85rem;
    color: var(--text-muted);
    font-style: normal;
    font-weight: 600;
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .value-card {
    background: var(--green-light);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    border: 1.5px solid var(--border);
  }

  .value-icon { font-size: 1.75rem; margin-bottom: .85rem; }
  .value-title { font-size: .97rem; font-weight: 700; color: var(--text); margin-bottom: .45rem; }
  .value-desc { font-size: .87rem; color: var(--text-secondary); line-height: 1.65; }

  /* Join */
  .join-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .join-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .55rem;
    margin-top: .5rem;
  }

  .join-list li {
    font-size: .9rem;
    color: var(--text-secondary);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.55;
  }

  .join-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--green);
    font-size: .8rem;
  }

  .join-image-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .join-stat {
    background: #fff;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    border: 1.5px solid var(--border-light);
  }

  .join-stat--highlight {
    background: var(--green);
    border-color: var(--green);
  }

  .join-stat--highlight .join-stat-num { color: #fff; }
  .join-stat--highlight .join-stat-label { color: rgba(255,255,255,.8); }

  .join-stat-num {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--green-dark);
    letter-spacing: -.04em;
    margin-bottom: .35rem;
  }

  .join-stat-label {
    font-size: .88rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .founder-card { grid-template-columns: 1fr; }
    .founder-photo-wrap { max-width: 280px; }
    .mission-layout { grid-template-columns: 1fr; gap: 1.5rem; }
    .values-grid { grid-template-columns: repeat(2, 1fr); }
    .join-layout { grid-template-columns: 1fr; }
    .experts-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .values-grid { grid-template-columns: 1fr; }
  }
</style>
