---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post  = posts.find(p => p.slug === slug);

if (!post) return Astro.redirect('/blog');

const { Content } = await post.render();

function formatDate(d: Date) {
  return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
}

// Related posts (same tags, exclude current)
const related = posts
  .filter(p => p.slug !== slug && p.data.tags.some(t => post.data.tags.includes(t)))
  .slice(0, 2);
---

<Layout title={`${post.data.title} — The Second Spring`} description={post.data.description}>

  <!-- Article hero -->
  <section class="post-hero">
    <div class="container">
      <a href="/blog" class="back-link">← Back to Journal</a>
      <div class="post-tags">
        {post.data.tags.slice(0,3).map(t => <span class="tag">{t}</span>)}
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
      <div class="post-meta">
        <span>{post.data.author}</span>
        <span>·</span>
        <span>{formatDate(post.data.pubDate)}</span>
        <span>·</span>
        <span>{post.data.readTime}</span>
      </div>
    </div>
  </section>

  <!-- Article body -->
  <section class="post-body-section">
    <div class="container">
      <div class="post-layout">
        <article class="post-content prose">
          <Content />
        </article>

        <!-- Sidebar -->
        <aside class="post-sidebar">
          <div class="sidebar-card">
            <p class="sidebar-eyebrow">Have questions?</p>
            <h3 class="sidebar-title">Talk to our private companion</h3>
            <p class="sidebar-body">Ask anything about what you're experiencing — anonymously, any time.</p>
            <a href="/chat" class="btn btn-peach sidebar-btn">Start chatting →</a>
          </div>
          <div class="sidebar-card sidebar-quiz">
            <p class="sidebar-eyebrow">Not sure if it's perimenopause?</p>
            <h3 class="sidebar-title">Take the free symptom check</h3>
            <p class="sidebar-body">2 minutes. Instant personalised results.</p>
            <a href="/quiz" class="btn btn-outline sidebar-btn">Check my symptoms →</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="related-section">
      <div class="container">
        <p class="related-label">Keep reading</p>
        <div class="related-grid">
          {related.map(p => (
            <a href={`/blog/${p.slug}`} class="related-card">
              <div class="related-tags">
                {p.data.tags.slice(0,1).map(t => <span class="tag">{t}</span>)}
              </div>
              <h3 class="related-title">{p.data.title}</h3>
              <p class="related-meta">{p.data.readTime}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Layout>

<style>
  .post-hero {
    background: linear-gradient(150deg, #0F2A1A 0%, #1A3D2B 100%);
    padding: 4rem 0 3.5rem;
  }
  .back-link { font-size: .85rem; color: rgba(255,255,255,.6); text-decoration: none; font-weight: 500; display: inline-flex; margin-bottom: 1.5rem; transition: color .15s; }
  .back-link:hover { color: rgba(255,255,255,.9); }
  .post-tags { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .tag { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--green-light); background: rgba(255,255,255,.12); padding: .2rem .65rem; border-radius: 100px; }
  .post-title { font-size: clamp(1.7rem, 4vw, 2.6rem); font-weight: 900; letter-spacing: -.03em; color: #fff; line-height: 1.18; margin-bottom: 1rem; max-width: 760px; }
  .post-desc  { font-size: 1.05rem; color: rgba(255,255,255,.72); line-height: 1.72; max-width: 640px; margin-bottom: 1.25rem; }
  .post-meta  { font-size: .82rem; color: rgba(255,255,255,.5); display: flex; gap: .5rem; flex-wrap: wrap; }

  .post-body-section { padding: 4rem 0 5rem; background: #fff; }
  .post-layout { display: grid; grid-template-columns: 1fr 280px; gap: 4rem; align-items: start; }

  /* Prose styles */
  .prose { max-width: 680px; font-size: 1.02rem; line-height: 1.82; color: var(--text-secondary); }
  .prose :global(h2) { font-size: 1.45rem; font-weight: 800; color: var(--text); letter-spacing: -.025em; line-height: 1.25; margin: 2.5rem 0 .85rem; }
  .prose :global(h3) { font-size: 1.1rem; font-weight: 700; color: var(--text); margin: 1.75rem 0 .6rem; }
  .prose :global(p)  { margin-bottom: 1.2rem; }
  .prose :global(strong) { color: var(--text); font-weight: 700; }
  .prose :global(em) { font-style: italic; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.2rem; display: flex; flex-direction: column; gap: .4rem; }
  .prose :global(li) { margin-bottom: .2rem; }
  .prose :global(a)  { color: var(--green); text-decoration: underline; font-weight: 500; }
  .prose :global(a:hover) { color: var(--green-dark); }
  .prose :global(blockquote) { border-left: 3px solid var(--peach); padding-left: 1.25rem; margin: 1.5rem 0; font-style: italic; color: var(--text-secondary); }
  .prose :global(hr) { border: none; border-top: 1.5px solid var(--border); margin: 2.5rem 0; }

  /* Sidebar */
  .post-sidebar { display: flex; flex-direction: column; gap: 1.25rem; position: sticky; top: calc(var(--nav-h) + 1.5rem); }
  .sidebar-card { background: var(--cream-mid); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; display: flex; flex-direction: column; gap: .6rem; }
  .sidebar-quiz { background: var(--green-light); }
  .sidebar-eyebrow { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-muted); }
  .sidebar-title { font-size: 1rem; font-weight: 800; color: var(--text); line-height: 1.3; }
  .sidebar-body  { font-size: .84rem; color: var(--text-secondary); line-height: 1.6; }
  .sidebar-btn   { width: 100%; justify-content: center; margin-top: .25rem; }

  /* Related */
  .related-section { background: var(--cream-mid); padding: 3.5rem 0; }
  .related-label   { font-size: .76rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--text-muted); margin-bottom: 1.25rem; }
  .related-grid    { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  .related-card    { background: #fff; border: 1.5px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-decoration: none; color: var(--text); display: flex; flex-direction: column; gap: .5rem; transition: all .18s; }
  .related-card:hover { border-color: var(--green); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(61,122,95,.1); }
  .related-tags  { display: flex; gap: .4rem; }
  .related-title { font-size: .97rem; font-weight: 700; color: var(--text); line-height: 1.35; }
  .related-meta  { font-size: .76rem; color: var(--text-muted); }

  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; }
    .post-sidebar { position: static; flex-direction: row; }
    .related-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .post-sidebar { flex-direction: column; }
  }
</style>
