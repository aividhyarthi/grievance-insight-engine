---
import ElectionLayout from '../layouts/ElectionLayout.astro';
import electionData from '../data/elections2026.json';
import finData from '../data/stateFinances.json';

const { nationalParties, partyFinancials } = electionData;
const { promiseTracker, stateFinances, freebies } = finData;

// Pre-join all party data for the compare tool
const partyData = nationalParties.map(p => {
  const fin = partyFinancials.find(f => f.name === p.name);

  // Aggregate promises across states where this party rules
  let totalPromises = 0, fulfilled = 0, broken = 0;
  for (const [stateId, tracker] of Object.entries(promiseTracker)) {
    // Check if party name is contained in the ruling party string
    if (tracker.party.includes(p.name) || (p.name === 'INC' && tracker.party.includes('INC')) || (p.name === 'BJP' && tracker.party.includes('BJP'))) {
      totalPromises += tracker.totalPromises;
      fulfilled += tracker.fulfilled;
      broken += tracker.broken;
    }
  }

  return {
    ...p,
    fin,
    totalPromises,
    fulfilled,
    broken,
    fulfilledPct: totalPromises ? Math.round((fulfilled / totalPromises) * 100) : 0,
    brokenPct: totalPromises ? Math.round((broken / totalPromises) * 100) : 0
  };
});
---

<ElectionLayout title="Compare Parties | Election Pulse 2026">
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <div class="ep-badge">HEAD TO HEAD</div>
        <h1 class="ep-section-title" style="margin-top:1rem">Party vs Party</h1>
        <p class="ep-section-sub">Pick two parties. Compare everything. Money, promises, delivery, ideology. No spin.</p>
      </div>

      <!-- Party Selector -->
      <div class="cp-selector">
        <div class="cp-select-group">
          <label class="cp-label">Party A</label>
          <select id="cp-party-a" class="cp-select">
            {nationalParties.map((p, i) => (
              <option value={i} selected={i === 0}>{p.icon} {p.name} — {p.fullName}</option>
            ))}
          </select>
        </div>
        <div class="cp-vs">VS</div>
        <div class="cp-select-group">
          <label class="cp-label">Party B</label>
          <select id="cp-party-b" class="cp-select">
            {nationalParties.map((p, i) => (
              <option value={i} selected={i === 1}>{p.icon} {p.name} — {p.fullName}</option>
            ))}
          </select>
        </div>
      </div>

      <!-- Comparison Table -->
      <div class="cp-table" id="cp-table"></div>

    </div>
  </section>
</ElectionLayout>

<script define:vars={{ partyData }}>
  const selectA = document.getElementById('cp-party-a');
  const selectB = document.getElementById('cp-party-b');
  const table = document.getElementById('cp-table');

  function render() {
    const a = partyData[parseInt(selectA.value)];
    const b = partyData[parseInt(selectB.value)];

    const rows = [
      { label: 'Symbol', a: a.icon, b: b.icon, type: 'icon' },
      { label: 'Full Name', a: a.fullName, b: b.fullName },
      { label: 'Ideology', a: a.ideology, b: b.ideology },
      { label: 'Founded', a: a.founded, b: b.founded },
      { label: 'President', a: a.president, b: b.president },
      { label: 'Members', a: a.members, b: b.members },
      { label: 'HQ', a: a.hq, b: b.hq },
      { label: '── FINANCES ──', a: '', b: '', type: 'divider' },
      { label: 'Total Assets', a: a.fin?.totalAssets || 'N/A', b: b.fin?.totalAssets || 'N/A', type: 'money' },
      { label: 'Annual Income', a: a.fin?.annualIncome || 'N/A', b: b.fin?.annualIncome || 'N/A', type: 'money' },
      { label: 'Electoral Bonds', a: a.fin?.electoralBonds || 'N/A', b: b.fin?.electoralBonds || 'N/A', type: 'money' },
      { label: 'Donations', a: a.fin?.donations || 'N/A', b: b.fin?.donations || 'N/A', type: 'money' },
      { label: '── PROMISES ──', a: '', b: '', type: 'divider' },
      { label: 'Total Tracked', a: a.totalPromises || '—', b: b.totalPromises || '—' },
      { label: 'Fulfilled', a: a.totalPromises ? `${a.fulfilled} (${a.fulfilledPct}%)` : '—', b: b.totalPromises ? `${b.fulfilled} (${b.fulfilledPct}%)` : '—', type: 'good' },
      { label: 'Broken', a: a.totalPromises ? `${a.broken} (${a.brokenPct}%)` : '—', b: b.totalPromises ? `${b.broken} (${b.brokenPct}%)` : '—', type: 'bad' },
    ];

    table.innerHTML = `
      <div class="cp-head">
        <div class="cp-head-cell cp-head-label"></div>
        <div class="cp-head-cell cp-head-a" style="border-top-color:${a.color}">
          <span class="cp-head-icon">${a.icon}</span>
          <span class="cp-head-name">${a.name}</span>
        </div>
        <div class="cp-head-cell cp-head-b" style="border-top-color:${b.color}">
          <span class="cp-head-icon">${b.icon}</span>
          <span class="cp-head-name">${b.name}</span>
        </div>
      </div>
      ${rows.map(r => {
        if (r.type === 'divider') {
          return `<div class="cp-divider"><span>${r.label}</span></div>`;
        }
        const iconClass = r.type === 'icon' ? 'cp-icon-cell' : '';
        const moneyClass = r.type === 'money' ? 'cp-money' : '';
        const goodClass = r.type === 'good' ? 'cp-good' : '';
        const badClass = r.type === 'bad' ? 'cp-bad' : '';
        return `<div class="cp-row">
          <div class="cp-cell cp-cell-label">${r.label}</div>
          <div class="cp-cell cp-cell-a ${iconClass} ${moneyClass} ${goodClass} ${badClass}">${r.a}</div>
          <div class="cp-cell cp-cell-b ${iconClass} ${moneyClass} ${goodClass} ${badClass}">${r.b}</div>
        </div>`;
      }).join('')}
    `;
  }

  selectA?.addEventListener('change', render);
  selectB?.addEventListener('change', render);
  render();
</script>

<style is:global>
.cp-selector { display: flex; align-items: center; justify-content: center; gap: 1.5rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
.cp-select-group { display: flex; flex-direction: column; gap: 0.3rem; }
.cp-label { font-size: 0.7rem; font-weight: 700; color: var(--ep-text-muted); text-transform: uppercase; letter-spacing: 1px; }
.cp-select { font-family: var(--ep-font); font-size: 0.9rem; padding: 0.7rem 1rem; background: var(--ep-bg-card); color: var(--ep-text); border: 2px solid var(--ep-border); border-radius: var(--ep-radius-sm); outline: none; min-width: 260px; cursor: pointer; }
.cp-select:focus { border-color: var(--ep-accent); }
.cp-vs { font-family: var(--ep-font-display); font-size: 1.5rem; font-weight: 800; color: var(--ep-accent); }

.cp-table { max-width: 800px; margin: 0 auto; }

.cp-head { display: grid; grid-template-columns: 140px 1fr 1fr; gap: 2px; margin-bottom: 2px; }
.cp-head-cell { padding: 1rem; text-align: center; }
.cp-head-label { }
.cp-head-a, .cp-head-b { background: var(--ep-bg-card); border-radius: var(--ep-radius-sm) var(--ep-radius-sm) 0 0; border-top: 3px solid; }
.cp-head-icon { font-size: 2rem; display: block; }
.cp-head-name { font-family: var(--ep-font-display); font-size: 1.2rem; font-weight: 800; }

.cp-row { display: grid; grid-template-columns: 140px 1fr 1fr; gap: 2px; }
.cp-cell { padding: 0.7rem 1rem; font-size: 0.85rem; }
.cp-cell-label { color: var(--ep-text-muted); font-weight: 600; font-size: 0.8rem; display: flex; align-items: center; }
.cp-cell-a, .cp-cell-b { background: var(--ep-bg-card); text-align: center; font-weight: 500; }
.cp-icon-cell { font-size: 2rem; }
.cp-money { font-family: var(--ep-font-display); font-weight: 700; color: var(--ep-accent); }
.cp-good { color: #38a169; font-weight: 700; }
.cp-bad { color: #e53e3e; font-weight: 700; }

.cp-divider { padding: 0.8rem 0 0.4rem; }
.cp-divider span { font-size: 0.7rem; font-weight: 700; letter-spacing: 2px; color: var(--ep-text-muted); }

@media (max-width: 768px) {
  .cp-select { min-width: 200px; font-size: 0.8rem; }
  .cp-head, .cp-row { grid-template-columns: 100px 1fr 1fr; }
  .cp-cell { padding: 0.5rem 0.6rem; font-size: 0.75rem; }
}
</style>
