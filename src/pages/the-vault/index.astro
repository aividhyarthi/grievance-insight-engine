---
// The Vault — A 2am companion for men who need to be heard.
// No therapy. No fixing. Just space. Just talk.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="description" content="A private, anonymous space for men who need to be heard. No therapy. No fixing. Just space." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>The Vault — Just Talk</title>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #0a0a0b;
        --bg-card: #111113;
        --bg-input: #161618;
        --bg-hover: #1a1a1d;
        --bg-user: #1c1c2e;
        --bg-echo: #111113;
        --border: #222225;
        --border-focus: #333338;
        --text: #e4e4e7;
        --text-dim: #71717a;
        --text-muted: #52525b;
        --accent: #6366f1;
        --accent-dim: rgba(99, 102, 241, 0.15);
        --accent-glow: rgba(99, 102, 241, 0.3);
        --feeling-bg: rgba(99, 102, 241, 0.08);
        --feeling-border: rgba(99, 102, 241, 0.2);
        --danger: #ef4444;
        --danger-dim: rgba(239, 68, 68, 0.1);
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
        --radius: 16px;
        --radius-sm: 10px;
        --transition: 0.2s ease;
      }

      /* 2AM Mode */
      .mode-2am {
        --bg: #08070a;
        --bg-card: #0e0d11;
        --bg-input: #13121a;
        --bg-user: #17162a;
        --bg-echo: #0e0d11;
        --border: #1e1d26;
        --accent: #818cf8;
        --accent-dim: rgba(129, 140, 248, 0.12);
        --text: #d4d4dc;
        --text-dim: #6b6b7b;
      }

      html, body {
        height: 100%;
        overflow: hidden;
      }

      body {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        transition: background 0.5s ease, color 0.3s ease;
      }

      /* ---- Full-screen chat layout ---- */
      .vault-app {
        display: flex;
        flex-direction: column;
        height: 100vh;
        height: 100dvh;
        max-width: 720px;
        margin: 0 auto;
      }

      /* ---- Header ---- */
      .vault-header {
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
        background: var(--bg);
        z-index: 10;
      }

      .vault-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--text);
      }

      .vault-logo-icon {
        width: 32px;
        height: 32px;
        background: var(--accent-dim);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
      }

      .vault-logo-text {
        font-size: 15px;
        font-weight: 600;
        letter-spacing: -0.02em;
      }

      .vault-logo-text span {
        color: var(--text-dim);
        font-weight: 400;
      }

      .header-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .mode-indicator {
        font-size: 10px;
        font-family: var(--font-mono);
        color: var(--text-muted);
        padding: 3px 8px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
      }

      .btn-icon {
        width: 34px;
        height: 34px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text-dim);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        transition: all var(--transition);
      }

      .btn-icon:hover {
        border-color: var(--border-focus);
        color: var(--text);
      }

      .btn-icon.active {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }

      /* ---- Chat area ---- */
      .chat-area {
        flex: 1;
        overflow-y: auto;
        padding: 20px 20px 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        scroll-behavior: smooth;
      }

      /* Welcome message */
      .welcome {
        text-align: center;
        padding: 60px 20px 40px;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .welcome h1 {
        font-size: 26px;
        font-weight: 600;
        letter-spacing: -0.03em;
        margin-bottom: 12px;
      }

      .welcome p {
        font-size: 14px;
        color: var(--text-dim);
        max-width: 400px;
        line-height: 1.7;
      }

      .welcome .tagline {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 16px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .welcome .starters {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
        margin-top: 28px;
        max-width: 480px;
      }

      .welcome .starter-chip {
        font-family: var(--font-sans);
        font-size: 12px;
        color: var(--text-dim);
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 8px 14px;
        border-radius: 20px;
        cursor: pointer;
        transition: all var(--transition);
        white-space: nowrap;
      }

      .welcome .starter-chip:hover {
        border-color: var(--accent);
        color: var(--text);
        background: var(--accent-dim);
      }

      /* Chat bubbles */
      .msg-row {
        display: flex;
        animation: fadeIn 0.3s ease;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .msg-row.user {
        justify-content: flex-end;
      }

      .msg-row.echo {
        justify-content: flex-start;
      }

      .msg-bubble {
        max-width: 80%;
        padding: 12px 16px;
        font-size: 14px;
        line-height: 1.7;
        word-wrap: break-word;
      }

      .msg-row.user .msg-bubble {
        background: var(--bg-user);
        border: 1px solid rgba(99, 102, 241, 0.15);
        border-radius: var(--radius) var(--radius) 4px var(--radius);
        color: var(--text);
      }

      .msg-row.echo .msg-bubble {
        background: var(--bg-echo);
        border: 1px solid var(--border);
        border-radius: var(--radius) var(--radius) var(--radius) 4px;
        color: var(--text);
      }

      .msg-sender {
        font-size: 11px;
        color: var(--text-muted);
        margin-bottom: 4px;
        padding: 0 4px;
      }

      /* Typing indicator */
      .typing-row {
        display: flex;
        justify-content: flex-start;
        animation: fadeIn 0.3s ease;
      }

      .typing-bubble {
        background: var(--bg-echo);
        border: 1px solid var(--border);
        border-radius: var(--radius) var(--radius) var(--radius) 4px;
        padding: 14px 20px;
        display: flex;
        gap: 5px;
        align-items: center;
      }

      .typing-dot {
        width: 6px;
        height: 6px;
        background: var(--text-muted);
        border-radius: 50%;
        animation: typingBounce 1.2s ease-in-out infinite;
      }

      .typing-dot:nth-child(2) { animation-delay: 0.2s; }
      .typing-dot:nth-child(3) { animation-delay: 0.4s; }

      @keyframes typingBounce {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
        30% { transform: translateY(-4px); opacity: 1; }
      }

      /* Session divider */
      .session-divider {
        text-align: center;
        padding: 12px 0;
      }

      .session-divider span {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--text-muted);
        background: var(--bg);
        padding: 0 12px;
        position: relative;
      }

      /* ---- Input bar (bottom) ---- */
      .input-bar {
        padding: 12px 20px 16px;
        border-top: 1px solid var(--border);
        background: var(--bg);
        flex-shrink: 0;
      }

      .input-row {
        display: flex;
        gap: 10px;
        align-items: flex-end;
      }

      .input-field {
        flex: 1;
        padding: 12px 16px;
        font-family: var(--font-sans);
        font-size: 14px;
        line-height: 1.5;
        color: var(--text);
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        resize: none;
        outline: none;
        min-height: 44px;
        max-height: 150px;
        overflow-y: auto;
        transition: border-color var(--transition), box-shadow var(--transition);
      }

      .input-field::placeholder {
        color: var(--text-muted);
      }

      .input-field:focus {
        border-color: var(--border-focus);
        box-shadow: 0 0 0 3px var(--accent-dim);
      }

      .send-btn {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-sm);
        border: none;
        background: var(--accent);
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        transition: all var(--transition);
        flex-shrink: 0;
      }

      .send-btn:hover {
        filter: brightness(1.15);
        box-shadow: 0 0 16px var(--accent-glow);
      }

      .send-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        filter: none;
        box-shadow: none;
      }

      .send-btn svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
      }

      .input-hint {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--text-muted);
        margin-top: 6px;
        padding: 0 4px;
        display: flex;
        justify-content: space-between;
      }

      /* ---- New chat button ---- */
      .new-chat-btn {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--text-muted);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        transition: color var(--transition);
      }

      .new-chat-btn:hover {
        color: var(--accent);
      }

      /* ---- Archive sidebar ---- */
      .archive-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        z-index: 99;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }

      .archive-overlay.open {
        opacity: 1;
        pointer-events: all;
      }

      .archive-panel {
        position: fixed;
        top: 0;
        right: -360px;
        width: 340px;
        max-width: 85vw;
        height: 100vh;
        background: var(--bg-card);
        border-left: 1px solid var(--border);
        z-index: 100;
        transition: right 0.3s ease;
        display: flex;
        flex-direction: column;
      }

      .archive-panel.open {
        right: 0;
      }

      .archive-panel-header {
        padding: 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .archive-panel-title {
        font-size: 14px;
        font-weight: 600;
      }

      .archive-close {
        width: 30px;
        height: 30px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--bg);
        color: var(--text-dim);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
      }

      .archive-panel-body {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
      }

      .archive-session {
        margin-bottom: 16px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 12px;
        cursor: pointer;
        transition: border-color var(--transition);
      }

      .archive-session:hover {
        border-color: var(--border-focus);
      }

      .archive-session-time {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--text-muted);
        margin-bottom: 6px;
      }

      .archive-session-preview {
        font-size: 12px;
        color: var(--text-dim);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .archive-session-count {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--text-muted);
        margin-top: 6px;
      }

      .archive-empty {
        text-align: center;
        padding: 40px 20px;
        color: var(--text-muted);
        font-size: 12px;
        font-family: var(--font-mono);
      }

      .archive-panel-footer {
        padding: 12px 16px;
        border-top: 1px solid var(--border);
      }

      .archive-clear-btn {
        width: 100%;
        padding: 8px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--danger);
        background: var(--danger-dim);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 6px;
        cursor: pointer;
        transition: all var(--transition);
      }

      .archive-clear-btn:hover {
        background: rgba(239, 68, 68, 0.15);
      }

      /* ---- Footer (inside chat) ---- */
      .vault-footer {
        text-align: center;
        padding: 8px 20px 12px;
        flex-shrink: 0;
      }

      .vault-footer p {
        font-size: 10px;
        color: var(--text-muted);
        font-family: var(--font-mono);
        line-height: 1.6;
      }

      .vault-footer a {
        color: var(--text-dim);
        text-decoration: none;
      }

      .vault-footer a:hover {
        color: var(--accent);
      }

      /* ---- Responsive ---- */
      @media (max-width: 600px) {
        .welcome h1 { font-size: 22px; }
        .welcome p { font-size: 13px; }
        .vault-header { padding: 12px 16px; }
        .chat-area { padding: 16px 12px 8px; }
        .input-bar { padding: 10px 12px 12px; }
        .msg-bubble { max-width: 88%; font-size: 13px; }
        .archive-panel { width: 300px; }
      }

      /* ---- Scrollbar ---- */
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--border-focus); }

      .hidden { display: none !important; }
    </style>
  </head>
  <body>
    <div class="vault-app">

      <!-- Header -->
      <header class="vault-header">
        <a href="/the-vault" class="vault-logo">
          <div class="vault-logo-icon">&#9670;</div>
          <div class="vault-logo-text">The Vault <span>/ just talk</span></div>
        </a>
        <div class="header-right">
          <span class="mode-indicator" id="modeIndicator">--:--</span>
          <button class="btn-icon" id="archiveToggle" title="Past conversations" aria-label="Open archive">&#9776;</button>
        </div>
      </header>

      <!-- Chat area -->
      <div class="chat-area" id="chatArea">
        <div class="welcome" id="welcomeScreen">
          <h1>Say what's on your mind.</h1>
          <p>No judgement. No fixing. No one sees this but you.<br/>Just talk. I'll listen.</p>
          <div class="tagline">Anonymous. Private. Yours.</div>
          <div class="starters">
            <button class="starter-chip" data-msg="I can't sleep and my mind won't stop">Can't sleep</button>
            <button class="starter-chip" data-msg="I feel alone even though I'm not physically alone">Feeling alone</button>
            <button class="starter-chip" data-msg="I don't even know what I'm feeling right now">Don't know what I feel</button>
            <button class="starter-chip" data-msg="I'm going through a breakup and it's hitting hard">Going through a breakup</button>
            <button class="starter-chip" data-msg="I keep asking myself... is this it?">Is this it?</button>
          </div>
        </div>
      </div>

      <!-- Input bar -->
      <div class="input-bar">
        <div class="input-row">
          <textarea
            class="input-field"
            id="chatInput"
            placeholder="Say anything..."
            rows="1"
            aria-label="Type your message"
          ></textarea>
          <button class="send-btn" id="sendBtn" disabled aria-label="Send">
            <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </button>
        </div>
        <div class="input-hint">
          <span id="inputHint">Enter to send &middot; Shift+Enter for new line</span>
          <button class="new-chat-btn" id="newChatBtn">new chat</button>
        </div>
      </div>

      <!-- Footer -->
      <footer class="vault-footer">
        <p>
          Not therapy. Just space. &middot; <a href="/">Rudra Kasturi</a> &middot;
          Crisis? <a href="tel:988">988</a> (US) &middot; <a href="tel:13 11 14">13 11 14</a> (AU) &middot; <a href="tel:116 123">116 123</a> (UK)
        </p>
      </footer>
    </div>

    <!-- Archive panel -->
    <div class="archive-overlay" id="archiveOverlay"></div>
    <div class="archive-panel" id="archivePanel">
      <div class="archive-panel-header">
        <span class="archive-panel-title">Past Conversations</span>
        <button class="archive-close" id="archiveClose">&times;</button>
      </div>
      <div class="archive-panel-body" id="archiveBody"></div>
      <div class="archive-panel-footer">
        <button class="archive-clear-btn" id="archiveClear">Clear All Conversations</button>
      </div>
    </div>

    <script>
      // =============================================
      // THE VAULT — Chat Experience
      // =============================================

      const $ = (sel) => document.querySelector(sel);
      const body = document.body;
      const chatArea = $('#chatArea');
      const welcomeScreen = $('#welcomeScreen');
      const chatInput = $('#chatInput');
      const sendBtn = $('#sendBtn');
      const inputHint = $('#inputHint');
      const modeIndicator = $('#modeIndicator');
      const newChatBtn = $('#newChatBtn');

      // Archive elements
      const archiveToggle = $('#archiveToggle');
      const archiveOverlay = $('#archiveOverlay');
      const archivePanel = $('#archivePanel');
      const archiveClose = $('#archiveClose');
      const archiveBody = $('#archiveBody');
      const archiveClear = $('#archiveClear');

      // Current conversation
      let conversation = []; // {role: 'user'|'echo', text, feeling?}
      let sessionId = Date.now().toString(36);

      // ---- 2AM Mode ----
      function check2amMode() {
        const hour = new Date().getHours();
        const is2am = hour >= 22 || hour < 5;
        body.classList.toggle('mode-2am', is2am);
        modeIndicator.textContent = is2am ? '2am mode' : formatTime();
      }

      function formatTime() {
        const now = new Date();
        return now.getHours().toString().padStart(2, '0') + ':' +
               now.getMinutes().toString().padStart(2, '0');
      }

      check2amMode();
      setInterval(check2amMode, 60000);

      // ---- Auto-resize textarea ----
      chatInput.addEventListener('input', () => {
        chatInput.style.height = 'auto';
        chatInput.style.height = Math.min(chatInput.scrollHeight, 150) + 'px';
        sendBtn.disabled = !chatInput.value.trim();
      });

      // ---- Send message ----
      async function sendMessage(text) {
        if (!text || !text.trim()) return;
        text = text.trim();

        // Hide welcome
        if (welcomeScreen) {
          welcomeScreen.remove();
        }

        // Add user bubble
        addBubble('user', text);
        conversation.push({ role: 'user', text });

        // Clear input
        chatInput.value = '';
        chatInput.style.height = 'auto';
        sendBtn.disabled = true;

        // Show typing indicator
        const typingEl = showTyping();

        try {
          const res = await fetch('/api/echo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              message: text,
              conversation: conversation.slice(-10), // send recent context
            }),
          });

          const data = await res.json();

          // Remove typing
          typingEl.remove();

          // Add echo bubble
          addBubble('echo', data.echo);
          conversation.push({ role: 'echo', text: data.echo });

          // Save session
          saveSession();

        } catch (err) {
          typingEl.remove();
          addBubble('echo', "Something went wrong on my end. Try sending that again.");
          console.error('Echo error:', err);
        }
      }

      function addBubble(role, text) {
        const row = document.createElement('div');
        row.className = `msg-row ${role}`;

        const sender = role === 'user' ? 'You' : 'Vault';
        let html = `<div><div class="msg-sender">${sender}</div>`;
        html += '<div class="msg-bubble">';
        html += escapeHtml(text);
        html += '</div></div>';

        row.innerHTML = html;
        chatArea.appendChild(row);
        scrollToBottom();
      }

      function showTyping() {
        const row = document.createElement('div');
        row.className = 'typing-row';
        row.innerHTML = `
          <div class="typing-bubble">
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
          </div>
        `;
        chatArea.appendChild(row);
        scrollToBottom();
        return row;
      }

      function scrollToBottom() {
        requestAnimationFrame(() => {
          chatArea.scrollTop = chatArea.scrollHeight;
        });
      }

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      // ---- Event listeners ----
      sendBtn.addEventListener('click', () => sendMessage(chatInput.value));

      chatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage(chatInput.value);
        }
      });

      // Starter chips
      document.querySelectorAll('.starter-chip').forEach(chip => {
        chip.addEventListener('click', () => {
          sendMessage(chip.dataset.msg);
        });
      });

      // New chat
      newChatBtn.addEventListener('click', () => {
        if (conversation.length > 0) {
          saveSession();
        }
        conversation = [];
        sessionId = Date.now().toString(36);
        chatArea.innerHTML = `
          <div class="welcome" id="welcomeScreen">
            <h1>Say what's on your mind.</h1>
            <p>No judgement. No fixing. No one sees this but you.<br/>Just talk. I'll listen.</p>
            <div class="tagline">Anonymous. Private. Yours.</div>
            <div class="starters">
              <button class="starter-chip" data-msg="I can't sleep and my mind won't stop">Can't sleep</button>
              <button class="starter-chip" data-msg="I feel alone even though I'm not physically alone">Feeling alone</button>
              <button class="starter-chip" data-msg="I don't even know what I'm feeling right now">Don't know what I feel</button>
              <button class="starter-chip" data-msg="I'm going through a breakup and it's hitting hard">Going through a breakup</button>
              <button class="starter-chip" data-msg="I keep asking myself... is this it?">Is this it?</button>
            </div>
          </div>
        `;
        // Re-bind starter chips
        document.querySelectorAll('.starter-chip').forEach(chip => {
          chip.addEventListener('click', () => sendMessage(chip.dataset.msg));
        });
        chatInput.focus();
      });

      // ---- Archive (localStorage) ----
      const STORAGE_KEY = 'vault_sessions';

      function getSessions() {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        } catch { return []; }
      }

      function saveSession() {
        if (conversation.length === 0) return;
        const sessions = getSessions();
        // Update existing or create new
        const idx = sessions.findIndex(s => s.id === sessionId);
        const sessionData = {
          id: sessionId,
          messages: conversation,
          time: new Date().toLocaleDateString('en-US', {
            month: 'short', day: 'numeric',
            hour: '2-digit', minute: '2-digit', hour12: true,
          }),
          timestamp: Date.now(),
          preview: conversation.find(m => m.role === 'user')?.text || '',
        };

        if (idx >= 0) {
          sessions[idx] = sessionData;
        } else {
          sessions.unshift(sessionData);
        }
        // Keep last 50 sessions
        if (sessions.length > 50) sessions.length = 50;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(sessions));
      }

      function renderArchive() {
        const sessions = getSessions();
        if (sessions.length === 0) {
          archiveBody.innerHTML = '<div class="archive-empty">No conversations yet.<br/>Your words are waiting.</div>';
          return;
        }

        archiveBody.innerHTML = sessions.map(s => `
          <div class="archive-session" data-id="${s.id}">
            <div class="archive-session-time">${escapeHtml(s.time)}</div>
            <div class="archive-session-preview">${escapeHtml(s.preview)}</div>
            <div class="archive-session-count">${s.messages.length} messages</div>
          </div>
        `).join('');

        // Click to load session
        archiveBody.querySelectorAll('.archive-session').forEach(el => {
          el.addEventListener('click', () => {
            const id = el.dataset.id;
            const session = sessions.find(s => s.id === id);
            if (session) loadSession(session);
          });
        });
      }

      function loadSession(session) {
        // Save current session first
        if (conversation.length > 0) saveSession();

        // Load the selected session
        sessionId = session.id;
        conversation = session.messages;

        // Clear chat area and render messages
        chatArea.innerHTML = '';
        conversation.forEach(msg => {
          addBubble(msg.role, msg.text);
        });

        closeArchive();
        scrollToBottom();
        chatInput.focus();
      }

      // Archive open/close
      function openArchive() {
        renderArchive();
        archivePanel.classList.add('open');
        archiveOverlay.classList.add('open');
        archiveToggle.classList.add('active');
      }

      function closeArchive() {
        archivePanel.classList.remove('open');
        archiveOverlay.classList.remove('open');
        archiveToggle.classList.remove('active');
      }

      archiveToggle.addEventListener('click', () => {
        if (archivePanel.classList.contains('open')) {
          closeArchive();
        } else {
          openArchive();
        }
      });

      archiveClose.addEventListener('click', closeArchive);
      archiveOverlay.addEventListener('click', closeArchive);

      archiveClear.addEventListener('click', () => {
        if (confirm('Clear all past conversations? This cannot be undone.')) {
          localStorage.removeItem(STORAGE_KEY);
          renderArchive();
        }
      });

      // ---- Init ----
      chatInput.focus();
    </script>
  </body>
</html>
