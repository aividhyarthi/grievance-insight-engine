---
// The Vault — A 2am companion for men who need to be heard.
// No therapy. No fixing. Just space.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A private, anonymous space for men who need to be heard. No therapy. No fixing. Just space." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>The Vault — Say what's on your mind</title>
    <style>
      /* ========================================
         THE VAULT — CSS
         Dark, minimal, 2am-friendly
         ======================================== */

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #0a0a0b;
        --bg-card: #111113;
        --bg-input: #161618;
        --bg-hover: #1a1a1d;
        --border: #222225;
        --border-focus: #333338;
        --text: #e4e4e7;
        --text-dim: #71717a;
        --text-muted: #52525b;
        --accent: #6366f1;
        --accent-dim: rgba(99, 102, 241, 0.15);
        --accent-glow: rgba(99, 102, 241, 0.3);
        --feeling-bg: rgba(99, 102, 241, 0.08);
        --feeling-border: rgba(99, 102, 241, 0.2);
        --danger: #ef4444;
        --danger-dim: rgba(239, 68, 68, 0.1);
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
        --radius: 12px;
        --radius-sm: 8px;
        --transition: 0.2s ease;
      }

      /* 2AM Mode — softer, warmer */
      .mode-2am {
        --bg: #08070a;
        --bg-card: #0e0d11;
        --bg-input: #13121a;
        --border: #1e1d26;
        --accent: #818cf8;
        --accent-dim: rgba(129, 140, 248, 0.12);
        --text: #d4d4dc;
        --text-dim: #6b6b7b;
      }

      body {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        transition: background 0.5s ease, color 0.3s ease;
      }

      /* ---- Layout ---- */
      .vault-container {
        max-width: 680px;
        margin: 0 auto;
        padding: 0 20px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ---- Header ---- */
      .vault-header {
        padding: 32px 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--border);
      }

      .vault-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--text);
      }

      .vault-logo-icon {
        width: 32px;
        height: 32px;
        background: var(--accent-dim);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
      }

      .vault-logo-text {
        font-size: 16px;
        font-weight: 600;
        letter-spacing: -0.02em;
      }

      .vault-logo-text span {
        color: var(--text-dim);
        font-weight: 400;
      }

      .vault-header-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .vault-btn-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text-dim);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        transition: all var(--transition);
      }

      .vault-btn-icon:hover {
        border-color: var(--border-focus);
        color: var(--text);
        background: var(--bg-hover);
      }

      .vault-btn-icon.active {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }

      .mode-indicator {
        font-size: 11px;
        font-family: var(--font-mono);
        color: var(--text-muted);
        padding: 4px 8px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
      }

      /* ---- Hero / Intro ---- */
      .vault-hero {
        padding: 48px 0 32px;
        text-align: center;
      }

      .vault-hero h1 {
        font-size: 28px;
        font-weight: 600;
        letter-spacing: -0.03em;
        margin-bottom: 12px;
        color: var(--text);
      }

      .vault-hero p {
        font-size: 15px;
        color: var(--text-dim);
        max-width: 440px;
        margin: 0 auto;
        line-height: 1.7;
      }

      .vault-hero .tagline {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 16px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      /* ---- The Dump (input area) ---- */
      .dump-section {
        flex: 1;
        padding: 24px 0;
      }

      .dump-box {
        position: relative;
      }

      .dump-textarea {
        width: 100%;
        min-height: 160px;
        max-height: 400px;
        padding: 20px;
        font-family: var(--font-sans);
        font-size: 15px;
        line-height: 1.7;
        color: var(--text);
        background: var(--bg-input);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        resize: vertical;
        outline: none;
        transition: border-color var(--transition), box-shadow var(--transition);
      }

      .dump-textarea::placeholder {
        color: var(--text-muted);
      }

      .dump-textarea:focus {
        border-color: var(--border-focus);
        box-shadow: 0 0 0 3px var(--accent-dim);
      }

      .dump-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 12px;
      }

      .dump-hint {
        font-size: 12px;
        font-family: var(--font-mono);
        color: var(--text-muted);
      }

      .dump-submit {
        padding: 10px 24px;
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 500;
        color: #fff;
        background: var(--accent);
        border: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: all var(--transition);
        position: relative;
        overflow: hidden;
      }

      .dump-submit:hover {
        filter: brightness(1.1);
        box-shadow: 0 0 20px var(--accent-glow);
      }

      .dump-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        filter: none;
        box-shadow: none;
      }

      .dump-submit.loading {
        color: transparent;
      }

      .dump-submit.loading::after {
        content: '';
        position: absolute;
        width: 18px;
        height: 18px;
        top: 50%;
        left: 50%;
        margin-top: -9px;
        margin-left: -9px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      /* ---- The Echo (AI response) ---- */
      .echo-section {
        padding: 0 0 32px;
        animation: fadeUp 0.4s ease;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .echo-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
      }

      .echo-label {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 12px;
      }

      .echo-text {
        font-size: 16px;
        line-height: 1.8;
        color: var(--text);
      }

      .echo-feeling {
        margin-top: 16px;
        padding: 10px 14px;
        background: var(--feeling-bg);
        border: 1px solid var(--feeling-border);
        border-radius: var(--radius-sm);
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--accent);
      }

      .echo-feeling strong {
        color: var(--text-dim);
        font-weight: 400;
        margin-right: 6px;
      }

      /* ---- Archive ---- */
      .archive-section {
        padding: 24px 0 48px;
        border-top: 1px solid var(--border);
      }

      .archive-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
      }

      .archive-title {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-dim);
      }

      .archive-count {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
      }

      .archive-clear {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--danger);
        background: var(--danger-dim);
        border: 1px solid rgba(239, 68, 68, 0.2);
        padding: 4px 10px;
        border-radius: 4px;
        cursor: pointer;
        transition: all var(--transition);
      }

      .archive-clear:hover {
        background: rgba(239, 68, 68, 0.15);
      }

      .archive-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .archive-item {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 16px;
        transition: border-color var(--transition);
      }

      .archive-item:hover {
        border-color: var(--border-focus);
      }

      .archive-item-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
      }

      .archive-item-time {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
      }

      .archive-item-feeling {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--accent);
        background: var(--accent-dim);
        padding: 2px 6px;
        border-radius: 3px;
      }

      .archive-item-message {
        font-size: 13px;
        color: var(--text-dim);
        line-height: 1.6;
        margin-bottom: 8px;
      }

      .archive-item-echo {
        font-size: 13px;
        color: var(--text);
        line-height: 1.6;
        padding-left: 12px;
        border-left: 2px solid var(--accent-dim);
      }

      .archive-empty {
        text-align: center;
        padding: 32px;
        color: var(--text-muted);
        font-size: 13px;
        font-family: var(--font-mono);
      }

      /* ---- Footer ---- */
      .vault-footer {
        padding: 24px 0;
        border-top: 1px solid var(--border);
        text-align: center;
      }

      .vault-footer p {
        font-size: 12px;
        color: var(--text-muted);
        font-family: var(--font-mono);
        line-height: 1.8;
      }

      .vault-footer a {
        color: var(--text-dim);
        text-decoration: none;
      }

      .vault-footer a:hover {
        color: var(--accent);
      }

      .vault-footer .crisis-line {
        margin-top: 8px;
        font-size: 11px;
        color: var(--text-muted);
      }

      .vault-footer .crisis-line a {
        color: var(--accent);
      }

      /* ---- Responsive ---- */
      @media (max-width: 600px) {
        .vault-hero h1 { font-size: 22px; }
        .vault-hero p { font-size: 14px; }
        .dump-textarea { min-height: 120px; font-size: 14px; }
        .echo-text { font-size: 15px; }
        .vault-header { padding: 20px 0 16px; }
        .vault-hero { padding: 32px 0 20px; }
      }

      /* ---- Scrollbar ---- */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--border-focus); }

      /* ---- Hidden utility ---- */
      .hidden { display: none !important; }
    </style>
  </head>
  <body>
    <div class="vault-container">

      <!-- Header -->
      <header class="vault-header">
        <a href="/the-vault" class="vault-logo">
          <div class="vault-logo-icon">&#9670;</div>
          <div class="vault-logo-text">The Vault <span>/ just talk</span></div>
        </a>
        <div class="vault-header-actions">
          <span class="mode-indicator" id="modeIndicator">--:--</span>
          <button class="vault-btn-icon" id="archiveToggle" title="Your Archive" aria-label="Toggle archive">&#9776;</button>
        </div>
      </header>

      <!-- Hero -->
      <section class="vault-hero" id="heroSection">
        <h1>Say what's on your mind.</h1>
        <p>No judgement. No advice unless you want it. No one sees this but you. Just get it out.</p>
        <div class="tagline">Anonymous. Private. Yours.</div>
      </section>

      <!-- The Dump -->
      <section class="dump-section">
        <div class="dump-box">
          <textarea
            class="dump-textarea"
            id="dumpInput"
            placeholder="Whatever you're feeling right now... just start typing. There's no wrong thing to say here."
            aria-label="Write what's on your mind"
          ></textarea>
          <div class="dump-actions">
            <span class="dump-hint" id="dumpHint">Just you and this box.</span>
            <button class="dump-submit" id="dumpSubmit">Let it out</button>
          </div>
        </div>
      </section>

      <!-- The Echo (AI Response) -->
      <section class="echo-section hidden" id="echoSection">
        <div class="echo-card">
          <div class="echo-label">&#9672; The Echo</div>
          <div class="echo-text" id="echoText"></div>
          <div class="echo-feeling hidden" id="echoFeeling">
            <strong>This sounds like:</strong>
            <span id="echoFeelingName"></span>
          </div>
        </div>
      </section>

      <!-- Archive -->
      <section class="archive-section hidden" id="archiveSection">
        <div class="archive-header">
          <div>
            <span class="archive-title">Your Archive</span>
            <span class="archive-count" id="archiveCount"></span>
          </div>
          <button class="archive-clear hidden" id="archiveClear">Clear All</button>
        </div>
        <div class="archive-list" id="archiveList">
          <div class="archive-empty">Nothing here yet. Your words are waiting.</div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="vault-footer">
        <p>
          The Vault is not therapy. It's a space to be heard.<br/>
          Built by <a href="/">Rudra Kasturi</a> &mdash; because men deserve space too.
        </p>
        <p class="crisis-line">
          If you're in crisis: <a href="tel:988">988 Suicide & Crisis Lifeline</a> (US) &bull;
          <a href="tel:13 11 14">13 11 14</a> (AU) &bull;
          <a href="tel:116 123">116 123</a> (UK)
        </p>
      </footer>
    </div>

    <script>
      // =============================================
      // THE VAULT — Client-side logic
      // =============================================

      const $ = (sel) => document.querySelector(sel);
      const $$ = (sel) => document.querySelectorAll(sel);

      // Elements
      const body = document.body;
      const input = $('#dumpInput');
      const submitBtn = $('#dumpSubmit');
      const hint = $('#dumpHint');
      const echoSection = $('#echoSection');
      const echoText = $('#echoText');
      const echoFeeling = $('#echoFeeling');
      const echoFeelingName = $('#echoFeelingName');
      const archiveToggle = $('#archiveToggle');
      const archiveSection = $('#archiveSection');
      const archiveList = $('#archiveList');
      const archiveCount = $('#archiveCount');
      const archiveClear = $('#archiveClear');
      const modeIndicator = $('#modeIndicator');
      const heroSection = $('#heroSection');

      // ---- 2AM Mode Detection ----
      function check2amMode() {
        const hour = new Date().getHours();
        const is2am = hour >= 22 || hour < 5; // 10pm to 5am
        body.classList.toggle('mode-2am', is2am);
        modeIndicator.textContent = is2am ? '2am mode' : formatTime();
      }

      function formatTime() {
        const now = new Date();
        return now.getHours().toString().padStart(2, '0') + ':' +
               now.getMinutes().toString().padStart(2, '0');
      }

      check2amMode();
      setInterval(check2amMode, 60000); // check every minute
      setInterval(() => {
        if (!body.classList.contains('mode-2am')) {
          modeIndicator.textContent = formatTime();
        }
      }, 30000);

      // ---- Archive (localStorage) ----
      const STORAGE_KEY = 'vault_archive';

      function getArchive() {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        } catch {
          return [];
        }
      }

      function saveToArchive(entry) {
        const archive = getArchive();
        archive.unshift(entry);
        // Keep last 100 entries
        if (archive.length > 100) archive.length = 100;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(archive));
      }

      function clearArchive() {
        localStorage.removeItem(STORAGE_KEY);
        renderArchive();
      }

      function renderArchive() {
        const archive = getArchive();
        archiveCount.textContent = archive.length > 0 ? `(${archive.length})` : '';

        if (archive.length === 0) {
          archiveList.innerHTML = '<div class="archive-empty">Nothing here yet. Your words are waiting.</div>';
          archiveClear.classList.add('hidden');
          return;
        }

        archiveClear.classList.remove('hidden');
        archiveList.innerHTML = archive.map(entry => `
          <div class="archive-item">
            <div class="archive-item-meta">
              <span class="archive-item-time">${entry.time}</span>
              ${entry.feeling ? `<span class="archive-item-feeling">${entry.feeling}</span>` : ''}
            </div>
            <div class="archive-item-message">${escapeHtml(entry.message.length > 200 ? entry.message.slice(0, 200) + '...' : entry.message)}</div>
            <div class="archive-item-echo">${escapeHtml(entry.echo)}</div>
          </div>
        `).join('');
      }

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      // ---- Archive Toggle ----
      let archiveOpen = false;
      archiveToggle.addEventListener('click', () => {
        archiveOpen = !archiveOpen;
        archiveSection.classList.toggle('hidden', !archiveOpen);
        archiveToggle.classList.toggle('active', archiveOpen);
        if (archiveOpen) renderArchive();
      });

      archiveClear.addEventListener('click', () => {
        if (confirm('Clear your entire archive? This cannot be undone.')) {
          clearArchive();
        }
      });

      // ---- Submit / The Dump ----
      async function submitDump() {
        const message = input.value.trim();
        if (!message) return;

        // UI: loading state
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');
        hint.textContent = 'Listening...';

        try {
          const res = await fetch('/api/echo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message }),
          });

          const data = await res.json();

          // Show echo
          echoText.textContent = data.echo;
          echoSection.classList.remove('hidden');

          if (data.feeling) {
            echoFeelingName.textContent = data.feeling;
            echoFeeling.classList.remove('hidden');
          } else {
            echoFeeling.classList.add('hidden');
          }

          // Hide hero after first use
          heroSection.style.display = 'none';

          // Save to archive
          const now = new Date();
          saveToArchive({
            message,
            echo: data.echo,
            feeling: data.feeling || null,
            time: now.toLocaleDateString('en-US', {
              month: 'short', day: 'numeric',
              hour: '2-digit', minute: '2-digit',
              hour12: true,
            }),
            timestamp: now.getTime(),
          });

          // Update archive count
          const archive = getArchive();
          archiveCount.textContent = `(${archive.length})`;

          // Clear input
          input.value = '';
          hint.textContent = 'Come back whenever you need.';

          // Scroll to echo
          echoSection.scrollIntoView({ behavior: 'smooth', block: 'center' });

        } catch (err) {
          hint.textContent = 'Something went wrong. Try again.';
          console.error('Echo error:', err);
        } finally {
          submitBtn.disabled = false;
          submitBtn.classList.remove('loading');
        }
      }

      submitBtn.addEventListener('click', submitDump);

      // Ctrl+Enter / Cmd+Enter to submit
      input.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
          e.preventDefault();
          submitDump();
        }
      });

      // Update hint based on input
      input.addEventListener('input', () => {
        if (input.value.trim().length > 0) {
          hint.textContent = 'Ctrl+Enter to send';
        } else {
          hint.textContent = 'Just you and this box.';
        }
      });

      // Auto-focus the textarea on load
      setTimeout(() => input.focus(), 100);

      // ---- Init ----
      const archive = getArchive();
      if (archive.length > 0) {
        archiveCount.textContent = `(${archive.length})`;
      }
    </script>
  </body>
</html>
