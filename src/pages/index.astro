---
import ElectionLayout from '../layouts/ElectionLayout.astro';
import electionData from '../data/elections2026.json';

const { meta, states, quickFacts, genZIssues, timeline, electionStats } = electionData;
---

<ElectionLayout title="Election Pulse 2026 | India Votes Visually">

  <!-- Hero -->
  <section class="ep-hero">
    <div class="ep-hero-bg">
      <div class="ep-hero-orb ep-hero-orb-1"></div>
      <div class="ep-hero-orb ep-hero-orb-2"></div>
      <div class="ep-hero-orb ep-hero-orb-3"></div>
    </div>
    <div class="ep-container ep-hero-content">
      <div class="ep-badge">2026 ELECTION TEA ☕</div>
      <h1 class="ep-hero-title">
        Election<br/><span class="ep-hero-gradient">Pulse</span> 2026
      </h1>
      <p class="ep-hero-sub">{meta.tagline}</p>
      <div class="ep-hero-stats">
        {quickFacts.map((fact) => (
          <div class="ep-hero-stat">
            <span class="ep-hero-stat-icon">{fact.icon}</span>
            <span class="ep-hero-stat-value">{fact.value}</span>
            <span class="ep-hero-stat-label">{fact.label}</span>
          </div>
        ))}
      </div>
      <div class="ep-hero-actions">
        <a href="/quiz" class="ep-btn ep-btn-primary">🎯 60-sec Party Match</a>
        <a href="#start-here" class="ep-btn ep-btn-outline">New here? Start here</a>
      </div>
    </div>
  </section>

  <!-- START HERE — Gen Z 3-step onboarding -->
  <section class="ep-start-here" id="start-here">
    <div class="ep-container">
      <div class="ep-sh-wrap">
        <div class="ep-sh-title-row">
          <span class="ep-sh-kicker">new here?</span>
          <h2 class="ep-sh-title">Figure this out in <span class="ep-hero-gradient">60 seconds</span></h2>
          <p class="ep-sh-sub">No scrolling. No reading walls of text. Just tap.</p>
        </div>
        <ol class="ep-sh-steps">
          <li class="ep-sh-step">
            <span class="ep-sh-num">1</span>
            <div class="ep-sh-body">
              <h3>Pick your state</h3>
              <p>Kerala? Bengal? TN? Assam? Puducherry? Start with yours.</p>
              <a href="/states" class="ep-sh-go">Pick state →</a>
            </div>
          </li>
          <li class="ep-sh-step">
            <span class="ep-sh-num">2</span>
            <div class="ep-sh-body">
              <h3>Find your vibe</h3>
              <p>Pick 3 issues that actually matter to you. We match you to a party.</p>
              <a href="/quiz" class="ep-sh-go">Match me →</a>
            </div>
          </li>
          <li class="ep-sh-step">
            <span class="ep-sh-num">3</span>
            <div class="ep-sh-body">
              <h3>Check the receipts</h3>
              <p>What they promised last time vs what they actually did. No cap.</p>
              <a href="/promises" class="ep-sh-go">See receipts →</a>
            </div>
          </li>
        </ol>
        <div class="ep-sh-register">
          <span class="ep-sh-reg-icon">🗳️</span>
          <div>
            <strong>Not registered?</strong>
            <span>You can't vote if you're not on the rolls. Fix it in 5 mins.</span>
          </div>
          <a href="https://voters.eci.gov.in" target="_blank" rel="noopener" class="ep-btn ep-btn-primary ep-sh-reg-btn">Register →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- DO Strip — quick tools -->
  <section class="ep-do-strip">
    <div class="ep-container">
      <div class="ep-section-header ep-do-header">
        <span class="ep-sh-kicker">the tools</span>
        <h2 class="ep-section-title">Everything in one scroll</h2>
      </div>
      <div class="ep-do-grid">
        <a href="/quiz" class="ep-do-card">
          <span class="ep-do-icon">🎯</span>
          <span class="ep-do-title">Match-a-Party</span>
          <span class="ep-do-sub">Pick your issues. See who gets you.</span>
        </a>
        <a href="/compare" class="ep-do-card">
          <span class="ep-do-icon">⚖️</span>
          <span class="ep-do-title">Head-to-Head</span>
          <span class="ep-do-sub">Two parties. Every receipt. No spin.</span>
        </a>
        <a href="/promises" class="ep-do-card">
          <span class="ep-do-icon">✅</span>
          <span class="ep-do-title">Did They Do It?</span>
          <span class="ep-do-sub">Last-term promises vs actual delivery.</span>
        </a>
        <a href="/candidates" class="ep-do-card">
          <span class="ep-do-icon">🗣️</span>
          <span class="ep-do-title">Who's Running?</span>
          <span class="ep-do-sub">Criminal cases, assets, dynasty — filter it.</span>
        </a>
        <a href="/freebies" class="ep-do-card">
          <span class="ep-do-icon">💸</span>
          <span class="ep-do-title">Freebie Math</span>
          <span class="ep-do-sub">Who's promising what. And who pays.</span>
        </a>
        <a href="/ask" class="ep-do-card">
          <span class="ep-do-icon">💬</span>
          <span class="ep-do-title">Ask Me Anything</span>
          <span class="ep-do-sub">Type a question. Get the answer.</span>
        </a>
      </div>
    </div>
  </section>

  <!-- State Cards Preview -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <span class="ep-sh-kicker">the battlegrounds</span>
        <h2 class="ep-section-title">5 states. 824 seats. One scroll.</h2>
        <p class="ep-section-sub">Tap your state. Get the whole tea.</p>
        <span class="ep-source-chip">📊 Source: ECI · 2021 assembly results · Updated Apr 2026</span>
      </div>
      <div class="ep-state-grid">
        {states.map((state) => (
          <a href={`/states/${state.id}`} class="ep-state-card" style={`--sc: ${state.color}`}>
            <div class="ep-sc-top">
              <span class="ep-sc-emoji">{state.mapEmoji}</span>
              <span class="ep-sc-badge">UPCOMING</span>
            </div>
            <h3 class="ep-sc-name">{state.name}</h3>
            <div class="ep-sc-stats">
              <div class="ep-sc-stat">
                <span class="ep-sc-num">{state.seats}</span>
                <span class="ep-sc-lbl">Seats</span>
              </div>
              <div class="ep-sc-stat">
                <span class="ep-sc-num">{state.voters}</span>
                <span class="ep-sc-lbl">Voters</span>
              </div>
              <div class="ep-sc-stat">
                <span class="ep-sc-num">{state.genZPercent}%</span>
                <span class="ep-sc-lbl">Gen Z</span>
              </div>
            </div>
            <div class="ep-sc-bar">
              {state.parties.map((p) => (
                <div class="ep-sc-seg" style={`width:${(p.seats2021/state.seats)*100}%;background:${p.color}`} title={`${p.name}: ${p.seats2021}`}></div>
              ))}
            </div>
            <div class="ep-sc-parties">
              {state.parties.map((p) => (
                <span class="ep-sc-party">
                  <span class="ep-sc-dot" style={`background:${p.color}`}></span>
                  {p.icon} {p.name} <strong>{p.seats2021}</strong>
                </span>
              ))}
            </div>
            <div class="ep-sc-footer">
              <span class="ep-sc-date">{state.electionDate}</span>
              <span class="ep-sc-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Shocking Stats Strip -->
  <section class="ep-section ep-shock-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <span class="ep-sh-kicker">the numbers</span>
        <h2 class="ep-section-title">These hit different 💀</h2>
        <p class="ep-section-sub">Pulled straight from candidate affidavits. No vibes, just data.</p>
        <span class="ep-source-chip">📊 Source: <a href="https://adrindia.org" target="_blank" rel="noopener">ADR</a> analysis of ECI affidavits · 2021 cycle</span>
      </div>
      <div class="ep-shock-grid">
        <div class="ep-shock-card ep-shock-red">
          <span class="ep-shock-num">{electionStats.candidatesWithCriminalCases}</span>
          <span class="ep-shock-label">Candidates with Criminal Cases</span>
          <span class="ep-shock-icon">🚨</span>
        </div>
        <div class="ep-shock-card ep-shock-gold">
          <span class="ep-shock-num">{electionStats.crorepatiCandidates}</span>
          <span class="ep-shock-label">Are Crorepatis</span>
          <span class="ep-shock-icon">💰</span>
        </div>
        <div class="ep-shock-card ep-shock-blue">
          <span class="ep-shock-num">{electionStats.avgWinnerAssets}</span>
          <span class="ep-shock-label">Avg Winner's Assets</span>
          <span class="ep-shock-icon">🏆</span>
        </div>
        <div class="ep-shock-card ep-shock-pink">
          <span class="ep-shock-num">{electionStats.womenCandidates}</span>
          <span class="ep-shock-label">Women Candidates</span>
          <span class="ep-shock-icon">♀️</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Gen Z Issues -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <span class="ep-sh-kicker">what's rent-free in our heads</span>
        <h2 class="ep-section-title">What we actually care about</h2>
        <p class="ep-section-sub">48M of us are voting this cycle. Here's what's on the mind.</p>
        <span class="ep-source-chip">📊 Source: CSDS-Lokniti Youth Survey · 2024 · indicative weights</span>
      </div>
      <div class="ep-issues-wrap">
        {genZIssues.map((item, idx) => (
          <div class="ep-issue-row">
            <span class="ep-issue-rank">#{idx + 1}</span>
            <span class="ep-issue-name">{item.issue}</span>
            <div class="ep-issue-track">
              <div class="ep-issue-fill" style={`width:${item.percent}%;background:${item.color}`}></div>
            </div>
            <span class="ep-issue-pct">{item.percent}%</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <span class="ep-sh-kicker">the roadmap</span>
        <h2 class="ep-section-title">Mark your calendar bestie</h2>
        <p class="ep-section-sub">From announcement to results — the full schedule.</p>
      </div>
      <div class="ep-timeline">
        {timeline.map((t, i) => (
          <div class="ep-tl-item">
            <div class="ep-tl-dot-col">
              <span class="ep-tl-icon">{t.icon}</span>
              {i < timeline.length - 1 && <div class="ep-tl-line"></div>}
            </div>
            <div class="ep-tl-content">
              <span class="ep-tl-month">{t.month}</span>
              <span class="ep-tl-event">{t.event}</span>
              <span class="ep-tl-detail">{t.detail}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 30-Second Explainers -->
  <section class="ep-section ep-explainers-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <span class="ep-sh-kicker">the 30-sec version</span>
        <h2 class="ep-section-title">Each state, in one paragraph</h2>
        <p class="ep-section-sub">No time? Each card = one state, zero fluff.</p>
      </div>
      <div class="ep-explainer-grid">
        {states.map((s) => (
          <div class="ep-explainer-card" style={`--sc:${s.color}`}>
            <span class="ep-exp-emoji">{s.mapEmoji}</span>
            <h3>{s.name}</h3>
            <p class="ep-exp-tldr">
              <strong>{s.currentRuling}</strong> defends {s.seats} seats.
              Main fight: {s.parties[0].name} ({s.parties[0].seats2021}) vs {s.parties[1].name} ({s.parties[1].seats2021}).
              Key issue: {s.keyIssues[0]}.
              {s.genZPercent}% voters are Gen Z.
            </p>
            <a href={`/states/${s.id}`} class="ep-exp-link">Deep Dive &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quiz CTA -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-quiz-cta">
        <div class="ep-quiz-cta-left">
          <span class="ep-quiz-icon">🎯</span>
          <h2>Which party actually gets you?</h2>
          <p>Pick 3 issues. Get your match. 60 seconds. Zero bias. Shareable.</p>
        </div>
        <a href="/quiz" class="ep-btn ep-btn-primary ep-quiz-btn">Match me &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Explore CTA -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-cta-card">
        <h2>Voting blind is an L.</h2>
        <p>Know the money, the promises, the receipts — before you tap the button.</p>
        <div class="ep-cta-btns">
          <a href="/candidates" class="ep-btn ep-btn-primary">Meet the Contenders</a>
          <a href="/compare" class="ep-btn ep-btn-outline">Head-to-Head</a>
          <a href="/promises" class="ep-btn ep-btn-outline">Did They Do It?</a>
          <a href="/freebies" class="ep-btn ep-btn-outline">Freebie Math</a>
          <a href="/ask" class="ep-btn ep-btn-outline">Ask MA</a>
        </div>
      </div>
    </div>
  </section>

</ElectionLayout>

<style>
/* HERO */
.ep-hero {
  position: relative;
  overflow: hidden;
  padding: 5rem 0 4rem;
  text-align: center;
}
.ep-hero-bg { position: absolute; inset: 0; }
.ep-hero-orb { position: absolute; border-radius: 50%; filter: blur(110px); opacity: 0.4; animation: ep-pulse 10s ease-in-out infinite; }
.ep-hero-orb-1 { width: 520px; height: 520px; background: #a855f7; top: -160px; left: -120px; }
.ep-hero-orb-2 { width: 420px; height: 420px; background: #22d3ee; bottom: -120px; right: -120px; animation-delay: 3s; }
.ep-hero-orb-3 { width: 360px; height: 360px; background: #f472b6; top: 40%; left: 50%; transform: translate(-50%,-50%); animation-delay: 6s; }
@keyframes ep-pulse { 0%,100% { opacity: 0.3; transform: scale(1); } 50% { opacity: 0.45; transform: scale(1.08); } }
.ep-hero-content { position: relative; z-index: 2; }
.ep-hero-title { font-family: var(--ep-font-display); font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 800; line-height: 1; margin: 1.5rem 0 1rem; color: var(--ep-text); }
.ep-hero-gradient { background: linear-gradient(135deg, #a855f7, #22d3ee, #f472b6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ep-hero-sub { font-size: 1.2rem; color: var(--ep-text-muted); margin-bottom: 2.5rem; }
.ep-hero-stats { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 2rem; }
.ep-hero-stat { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; background: rgba(255,255,255,0.04); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); padding: 1rem 1.2rem; min-width: 120px; }
.ep-hero-stat-icon { font-size: 1.5rem; }
.ep-hero-stat-value { font-family: var(--ep-font-display); font-size: 1.5rem; font-weight: 800; }
.ep-hero-stat-label { font-size: 0.7rem; color: var(--ep-text-muted); text-transform: uppercase; letter-spacing: 1px; }
.ep-hero-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.8rem; }

/* KICKER LABEL (shared) */
.ep-sh-kicker { display: inline-block; font-family: var(--ep-font-display); font-size: 0.7rem; font-weight: 700; letter-spacing: 2px; text-transform: lowercase; color: var(--ep-accent-2); margin-bottom: 0.5rem; padding: 0.3rem 0.8rem; border: 1px solid rgba(34,211,238,0.25); border-radius: var(--ep-radius-pill); background: rgba(34,211,238,0.06); }

/* SOURCE CHIP */
.ep-source-chip { display: inline-block; margin-top: 0.8rem; font-size: 0.7rem; color: var(--ep-text-muted); padding: 0.35rem 0.8rem; border-radius: var(--ep-radius-pill); background: rgba(255,255,255,0.03); border: 1px solid var(--ep-border); }
.ep-source-chip a { color: var(--ep-accent-2); font-weight: 600; }

/* START HERE BLOCK */
.ep-start-here { padding: 1rem 0 2.5rem; scroll-margin-top: 80px; }
.ep-sh-wrap { background: linear-gradient(135deg, rgba(168,85,247,0.10), rgba(34,211,238,0.08) 50%, rgba(244,114,182,0.08)); border: 1px solid var(--ep-border); border-radius: 28px; padding: 2.5rem 2rem; }
.ep-sh-title-row { text-align: center; margin-bottom: 2rem; }
.ep-sh-title { font-family: var(--ep-font-display); font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 900; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
.ep-sh-sub { color: var(--ep-text-secondary); font-size: 0.95rem; }

.ep-sh-steps { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; padding: 0; margin: 0; }
.ep-sh-step { display: flex; gap: 1rem; padding: 1.3rem; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); transition: all 0.2s; }
.ep-sh-step:hover { border-color: var(--ep-border-hover); transform: translateY(-3px); }
.ep-sh-num { flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--ep-accent), var(--ep-accent-2)); display: flex; align-items: center; justify-content: center; font-family: var(--ep-font-display); font-weight: 900; font-size: 1.1rem; color: #fff; }
.ep-sh-body { flex: 1; display: flex; flex-direction: column; gap: 0.3rem; }
.ep-sh-body h3 { font-family: var(--ep-font-display); font-size: 1.05rem; font-weight: 800; }
.ep-sh-body p { font-size: 0.82rem; color: var(--ep-text-secondary); line-height: 1.45; margin-bottom: 0.3rem; }
.ep-sh-go { font-size: 0.8rem; font-weight: 700; color: var(--ep-accent-2); margin-top: auto; }
.ep-sh-go:hover { color: var(--ep-accent); }

.ep-sh-register { display: flex; align-items: center; gap: 1rem; margin-top: 1.8rem; padding: 1.2rem 1.5rem; background: linear-gradient(135deg, rgba(168,85,247,0.18), rgba(244,114,182,0.12)); border: 1px solid var(--ep-accent); border-radius: var(--ep-radius); flex-wrap: wrap; }
.ep-sh-reg-icon { font-size: 2rem; }
.ep-sh-register > div { flex: 1; display: flex; flex-direction: column; }
.ep-sh-register strong { font-family: var(--ep-font-display); font-size: 1rem; }
.ep-sh-register span { font-size: 0.82rem; color: var(--ep-text-secondary); }

@media (max-width: 768px) {
  .ep-sh-steps { grid-template-columns: 1fr; }
  .ep-sh-register { flex-direction: column; text-align: center; }
  .ep-sh-register > div { align-items: center; }
}

/* DO STRIP */
.ep-do-header { margin-bottom: 1.5rem; text-align: center; }
.ep-do-strip { padding: 2rem 0 1rem; }
.ep-do-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.9rem; }
.ep-do-card { display: flex; flex-direction: column; gap: 0.3rem; padding: 1.3rem; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); transition: all 0.2s; color: var(--ep-text); }
.ep-do-card:hover { transform: translateY(-4px); background: var(--ep-bg-card-hover); border-color: var(--ep-border-hover); color: var(--ep-text); box-shadow: var(--ep-shadow); }
.ep-do-card-hot { border: 1px solid var(--ep-accent); background: linear-gradient(135deg, rgba(168,85,247,0.18), rgba(34,211,238,0.10)); }
.ep-do-card-hot:hover { border-color: var(--ep-accent-2); }
.ep-do-icon { font-size: 1.8rem; }
.ep-do-title { font-family: var(--ep-font-display); font-weight: 800; font-size: 1.05rem; }
.ep-do-sub { font-size: 0.8rem; color: var(--ep-text-muted); line-height: 1.4; }

/* STATE CARDS */
.ep-state-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.2rem; }
.ep-state-card { display: block; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); padding: 1.5rem; transition: all 0.25s; border-top: 3px solid var(--sc); color: var(--ep-text); }
.ep-state-card:hover { transform: translateY(-6px); background: var(--ep-bg-card-hover); box-shadow: var(--ep-shadow-lg); color: var(--ep-text); border-color: var(--ep-border-hover); }
.ep-sc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; }
.ep-sc-emoji { font-size: 2rem; }
.ep-sc-badge { font-size: 0.6rem; font-weight: 700; letter-spacing: 2px; color: var(--sc); background: color-mix(in srgb, var(--sc) 12%, transparent); padding: 0.25rem 0.7rem; border-radius: var(--ep-radius-pill); border: 1px solid color-mix(in srgb, var(--sc) 25%, transparent); }
.ep-sc-name { font-family: var(--ep-font-display); font-size: 1.4rem; font-weight: 700; margin-bottom: 1rem; }
.ep-sc-stats { display: flex; gap: 0.6rem; margin-bottom: 1rem; }
.ep-sc-stat { flex: 1; text-align: center; padding: 0.6rem; background: rgba(255,255,255,0.03); border-radius: var(--ep-radius-sm); }
.ep-sc-num { display: block; font-family: var(--ep-font-display); font-size: 1.15rem; font-weight: 800; }
.ep-sc-lbl { font-size: 0.65rem; color: var(--ep-text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.ep-sc-bar { display: flex; height: 24px; border-radius: 6px; overflow: hidden; gap: 2px; margin-bottom: 0.6rem; }
.ep-sc-seg { min-width: 3px; transition: opacity 0.2s; }
.ep-sc-seg:hover { opacity: 0.8; }
.ep-sc-parties { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 0.8rem; }
.ep-sc-party { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; color: var(--ep-text-secondary); }
.ep-sc-dot { width: 6px; height: 6px; border-radius: 50%; }
.ep-sc-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 0.8rem; border-top: 1px solid var(--ep-border); }
.ep-sc-date { font-size: 0.8rem; color: var(--ep-text-muted); }
.ep-sc-arrow { font-size: 1.2rem; color: var(--sc); transition: transform 0.2s; }
.ep-state-card:hover .ep-sc-arrow { transform: translateX(4px); }

/* SHOCK STATS */
