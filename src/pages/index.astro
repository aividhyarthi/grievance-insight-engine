</BaseLayout>

<script>
  const form = document.getElementById('quickLeadForm') as HTMLFormElement;
  const success = document.getElementById('formSuccess') as HTMLElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    console.log('Lead captured:', data);

    // Store lead in localStorage
    const leads = JSON.parse(localStorage.getItem('driveease_leads') || '[]');
    leads.push({ ...data, timestamp: new Date().toISOString(), source: 'homepage' });
    localStorage.setItem('driveease_leads', JSON.stringify(leads));

    form.style.display = 'none';
    success.classList.add('show');
  });
</script>
