---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="DriveEase India | #1 Doorstep Car Servicing - Pickup, Service & Delivery">

  <!-- ====== HERO ====== -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">Serving 50+ Cities Across India</div>
        <h1>Your Car Deserves a <span class="highlight">5-Star Service</span> Without You Leaving Home</h1>
        <p>We pick up your car from your doorstep, get it serviced at certified garages by expert mechanics, and deliver it back — spotless, on time, and at 40% less than dealership prices.</p>
        <div class="hero-buttons">
          <a href="/get-quote" class="btn-primary">Get Free Quote</a>
          <a href="#how-it-works" class="btn-outline">See How It Works</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="number">50,000+</span>
            <span class="label">Cars Serviced</span>
          </div>
          <div class="hero-stat">
            <span class="number">4.8/5</span>
            <span class="label">Customer Rating</span>
          </div>
          <div class="hero-stat">
            <span class="number">50+</span>
            <span class="label">Cities</span>
          </div>
          <div class="hero-stat">
            <span class="number">2,000+</span>
            <span class="label">Expert Mechanics</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card">
          <h3>How DriveEase Works</h3>
          <div class="process-steps">
            <div class="process-step">
              <div class="step-number">1</div>
              <div class="step-content">
                <h4>Book Online</h4>
                <p>Choose your service & schedule pickup</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">2</div>
              <div class="step-content">
                <h4>We Pick Up Your Car</h4>
                <p>Our driver arrives at your doorstep</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">3</div>
              <div class="step-content">
                <h4>Expert Service</h4>
                <p>Serviced at certified partner garages</p>
              </div>
            </div>
            <div class="process-step">
              <div class="step-number">4</div>
              <div class="step-content">
                <h4>Delivered Back</h4>
                <p>Clean car delivered to your door</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== TRUST BAR ====== -->
  <section class="trust-bar">
    <div class="container">
      <div class="trust-item">
        <div class="value">40%</div>
        <div class="desc">Cheaper Than Dealerships</div>
      </div>
      <div class="trust-item">
        <div class="value">FREE</div>
        <div class="desc">Doorstep Pickup & Drop</div>
      </div>
      <div class="trust-item">
        <div class="value">100%</div>
        <div class="desc">Genuine Spare Parts</div>
      </div>
      <div class="trust-item">
        <div class="value">1 Year</div>
        <div class="desc">Service Warranty</div>
      </div>
      <div class="trust-item">
        <div class="value">Live</div>
        <div class="desc">Service Tracking</div>
      </div>
    </div>
  </section>

  <!-- ====== SERVICES ====== -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header">
        <h2>Our Car Services</h2>
        <p>From basic maintenance to major repairs — all with free doorstep pickup and delivery across India</p>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="icon">🔧</div>
          <h3>Basic Service</h3>
          <p>Oil change, oil filter, air filter, coolant top-up, brake inspection, battery check & 15-point inspection.</p>
          <span class="price">From ₹2,999</span>
          <span class="time">4-5 Hours</span>
        </div>
        <div class="service-card">
          <div class="icon">⚙️</div>
          <h3>Comprehensive Service</h3>
          <p>Everything in basic + spark plugs, fuel filter, transmission fluid, wheel alignment, AC check & 40-point inspection.</p>
          <span class="price">From ₹5,499</span>
          <span class="time">6-8 Hours</span>
        </div>
        <div class="service-card">
          <div class="icon">❄️</div>
          <h3>AC Service & Repair</h3>
          <p>AC gas top-up, compressor check, condenser cleaning, cabin filter replacement & complete cooling system diagnosis.</p>
          <span class="price">From ₹1,999</span>
          <span class="time">2-3 Hours</span>
        </div>
        <div class="service-card">
          <div class="icon">🎨</div>
          <h3>Denting & Painting</h3>
          <p>Scratch removal, dent repair, full body painting, bumper repair with colour-matched paint and clear coat finish.</p>
          <span class="price">From ₹2,499</span>
          <span class="time">1-3 Days</span>
        </div>
        <div class="service-card">
          <div class="icon">🛞</div>
          <h3>Tyres & Wheel Care</h3>
          <p>Tyre replacement (all brands), wheel alignment, wheel balancing, nitrogen filling & tyre rotation service.</p>
          <span class="price">From ₹999</span>
          <span class="time">1-2 Hours</span>
        </div>
        <div class="service-card">
          <div class="icon">🔋</div>
          <h3>Battery & Electrical</h3>
          <p>Battery replacement (Amaron, Exide, etc.), alternator check, starter motor repair & complete electrical diagnostics.</p>
          <span class="price">From ₹3,499</span>
          <span class="time">1-2 Hours</span>
        </div>
        <div class="service-card">
          <div class="icon">✨</div>
          <h3>Car Detailing & Wash</h3>
          <p>Interior deep cleaning, exterior polish, ceramic coating, Teflon coating, underbody anti-rust treatment & PPF.</p>
          <span class="price">From ₹999</span>
          <span class="time">3-5 Hours</span>
        </div>
        <div class="service-card">
          <div class="icon">📋</div>
          <h3>Insurance Claims</h3>
          <p>Cashless insurance claim processing, accident repair management, RSA & complete paperwork handled by us.</p>
          <span class="price">Cashless</span>
          <span class="time">3-7 Days</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="section section-alt" id="how-it-works">
    <div class="container">
      <div class="section-header">
        <h2>How DriveEase Works</h2>
        <p>Get your car serviced in 4 simple steps — without stepping out of your home</p>
      </div>
      <div class="how-it-works-grid">
        <div class="how-step">
          <div class="step-icon">📱</div>
          <h3>Book Online</h3>
          <p>Select your car, choose a service, and pick a convenient time slot</p>
        </div>
        <div class="how-step">
          <div class="step-icon">🚗</div>
          <h3>Doorstep Pickup</h3>
          <p>Our trained driver picks up your car from your home or office</p>
        </div>
        <div class="how-step">
          <div class="step-icon">🔧</div>
          <h3>Expert Service</h3>
          <p>Your car is serviced at a certified garage with real-time status updates</p>
        </div>
        <div class="how-step">
          <div class="step-icon">✅</div>
          <h3>Delivered Clean</h3>
          <p>Sanitised, washed and delivered back to your doorstep — good as new</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== PRICING ====== -->
  <section class="section" id="pricing">
    <div class="container">
      <div class="section-header">
        <h2>Transparent Pricing</h2>
        <p>No hidden charges. No surprises. What you see is what you pay.</p>
      </div>
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Essential Care</h3>
          <div class="price-amount">₹2,999</div>
          <div class="price-note">Starting price for hatchbacks</div>
          <ul class="pricing-features">
            <li>Engine oil + filter change</li>
            <li>Air filter cleaning</li>
            <li>Coolant top-up</li>
            <li>Brake inspection</li>
            <li>Battery health check</li>
            <li>15-point inspection</li>
            <li>Free pickup & delivery</li>
          </ul>
          <a href="/get-quote" class="btn-primary" style="width: 100%; text-align: center;">Book Now</a>
        </div>
        <div class="pricing-card featured">
          <h3>Complete Care</h3>
          <div class="price-amount">₹5,499</div>
          <div class="price-note">Starting price for hatchbacks</div>
          <ul class="pricing-features">
            <li>Everything in Essential Care</li>
            <li>Spark plug replacement</li>
            <li>Fuel filter service</li>
            <li>Wheel alignment & balancing</li>
            <li>AC performance check</li>
            <li>Transmission fluid top-up</li>
            <li>40-point inspection</li>
            <li>Interior vacuuming</li>
            <li>Exterior wash & wax</li>
          </ul>
          <a href="/get-quote" class="btn-primary" style="width: 100%; text-align: center;">Book Now</a>
        </div>
        <div class="pricing-card">
          <h3>Premium Care</h3>
          <div class="price-amount">₹8,999</div>
          <div class="price-note">Starting price for hatchbacks</div>
          <ul class="pricing-features">
            <li>Everything in Complete Care</li>
            <li>Brake pad replacement</li>
            <li>Clutch inspection</li>
            <li>Suspension check</li>
            <li>AC gas top-up</li>
            <li>Engine flush treatment</li>
            <li>Underbody inspection</li>
            <li>Full interior detailing</li>
            <li>Ceramic wash</li>
            <li>60-point inspection</li>
          </ul>
          <a href="/get-quote" class="btn-primary" style="width: 100%; text-align: center;">Book Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== COMPETITOR COMPARISON ====== -->
  <section class="section section-alt" id="comparison">
    <div class="container">
      <div class="section-header">
        <h2>How We Compare</h2>
        <p>See why 50,000+ car owners switched to DriveEase from other service providers</p>
      </div>
      <div class="comparison-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Feature</th>
              <th class="highlight-col">DriveEase</th>
              <th>GoMechanic</th>
              <th>MyTVS</th>
              <th>Pitstop</th>
              <th>Authorized Dealers</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Basic Service Price</strong></td>
              <td class="highlight-col">₹2,999</td>
              <td>₹3,199-₹3,999</td>
              <td>₹3,499-₹4,499</td>
              <td>₹2,999-₹3,499</td>
              <td>₹5,000-₹8,000+</td>
            </tr>
            <tr>
              <td><strong>Free Pickup & Drop</strong></td>
              <td class="highlight-col"><span class="check">Yes (Always)</span></td>
              <td><span class="check">Yes</span></td>
              <td><span class="cross">Limited</span></td>
              <td><span class="check">Yes</span></td>
              <td><span class="cross">No / ₹500+</span></td>
            </tr>
            <tr>
              <td><strong>Service Delivery Time</strong></td>
              <td class="highlight-col">4-6 Hours</td>
              <td>6-8 Hours</td>
              <td>1-2 Days</td>
              <td>6-8 Hours</td>
              <td>1-3 Days</td>
            </tr>
            <tr>
              <td><strong>Live Service Tracking</strong></td>
              <td class="highlight-col"><span class="check">Real-time Video</span></td>
              <td><span class="check">Status updates</span></td>
              <td><span class="cross">No</span></td>
              <td><span class="check">Status updates</span></td>
              <td><span class="cross">No</span></td>
            </tr>
            <tr>
              <td><strong>Service Warranty</strong></td>
              <td class="highlight-col"><span class="check">1 Year / 10,000 km</span></td>
              <td>1 Month</td>
              <td>6 Months</td>
              <td>1 Month</td>
              <td>Varies</td>
            </tr>
            <tr>
              <td><strong>Genuine Spare Parts</strong></td>
              <td class="highlight-col"><span class="check">100% OEM/OES</span></td>
              <td>Mix of OEM & aftermarket</td>
              <td>OEM</td>
              <td>Mix</td>
              <td>OEM</td>
            </tr>
            <tr>
              <td><strong>Cities Covered</strong></td>
              <td class="highlight-col">50+ Cities</td>
              <td>30+ Cities</td>
              <td>20+ Cities</td>
              <td>10+ Cities</td>
              <td>City-specific</td>
            </tr>
            <tr>
              <td><strong>Insurance Claim Help</strong></td>
              <td class="highlight-col"><span class="check">Full Cashless</span></td>
              <td><span class="check">Yes</span></td>
              <td><span class="check">Yes</span></td>
              <td><span class="cross">Limited</span></td>
              <td><span class="check">Yes</span></td>
            </tr>
            <tr>
              <td><strong>Post-Service Car Wash</strong></td>
              <td class="highlight-col"><span class="check">Free (Always)</span></td>
              <td><span class="check">Free</span></td>
              <td><span class="cross">Paid</span></td>
              <td><span class="check">Free</span></td>
              <td><span class="cross">Paid</span></td>
            </tr>
            <tr>
              <td><strong>Customer Rating</strong></td>
              <td class="highlight-col">4.8/5</td>
              <td>4.2/5</td>
              <td>4.0/5</td>
              <td>4.3/5</td>
              <td>3.5/5</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ====== USPs ====== -->
  <section class="section section-dark" id="why-us">
    <div class="container">
      <div class="section-header">
        <h2>Why 50,000+ Car Owners Trust DriveEase</h2>
        <p>We're not just another car service aggregator — we're reimagining how India gets its cars serviced</p>
      </div>
      <div class="usp-grid">
        <div class="usp-card">
          <div class="icon">🎥</div>
          <h3>Live Video Updates</h3>
          <p>Watch your car being serviced in real-time through our app. No more wondering what's happening at the garage. Full transparency, zero guesswork.</p>
        </div>
        <div class="usp-card">
          <div class="icon">🏷️</div>
          <h3>Price Match Guarantee</h3>
          <p>Found a lower price for the same service? We'll match it and give you an additional 10% off. No questions asked — we stand behind our pricing.</p>
        </div>
        <div class="usp-card">
          <div class="icon">🛡️</div>
          <h3>1-Year Service Warranty</h3>
          <p>While competitors offer 30 days, we back every service with a full 1-year or 10,000 km warranty. Industry-leading confidence in our work quality.</p>
        </div>
        <div class="usp-card">
          <div class="icon">🚘</div>
          <h3>Free Courtesy Car</h3>
          <p>Need your car for more than a day? We provide a free courtesy car so you're never stranded. The only service provider in India offering this.</p>
        </div>
        <div class="usp-card">
          <div class="icon">📊</div>
          <h3>Digital Health Report</h3>
          <p>Receive a detailed digital car health report with photos after every service. Track your car's condition over time. No upselling — just honest assessments.</p>
        </div>
        <div class="usp-card">
          <div class="icon">🌙</div>
          <h3>Night Owl Service</h3>
          <p>India's first after-hours car service. Book pickups between 8 PM - 6 AM and wake up to a fully serviced car. Perfect for busy professionals.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CITIES ====== -->
  <section class="section" id="cities">
    <div class="container">
      <div class="section-header">
        <h2>Available Across India</h2>
        <p>DriveEase operates in 50+ cities and rapidly expanding. Find us in your city.</p>
      </div>
      <div class="cities-grid">
        <div class="city-card">
          <div class="city-icon">🏙️</div>
          <h3>Mumbai</h3>
          <p>200+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">🏛️</div>
          <h3>Delhi NCR</h3>
          <p>250+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">💻</div>
          <h3>Bangalore</h3>
          <p>180+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">🏰</div>
          <h3>Hyderabad</h3>
          <p>150+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">🎭</div>
          <h3>Chennai</h3>
          <p>140+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">🌆</div>
          <h3>Pune</h3>
          <p>120+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">🏖️</div>
          <h3>Kolkata</h3>
          <p>100+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">🏗️</div>
          <h3>Ahmedabad</h3>
          <p>90+ garages</p>
        </div>
        <div class="city-card">
          <div class="city-icon">🌿</div>
