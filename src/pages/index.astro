---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <h1>Optimize Your YouTube<br /><span>Title, Description &amp; Hashtags</span></h1>
    <p>Paste any YouTube video URL and get AI-powered metadata recommendations to maximize views and search ranking.</p>
  </section>

  <!-- Input Card -->
  <div class="container">
    <div class="input-card">
      <div class="input-row">
        <input
          id="url-input"
          type="url"
          class="url-input"
          placeholder="https://www.youtube.com/watch?v=... or youtu.be/..."
          autocomplete="off"
          spellcheck="false"
        />
        <button id="analyze-btn" class="btn-analyze">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Analyze
        </button>
      </div>
      <div class="input-hint">
        <span>📹 Videos</span>
        <span>⚡ Shorts</span>
        <span>🔴 Live streams</span>
        <span>📺 Any channel</span>
      </div>
    </div>
  </div>

  <!-- Error message -->
  <div id="error-msg" class="error-msg hidden container"></div>

  <!-- Loading -->
  <div id="loading-msg" class="status-msg hidden">
    <span class="spinner"></span>&nbsp;&nbsp;Fetching metadata and generating AI recommendations…
  </div>

  <!-- Results -->
  <section id="results-section" class="results-section hidden">
    <!-- Video info bar -->
    <div id="video-info-bar" class="video-info-bar container"></div>

    <!-- Comparison grid -->
    <div class="results-grid">
      <!-- Original card -->
      <div class="meta-card">
        <div class="card-header">
          <h2>Original Metadata</h2>
        </div>
        <div class="card-body">
          <div class="meta-field">
            <div class="meta-label">Title</div>
            <div id="orig-title" class="meta-value title-val"></div>
          </div>
          <div class="meta-field">
            <div class="meta-label">Description</div>
            <div id="orig-desc" class="meta-value desc-val"></div>
          </div>
          <div class="meta-field">
            <div class="meta-label">Tags / Keywords</div>
            <div id="orig-tags" class="tags-list"></div>
          </div>
          <div class="meta-field">
            <div class="meta-label">Hashtags (in description)</div>
            <div id="orig-hashtags" class="tags-list"></div>
          </div>
          <div class="meta-field">
            <div class="meta-label">Title SEO Score</div>
            <div id="orig-score" class="seo-score">
              <div class="score-bar"><div class="score-fill" id="orig-score-fill" style="width:0%"></div></div>
              <span class="score-label" id="orig-score-label">—</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Recommended card -->
      <div class="meta-card recommended">
        <div class="card-header rec-header">
          <h2>AI Recommendations</h2>
          <button class="copy-btn" id="copy-all-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copy All
          </button>
        </div>
        <div class="card-body">
          <div class="meta-field">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
              <div class="meta-label" style="margin:0">Optimized Title</div>
              <button class="copy-btn" data-copy="rec-title">Copy</button>
            </div>
            <div id="rec-title" class="meta-value title-val" style="color:#FF6B6B"></div>
          </div>
          <div class="meta-field">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
              <div class="meta-label" style="margin:0">Optimized Description</div>
              <button class="copy-btn" data-copy="rec-desc">Copy</button>
            </div>
            <div id="rec-desc" class="meta-value desc-val"></div>
          </div>
          <div class="meta-field">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
              <div class="meta-label" style="margin:0">Recommended Hashtags</div>
              <button class="copy-btn" data-copy="rec-hashtags">Copy</button>
            </div>
            <div id="rec-hashtags" class="tags-list"></div>
          </div>
          <div class="meta-field">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
              <div class="meta-label" style="margin:0">Recommended Keywords</div>
              <button class="copy-btn" data-copy="rec-keywords">Copy</button>
            </div>
            <div id="rec-keywords" class="tags-list"></div>
          </div>
          <div class="meta-field">
            <div class="meta-label">Optimized Title SEO Score</div>
            <div id="rec-score" class="seo-score">
              <div class="score-bar"><div class="score-fill" id="rec-score-fill" style="width:0%;background:var(--green)"></div></div>
              <span class="score-label" id="rec-score-label">—</span>
            </div>
          </div>
          <div class="meta-field" id="improvement-tips-wrap" style="display:none">
            <div class="meta-label">Improvement Notes</div>
            <ul id="improvement-tips" style="padding-left:16px;color:var(--text-sec);font-size:0.85rem;display:flex;flex-direction:column;gap:4px;"></ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
  const analyzeBtn = document.getElementById('analyze-btn') as HTMLButtonElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const loadingMsg = document.getElementById('loading-msg') as HTMLDivElement;
  const resultsSection = document.getElementById('results-section') as HTMLElement;

  analyzeBtn.addEventListener('click', runAnalysis);
  urlInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runAnalysis(); });

  async function runAnalysis() {
    const url = urlInput.value.trim();
    if (!url) { showError('Please enter a YouTube URL.'); return; }

    setLoading(true);
    hideError();
    resultsSection.classList.add('hidden');

    try {
      const res = await fetch('/api/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      });

      const data = await res.json();

      if (!res.ok || data.error) {
        showError(data.error || 'Something went wrong. Please try again.');
        return;
      }

      renderResults(data);
    } catch (err) {
      showError('Network error. Please check your connection and try again.');
    } finally {
      setLoading(false);
    }
  }

  function renderResults(data: any) {
    const bar = document.getElementById('video-info-bar')!;
    const badgeClass = data.contentType === 'shorts' ? 'badge-shorts' : data.contentType === 'live' ? 'badge-live' : 'badge-video';
    const typeLabel = data.contentType === 'shorts' ? '⚡ Short' : data.contentType === 'live' ? '🔴 Live' : '📹 Video';
    bar.innerHTML = `
      ${data.thumbnail ? `<img src="${esc(data.thumbnail)}" alt="thumbnail" class="video-thumb" />` : ''}
      <div class="video-meta">
        <h3>${esc(data.original.title)}</h3>
        <p>${esc(data.channelTitle || '')} ${data.publishedAt ? '&bull; ' + new Date(data.publishedAt).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'}) : ''}</p>
      </div>
      <span class="content-type-badge ${badgeClass}">${typeLabel}</span>
    `;

    setText('orig-title', data.original.title);
    setText('orig-desc', data.original.description || '(no description)');
    renderTags('orig-tags', data.original.tags || [], false);
    renderTags('orig-hashtags', data.original.hashtags || [], false);
    const origScore = calcSeoScore(data.original.title);
    setScore('orig-score-fill', 'orig-score-label', origScore, false);

    setText('rec-title', data.recommended.title);
    setText('rec-desc', data.recommended.description);
    renderTags('rec-hashtags', data.recommended.hashtags || [], true);
    renderTags('rec-keywords', data.recommended.keywords || [], true);
    const recScore = calcSeoScore(data.recommended.title);
    setScore('rec-score-fill', 'rec-score-label', recScore, true);

    if (data.recommended.tips && data.recommended.tips.length) {
      const wrap = document.getElementById('improvement-tips-wrap')!;
      const list = document.getElementById('improvement-tips')!;
      wrap.style.display = '';
      list.innerHTML = data.recommended.tips.map((t: string) => `<li>${esc(t)}</li>`).join('');
    }

    resultsSection.classList.remove('hidden');
    resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setupCopyButtons(data);
  }

  function setText(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  function renderTags(id: string, tags: string[], rec: boolean) {
    const el = document.getElementById(id);
    if (!el) return;
    if (!tags.length) { el.innerHTML = '<span style="color:var(--text-muted);font-size:0.82rem">None</span>'; return; }
    el.innerHTML = tags.slice(0, 20).map(t => `<span class="tag${rec ? ' rec-tag' : ''}">${esc(t)}</span>`).join('');
  }

  function calcSeoScore(title: string): number {
    if (!title) return 0;
    let score = 0;
    if (title.length >= 40 && title.length <= 70) score += 30;
    else if (title.length >= 30) score += 15;
    if (/\d/.test(title)) score += 15;
    if (/[|:\-–]/.test(title)) score += 10;
    if (title.charAt(0) === title.charAt(0).toUpperCase()) score += 10;
    const words = title.toLowerCase().split(/\s+/);
    const power = ['how','why','what','best','top','secret','guide','tips','free','easy','fast','ultimate','proven'];
    if (words.some(w => power.includes(w))) score += 20;
    if (title.length >= 10) score += 15;
    return Math.min(score, 100);
  }

  function setScore(fillId: string, labelId: string, score: number, green: boolean) {
    const fill = document.getElementById(fillId);
    const label = document.getElementById(labelId);
    if (fill) { fill.style.width = score + '%'; if (green) fill.style.background = 'var(--green)'; }
    if (label) {
      const grade = score >= 80 ? 'Excellent' : score >= 60 ? 'Good' : score >= 40 ? 'Fair' : 'Weak';
      label.textContent = `${score}/100 – ${grade}`;
      label.style.color = score >= 80 ? 'var(--green)' : score >= 60 ? '#FFC107' : '#FF6B6B';
    }
  }

  function setupCopyButtons(data: any) {
    document.querySelectorAll<HTMLButtonElement>('.copy-btn[data-copy]').forEach(btn => {
      const clone = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode!.replaceChild(clone, btn);
      clone.addEventListener('click', () => {
        let text = '';
        if (clone.dataset.copy === 'rec-title') text = data.recommended.title;
        else if (clone.dataset.copy === 'rec-desc') text = data.recommended.description;
        else if (clone.dataset.copy === 'rec-hashtags') text = (data.recommended.hashtags || []).join(' ');
        else if (clone.dataset.copy === 'rec-keywords') text = (data.recommended.keywords || []).join(', ');
        copyText(clone, text);
      });
    });

    const copyAll = document.getElementById('copy-all-btn') as HTMLButtonElement;
    if (copyAll) {
      const clone = copyAll.cloneNode(true) as HTMLButtonElement;
      copyAll.parentNode!.replaceChild(clone, copyAll);
      clone.addEventListener('click', () => {
        const all = [
          `TITLE:\n${data.recommended.title}`,
          `\nDESCRIPTION:\n${data.recommended.description}`,
          `\nHASHTAGS:\n${(data.recommended.hashtags || []).join(' ')}`,
          `\nKEYWORDS:\n${(data.recommended.keywords || []).join(', ')}`,
        ].join('\n');
        copyText(clone, all);
      });
    }
  }

  function copyText(btn: HTMLButtonElement, text: string) {
    navigator.clipboard.writeText(text).then(() => {
      btn.classList.add('copied');
      const orig = btn.innerHTML;
      btn.textContent = '✓ Copied!';
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
    });
  }

  function esc(str: string) {
    return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function setLoading(on: boolean) {
    loadingMsg.classList.toggle('hidden', !on);
    analyzeBtn.disabled = on;
    analyzeBtn.innerHTML = on
      ? '<span class="spinner"></span> Analyzing…'
      : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Analyze';
  }

  function showError(msg: string) { errorMsg.textContent = msg; errorMsg.classList.remove('hidden'); }
  function hideError() { errorMsg.classList.add('hidden'); }
</script>
