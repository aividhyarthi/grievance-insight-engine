---
import ElectionLayout from '../layouts/ElectionLayout.astro';
import electionData from '../data/elections2026.json';

const { meta, states, quickFacts, genZIssues, timeline, electionStats } = electionData;
---

<ElectionLayout title="Election Pulse 2026 | India Votes Visually">

  <!-- Hero -->
  <section class="ep-hero">
    <div class="ep-hero-bg">
      <div class="ep-hero-orb ep-hero-orb-1"></div>
      <div class="ep-hero-orb ep-hero-orb-2"></div>
      <div class="ep-hero-orb ep-hero-orb-3"></div>
    </div>
    <div class="ep-container ep-hero-content">
      <div class="ep-badge">LIVE ELECTION TRACKER 2026</div>
      <h1 class="ep-hero-title">
        Election<br/><span class="ep-hero-gradient">Pulse</span> 2026
      </h1>
      <p class="ep-hero-sub">{meta.tagline}</p>
      <div class="ep-hero-stats">
        {quickFacts.map((fact) => (
          <div class="ep-hero-stat">
            <span class="ep-hero-stat-icon">{fact.icon}</span>
            <span class="ep-hero-stat-value">{fact.value}</span>
            <span class="ep-hero-stat-label">{fact.label}</span>
          </div>
        ))}
      </div>
      <div class="ep-hero-actions">
        <a href="/quiz" class="ep-btn ep-btn-primary">🎯 Take the 60-sec Quiz</a>
        <a href="/states" class="ep-btn ep-btn-outline">Explore States</a>
        <a href="/ask" class="ep-btn ep-btn-outline">Ask Anything</a>
      </div>
    </div>
  </section>

  <!-- DO Strip — what's in it for me -->
  <section class="ep-do-strip">
    <div class="ep-container">
      <div class="ep-do-grid">
        <a href="/quiz" class="ep-do-card">
          <span class="ep-do-icon">🎯</span>
          <span class="ep-do-title">Match a Party</span>
          <span class="ep-do-sub">Pick your top issues. See who fits your worldview.</span>
        </a>
        <a href="/compare" class="ep-do-card">
          <span class="ep-do-icon">⚖️</span>
          <span class="ep-do-title">Compare Parties</span>
          <span class="ep-do-sub">Money, promises, delivery — side by side.</span>
        </a>
        <a href="/promises" class="ep-do-card">
          <span class="ep-do-icon">✅</span>
          <span class="ep-do-title">Promise Tracker</span>
          <span class="ep-do-sub">What they said. What they did. The receipts.</span>
        </a>
        <a href="https://voters.eci.gov.in" target="_blank" rel="noopener" class="ep-do-card ep-do-card-hot">
          <span class="ep-do-icon">🗳️</span>
          <span class="ep-do-title">Register to Vote</span>
          <span class="ep-do-sub">Not on the rolls? You can't vote. Fix it in 5 mins.</span>
        </a>
      </div>
    </div>
  </section>

  <!-- State Cards Preview -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <h2 class="ep-section-title">5 States. 824 Seats. One Dashboard.</h2>
        <p class="ep-section-sub">Tap any state to deep-dive into candidates, parties & predictions</p>
      </div>
      <div class="ep-state-grid">
        {states.map((state) => (
          <a href={`/states/${state.id}`} class="ep-state-card" style={`--sc: ${state.color}`}>
            <div class="ep-sc-top">
              <span class="ep-sc-emoji">{state.mapEmoji}</span>
              <span class="ep-sc-badge">UPCOMING</span>
            </div>
            <h3 class="ep-sc-name">{state.name}</h3>
            <div class="ep-sc-stats">
              <div class="ep-sc-stat">
                <span class="ep-sc-num">{state.seats}</span>
                <span class="ep-sc-lbl">Seats</span>
              </div>
              <div class="ep-sc-stat">
                <span class="ep-sc-num">{state.voters}</span>
                <span class="ep-sc-lbl">Voters</span>
              </div>
              <div class="ep-sc-stat">
                <span class="ep-sc-num">{state.genZPercent}%</span>
                <span class="ep-sc-lbl">Gen Z</span>
              </div>
            </div>
            <div class="ep-sc-bar">
              {state.parties.map((p) => (
                <div class="ep-sc-seg" style={`width:${(p.seats2021/state.seats)*100}%;background:${p.color}`} title={`${p.name}: ${p.seats2021}`}></div>
              ))}
            </div>
            <div class="ep-sc-parties">
              {state.parties.map((p) => (
                <span class="ep-sc-party">
                  <span class="ep-sc-dot" style={`background:${p.color}`}></span>
                  {p.icon} {p.name} <strong>{p.seats2021}</strong>
                </span>
              ))}
            </div>
            <div class="ep-sc-footer">
              <span class="ep-sc-date">{state.electionDate}</span>
              <span class="ep-sc-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Shocking Stats Strip -->
  <section class="ep-section ep-shock-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <h2 class="ep-section-title">The Numbers They Don't Want You to See</h2>
        <p class="ep-section-sub">Data from ADR analysis of declared affidavits</p>
      </div>
      <div class="ep-shock-grid">
        <div class="ep-shock-card ep-shock-red">
          <span class="ep-shock-num">{electionStats.candidatesWithCriminalCases}</span>
          <span class="ep-shock-label">Candidates with Criminal Cases</span>
          <span class="ep-shock-icon">🚨</span>
        </div>
        <div class="ep-shock-card ep-shock-gold">
          <span class="ep-shock-num">{electionStats.crorepatiCandidates}</span>
          <span class="ep-shock-label">Are Crorepatis</span>
          <span class="ep-shock-icon">💰</span>
        </div>
        <div class="ep-shock-card ep-shock-blue">
          <span class="ep-shock-num">{electionStats.avgWinnerAssets}</span>
          <span class="ep-shock-label">Avg Winner's Assets</span>
          <span class="ep-shock-icon">🏆</span>
        </div>
        <div class="ep-shock-card ep-shock-pink">
          <span class="ep-shock-num">{electionStats.womenCandidates}</span>
          <span class="ep-shock-label">Women Candidates</span>
          <span class="ep-shock-icon">♀️</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Gen Z Issues -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <h2 class="ep-section-title">What Gen Z Actually Cares About</h2>
        <p class="ep-section-sub">48M+ young voters. These are their priorities.</p>
      </div>
      <div class="ep-issues-wrap">
        {genZIssues.map((item, idx) => (
          <div class="ep-issue-row">
            <span class="ep-issue-rank">#{idx + 1}</span>
            <span class="ep-issue-name">{item.issue}</span>
            <div class="ep-issue-track">
              <div class="ep-issue-fill" style={`width:${item.percent}%;background:${item.color}`}></div>
            </div>
            <span class="ep-issue-pct">{item.percent}%</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <h2 class="ep-section-title">Election Timeline</h2>
        <p class="ep-section-sub">Key milestones from announcement to results</p>
      </div>
      <div class="ep-timeline">
        {timeline.map((t, i) => (
          <div class="ep-tl-item">
            <div class="ep-tl-dot-col">
              <span class="ep-tl-icon">{t.icon}</span>
              {i < timeline.length - 1 && <div class="ep-tl-line"></div>}
            </div>
            <div class="ep-tl-content">
              <span class="ep-tl-month">{t.month}</span>
              <span class="ep-tl-event">{t.event}</span>
              <span class="ep-tl-detail">{t.detail}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 30-Second Explainers -->
  <section class="ep-section ep-explainers-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <h2 class="ep-section-title">Understood in 30 Seconds</h2>
        <p class="ep-section-sub">Don't have time? Each card = one state battle, simplified.</p>
      </div>
      <div class="ep-explainer-grid">
        {states.map((s) => (
          <div class="ep-explainer-card" style={`--sc:${s.color}`}>
            <span class="ep-exp-emoji">{s.mapEmoji}</span>
            <h3>{s.name}</h3>
            <p class="ep-exp-tldr">
              <strong>{s.currentRuling}</strong> defends {s.seats} seats.
              Main fight: {s.parties[0].name} ({s.parties[0].seats2021}) vs {s.parties[1].name} ({s.parties[1].seats2021}).
              Key issue: {s.keyIssues[0]}.
              {s.genZPercent}% voters are Gen Z.
            </p>
            <a href={`/states/${s.id}`} class="ep-exp-link">Deep Dive &rarr;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quiz CTA -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-quiz-cta">
        <div class="ep-quiz-cta-left">
          <span class="ep-quiz-icon">🎯</span>
          <h2>Which party matches YOUR issues?</h2>
          <p>Pick the issues you care about. We'll show you which parties align. 2 minutes. Zero bias.</p>
        </div>
        <a href="/quiz" class="ep-btn ep-btn-primary ep-quiz-btn">Take the Quiz &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Explore CTA -->
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-cta-card">
        <h2>Your Vote. Your Future. Get Informed.</h2>
        <p>Don't just vote. Know who you're voting for. Explore candidates, their records, their money, their promises.</p>
        <div class="ep-cta-btns">
          <a href="/candidates" class="ep-btn ep-btn-primary">Explore Candidates</a>
          <a href="/compare" class="ep-btn ep-btn-outline">Compare Parties</a>
          <a href="/promises" class="ep-btn ep-btn-outline">Promise Tracker</a>
          <a href="/freebies" class="ep-btn ep-btn-outline">Freebies Cost</a>
          <a href="/ask" class="ep-btn ep-btn-outline">Ask Questions</a>
        </div>
      </div>
    </div>
  </section>

</ElectionLayout>

<style>
/* HERO */
.ep-hero {
  position: relative;
  overflow: hidden;
  padding: 5rem 0 4rem;
  text-align: center;
}
.ep-hero-bg { position: absolute; inset: 0; }
.ep-hero-orb { position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.3; animation: ep-pulse 10s ease-in-out infinite; }
.ep-hero-orb-1 { width: 500px; height: 500px; background: #ff6b35; top: -150px; left: -100px; }
.ep-hero-orb-2 { width: 400px; height: 400px; background: #138808; bottom: -100px; right: -100px; animation-delay: 3s; }
.ep-hero-orb-3 { width: 350px; height: 350px; background: #2563eb; top: 40%; left: 50%; transform: translate(-50%,-50%); animation-delay: 6s; }
@keyframes ep-pulse { 0%,100% { opacity: 0.3; transform: scale(1); } 50% { opacity: 0.45; transform: scale(1.08); } }
.ep-hero-content { position: relative; z-index: 2; }
.ep-hero-title { font-family: var(--ep-font-display); font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 800; line-height: 1; margin: 1.5rem 0 1rem; color: var(--ep-text); }
.ep-hero-gradient { background: linear-gradient(135deg, #ff6b35, #ff9f1c, #ffcc02); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ep-hero-sub { font-size: 1.2rem; color: var(--ep-text-muted); margin-bottom: 2.5rem; }
.ep-hero-stats { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 2rem; }
.ep-hero-stat { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; background: rgba(255,255,255,0.04); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); padding: 1rem 1.2rem; min-width: 120px; }
.ep-hero-stat-icon { font-size: 1.5rem; }
.ep-hero-stat-value { font-family: var(--ep-font-display); font-size: 1.5rem; font-weight: 800; }
.ep-hero-stat-label { font-size: 0.7rem; color: var(--ep-text-muted); text-transform: uppercase; letter-spacing: 1px; }
.ep-hero-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.8rem; }

/* DO STRIP */
.ep-do-strip { padding: 2rem 0 1rem; }
.ep-do-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.9rem; }
.ep-do-card { display: flex; flex-direction: column; gap: 0.3rem; padding: 1.3rem; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); transition: all 0.2s; color: var(--ep-text); }
.ep-do-card:hover { transform: translateY(-4px); background: var(--ep-bg-card-hover); border-color: var(--ep-border-hover); color: var(--ep-text); box-shadow: var(--ep-shadow); }
.ep-do-card-hot { border: 1px solid var(--ep-accent); background: linear-gradient(135deg, rgba(255,107,53,0.12), rgba(255,159,28,0.06)); }
.ep-do-card-hot:hover { border-color: var(--ep-accent-2); }
.ep-do-icon { font-size: 1.8rem; }
.ep-do-title { font-family: var(--ep-font-display); font-weight: 800; font-size: 1.05rem; }
.ep-do-sub { font-size: 0.8rem; color: var(--ep-text-muted); line-height: 1.4; }

/* STATE CARDS */
.ep-state-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.2rem; }
.ep-state-card { display: block; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); padding: 1.5rem; transition: all 0.25s; border-top: 3px solid var(--sc); color: var(--ep-text); }
.ep-state-card:hover { transform: translateY(-6px); background: var(--ep-bg-card-hover); box-shadow: var(--ep-shadow-lg); color: var(--ep-text); border-color: var(--ep-border-hover); }
.ep-sc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; }
.ep-sc-emoji { font-size: 2rem; }
.ep-sc-badge { font-size: 0.6rem; font-weight: 700; letter-spacing: 2px; color: var(--sc); background: color-mix(in srgb, var(--sc) 12%, transparent); padding: 0.25rem 0.7rem; border-radius: var(--ep-radius-pill); border: 1px solid color-mix(in srgb, var(--sc) 25%, transparent); }
.ep-sc-name { font-family: var(--ep-font-display); font-size: 1.4rem; font-weight: 700; margin-bottom: 1rem; }
.ep-sc-stats { display: flex; gap: 0.6rem; margin-bottom: 1rem; }
.ep-sc-stat { flex: 1; text-align: center; padding: 0.6rem; background: rgba(255,255,255,0.03); border-radius: var(--ep-radius-sm); }
.ep-sc-num { display: block; font-family: var(--ep-font-display); font-size: 1.15rem; font-weight: 800; }
.ep-sc-lbl { font-size: 0.65rem; color: var(--ep-text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.ep-sc-bar { display: flex; height: 24px; border-radius: 6px; overflow: hidden; gap: 2px; margin-bottom: 0.6rem; }
.ep-sc-seg { min-width: 3px; transition: opacity 0.2s; }
.ep-sc-seg:hover { opacity: 0.8; }
.ep-sc-parties { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 0.8rem; }
.ep-sc-party { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; color: var(--ep-text-secondary); }
.ep-sc-dot { width: 6px; height: 6px; border-radius: 50%; }
.ep-sc-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 0.8rem; border-top: 1px solid var(--ep-border); }
.ep-sc-date { font-size: 0.8rem; color: var(--ep-text-muted); }
.ep-sc-arrow { font-size: 1.2rem; color: var(--sc); transition: transform 0.2s; }
.ep-state-card:hover .ep-sc-arrow { transform: translateX(4px); }

/* SHOCK STATS */
.ep-shock-section { background: var(--ep-bg-surface); }
.ep-shock-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
.ep-shock-card { position: relative; overflow: hidden; padding: 2rem 1.5rem; border-radius: var(--ep-radius); text-align: center; border: 1px solid var(--ep-border); transition: transform 0.2s; }
.ep-shock-card:hover { transform: translateY(-4px); }
.ep-shock-num { display: block; font-family: var(--ep-font-display); font-size: 2.5rem; font-weight: 900; margin-bottom: 0.3rem; }
.ep-shock-label { font-size: 0.85rem; color: var(--ep-text-secondary); }
.ep-shock-icon { position: absolute; top: 12px; right: 16px; font-size: 1.5rem; opacity: 0.5; }
.ep-shock-red { background: rgba(229,62,62,0.08); }
.ep-shock-red .ep-shock-num { color: #e53e3e; }
.ep-shock-gold { background: rgba(237,137,54,0.08); }
.ep-shock-gold .ep-shock-num { color: #ed8936; }
.ep-shock-blue { background: rgba(37,99,235,0.08); }
.ep-shock-blue .ep-shock-num { color: #2563eb; }
.ep-shock-pink { background: rgba(213,63,140,0.08); }
.ep-shock-pink .ep-shock-num { color: #d53f8c; }

/* GEN Z ISSUES */
.ep-issues-wrap { max-width: 750px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.7rem; }
.ep-issue-row { display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1rem; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius-sm); transition: transform 0.2s; }
.ep-issue-row:hover { transform: translateX(6px); }
.ep-issue-rank { font-family: var(--ep-font-display); font-weight: 800; color: var(--ep-text-muted); min-width: 2rem; font-size: 0.95rem; }
.ep-issue-name { font-weight: 600; min-width: 130px; font-size: 0.9rem; }
.ep-issue-track { flex: 1; height: 8px; background: rgba(255,255,255,0.06); border-radius: 8px; overflow: hidden; }
.ep-issue-fill { height: 100%; border-radius: 8px; }
.ep-issue-pct { font-family: var(--ep-font-display); font-weight: 700; min-width: 2.5rem; text-align: right; font-size: 0.95rem; }

/* TIMELINE */
.ep-timeline { max-width: 600px; margin: 0 auto; }
.ep-tl-item { display: flex; gap: 1rem; }
.ep-tl-dot-col { display: flex; flex-direction: column; align-items: center; width: 48px; flex-shrink: 0; }
.ep-tl-icon { font-size: 1.6rem; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: 50%; }
.ep-tl-line { width: 2px; flex: 1; min-height: 30px; background: linear-gradient(to bottom, var(--ep-border), transparent); }
.ep-tl-content { padding: 0.5rem 0 2rem; }
.ep-tl-month { display: block; font-family: var(--ep-font-display); font-weight: 700; font-size: 1rem; }
.ep-tl-event { display: block; font-size: 0.9rem; color: var(--ep-text-secondary); }
.ep-tl-detail { display: block; font-size: 0.8rem; color: var(--ep-text-muted); margin-top: 0.2rem; }

/* CTA */
.ep-cta-card { background: linear-gradient(135deg, rgba(255,107,53,0.08), rgba(37,99,235,0.08)); border: 1px solid var(--ep-border); border-radius: 24px; padding: 3rem 2rem; text-align: center; }
.ep-cta-card h2 { font-family: var(--ep-font-display); font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 0.6rem; }
.ep-cta-card p { color: var(--ep-text-muted); margin-bottom: 1.5rem; max-width: 500px; margin-left: auto; margin-right: auto; }
.ep-cta-btns { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.8rem; }

@media (max-width: 768px) {
  .ep-hero { padding: 3rem 0 2.5rem; }
  .ep-hero-stats { gap: 0.5rem; }
  .ep-hero-stat { min-width: 90px; padding: 0.7rem 0.8rem; }
  .ep-state-grid { grid-template-columns: 1fr; }
  .ep-shock-grid { grid-template-columns: repeat(2, 1fr); }
  .ep-issue-row { flex-wrap: wrap; }
  .ep-issue-name { min-width: auto; }
  .ep-issue-track { flex-basis: 100%; order: 4; }
}
/* 30-Second Explainers */
.ep-explainers-section { background: var(--ep-bg-surface, rgba(15,15,26,1)); }
.ep-explainer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
.ep-explainer-card { background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-top: 3px solid var(--sc); border-radius: var(--ep-radius); padding: 1.3rem; transition: all 0.2s; }
.ep-explainer-card:hover { transform: translateY(-4px); background: var(--ep-bg-card-hover); }
.ep-exp-emoji { font-size: 2rem; }
.ep-explainer-card h3 { font-family: var(--ep-font-display); font-size: 1.2rem; font-weight: 700; margin: 0.3rem 0 0.6rem; }
.ep-exp-tldr { font-size: 0.85rem; color: var(--ep-text-secondary); line-height: 1.6; margin-bottom: 0.8rem; }
.ep-exp-link { font-size: 0.85rem; font-weight: 600; color: var(--sc); }

/* Quiz CTA */
.ep-quiz-cta { display: flex; align-items: center; justify-content: space-between; gap: 2rem; background: linear-gradient(135deg, rgba(255,107,53,0.08), rgba(37,99,235,0.08)); border: 1px solid var(--ep-border); border-radius: 20px; padding: 2rem; }
.ep-quiz-cta-left { flex: 1; }
.ep-quiz-icon { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; }
.ep-quiz-cta h2 { font-family: var(--ep-font-display); font-size: 1.4rem; font-weight: 700; margin-bottom: 0.4rem; }
.ep-quiz-cta p { font-size: 0.9rem; color: var(--ep-text-muted); }
.ep-quiz-btn { white-space: nowrap; padding: 1rem 2rem; font-size: 1rem; }

@media (max-width: 768px) {
  .ep-quiz-cta { flex-direction: column; text-align: center; }
  .ep-quiz-btn { width: 100%; justify-content: center; }
}
@media (max-width: 480px) {
  .ep-hero-stat { min-width: calc(50% - 0.5rem); }
  .ep-explainer-grid { grid-template-columns: 1fr; }
}
</style>
