---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPosts, stripHtml, formatDate, getFirstTag } from '../lib/wordpress';

let featuredPosts = [];
let totalPosts = 0;

try {
  const { posts } = await getPosts(1, 3);
  featuredPosts = posts;
  totalPosts = posts.length;
} catch (e) {
  console.error('Failed to fetch posts from WordPress:', e);
}
---

<BaseLayout title="Rudra Kasturi — Blog & Portfolio">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <p class="hero-tagline">Welcome to my corner of the internet</p>
      <h1>
        Hi, I'm <span class="gradient-text">Rudra Kasturi</span>.<br />
        I write about tech & ideas.
      </h1>
      <p>
        Exploring AI, cloud computing, and building things that matter.
        Sharing what I learn along the way.
      </p>
      <div class="hero-buttons">
        <a href="/blog" class="btn btn-primary">Read the Blog</a>
        <a href="#about" class="btn btn-outline">About Me</a>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Latest Posts</h2>
      <p class="section-subtitle">What I've been writing about recently</p>

      {featuredPosts.length > 0 ? (
        <div class="posts-grid">
          {featuredPosts.map((post) => {
            const tag = getFirstTag(post);
            const excerpt = stripHtml(post.excerpt.rendered);
            return (
              <article class="post-card">
                {tag && <span class="tag">{tag}</span>}
                <h3><a href={`/blog/${post.slug}`} set:html={post.title.rendered} /></h3>
                <p>{excerpt.length > 150 ? excerpt.slice(0, 150) + '...' : excerpt}</p>
                <span class="post-meta">{formatDate(post.date)}</span>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="section-subtitle">Posts are loading... Check back soon!</p>
      )}

      <div class="view-all">
        <a href="/blog" class="btn btn-outline" style="margin-top: 1.5rem;">View All Posts &rarr;</a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2 class="section-title">About Me</h2>
          <h3>Builder. Learner. Writer.</h3>
          <p>
            I'm Rudra Kasturi — passionate about AI, cloud technologies, and
            solving real-world problems through code. This blog is where I share
            my thoughts, projects, and things I find interesting.
          </p>
          <p>
            When I'm not coding, you'll find me exploring new tech, contributing
            to open source, or diving into research papers.
          </p>
          <div class="social-links">
            <a href="https://github.com/aividhyarthi" target="_blank" rel="noopener">GitHub</a>
            <a href="https://linkedin.com/in/rudrakasturi" target="_blank" rel="noopener">LinkedIn</a>
          </div>
        </div>
        <div class="about-stats">
          <div class="stat-card">
            <div class="stat-number">{totalPosts}+</div>
            <div class="stat-label">Blog Posts</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">AI</div>
            <div class="stat-label">Focus Area</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">Open</div>
            <div class="stat-label">Source Contributor</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">&infin;</div>
            <div class="stat-label">Curiosity</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
