---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPosts, stripHtml, formatDate, getFirstTag } from '../lib/wordpress';

let featuredPosts = [];
let totalPosts = 0;

try {
  const { posts } = await getPosts(1, 6);
  featuredPosts = posts;
  totalPosts = posts.length;
} catch (e) {
  console.error('Failed to fetch posts from WordPress:', e);
}
---

<BaseLayout title="Rudra Kasturi — Search to AI | Ex-Amazon, Yahoo, BYJU's, India Today | CGO & CSO">
  <!-- Hero Section -->
  <section class="hero-premium">
    <div class="hero-bg-effects">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
      <div class="hero-grid-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Search. Strategy. AI. Growth. Revenue.
        </div>
        <h1>
          <span class="hero-line-1">I'm <span class="gradient-text-hero">Rudra Kasturi</span></span>
          <span class="hero-line-2">From Search to AI.</span>
          <span class="hero-line-3">From Startups to <span class="gradient-text-hero">Billion-Dollar</span> Companies.</span>
        </h1>
        <p class="hero-desc">
          CSO at India Today Group. Ex-VP at Times Internet. Ex-SVP at BYJU's.
          Former SEO Head at <strong>Amazon India</strong> & <strong>Yahoo</strong>.
          NVIDIA Alumni. Speaker at <strong>Google I/O</strong>.
          Scaled products to <strong>500M+ users</strong>.
        </p>
        <div class="hero-buttons">
          <a href="/blog" class="btn btn-primary btn-glow">Read My Blog</a>
          <a href="#about" class="btn btn-outline">Discover My Story</a>
          <a href="#contact" class="btn btn-ghost">Get In Touch</a>
        </div>
        <div class="hero-logos">
          <span class="hero-logos-label">Worked With & Featured At</span>
          <div class="logo-strip">
            <span class="logo-tag">Amazon</span>
            <span class="logo-tag">Yahoo</span>
            <span class="logo-tag">NVIDIA</span>
            <span class="logo-tag">Google I/O</span>
            <span class="logo-tag">Times Group</span>
            <span class="logo-tag">BYJU's</span>
            <span class="logo-tag">India Today</span>
            <span class="logo-tag">Tencent</span>
          </div>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-image-wrapper">
          <img src="/images/rudra-googleio.jpeg" alt="Rudra Kasturi speaking at Google I/O 2019" class="hero-main-image" />
          <div class="hero-image-badge">
            <span>Speaker</span>
            Google I/O '19
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credibility Bar -->
  <section class="credibility-bar">
    <div class="container">
      <div class="cred-scroll">
        <div class="cred-item">
          <div class="cred-number">500M+</div>
          <div class="cred-label">Users Scaled</div>
        </div>
        <div class="cred-divider"></div>
        <div class="cred-item">
          <div class="cred-number">20+</div>
          <div class="cred-label">Years in Digital</div>
        </div>
        <div class="cred-divider"></div>
        <div class="cred-item">
          <div class="cred-number">4</div>
          <div class="cred-label">Companies Founded</div>
        </div>
        <div class="cred-divider"></div>
        <div class="cred-item">
          <div class="cred-number">CSO</div>
          <div class="cred-label">Chief Strategy Officer</div>
        </div>
        <div class="cred-divider"></div>
        <div class="cred-item">
          <div class="cred-number">SVP</div>
          <div class="cred-label">Senior Vice President</div>
        </div>
        <div class="cred-divider"></div>
        <div class="cred-item">
          <div class="cred-number">3</div>
          <div class="cred-label">Universities Taught</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Career Timeline / Companies -->
  <section class="section career-section">
    <div class="container">
      <h2 class="section-title text-center">Career at the World's Biggest Companies</h2>
      <p class="section-subtitle text-center">From leading search at Amazon & Yahoo to driving strategy at billion-dollar media empires</p>
      <div class="career-grid">
        <div class="career-card">
          <div class="career-role">Chief Strategy Officer</div>
          <div class="career-company">India Today Group</div>
          <p>Drove digital business strategy, leveraging AI and emerging technologies for revenue and market expansion</p>
        </div>
        <div class="career-card">
          <div class="career-role">VP & Head of Audience Growth</div>
          <div class="career-company">Times Internet (Times Group)</div>
          <p>Grew SEO traffic by 250% in 2 years. Scaled Navbharat Times 10X, GadgetsNow 11X, TimesNowNews 600%</p>
        </div>
        <div class="career-card">
          <div class="career-role">Senior Vice President — Growth</div>
          <div class="career-company">BYJU's</div>
          <p>Headed growth strategy for India and International businesses at the world's largest ed-tech company</p>
        </div>
        <div class="career-card">
          <div class="career-role">SEO Director</div>
          <div class="career-company">Snapdeal</div>
          <p>Led organic search strategy for one of India's largest e-commerce platforms</p>
        </div>
        <div class="career-card">
          <div class="career-role">SEO Head</div>
          <div class="career-company">Amazon India</div>
          <p>Built and scaled organic search for Amazon's India marketplace from the ground up</p>
        </div>
        <div class="career-card">
          <div class="career-role">SEO Head — India, SE Asia & Middle East</div>
          <div class="career-company">Yahoo</div>
          <p>Led search strategy across multiple regions for one of the internet's pioneering companies</p>
        </div>
      </div>
      <div class="career-advisory">
        <h3 class="text-center">Advisory & Consulting</h3>
        <div class="advisory-strip">
          <span class="advisory-tag">NVIDIA Alumni</span>
          <span class="advisory-tag">Tencent Group — Growth Consultant</span>
          <span class="advisory-tag">CRED — Advisor</span>
          <span class="advisory-tag">Antler India — Growth Advisor</span>
          <span class="advisory-tag">Haptik Group — Advisor</span>
          <span class="advisory-tag">Tasva (Aditya Birla) — Consultant</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Gallery - Flashy -->
  <section class="section photo-showcase">
    <div class="container">
      <h2 class="section-title text-center">In The Arena With Industry Titans</h2>
      <p class="section-subtitle text-center">Building relationships with the brightest minds in Search, AI, and Digital</p>
      <div class="photo-grid">
        <div class="photo-card photo-card-featured">
          <div class="photo-wrapper">
            <img src="/images/rudra-googleio.jpeg" alt="Rudra Kasturi speaking at Google I/O 2019" />
            <div class="photo-overlay">
              <span class="photo-tag">Keynote Speaker</span>
            </div>
          </div>
          <div class="photo-info">
            <h3>Google I/O 2019</h3>
            <p>Speaking at Google's flagship developer conference — featured ET & Gaana for PWA at Google I/O</p>
          </div>
        </div>
        <div class="photo-card">
          <div class="photo-wrapper">
            <img src="/images/rudra-rand-fishkin.jpeg" alt="Rudra Kasturi with Rand Fishkin, founder of Moz and SparkToro" />
            <div class="photo-overlay">
              <span class="photo-tag">MozCon</span>
            </div>
          </div>
          <div class="photo-info">
            <h3>With Rand Fishkin</h3>
            <p>Founder of Moz & SparkToro — the godfather of modern SEO</p>
          </div>
        </div>
        <div class="photo-card">
          <div class="photo-wrapper">
            <img src="/images/rudra-matt.jpeg" alt="Rudra Kasturi with Matt Cutts, former head of Google Webspam" />
            <div class="photo-overlay">
              <span class="photo-tag">Google</span>
            </div>
          </div>
          <div class="photo-info">
            <h3>With Matt Cutts</h3>
            <p>Former Head of Google Webspam — the legend who shaped search quality</p>
          </div>
        </div>
        <div class="photo-card">
          <div class="photo-wrapper">
            <img src="/images/rudra-john.jpeg" alt="Rudra Kasturi with John Mueller, Google Search Advocate" />
            <div class="photo-overlay">
              <span class="photo-tag">Google Search</span>
            </div>
          </div>
          <div class="photo-info">
            <h3>With John Mueller</h3>
            <p>Google's Senior Search Analyst & Search Advocate — the voice of Google Search</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section about-premium" id="about">
    <div class="container">
      <div class="about-layout">
        <div class="about-content">
          <div class="about-badge">About Me</div>
          <h2 class="about-headline">The Go-To Person —<br/>From <span class="gradient-text">Search to AI</span>,<br/>Startups to Scale</h2>
          <p class="about-lead">
            I'm Rudra Kasturi — a global digital strategist, growth architect, and AI pioneer
            with 20+ years of experience building, scaling, and transforming digital businesses
            from zero to hundreds of millions of users.
          </p>
          <p>
            I've held C-suite and VP positions as <strong>Chief Strategy Officer</strong> at India Today Group,
            <strong>VP & Head of Audience Growth</strong> at Times Internet, and
            <strong>SVP of Growth</strong> at BYJU's. Before that, I built and led search teams at
            <strong>Amazon India</strong>, <strong>Yahoo</strong>, and <strong>Snapdeal</strong>.
          </p>
          <p>
            At Times Group alone, I grew SEO traffic by <strong>250% in 2 years</strong>, scaled
            Navbharat Times by <strong>10X</strong>, GadgetsNow by <strong>11X</strong>, and
            TimesNowNews by <strong>600%</strong> to No. 3 on comScore. I grew organic traffic
            by <strong>5X from mobile search</strong> and helped Gaana grow by <strong>250%</strong>
            from organic.
          </p>
          <p>
            As a growth consultant, I've worked with <strong>Tencent Group</strong>,
            <strong>CRED</strong>, <strong>Antler India</strong>, <strong>Haptik</strong>,
            and <strong>Tasva (Aditya Birla Group)</strong>. Whether it's a Series A startup
            or a Fortune 500 company — I'm the person who makes growth happen.
          </p>
        </div>
        <div class="about-highlights">
          <div class="highlight-card">
            <div class="highlight-icon">&#9733;</div>
            <h4>C-Suite Executive</h4>
            <p>CSO, SVP, VP — led strategy & growth at India Today, Times Internet, BYJU's</p>
          </div>
          <div class="highlight-card">
            <div class="highlight-icon">&#9775;</div>
            <h4>Search & AI Pioneer</h4>
            <p>From SEO Head at Amazon & Yahoo to driving AI strategy at billion-dollar companies</p>
          </div>
          <div class="highlight-card">
            <div class="highlight-icon">&#9889;</div>
            <h4>500M+ Users Scaled</h4>
            <p>250% SEO growth, 10X traffic, No.1 on comScore — proven results at massive scale</p>
          </div>
          <div class="highlight-card">
            <div class="highlight-icon">&#127758;</div>
            <h4>Global Impact</h4>
            <p>NVIDIA Alumni. Tencent Consultant. Advised startups and enterprises across India, SE Asia & US</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Founder Section -->
  <section class="section founder-section">
    <div class="container">
      <h2 class="section-title text-center">Founder & Builder</h2>
      <p class="section-subtitle text-center">Building companies that create real impact</p>
      <div class="founder-grid">
        <a href="https://aividhyarthi.org" target="_blank" rel="noopener" class="founder-card">
          <div class="founder-logo-text">AIVidhyaRthi</div>
          <p>AI-powered education platform — democratizing learning through artificial intelligence</p>
          <span class="founder-link">aividhyarthi.org &rarr;</span>
        </a>
        <a href="https://appstudiox.com" target="_blank" rel="noopener" class="founder-card">
          <div class="founder-logo-text">AppStudioX</div>
          <p>Product studio building next-generation apps and digital experiences</p>
          <span class="founder-link">appstudiox.com &rarr;</span>
        </a>
        <a href="https://hermidlife.com" target="_blank" rel="noopener" class="founder-card">
          <div class="founder-logo-text">HerMidLife</div>
          <p>Empowering women through content, community, and curated experiences</p>
          <span class="founder-link">hermidlife.com &rarr;</span>
        </a>
        <div class="founder-card founder-card-accent">
          <div class="founder-logo-text">Rudra Kasturi Inc.</div>
          <p>Strategic consulting for enterprises and startups — from search to AI, zero to scale</p>
          <span class="founder-link">Consulting &amp; Advisory</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Speaking & Thought Leadership -->
  <section class="section speaking-section">
    <div class="container">
      <h2 class="section-title text-center">Speaker & Thought Leader</h2>
      <p class="section-subtitle text-center">Sharing knowledge on the world's biggest stages</p>
      <div class="speaking-grid">
        <div class="speaking-card speaking-featured">
          <div class="speaking-video">
            <a href="https://www.youtube.com/watch?v=3As9NibdIjk" target="_blank" rel="noopener" class="video-thumb">
              <img src="/images/rudra-googleio.jpeg" alt="Rudra Kasturi at Google I/O" />
              <div class="play-button">&#9654;</div>
            </a>
          </div>
          <div class="speaking-info">
            <span class="speaking-tag">Featured Talk</span>
            <h3>Google I/O 2019</h3>
            <p>Featured ET & Gaana for Progressive Web Apps at Google's premier developer conference</p>
            <a href="https://www.youtube.com/watch?v=3As9NibdIjk" target="_blank" rel="noopener" class="btn btn-outline btn-sm">Watch on YouTube &rarr;</a>
          </div>
        </div>
        <div class="speaking-list">
          <div class="speaking-item">
            <div class="speaking-item-icon">&#127911;</div>
            <div>
              <h4>Google I/O & AMP Conferences</h4>
              <p>Seasonal speaker at Google's flagship developer and AMP conferences</p>
            </div>
          </div>
          <div class="speaking-item">
            <div class="speaking-item-icon">&#127891;</div>
            <div>
              <h4>MMA Global & Industry Summits</h4>
              <p>Speaker at Mobile Marketing Association and global digital marketing summits</p>
            </div>
          </div>
          <div class="speaking-item">
            <div class="speaking-item-icon">&#128218;</div>
            <div>
              <h4>University Guest Faculty</h4>
              <p>Teaching Digital & AI at Bennett University, ITMI, and Masters' Union</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Teaching & Writing -->
  <section class="section credentials-section">
    <div class="container">
      <div class="credentials-grid">
        <div class="credential-block">
          <h3 class="credential-heading">Educator & Guest Faculty</h3>
          <p class="credential-desc">Shaping the next generation of digital leaders</p>
          <ul class="credential-list">
            <li>
              <strong>Times Bennett University</strong>
              <span>Digital Marketing & AI</span>
            </li>
            <li>
              <strong>ITMI</strong>
              <span>Media, AI & Digital Strategy</span>
            </li>
            <li>
              <strong>Masters' Union</strong>
              <span>Generative AI</span>
            </li>
          </ul>
        </div>
        <div class="credential-block">
          <h3 class="credential-heading">Writer & Columnist</h3>
          <p class="credential-desc">Published in leading global media organizations</p>
          <ul class="credential-list">
            <li>
              <strong>INMA</strong>
              <span>International News Media Association</span>
            </li>
            <li>
              <strong>Times of India</strong>
              <span>India's largest English daily</span>
            </li>
            <li>
              <strong>CNTI.org</strong>
              <span>Center for News, Technology & Innovation</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="section" id="blog">
    <div class="container">
      <h2 class="section-title text-center">Latest From The Blog</h2>
      <p class="section-subtitle text-center">Insights on AI, Search, Digital Strategy, and Building at Scale</p>

      {featuredPosts.length > 0 ? (
        <div class="posts-grid">
          {featuredPosts.map((post) => {
            const tag = getFirstTag(post);
            const excerpt = stripHtml(post.excerpt.rendered);
            return (
              <article class="post-card">
                {tag && <span class="tag">{tag}</span>}
                <h3><a href={`/blog/${post.slug}`} set:html={post.title.rendered} /></h3>
                <p>{excerpt.length > 150 ? excerpt.slice(0, 150) + '...' : excerpt}</p>
                <span class="post-meta">{formatDate(post.date)}</span>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="section-subtitle text-center">Posts are loading... Check back soon!</p>
      )}

      <div class="view-all">
        <a href="/blog" class="btn btn-primary btn-glow" style="margin-top: 2rem;">Read All Posts &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section contact-section" id="contact">
    <div class="container">
      <div class="contact-card">
        <div class="contact-content">
          <h2>Let's Build Something <span class="gradient-text">Extraordinary</span></h2>
          <p>
            Whether you need a growth strategist, an AI advisor, a keynote speaker, or a co-founder
            — I'd love to hear from you. Let's connect and create impact together.
          </p>
          <div class="contact-links">
            <a href="https://linkedin.com/in/rudrakasturi" target="_blank" rel="noopener" class="btn btn-primary btn-glow">Connect on LinkedIn</a>
            <a href="https://github.com/aividhyarthi" target="_blank" rel="noopener" class="btn btn-outline">GitHub</a>
            <a href="https://twitter.com/kasturitagore" target="_blank" rel="noopener" class="btn btn-outline">Twitter / X</a>
          </div>
        </div>
        <div class="contact-roles">
          <div class="role-chip">Keynote Speaker</div>
          <div class="role-chip">AI Strategy Advisor</div>
          <div class="role-chip">Growth Consulting</div>
          <div class="role-chip">Digital Transformation</div>
          <div class="role-chip">Startup Mentorship</div>
          <div class="role-chip">Guest Faculty</div>
          <div class="role-chip">NVIDIA Alumni</div>
          <div class="role-chip">GTM Strategy</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
