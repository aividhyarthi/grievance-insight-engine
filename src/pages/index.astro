---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="QuitDr – Quit Smoking with Doctor-Led Support | Australia"
  description="Book a $10 telehealth consult with an Australian-registered doctor. Get a personalised smoking cessation plan and discreet medication delivery in 24–48 hours."
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-eyebrow">
            <span class="dot"></span>
            Australian-Registered Doctors
          </div>
          <h1>Quit Smoking with<br/><em>Doctor-Led</em> Support</h1>
          <p class="hero-desc">
            Affordable, evidence-based care with discreet medication delivery.
            Start your quit journey with a $10 consult — no GP referral needed.
          </p>
          <div class="hero-actions">
            <a href="/book" class="btn btn-primary btn-lg">Book $10 Consult</a>
            <a href="/services#program" class="btn btn-outline-white btn-lg">Start 3-Month Program</a>
          </div>
          <div class="hero-trust">
            <span class="hero-trust-item"><span class="tick">&#10003;</span> Australian-registered doctors</span>
            <span class="hero-trust-item"><span class="tick">&#10003;</span> Evidence-based care</span>
            <span class="hero-trust-item"><span class="tick">&#10003;</span> Private &amp; confidential</span>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-card">
            <div class="hero-card-title"><span class="dot"></span>Your Quit Plan</div>
            <div class="offer-row">
              <span class="offer-label">&#128203; Doctor Consult</span>
              <span class="offer-price">$10</span>
            </div>
            <div class="offer-row">
              <span class="offer-label">&#127919; 3-Month Program</span>
              <span class="offer-price">$299</span>
            </div>
            <div class="offer-row">
              <span class="offer-label">&#128230; Medication Delivery</span>
              <span class="offer-price">$15 flat</span>
            </div>
            <hr class="hero-card-divider"/>
            <p class="hero-card-note">Medications prescribed only if clinically appropriate. Results vary between individuals.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="section-sm" style="border-bottom: 1px solid var(--clr-border);">
    <div class="container">
      <div class="trust-bar">
        <div class="trust-item">
          <div class="trust-icon">&#9874;</div>
          Australian-Registered Doctors
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#128203;</div>
          Evidence-Based Care
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#128274;</div>
          Private &amp; Confidential
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#128230;</div>
          Discreet Fast Delivery
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#127891;</div>
          TGA-Compliant
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section-alt" id="how-it-works">
    <div class="container">
      <div class="text-center" style="margin-bottom: 1rem;">
        <span class="section-label">How It Works</span>
        <h2 class="section-title">Simple, Doctor-Led, End-to-End</h2>
        <p class="section-subtitle">From your first consult to medication at your door — everything is handled.</p>
      </div>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">1</div>
          <div class="step-icon">&#128203;</div>
          <h3 class="step-title">Book $10 Consult</h3>
          <p class="step-desc">Complete a short intake questionnaire online. Book your telehealth appointment in minutes.</p>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <div class="step-icon">&#128105;&#8205;&#9877;</div>
          <h3 class="step-title">Speak with a Doctor</h3>
          <p class="step-desc">A 10–15 minute telehealth consultation with an Australian-registered doctor. No GP referral needed.</p>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <div class="step-icon">&#127919;</div>
          <h3 class="step-title">Get Your Quit Plan</h3>
          <p class="step-desc">Receive a personalised smoking cessation strategy tailored to your history, triggers, and goals.</p>
        </div>
        <div class="step-card">
          <div class="step-num">4</div>
          <div class="step-icon">&#128230;</div>
          <h3 class="step-title">Medication Delivered</h3>
          <p class="step-desc">If clinically appropriate, your prescription is sent to our partner pharmacy. Discreet delivery in 24–48 hrs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="section" id="programs">
    <div class="container">
      <div class="text-center" style="margin-bottom: 1rem;">
        <span class="section-label">Programs</span>
        <h2 class="section-title">Choose Your Quit Journey</h2>
        <p class="section-subtitle">Whether you want to start with a single consult or commit to a full structured program, we have a path for you.</p>
      </div>
      <div class="pricing-grid">
        <!-- $10 consult -->
        <div class="pricing-card">
          <div class="pricing-badge orange">Entry Point</div>
          <div class="pricing-name">Doctor Consultation</div>
          <div class="pricing-price"><sup>$</sup>10</div>
          <div class="pricing-period">One-time telehealth appointment</div>
          <ul class="pricing-features">
            <li><span class="check">&#10003;</span> Online intake questionnaire</li>
            <li><span class="check">&#10003;</span> 10–15 min telehealth consult (if required)</li>
            <li><span class="check">&#10003;</span> Smoking history &amp; health review</li>
            <li><span class="check">&#10003;</span> Personalised quit strategy</li>
            <li><span class="check">&#10003;</span> Prescription if clinically appropriate</li>
            <li><span class="check">&#10003;</span> Australian-registered doctor</li>
          </ul>
          <a href="/book" class="btn btn-primary pricing-cta">Book Now — $10</a>
        </div>

        <!-- $299 program -->
        <div class="pricing-card featured">
          <div class="pricing-badge">Most Popular</div>
          <div class="pricing-name">3-Month Cessation Program</div>
          <div class="pricing-price"><sup>$</sup>299</div>
          <div class="pricing-period">Full 3-month structured support</div>
          <ul class="pricing-features">
            <li><span class="check">&#10003;</span> Initial doctor consultation</li>
            <li><span class="check">&#10003;</span> Weekly / fortnightly follow-up appointments</li>
            <li><span class="check">&#10003;</span> Structured quitting plan</li>
            <li><span class="check">&#10003;</span> Behavioural coaching &amp; support</li>
            <li><span class="check">&#10003;</span> NRT &amp; pharmacotherapy guidance</li>
            <li><span class="check">&#10003;</span> Progress tracking</li>
            <li><span class="check">&#10003;</span> Prescription management</li>
            <li><span class="check">&#10003;</span> Priority doctor access</li>
          </ul>
          <a href="/book?plan=program" class="btn btn-blue pricing-cta">Start 3-Month Program</a>
        </div>
      </div>

      <!-- Compliance note -->
      <div class="compliance-box" style="margin-top: 2rem; max-width: 760px; margin-left: auto; margin-right: auto;">
        <span class="icon">&#128274;</span>
        <span>This service is designed to support quitting, based on evidence-based care. Outcomes vary between individuals. Medications are prescribed only if clinically appropriate by an Australian-registered doctor. This is a telehealth service — not covered by Medicare.</span>
      </div>
    </div>
  </section>

  <!-- Delivery highlight -->
  <section class="section section-alt" id="delivery">
    <div class="container">
      <div class="text-center" style="margin-bottom: 1rem;">
        <span class="section-label">Pharmacy &amp; Delivery</span>
        <h2 class="section-title">Discreet Medication Delivery</h2>
        <p class="section-subtitle">Doctor prescribes. Partner pharmacy fulfils. Your door in 24–48 hours — discreetly packaged.</p>
      </div>
      <div class="delivery-grid">
        <div class="delivery-card">
          <div class="delivery-icon">&#128274;</div>
          <div class="delivery-title">Discreet Packaging</div>
          <div class="delivery-desc">Plain packaging with no identifying health content on the outside.</div>
        </div>
        <div class="delivery-card">
          <div class="delivery-icon">&#9889;</div>
          <div class="delivery-title">24–48 Hour Delivery</div>
          <div class="delivery-desc">Fast fulfilment via our trusted partner pharmacy network.</div>
        </div>
        <div class="delivery-card">
          <div class="delivery-icon">&#128176;</div>
          <div class="delivery-title">$15 Flat Fee</div>
          <div class="delivery-desc">Simple flat delivery rate. Free on orders over $150.</div>
        </div>
        <div class="delivery-card">
          <div class="delivery-icon">&#128203;</div>
          <div class="delivery-title">Digital Prescription</div>
          <div class="delivery-desc">Doctor sends the prescription directly to the pharmacy — no paperwork.</div>
        </div>
        <div class="delivery-card">
          <div class="delivery-icon">&#128269;</div>
          <div class="delivery-title">Track Your Order</div>
          <div class="delivery-desc">Real-time delivery tracking so you always know where your medication is.</div>
        </div>
        <div class="delivery-card">
          <div class="delivery-icon">&#127891;</div>
          <div class="delivery-title">TGA-Compliant</div>
          <div class="delivery-desc">All medications dispensed under Australian regulatory standards.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why QuitDr -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
        <div>
          <span class="section-label">Why QuitDr</span>
          <h2 class="section-title">Doctor-Led. Affordable. End-to-End.</h2>
          <p style="color: var(--clr-text-secondary); margin-bottom: 1.75rem; line-height: 1.8;">
            Most quit programs rely on coaches or apps. QuitDr puts a real, Australian-registered doctor at the centre of your care — from first consult to prescription to delivery. All in one place.
          </p>
          <div class="stats-row">
            <div class="stat-item">
              <div class="stat-num">$10</div>
              <div class="stat-label">Entry consultation</div>
            </div>
            <div class="stat-item">
              <div class="stat-num">24–48h</div>
              <div class="stat-label">Medication delivery</div>
            </div>
            <div class="stat-item">
              <div class="stat-num">3 months</div>
              <div class="stat-label">Structured support</div>
            </div>
          </div>
          <div style="margin-top: 2rem;">
            <a href="/book" class="btn btn-primary btn-lg">Book $10 Consult</a>
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div class="card" style="display: flex; gap: 1rem; align-items: flex-start;">
            <div class="trust-icon" style="flex-shrink:0;">&#9874;</div>
            <div>
              <strong>Doctor-Led (Not Coach-Only)</strong>
              <p style="font-size:.9rem; color:var(--clr-text-secondary); margin-top:.25rem;">All consultations conducted by Australian-registered doctors. Real medical oversight — not just app guidance.</p>
            </div>
          </div>
          <div class="card" style="display: flex; gap: 1rem; align-items: flex-start;">
            <div class="trust-icon" style="flex-shrink:0;">&#128176;</div>
            <div>
              <strong>Affordable Entry Point</strong>
              <p style="font-size:.9rem; color:var(--clr-text-secondary); margin-top:.25rem;">Start for just $10. No expensive membership or upfront commitment to get professional medical advice.</p>
            </div>
          </div>
          <div class="card" style="display: flex; gap: 1rem; align-items: flex-start;">
            <div class="trust-icon" style="flex-shrink:0;">&#128230;</div>
            <div>
              <strong>End-to-End Care</strong>
              <p style="font-size:.9rem; color:var(--clr-text-secondary); margin-top:.25rem;">Consult, prescription, and discreet delivery — everything managed in one platform. No running around.</p>
            </div>
          </div>
          <div class="card" style="display: flex; gap: 1rem; align-items: flex-start;">
            <div class="trust-icon" style="flex-shrink:0;">&#128274;</div>
            <div>
              <strong>Private &amp; Confidential</strong>
              <p style="font-size:.9rem; color:var(--clr-text-secondary); margin-top:.25rem;">Your health information is handled with full compliance with Australian privacy laws. Discreet delivery.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- For Employers CTA -->
  <section class="section section-dark">
    <div class="container text-center">
      <span class="section-label" style="color: rgba(255,255,255,.7); background: rgba(255,255,255,.1);">For Employers</span>
      <h2 class="section-title light" style="margin-top: .5rem;">Workplace Smoking Cessation Program</h2>
      <p class="section-subtitle light" style="margin: 0 auto 2rem;">Reduce absenteeism, improve productivity, and support your workforce with a fully managed, doctor-led quit program. Minimal HR burden.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/employers" class="btn btn-primary btn-lg">Learn About Employer Programs</a>
        <a href="/employers#contact" class="btn btn-outline-white btn-lg">Request a Demo</a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section-blue">
    <div class="container text-center">
      <h2 class="section-title light">Ready to Quit Smoking?</h2>
      <p class="section-subtitle light" style="margin: 0 auto 2.5rem;">Book your $10 doctor consultation today. Evidence-based support designed to help you quit — your way.</p>
      <a href="/book" class="btn btn-primary btn-lg" style="background:#fff; color:var(--clr-cta); border-color:#fff;">Book $10 Consult Now</a>
      <p style="margin-top: 1.5rem; font-size: .8rem; color: rgba(255,255,255,.6);">Results vary between individuals. Consult a healthcare professional. This is a telehealth service.</p>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 900px) {
    .section div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
