---
import PerimenopauseLayout from '../../layouts/PerimenopauseLayout.astro';
---

<PerimenopauseLayout
  title="Chat with Midlife Guide – hermidlife"
  description="Ask anything about perimenopause. Our compassionate AI companion listens, explains, and helps you understand what's happening in your body — privately and without judgement."
>

  <section class="hml-hero" style="padding: 3.5rem 0 3rem;">
    <div class="container">
      <div class="hml-hero-inner" style="max-width: 640px;">
        <div class="hml-eyebrow">&#128172; Private &amp; anonymous companion</div>
        <h1 style="font-size: clamp(1.9rem, 3.5vw, 2.6rem); margin-bottom: 1rem;">
          How are you feeling lately?
        </h1>
        <p class="hml-hero-desc" style="font-size: 1rem; margin-bottom: 0;">
          Talk freely about what you're experiencing. Our companion listens with empathy, explains in plain language,
          and helps you understand your body — no judgement, no jargon.
        </p>
      </div>
    </div>
  </section>

  <section class="section-sm" style="background: var(--hml-warm-bg); border-bottom: 1px solid var(--hml-border);">
    <div class="container">
      <div class="chat-disclaimer">
        <span class="chat-disclaimer-icon">&#128274;</span>
        <span>
          <strong>Information only — not medical advice.</strong>
          This companion helps you understand perimenopause but cannot diagnose or treat.
          Always consult your GP for personal medical advice.
          In an emergency, call <strong>000</strong>.
        </span>
      </div>
    </div>
  </section>

  <section class="section" style="background: #fff; padding-top: 2.5rem; padding-bottom: 4rem;">
    <div class="container">
      <div class="chat-layout">

        <!-- Sidebar -->
        <aside class="chat-sidebar">
          <div class="chat-sidebar-inner">
            <div class="chat-sidebar-title">What's on your mind?</div>
            <p class="chat-sidebar-desc">Pick a topic to start, or type your own question below.</p>
            <div class="chat-starters" id="chat-starters">
              {[
                { emoji: '😤', label: 'Mood & anger', msg: "I've been feeling irritable and angry lately, more than usual. Could this be perimenopause?" },
                { emoji: '💤', label: 'Sleep problems', msg: "I'm waking up in the night and can't get back to sleep. It's affecting everything. What's going on?" },
                { emoji: '🔥', label: 'Hot flushes', msg: "I keep getting sudden waves of heat, especially at night. Are these hot flushes? What can I do?" },
                { emoji: '🧠', label: 'Brain fog', msg: "My memory and concentration have changed. I forget words mid-sentence. Is this normal in perimenopause?" },
                { emoji: '📅', label: 'Irregular periods', msg: "My periods have become unpredictable — sometimes heavier, sometimes skipped. What does this mean?" },
                { emoji: '😔', label: 'Anxiety & low mood', msg: "I feel anxious and low for no obvious reason. I didn't used to be like this. Could hormones be causing this?" },
                { emoji: '💑', label: 'My wife / partner', msg: "My wife seems emotionally different lately. She's exhausted, irritable, and not herself. Could this be perimenopause?" },
                { emoji: '👩‍👧', label: 'My mum has changed', msg: "My mother has changed a lot in the last year — moody, forgetful, not sleeping. Could she be in perimenopause?" },
              ].map(s => (
                <button class="chat-starter-btn" data-msg={s.msg}>
                  <span class="chat-starter-emoji">{s.emoji}</span>
                  <span>{s.label}</span>
                </button>
              ))}
            </div>

            <div class="chat-sidebar-divider"></div>

            <div class="chat-consult-cta">
              <div class="chat-consult-icon">&#128101;</div>
              <div class="chat-consult-title">Want to talk to a person?</div>
              <p class="chat-consult-desc">
                Book a $10 introductory consult with a women's health specialist.
              </p>
              <a href="/book" class="btn" style="background: var(--hml-primary); color: #fff; border-color: var(--hml-primary); font-size: .88rem; padding: .65rem 1.25rem; display: block; text-align: center; margin-top: .75rem;">
                Book a Consult →
              </a>
            </div>
          </div>
        </aside>

        <!-- Chat window -->
        <div class="chat-window">
          <div class="chat-messages" id="chat-messages">
            <div class="chat-msg chat-msg-assistant" id="welcome-msg">
              <div class="chat-msg-avatar">&#127807;</div>
              <div class="chat-msg-bubble">
                <p>Hello, I'm your <strong>Midlife Guide</strong> — a compassionate companion for perimenopause questions.</p>
                <p style="margin-top: .6rem;">
                  You can ask me anything about what you're experiencing — sleep changes, mood shifts, hot flushes, irregular periods, brain fog, or anything else.
                  I'm here to listen and help you understand what might be happening.
                </p>
                <p style="margin-top: .6rem; font-size: .88rem; color: var(--clr-text-muted);">
                  Choose a topic on the left to start, or type your own question below.
                </p>
              </div>
            </div>
          </div>

          <div class="chat-input-area">
            <div class="chat-input-row">
              <textarea
                id="chat-input"
                class="chat-textarea"
                placeholder="Type your question here... (or choose a topic on the left)"
                rows="2"
                maxlength="1000"
              ></textarea>
              <button id="chat-send" class="chat-send-btn" aria-label="Send">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="22" y1="2" x2="11" y2="13"/>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
              </button>
            </div>
            <div class="chat-input-footer">
              <span id="char-count" class="chat-char-count">0 / 1000</span>
              <span class="chat-input-note">Not medical advice — always see your GP for personal health concerns</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</PerimenopauseLayout>

<style>
  /* ── Layout ── */
  .chat-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Disclaimer ── */
  .chat-disclaimer {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    background: var(--hml-primary-light);
    border: 1.5px solid var(--hml-border);
    border-left: 4px solid var(--hml-primary);
    border-radius: var(--radius-sm);
    padding: 1rem 1.25rem;
    font-size: .85rem;
    color: #5A3045;
    line-height: 1.6;
    max-width: 900px;
    margin: 0 auto;
  }
  .chat-disclaimer-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: .05rem; }

  /* ── Sidebar ── */
  .chat-sidebar-inner {
    background: var(--hml-warm-bg);
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    position: sticky;
    top: 130px;
  }
  .chat-sidebar-title {
    font-size: .95rem;
    font-weight: 700;
    color: var(--clr-text);
    margin-bottom: .35rem;
  }
  .chat-sidebar-desc {
    font-size: .82rem;
    color: var(--clr-text-secondary);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .chat-starters {
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }
  .chat-starter-btn {
    display: flex;
    align-items: center;
    gap: .6rem;
    background: #fff;
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius-sm);
    padding: .55rem .85rem;
    font-size: .83rem;
    color: var(--clr-text);
    cursor: pointer;
    text-align: left;
    transition: all .18s;
    font-family: inherit;
    font-weight: 500;
  }
  .chat-starter-btn:hover {
    border-color: var(--hml-primary);
    background: var(--hml-primary-light);
    color: var(--hml-primary-dark);
  }
  .chat-starter-emoji { font-size: 1rem; flex-shrink: 0; }
  .chat-sidebar-divider {
    border: none;
    border-top: 1px solid var(--hml-border);
    margin: 1.25rem 0;
  }
  .chat-consult-cta {
    background: #fff;
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius-sm);
    padding: 1.1rem;
  }
  .chat-consult-icon { font-size: 1.5rem; margin-bottom: .4rem; }
  .chat-consult-title { font-weight: 700; font-size: .9rem; margin-bottom: .25rem; }
  .chat-consult-desc {
    font-size: .8rem;
    color: var(--clr-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Chat window ── */
  .chat-window {
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #fff;
    min-height: 600px;
  }
  .chat-messages {
    flex: 1;
    padding: 1.75rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-height: 480px;
    max-height: 540px;
  }

  /* ── Messages ── */
  .chat-msg {
    display: flex;
    gap: .75rem;
    align-items: flex-start;
  }
  .chat-msg-user {
    flex-direction: row-reverse;
  }
  .chat-msg-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--hml-primary-light);
    border: 1.5px solid var(--hml-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: .1rem;
  }
  .chat-msg-user .chat-msg-avatar {
    background: var(--hml-sage-light);
  }
  .chat-msg-bubble {
    max-width: 78%;
    background: var(--hml-warm-bg);
    border: 1.5px solid var(--hml-border);
    border-radius: 0 var(--radius) var(--radius) var(--radius);
    padding: 1rem 1.25rem;
    font-size: .92rem;
    line-height: 1.7;
    color: var(--clr-text);
  }
  .chat-msg-bubble p { margin: 0; }
  .chat-msg-bubble p + p { margin-top: .5rem; }
  .chat-msg-user .chat-msg-bubble {
    background: var(--hml-primary);
    border-color: var(--hml-primary-dark);
    border-radius: var(--radius) 0 var(--radius) var(--radius);
    color: #fff;
  }
  .chat-msg-typing .chat-msg-bubble {
    color: var(--clr-text-muted);
    font-style: italic;
  }

  /* Streaming cursor */
  .chat-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--hml-primary);
    vertical-align: middle;
    margin-left: 1px;
    animation: blink .7s steps(1) infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* ── Input area ── */
  .chat-input-area {
    border-top: 1.5px solid var(--hml-border);
    padding: 1rem 1.25rem;
    background: var(--hml-warm-bg);
  }
  .chat-input-row {
    display: flex;
    gap: .6rem;
    align-items: flex-end;
  }
  .chat-textarea {
    flex: 1;
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius-sm);
    padding: .75rem 1rem;
    font-size: .93rem;
    font-family: inherit;
    resize: none;
    line-height: 1.5;
    color: var(--clr-text);
    background: #fff;
    transition: border-color .18s;
    outline: none;
  }
  .chat-textarea:focus {
    border-color: var(--hml-primary);
    box-shadow: 0 0 0 3px rgba(157,78,110,.1);
  }
  .chat-send-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--hml-primary);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background .18s, transform .15s;
  }
  .chat-send-btn:hover { background: var(--hml-primary-dark); }
  .chat-send-btn:active { transform: scale(.93); }
  .chat-send-btn:disabled { background: var(--clr-text-muted); cursor: not-allowed; transform: none; }
  .chat-input-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: .5rem;
  }
  .chat-char-count { font-size: .75rem; color: var(--clr-text-muted); }
  .chat-input-note { font-size: .73rem; color: var(--clr-text-muted); text-align: right; }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .chat-layout {
      grid-template-columns: 1fr;
    }
    .chat-sidebar-inner {
      position: static;
    }
    .chat-starters {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .chat-messages { max-height: 380px; }
  }
  @media (max-width: 480px) {
    .chat-starters { grid-template-columns: 1fr; }
    .chat-msg-bubble { max-width: 90%; }
  }
</style>

<script>
  const messagesEl = document.getElementById('chat-messages') as HTMLDivElement;
  const inputEl = document.getElementById('chat-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
  const charCount = document.getElementById('char-count') as HTMLSpanElement;
  const starterBtns = document.querySelectorAll('.chat-starter-btn') as NodeListOf<HTMLButtonElement>;

  type Message = { role: 'user' | 'assistant'; content: string };
  const history: Message[] = [];
  let isStreaming = false;

  inputEl.addEventListener('input', () => {
    charCount.textContent = `${inputEl.value.length} / 1000`;
    autoResize();
  });

  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage(inputEl.value.trim());
    }
  });

  sendBtn.addEventListener('click', () => sendMessage(inputEl.value.trim()));

  starterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const msg = btn.getAttribute('data-msg') || '';
      sendMessage(msg);
    });
  });

  function autoResize() {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px';
  }

  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function appendUserMsg(text: string) {
    const div = document.createElement('div');
    div.className = 'chat-msg chat-msg-user';
    div.innerHTML = `
      <div class="chat-msg-avatar">&#128100;</div>
      <div class="chat-msg-bubble"><p>${escapeHtml(text)}</p></div>
    `;
    messagesEl.appendChild(div);
    scrollToBottom();
  }

  function createAssistantMsgEl(): HTMLDivElement {
    const div = document.createElement('div');
    div.className = 'chat-msg chat-msg-assistant chat-msg-typing';
    div.innerHTML = `
      <div class="chat-msg-avatar">&#127807;</div>
      <div class="chat-msg-bubble"><p><span class="chat-cursor"></span></p></div>
    `;
    messagesEl.appendChild(div);
    scrollToBottom();
    return div;
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\n/g, '<br>');
  }

  function formatAssistantText(raw: string): string {
    // Convert markdown-ish line breaks to HTML paragraphs
    const paras = raw.split(/\n\n+/);
    return paras
      .map(p => `<p>${p.replace(/\n/g, '<br>')}</p>`)
      .join('');
  }

  async function sendMessage(text: string) {
    if (!text || isStreaming) return;

    isStreaming = true;
    sendBtn.disabled = true;
    inputEl.value = '';
    charCount.textContent = '0 / 1000';
    inputEl.style.height = 'auto';

    appendUserMsg(text);
    history.push({ role: 'user', content: text });

    const msgEl = createAssistantMsgEl();
    const bubble = msgEl.querySelector('.chat-msg-bubble') as HTMLDivElement;

    let accumulated = '';

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history }),
      });

      if (!res.ok || !res.body) {
        throw new Error('Request failed');
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const data = line.slice(6).trim();
          if (data === '[DONE]') break;

          try {
            const parsed = JSON.parse(data);
            if (parsed.text) {
              accumulated += parsed.text;
              bubble.innerHTML = formatAssistantText(accumulated) + '<span class="chat-cursor"></span>';
              scrollToBottom();
            }
            if (parsed.error) {
              throw new Error(parsed.error);
            }
          } catch {
            // ignore parse errors on partial chunks
          }
        }
      }

      // Finalise: remove cursor
      bubble.innerHTML = formatAssistantText(accumulated);
      msgEl.classList.remove('chat-msg-typing');
      history.push({ role: 'assistant', content: accumulated });

    } catch (err) {
      bubble.innerHTML = '<p style="color:#c0392b;">Something went wrong. Please try again.</p>';
      msgEl.classList.remove('chat-msg-typing');
      history.pop(); // remove user message from history on error
    }

    isStreaming = false;
    sendBtn.disabled = false;
    inputEl.focus();
    scrollToBottom();
  }
</script>

