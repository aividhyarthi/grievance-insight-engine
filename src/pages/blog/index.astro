---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog — Rudra Kasturi" description="All blog posts by Rudra Kasturi">
  <div class="container">
    <div class="page-header">
      <h1>Blog</h1>
      <p>All my posts in one place. Thoughts on tech, AI, and building things.</p>
    </div>
    <div class="posts-grid" style="padding-bottom: 4rem;">
      {allPosts.map((post) => (
        <article class="post-card">
          {post.data.tags[0] && <span class="tag">{post.data.tags[0]}</span>}
          <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <span class="post-meta">{formatDate(post.data.pubDate)}</span>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
