---
import BaseLayout from '../../layouts/BaseLayout.astro';
// SSR mode — redirect any unknown blog slugs back to /blog
return Astro.redirect('/blog', 301);
---

<BaseLayout title="QuitDr – Health Resources">
  <section class="page-hero" style="padding:3rem 0;">
    <div class="container">
      <h1>Article Not Found</h1>
      <p>This article doesn't exist.</p>
    </div>
  </section>
  <section class="section">
    <div class="container" style="text-align:center;">
      <a href="/blog" class="btn btn-outline">Back to Health Resources</a>
    </div>
  </section>
</BaseLayout>
