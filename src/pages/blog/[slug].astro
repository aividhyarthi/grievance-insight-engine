---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Blog articles are placeholder — redirect unknown slugs to blog index
export function getStaticPaths() {
  return [];
}
---

<BaseLayout title="Article Not Found – QuitDr">
  <section class="page-hero" style="padding:3rem 0;">
    <div class="container">
      <h1>Article Not Found</h1>
      <p>This article doesn't exist yet.</p>
    </div>
  </section>
  <section class="section">
    <div class="container" style="text-align:center;">
      <a href="/blog" class="btn btn-outline">Back to Health Resources</a>
    </div>
  </section>
</BaseLayout>
