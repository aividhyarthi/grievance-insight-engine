---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={`${post.data.title} — Rudra Kasturi`} description={post.data.description}>
  <div class="container">
    <div class="post-header">
      <a href="/blog" class="back-link">&larr; Back to all posts</a>
      <h1>{post.data.title}</h1>
      <p class="post-meta">
        Published on {formatDate(post.data.pubDate)}
        {post.data.updatedDate && <span> · Updated {formatDate(post.data.updatedDate)}</span>}
      </p>
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </div>
    <article class="post-content">
      <Content />
    </article>
  </div>
</BaseLayout>
