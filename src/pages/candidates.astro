---
import ElectionLayout from '../layouts/ElectionLayout.astro';
import electionData from '../data/elections2026.json';
const { sampleCandidates, candidateCategories, states, electionStats } = electionData;

// Pre-compute category info and state info for each candidate
const enrichedCandidates = sampleCandidates.map(c => ({
  ...c,
  stateName: states.find(s => s.id === c.state)?.name || '',
  categoryInfos: c.categories
    .map(catId => candidateCategories.find(cc => cc.id === catId))
    .filter(Boolean)
}));
---

<ElectionLayout title="Candidate Explorer | Election Pulse 2026">
  <section class="ep-section">
    <div class="ep-container">
      <div class="ep-section-header">
        <div class="ep-badge">CANDIDATE EXPLORER</div>
        <h1 class="ep-section-title" style="margin-top:1rem">Know Your Candidates</h1>
        <p class="ep-section-sub">Filter by type. See who's running. Criminal records, wealth, dynasty — all transparent.</p>
      </div>

      <!-- Shocking Stats -->
      <div class="cx-stats-bar">
        <div class="cx-stat">
          <span class="cx-stat-v cx-red">{electionStats.candidatesWithCriminalCases}</span>
          <span class="cx-stat-l">Have Criminal Cases</span>
        </div>
        <div class="cx-stat">
          <span class="cx-stat-v cx-gold">{electionStats.crorepatiCandidates}</span>
          <span class="cx-stat-l">Are Crorepatis</span>
        </div>
        <div class="cx-stat">
          <span class="cx-stat-v cx-blue">{electionStats.avgWinnerAssets}</span>
          <span class="cx-stat-l">Avg Winner Assets</span>
        </div>
        <div class="cx-stat">
          <span class="cx-stat-v cx-pink">{electionStats.womenCandidates}</span>
          <span class="cx-stat-l">Women Candidates</span>
        </div>
      </div>

      <!-- State Filter -->
      <div class="cx-state-filters">
        <span class="cx-filter-lbl">STATE</span>
        <button class="cx-state-btn cx-state-active" data-state="all">All States</button>
        {states.map((s) => (
          <button class="cx-state-btn" data-state={s.id}>{s.mapEmoji} {s.name}</button>
        ))}
      </div>

      <!-- Filter Tags -->
      <div class="cx-filters">
        <span class="cx-filter-lbl">TYPE</span>
        <button class="cx-filter-btn cx-filter-active" data-filter="all">All</button>
        {candidateCategories.map((cat) => (
          <button class="cx-filter-btn" data-filter={cat.id} style={`--fc:${cat.color}`}>
            {cat.emoji} {cat.label}
          </button>
        ))}
      </div>

      <div class="cx-result-count" id="cx-result-count"></div>

      <!-- Category Explainers -->
      <div class="cx-categories">
        {candidateCategories.map((cat) => (
          <div class="cx-cat-card" style={`--cc:${cat.color}`}>
            <span class="cx-cat-emoji">{cat.emoji}</span>
            <div>
              <span class="cx-cat-label">{cat.label}</span>
              <span class="cx-cat-desc">{cat.description}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Candidate Cards -->
      <div class="cx-grid" id="cx-grid">
        {enrichedCandidates.map((c) => (
            <div class="cx-card" data-categories={c.categories.join(',')} data-state={c.state} style={`--pc:${c.partyColor}`}>
              <div class="cx-card-top">
                <div class="cx-avatar">{c.name.charAt(0)}</div>
                <div class="cx-card-info">
                  <span class="cx-name">{c.name}</span>
                  <span class="cx-party-line">{c.party} &middot; {c.stateName}</span>
                  <span class="cx-const">{c.constituency}</span>
                </div>
                {c.gender === 'F' && <span class="cx-gender-badge">&female;</span>}
              </div>

              <p class="cx-bio">{c.background}</p>

              <div class="cx-data-grid">
                <div class="cx-data">
                  <span class="cx-data-label">Assets</span>
                  <span class="cx-data-value">{c.assets}</span>
                </div>
                <div class="cx-data">
                  <span class="cx-data-label">Criminal Cases</span>
                  <span class:list={['cx-data-value', { 'cx-data-red': c.criminalCases, 'cx-data-green': !c.criminalCases }]}>{c.criminalCases}</span>
                </div>
                <div class="cx-data">
                  <span class="cx-data-label">Age</span>
                  <span class="cx-data-value">{c.age}</span>
                </div>
                <div class="cx-data">
                  <span class="cx-data-label">Terms Won</span>
                  <span class="cx-data-value">{c.terms}</span>
                </div>
                <div class="cx-data">
                  <span class="cx-data-label">Education</span>
                  <span class="cx-data-value">{c.education}</span>
                </div>
              </div>

              <div class="cx-tags">
                {c.categoryInfos.map((catInfo) => (
                  <span class="cx-tag" style={`--tc:${catInfo.color}`}>{catInfo.emoji} {catInfo.label}</span>
                ))}
              </div>
            </div>
        ))}
      </div>

      <div class="cx-source">
        <p>Data sourced from candidate affidavits filed with ECI, analyzed by <a href="https://adrindia.org" target="_blank" rel="noopener">ADR</a> & <a href="https://myneta.info" target="_blank" rel="noopener">MyNeta.info</a></p>
      </div>
    </div>
  </section>
</ElectionLayout>

<script>
  const catButtons = document.querySelectorAll('.cx-filter-btn');
  const stateButtons = document.querySelectorAll('.cx-state-btn');
  const cards = document.querySelectorAll('.cx-card');
  const countEl = document.getElementById('cx-result-count');

  let activeCat = 'all';
  let activeState = 'all';

  // Read ?state=... from URL on load
  const urlState = new URLSearchParams(window.location.search).get('state');
  if (urlState) {
    activeState = urlState;
    stateButtons.forEach(b => {
      b.classList.toggle('cx-state-active', b.getAttribute('data-state') === urlState);
    });
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const cats = card.getAttribute('data-categories') || '';
      const cState = card.getAttribute('data-state') || '';
      const catOk = activeCat === 'all' || cats.split(',').includes(activeCat);
      const stateOk = activeState === 'all' || cState === activeState;
      if (catOk && stateOk) {
        (card as HTMLElement).style.display = '';
        visible++;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
    if (countEl) {
      const stateLabel = activeState === 'all' ? 'all states' : (document.querySelector(`.cx-state-btn[data-state="${activeState}"]`)?.textContent?.trim() || activeState);
      countEl.textContent = `Showing ${visible} candidate${visible === 1 ? '' : 's'} — ${stateLabel}`;
    }
  }

  catButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      catButtons.forEach(b => b.classList.remove('cx-filter-active'));
      btn.classList.add('cx-filter-active');
      activeCat = btn.getAttribute('data-filter') || 'all';
      applyFilters();
    });
  });

  stateButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      stateButtons.forEach(b => b.classList.remove('cx-state-active'));
      btn.classList.add('cx-state-active');
      activeState = btn.getAttribute('data-state') || 'all';
      // Update URL without reload
      const url = new URL(window.location.href);
      if (activeState === 'all') url.searchParams.delete('state');
      else url.searchParams.set('state', activeState);
      window.history.replaceState({}, '', url);
      applyFilters();
    });
  });

  applyFilters();
</script>

<style>
.cx-stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.8rem; margin-bottom: 2rem; }
.cx-stat { text-align: center; padding: 1.2rem; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); }
.cx-stat-v { display: block; font-family: var(--ep-font-display); font-size: 2rem; font-weight: 900; }
.cx-stat-l { font-size: 0.8rem; color: var(--ep-text-muted); }
.cx-red { color: #e53e3e; }
.cx-gold { color: #ed8936; }
.cx-blue { color: #2563eb; }
.cx-pink { color: #d53f8c; }

.cx-state-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; justify-content: center; align-items: center; }
.cx-state-btn { font-family: var(--ep-font); font-size: 0.8rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: var(--ep-radius-pill); background: var(--ep-bg-card); color: var(--ep-text-secondary); border: 1px solid var(--ep-border); cursor: pointer; transition: all 0.2s; }
.cx-state-btn:hover { border-color: var(--ep-border-hover); color: var(--ep-text); }
.cx-state-btn.cx-state-active { background: var(--ep-blue); color: #fff; border-color: var(--ep-blue); }
.cx-filter-lbl { font-size: 0.65rem; font-weight: 800; letter-spacing: 1.5px; color: var(--ep-text-muted); margin-right: 0.4rem; }

.cx-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; justify-content: center; align-items: center; }
.cx-filter-btn { font-family: var(--ep-font); font-size: 0.8rem; font-weight: 600; padding: 0.5rem 1rem; border-radius: var(--ep-radius-pill); background: var(--ep-bg-card); color: var(--ep-text-secondary); border: 1px solid var(--ep-border); cursor: pointer; transition: all 0.2s; }
.cx-filter-btn:hover { border-color: var(--ep-border-hover); color: var(--ep-text); }
.cx-filter-btn.cx-filter-active { background: var(--ep-accent); color: #fff; border-color: var(--ep-accent); }

.cx-result-count { text-align: center; font-size: 0.8rem; color: var(--ep-text-muted); margin-bottom: 1.5rem; font-weight: 600; }

.cx-categories { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0.6rem; margin-bottom: 2.5rem; }
.cx-cat-card { display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1rem; background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius-sm); border-left: 3px solid var(--cc); }
.cx-cat-emoji { font-size: 1.5rem; }
.cx-cat-label { display: block; font-weight: 700; font-size: 0.85rem; }
.cx-cat-desc { display: block; font-size: 0.75rem; color: var(--ep-text-muted); }

.cx-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
.cx-card { background: var(--ep-bg-card); border: 1px solid var(--ep-border); border-radius: var(--ep-radius); padding: 1.3rem; border-left: 3px solid var(--pc); transition: all 0.2s; }
.cx-card:hover { background: var(--ep-bg-card-hover); transform: translateY(-3px); box-shadow: var(--ep-shadow); }
.cx-card-top { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.8rem; }
.cx-avatar { width: 48px; height: 48px; border-radius: 50%; background: var(--pc); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--ep-font-display); font-weight: 800; font-size: 1.3rem; flex-shrink: 0; }
.cx-card-info { flex: 1; }
.cx-name { display: block; font-family: var(--ep-font-display); font-weight: 700; font-size: 1.05rem; }
.cx-party-line { display: block; font-size: 0.75rem; color: var(--ep-text-muted); }
.cx-const { display: block; font-size: 0.7rem; color: var(--ep-text-muted); }
.cx-gender-badge { background: rgba(213,63,140,0.15); color: #d53f8c; font-size: 1.2rem; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }

.cx-bio { font-size: 0.85rem; color: var(--ep-text-secondary); margin-bottom: 1rem; line-height: 1.5; }

.cx-data-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.8rem; }
.cx-data { background: rgba(255,255,255,0.03); padding: 0.4rem 0.7rem; border-radius: 6px; }
.cx-data-label { display: block; font-size: 0.6rem; color: var(--ep-text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.cx-data-value { font-family: var(--ep-font-display); font-weight: 700; font-size: 0.9rem; }
.cx-data-red { color: #e53e3e; }
.cx-data-green { color: #38a169; }

.cx-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.cx-tag { font-size: 0.65rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: var(--ep-radius-pill); background: color-mix(in srgb, var(--tc) 12%, transparent); color: var(--tc); border: 1px solid color-mix(in srgb, var(--tc) 25%, transparent); }

.cx-source { text-align: center; font-size: 0.8rem; color: var(--ep-text-muted); padding: 1.5rem 0; border-top: 1px solid var(--ep-border); }

@media (max-width: 768px) {
  .cx-grid { grid-template-columns: 1fr; }
  .cx-stats-bar { grid-template-columns: repeat(2, 1fr); }
  .cx-categories { grid-template-columns: 1fr; }
}
</style>
