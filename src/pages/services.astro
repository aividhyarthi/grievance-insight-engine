---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Services – QuitDr | $10 Consult & $299 Quit Program"
  description="Explore QuitDr's $10 doctor consultation and $299 3-month smoking cessation program. Doctor-led, evidence-based, with discreet pharmacy delivery."
>

  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label" style="color:rgba(255,255,255,.8); background:rgba(255,255,255,.15); margin-bottom:1rem; display:inline-flex;">Our Services</span>
      <h1>Doctor-Led Smoking Cessation</h1>
      <p>Evidence-based care from an Australian-registered doctor — from first consult to ongoing support and medication delivery.</p>
    </div>
  </section>

  <!-- $10 Consult -->
  <section class="section" id="consult">
    <div class="container">
      <div class="service-detail">
        <div>
          <span class="pill pill-orange">Entry Point</span>
          <div class="service-price-pill" style="margin-top: 1rem;">
            <span class="price">$10</span>
            <span class="period">one-time</span>
          </div>
          <h2 class="section-title">Doctor Consultation</h2>
          <p style="color:var(--clr-text-secondary); line-height:1.8; margin-bottom:1.5rem;">
            Your first step to quitting. A qualified Australian doctor reviews your smoking history, discusses your health, and creates a personalised quit plan. No referral needed, no bulk-billing hassle.
          </p>
          <p style="color:var(--clr-text-secondary); line-height:1.8; margin-bottom:2rem;">
            The consultation is primarily questionnaire-based, with a 10–15 minute telehealth call if required. Fast, private, and designed to fit around your schedule.
          </p>
          <a href="/book" class="btn btn-primary btn-lg">Book $10 Consult</a>
        </div>

        <div style="background: var(--clr-bg-section); border-radius: var(--radius-lg); padding: 2.5rem;">
          <h3 style="font-weight:700; font-size:1.1rem; margin-bottom:1.5rem; color:var(--clr-text);">What's Included</h3>
          <ul class="service-includes">
            <li><span class="check">&#10003;</span> Online intake form (smoking habits, medical history, medications)</li>
            <li><span class="check">&#10003;</span> Telehealth consult with Australian-registered doctor (if required)</li>
            <li><span class="check">&#10003;</span> Comprehensive smoking history review</li>
            <li><span class="check">&#10003;</span> Medical assessment &amp; suitability review</li>
            <li><span class="check">&#10003;</span> Personalised quit strategy</li>
            <li><span class="check">&#10003;</span> Prescription issued if clinically appropriate</li>
            <li><span class="check">&#10003;</span> Option to add medication delivery</li>
          </ul>
          <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--clr-border);">
            <p style="font-size:.82rem; color:var(--clr-text-muted);">
              Medications are prescribed only if clinically appropriate. Results vary between individuals. This is a telehealth service.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div style="border-top: 1px solid var(--clr-border);"></div>

  <!-- $299 Program -->
  <section class="section section-alt" id="program">
    <div class="container">
      <div class="service-detail reverse">
        <div style="background: linear-gradient(135deg, var(--clr-primary) 0%, #2563EB 100%); border-radius: var(--radius-lg); padding: 2.5rem; color: #fff;">
          <h3 style="font-weight:700; font-size:1.1rem; margin-bottom:1.5rem;">What's Included</h3>
          <ul class="service-includes" style="border-color: rgba(255,255,255,.15);">
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> Initial doctor consultation</li>
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> Weekly &amp; fortnightly follow-up appointments</li>
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> Structured 3-month quitting plan</li>
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> Behavioural coaching &amp; support materials</li>
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> NRT &amp; pharmacotherapy guidance</li>
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> Progress tracking &amp; milestone check-ins</li>
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> Prescription management throughout program</li>
            <li style="border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.9);"><span class="check" style="color:#4ADE80;">&#10003;</span> Priority access to your treating doctor</li>
          </ul>
          <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(0,0,0,.2); border-radius: var(--radius-sm); font-size:.82rem; color:rgba(255,255,255,.65);">
            Structured support is designed to support quitting, based on evidence-based care. Outcomes vary between individuals.
          </div>
        </div>

        <div>
          <span class="pill">Most Popular</span>
          <div class="service-price-pill" style="margin-top: 1rem;">
            <span class="price">$299</span>
            <span class="period">3-month program</span>
          </div>
          <h2 class="section-title">3-Month Smoking Cessation Program</h2>
          <p style="color:var(--clr-text-secondary); line-height:1.8; margin-bottom:1.5rem;">
            The most comprehensive quit program we offer. Over three months, you'll work with an Australian-registered doctor through your entire quitting journey — from your first smoke-free day to sustained independence.
          </p>
          <p style="color:var(--clr-text-secondary); line-height:1.8; margin-bottom:2rem;">
            Structured support, regular doctor check-ins, behavioural coaching, and medication guidance — all in one program designed to give you the best chance of success.
          </p>
          <a href="/book?plan=program" class="btn btn-blue btn-lg">Start 3-Month Program</a>
          <p style="margin-top:1rem; font-size:.85rem; color:var(--clr-text-muted);">or <a href="/book" style="color:var(--clr-primary); font-weight:600;">start with a $10 consult first</a></p>
        </div>
      </div>
    </div>
  </section>

  <div style="border-top: 1px solid var(--clr-border);"></div>

  <!-- Pharmacy & Delivery -->
  <section class="section" id="pharmacy">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <span class="section-label">Pharmacy Integration</span>
        <h2 class="section-title">Seamless Medication Fulfilment</h2>
        <p class="section-subtitle">Your doctor sends the prescription digitally. Our partner pharmacy handles everything else.</p>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;">
        <div>
          <h3 style="font-weight:700; margin-bottom:1.25rem;">How the Pharmacy Flow Works</h3>
          <ol style="padding-left:1.5rem; list-style:decimal; display:flex; flex-direction:column; gap:1.25rem;">
            <li style="color:var(--clr-text-secondary); font-size:.95rem; line-height:1.7;">
              <strong style="color:var(--clr-text);">Doctor issues prescription</strong> — digitally, directly from your telehealth consult.
            </li>
            <li style="color:var(--clr-text-secondary); font-size:.95rem; line-height:1.7;">
              <strong style="color:var(--clr-text);">You select your medication</strong> — with guidance from your doctor on what's clinically appropriate.
            </li>
            <li style="color:var(--clr-text-secondary); font-size:.95rem; line-height:1.7;">
              <strong style="color:var(--clr-text);">Checkout</strong> — simple, secure payment. Add delivery to your order.
            </li>
            <li style="color:var(--clr-text-secondary); font-size:.95rem; line-height:1.7;">
              <strong style="color:var(--clr-text);">Partner pharmacy fulfils</strong> — your order is dispensed by a licensed Australian pharmacy.
            </li>
            <li style="color:var(--clr-text-secondary); font-size:.95rem; line-height:1.7;">
              <strong style="color:var(--clr-text);">Delivered to your door</strong> — discreet packaging within 24–48 hours.
            </li>
          </ol>
        </div>

        <div style="display:flex; flex-direction:column; gap:1.25rem;">
          <div class="card" style="display:flex; gap:1rem; align-items:flex-start;">
            <div class="trust-icon" style="flex-shrink:0; background:var(--clr-primary-light); color:var(--clr-primary);">&#128230;</div>
            <div>
              <strong>Discreet Packaging</strong>
              <p style="font-size:.88rem; color:var(--clr-text-secondary); margin-top:.25rem;">Plain packaging — no health content visible on the outside.</p>
            </div>
          </div>
          <div class="card" style="display:flex; gap:1rem; align-items:flex-start;">
            <div class="trust-icon" style="flex-shrink:0; background:var(--clr-primary-light); color:var(--clr-primary);">&#9889;</div>
            <div>
              <strong>24–48 Hour Delivery</strong>
              <p style="font-size:.88rem; color:var(--clr-text-secondary); margin-top:.25rem;">Fast nationwide fulfilment via our trusted pharmacy partner.</p>
            </div>
          </div>
          <div class="card" style="display:flex; gap:1rem; align-items:flex-start;">
            <div class="trust-icon" style="flex-shrink:0; background:var(--clr-primary-light); color:var(--clr-primary);">&#128176;</div>
            <div>
              <strong>Simple, Transparent Pricing</strong>
              <p style="font-size:.88rem; color:var(--clr-text-secondary); margin-top:.25rem;">$15 flat delivery fee. Free on orders over $150.</p>
            </div>
          </div>
          <div class="card" style="display:flex; gap:1rem; align-items:flex-start;">
            <div class="trust-icon" style="flex-shrink:0; background:var(--clr-primary-light); color:var(--clr-primary);">&#127891;</div>
            <div>
              <strong>TGA-Compliant</strong>
              <p style="font-size:.88rem; color:var(--clr-text-secondary); margin-top:.25rem;">All medications dispensed under Australian regulatory standards.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="compliance-box" style="margin-top: 3rem;">
        <span class="icon">&#128274;</span>
        <span>NRT and pharmacotherapy are available if clinically appropriate, as determined by your treating doctor. Medications are not directly promoted — treatment decisions are made by your doctor based on your individual assessment. This service complies with TGA and AHPRA guidelines.</span>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section-blue">
    <div class="container text-center">
      <h2 class="section-title light">Start Your Quit Journey Today</h2>
      <p class="section-subtitle light" style="margin: 0 auto 2.5rem;">Book your $10 doctor consultation. Get a personalised quit plan — and medication delivered if prescribed.</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/book" class="btn btn-primary btn-lg" style="background:#fff; color:var(--clr-cta); border-color:#fff;">Book $10 Consult</a>
        <a href="/book?plan=program" class="btn btn-outline-white btn-lg">Start 3-Month Program</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 900px) {
    .service-detail { grid-template-columns: 1fr !important; gap: 2rem !important; }
    .service-detail.reverse { direction: ltr !important; }
    .section div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
