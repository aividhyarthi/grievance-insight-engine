---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Workforce Smoking Cessation Program – QuitDr for Employers"
  description="Reduce absenteeism and improve productivity with QuitDr's doctor-led workplace smoking cessation program. Fully managed, minimal HR burden. Book a demo today."
>

  <!-- Employer Hero -->
  <section class="employer-hero">
    <div class="container employer-hero-inner">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
        <div>
          <div class="hero-eyebrow" style="margin-bottom:1.25rem;">
            <span class="dot" style="background:#4ADE80;"></span>
            For Employers &amp; HR Teams
          </div>
          <h1 style="font-size:clamp(2.2rem,4.5vw,3.2rem); font-weight:900; line-height:1.15; letter-spacing:-.03em; color:#fff; margin-bottom:1.25rem;">
            Reduce Absenteeism.<br/>
            <span style="color:#6EE7B7;">Support Your Workforce.</span>
          </h1>
          <p style="font-size:1.05rem; color:rgba(255,255,255,.82); line-height:1.75; margin-bottom:2rem; max-width:480px;">
            A doctor-led smoking cessation program for your team. Fully managed, discreet, and designed to deliver real outcomes — with minimal HR workload.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:2.5rem;">
            <a href="#contact" class="btn btn-green btn-lg">Request a Demo</a>
            <a href="#pilot" class="btn btn-outline-white btn-lg">Free Pilot — 10 Employees</a>
          </div>
          <div style="display:flex; flex-wrap:wrap; gap:1.5rem;">
            <span class="hero-trust-item"><span class="tick" style="color:#4ADE80;">&#10003;</span> Doctor-led, not coach-only</span>
            <span class="hero-trust-item"><span class="tick" style="color:#4ADE80;">&#10003;</span> No HR admin burden</span>
            <span class="hero-trust-item"><span class="tick" style="color:#4ADE80;">&#10003;</span> Fast rollout</span>
          </div>
        </div>

        <div>
          <div style="background:rgba(255,255,255,.1); backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,.18); border-radius:var(--radius-lg); padding:2.5rem;">
            <h3 style="color:#fff; font-weight:700; font-size:1rem; margin-bottom:1.5rem;">Workforce Program — At a Glance</h3>
            <div style="display:flex; flex-direction:column; gap:.85rem;">
              <div style="display:flex; justify-content:space-between; align-items:center; padding:.85rem 1rem; background:rgba(255,255,255,.09); border-radius:8px; border:1px solid rgba(255,255,255,.1);">
                <span style="color:rgba(255,255,255,.85); font-size:.9rem;">&#9874;&nbsp; Doctor-led consultations</span>
                <span style="color:#6EE7B7; font-weight:700; font-size:.85rem;">Included</span>
              </div>
              <div style="display:flex; justify-content:space-between; align-items:center; padding:.85rem 1rem; background:rgba(255,255,255,.09); border-radius:8px; border:1px solid rgba(255,255,255,.1);">
                <span style="color:rgba(255,255,255,.85); font-size:.9rem;">&#127919;&nbsp; Structured quit program</span>
                <span style="color:#6EE7B7; font-weight:700; font-size:.85rem;">Included</span>
              </div>
              <div style="display:flex; justify-content:space-between; align-items:center; padding:.85rem 1rem; background:rgba(255,255,255,.09); border-radius:8px; border:1px solid rgba(255,255,255,.1);">
                <span style="color:rgba(255,255,255,.85); font-size:.9rem;">&#128230;&nbsp; Discreet medication delivery</span>
                <span style="color:#6EE7B7; font-weight:700; font-size:.85rem;">Included</span>
              </div>
              <div style="display:flex; justify-content:space-between; align-items:center; padding:.85rem 1rem; background:rgba(255,255,255,.09); border-radius:8px; border:1px solid rgba(255,255,255,.1);">
                <span style="color:rgba(255,255,255,.85); font-size:.9rem;">&#128202;&nbsp; Employer reporting dashboard</span>
                <span style="color:#6EE7B7; font-weight:700; font-size:.85rem;">Included</span>
              </div>
              <div style="display:flex; justify-content:space-between; align-items:center; padding:.85rem 1rem; background:rgba(255,255,255,.09); border-radius:8px; border:1px solid rgba(255,255,255,.1);">
                <span style="color:rgba(255,255,255,.85); font-size:.9rem;">&#128084;&nbsp; HR admin required</span>
                <span style="color:#FCD34D; font-weight:700; font-size:.85rem;">Minimal</span>
              </div>
            </div>
            <div style="margin-top:1.5rem; padding:1rem; background:rgba(0,0,0,.2); border-radius:8px; font-size:.8rem; color:rgba(255,255,255,.6);">
              Co-pay model available — employer subsidises, employee contributes. Maximises uptake.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why it matters (ROI) -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <span class="section-label">The Business Case</span>
        <h2 class="section-title">Why Employers Invest in Smoking Cessation</h2>
        <p class="section-subtitle">Smoking costs Australian businesses through higher absenteeism, reduced productivity, and elevated health insurance premiums.</p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1.5rem;">
        <div class="card" style="text-align:center; border-top:3px solid var(--clr-green);">
          <div style="font-size:2.25rem; font-weight:900; color:var(--clr-green); letter-spacing:-.03em; margin-bottom:.35rem;">33%</div>
          <div style="font-weight:700; margin-bottom:.35rem;">More Sick Days</div>
          <p style="font-size:.87rem; color:var(--clr-text-secondary);">Smokers take significantly more sick days than non-smokers on average.</p>
        </div>
        <div class="card" style="text-align:center; border-top:3px solid var(--clr-primary);">
          <div style="font-size:2.25rem; font-weight:900; color:var(--clr-primary); letter-spacing:-.03em; margin-bottom:.35rem;">$3,200</div>
          <div style="font-weight:700; margin-bottom:.35rem;">Cost Per Employee p.a.</div>
          <p style="font-size:.87rem; color:var(--clr-text-secondary);">Estimated annual productivity cost of smoking per employee (absenteeism + smoke breaks).</p>
        </div>
        <div class="card" style="text-align:center; border-top:3px solid var(--clr-cta);">
          <div style="font-size:2.25rem; font-weight:900; color:var(--clr-cta); letter-spacing:-.03em; margin-bottom:.35rem;">2–3×</div>
          <div style="font-weight:700; margin-bottom:.35rem;">ROI on Cessation Programs</div>
          <p style="font-size:.87rem; color:var(--clr-text-secondary);">Workplace quit programs consistently deliver measurable ROI through productivity and health savings.</p>
        </div>
        <div class="card" style="text-align:center; border-top:3px solid #7C3AED;">
          <div style="font-size:2.25rem; font-weight:900; color:#7C3AED; letter-spacing:-.03em; margin-bottom:.35rem;">21%</div>
          <div style="font-weight:700; margin-bottom:.35rem;">of Australian Workers Smoke</div>
          <p style="font-size:.87rem; color:var(--clr-text-secondary);">Smoking prevalence is higher in trade, logistics, construction, and manufacturing sectors.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Target industries -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center" style="margin-bottom:1rem;">
        <span class="section-label">Industries We Serve</span>
        <h2 class="section-title">Built for High-Prevalence Workforces</h2>
        <p class="section-subtitle">QuitDr's program is particularly effective in industries with higher smoking rates and safety-sensitive roles.</p>
      </div>
      <div class="segments-grid">
        <div class="segment-card">
          <div class="segment-icon">&#127959;</div>
          <div class="segment-name">Construction &amp; Trades</div>
          <p class="segment-why">High smoking prevalence. Safety-sensitive roles. Strong ROI argument for health investment.</p>
          <div style="margin-top:.75rem;"><span class="pill pill-orange">Tier 1</span></div>
        </div>
        <div class="segment-card">
          <div class="segment-icon">&#128666;</div>
          <div class="segment-name">Logistics &amp; Transport</div>
          <p class="segment-why">Long hours drive nicotine dependence. Employers care about fatigue and driver safety.</p>
          <div style="margin-top:.75rem;"><span class="pill pill-orange">Tier 1</span></div>
        </div>
        <div class="segment-card">
          <div class="segment-icon">&#9935;</div>
          <div class="segment-name">Mining &amp; Resources</div>
          <p class="segment-why">FIFO workers. Very high smoking rates. Large employers with strong budgets for workforce health.</p>
          <div style="margin-top:.75rem;"><span class="pill pill-orange">Tier 1</span></div>
        </div>
        <div class="segment-card">
          <div class="segment-icon">&#127869;</div>
          <div class="segment-name">Hospitality</div>
          <p class="segment-why">High turnover and staff health challenges. Smoking cessation improves retention and productivity.</p>
          <div style="margin-top:.75rem;"><span class="pill">Tier 2</span></div>
        </div>
        <div class="segment-card">
          <div class="segment-icon">&#127981;</div>
          <div class="segment-name">Manufacturing</div>
          <p class="segment-why">Factory floor environments with high smoking prevalence. Improves safety culture.</p>
          <div style="margin-top:.75rem;"><span class="pill">Tier 2</span></div>
        </div>
        <div class="segment-card">
          <div class="segment-icon">&#127970;</div>
          <div class="segment-name">Corporate &amp; White Collar</div>
          <p class="segment-why">Lower smoking rates but strong brand credibility and employee wellbeing positioning.</p>
          <div style="margin-top:.75rem;"><span class="pill pill-green">Tier 3</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- The offer -->
  <section class="section">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start;">
        <div>
          <span class="section-label">The Employer Offer</span>
          <h2 class="section-title" style="margin-top:.5rem;">Workforce Smoking Cessation Program</h2>
          <p style="color:var(--clr-text-secondary); line-height:1.8; margin-bottom:1.75rem;">
            A fully managed, doctor-led quit program you can roll out to your workforce in days — not months. QuitDr handles all clinical delivery. Your HR team's workload? Minimal.
          </p>
          <ul class="service-includes">
            <li><span class="check">&#10003;</span> Doctor-led consultations for every enrolled employee</li>
            <li><span class="check">&#10003;</span> Structured 3-month quit program per participant</li>
            <li><span class="check">&#10003;</span> Discreet medication delivery (if prescribed)</li>
            <li><span class="check">&#10003;</span> Aggregate reporting dashboard (privacy-compliant)</li>
            <li><span class="check">&#10003;</span> Dedicated employer account manager</li>
            <li><span class="check">&#10003;</span> No individual health data shared with employer</li>
            <li><span class="check">&#10003;</span> Enrolment materials &amp; communication templates</li>
          </ul>
        </div>

        <!-- Pricing models -->
        <div style="display:flex; flex-direction:column; gap:1.5rem;">
          <h3 style="font-weight:700; font-size:1.05rem; color:var(--clr-text);">Flexible Pricing Models</h3>

          <div class="card" style="border-left:4px solid var(--clr-green);">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:.75rem;">
              <strong>Co-Pay Model</strong>
              <span class="pill pill-green">Recommended</span>
            </div>
            <p style="font-size:.9rem; color:var(--clr-text-secondary); margin-bottom:.75rem;">Employer pays $100–$150 per employee. Employee contributes the remainder. Maximises uptake by reducing the cost barrier.</p>
            <div style="font-size:.85rem; font-weight:600; color:var(--clr-green);">Best conversion rate &amp; ROI</div>
          </div>

          <div class="card" style="border-left:4px solid var(--clr-primary);">
            <div style="margin-bottom:.75rem;">
              <strong>Fully Employer-Paid</strong>
            </div>
            <p style="font-size:.9rem; color:var(--clr-text-secondary);">Employer covers 100% of program cost. Ideal for safety-critical roles or high-value workforce health initiatives.</p>
          </div>

          <div class="card" style="border-left:4px solid var(--clr-text-muted);">
            <div style="margin-bottom:.75rem;">
              <strong>Employee-Paid (Employer Benefit)</strong>
            </div>
            <p style="font-size:.9rem; color:var(--clr-text-secondary);">Employee pays, but QuitDr is offered as a workplace benefit with group access and employer endorsement.</p>
          </div>

          <div class="compliance-box">
            <span class="icon">&#128274;</span>
            <span style="font-size:.8rem;">Individual employee health data is never shared with employers. Reporting is aggregate only. QuitDr is compliant with the Australian Privacy Act.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Free pilot -->
  <section class="section section-dark" id="pilot">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
        <div>
          <span class="section-label" style="color:rgba(255,255,255,.7); background:rgba(255,255,255,.1);">Low Risk</span>
          <h2 class="section-title light" style="margin-top:.5rem;">Start with a Free Pilot</h2>
          <p style="color:rgba(255,255,255,.78); line-height:1.8; margin-bottom:1.75rem;">
            Not ready to commit to a full rollout? We offer a free pilot program for up to 10 employees. No contract, no risk. Just results.
          </p>
          <ul style="list-style:none; display:flex; flex-direction:column; gap:.85rem; margin-bottom:2rem;">
            <li style="display:flex; gap:.75rem; align-items:flex-start; color:rgba(255,255,255,.82); font-size:.95rem;">
              <span style="color:#4ADE80; font-size:1.1rem; flex-shrink:0;">&#10003;</span>
              Up to 10 employees enrolled at no cost
            </li>
            <li style="display:flex; gap:.75rem; align-items:flex-start; color:rgba(255,255,255,.82); font-size:.95rem;">
              <span style="color:#4ADE80; font-size:1.1rem; flex-shrink:0;">&#10003;</span>
              Full program access — consults, quit plan, medication support
            </li>
            <li style="display:flex; gap:.75rem; align-items:flex-start; color:rgba(255,255,255,.82); font-size:.95rem;">
              <span style="color:#4ADE80; font-size:1.1rem; flex-shrink:0;">&#10003;</span>
              Aggregate outcomes report at the end of the pilot
            </li>
            <li style="display:flex; gap:.75rem; align-items:flex-start; color:rgba(255,255,255,.82); font-size:.95rem;">
              <span style="color:#4ADE80; font-size:1.1rem; flex-shrink:0;">&#10003;</span>
              No commitment required to proceed after pilot
            </li>
          </ul>
          <a href="#contact" class="btn btn-green btn-lg">Claim Free Pilot</a>
        </div>
        <div>
          <!-- Funnel visual -->
          <div style="display:flex; flex-direction:column; gap:.75rem;">
            {[
              { step: "1", label: "Cold Outreach / Demo Request", sub: "We connect with your HR or operations team" },
              { step: "2", label: "Book a Demo", sub: "15-minute call — we walk through the program" },
              { step: "3", label: "Free Pilot (10 Employees)", sub: "Risk-free trial — see real results" },
              { step: "4", label: "Collect Pilot Feedback", sub: "We refine and prepare your full rollout" },
              { step: "5", label: "Company-Wide Rollout", sub: "Close the deal — 150–400+ users per company" },
            ].map(item => (
              <div style="display:flex; gap:1rem; align-items:flex-start; padding:1rem 1.25rem; background:rgba(255,255,255,.06); border-radius:var(--radius-sm); border:1px solid rgba(255,255,255,.1);">
                <div style="width:32px; height:32px; border-radius:50%; background:var(--clr-green); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.85rem; flex-shrink:0;">{item.step}</div>
                <div>
                  <div style="font-weight:700; font-size:.9rem; color:#fff; margin-bottom:.2rem;">{item.label}</div>
                  <div style="font-size:.8rem; color:rgba(255,255,255,.55);">{item.sub}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact / demo request -->
  <section class="section" id="contact">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start;">
        <div>
          <span class="section-label">Get in Touch</span>
          <h2 class="section-title" style="margin-top:.5rem;">Request a Demo or Pilot</h2>
          <p style="color:var(--clr-text-secondary); line-height:1.8; margin-bottom:2rem;">
            Tell us about your organisation. We'll get back to you within one business day to book a 15-minute walkthrough of the QuitDr employer program.
          </p>
          <div style="display:flex; flex-direction:column; gap:1.25rem;">
            <div class="trust-item" style="justify-content:flex-start;">
              <div class="trust-icon">&#128197;</div>
              Response within 1 business day
            </div>
            <div class="trust-item" style="justify-content:flex-start;">
              <div class="trust-icon">&#128084;</div>
              No obligation — just a conversation
            </div>
            <div class="trust-item" style="justify-content:flex-start;">
              <div class="trust-icon">&#9874;</div>
              All clinical delivery managed by QuitDr
            </div>
          </div>
        </div>

        <div style="background:#fff; border-radius:var(--radius-lg); border:1px solid var(--clr-border); padding:2.5rem; box-shadow:var(--shadow-sm);">
          <form id="employer-form" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">First Name <span class="required">*</span></label>
                <input type="text" class="form-input" name="first_name" placeholder="Jane" required />
              </div>
              <div class="form-group">
                <label class="form-label">Last Name <span class="required">*</span></label>
                <input type="text" class="form-input" name="last_name" placeholder="Smith" required />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Work Email <span class="required">*</span></label>
              <input type="email" class="form-input" name="email" placeholder="jane@company.com.au" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Company Name <span class="required">*</span></label>
                <input type="text" class="form-input" name="company" placeholder="Acme Pty Ltd" required />
              </div>
              <div class="form-group">
                <label class="form-label">Your Role <span class="required">*</span></label>
                <input type="text" class="form-input" name="role" placeholder="HR Manager" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Industry</label>
                <select class="form-select" name="industry">
                  <option value="">Select industry</option>
                  <option>Construction &amp; Trades</option>
                  <option>Logistics &amp; Transport</option>
                  <option>Mining &amp; Resources</option>
                  <option>Hospitality</option>
                  <option>Manufacturing</option>
                  <option>Corporate / White Collar</option>
                  <option>Healthcare</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Approx. Number of Employees</label>
                <select class="form-select" name="headcount">
                  <option value="">Select range</option>
                  <option>10–50</option>
                  <option>51–200</option>
                  <option>201–500</option>
                  <option>501–2,000</option>
                  <option>2,000+</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">What would you like to discuss?</label>
              <textarea class="form-textarea" name="message" placeholder="e.g. interested in the free pilot, want to understand pricing, have questions about the program..."></textarea>
            </div>
            <button type="submit" class="btn btn-green btn-lg" style="width:100%; justify-content:center;">
              Request Demo / Pilot
            </button>
            <p style="text-align:center; font-size:.8rem; color:var(--clr-text-muted); margin-top:.75rem;">We'll respond within 1 business day.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 900px) {
    section div[style*="grid-template-columns:1fr 1fr"],
    section div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>

<script>
  document.getElementById('employer-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    if (!form.checkValidity()) { form.reportValidity(); return; }
    alert('Thank you! We\'ll be in touch within 1 business day to arrange a demo.');
  });
</script>
