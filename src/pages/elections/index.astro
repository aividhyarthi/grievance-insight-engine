---
import BaseLayout from '../../layouts/BaseLayout.astro';
import electionData from '../../data/elections2026.json';

const { meta, states, nationalParties, timeline, quickFacts, genZIssues } = electionData;
---

<BaseLayout title="Election Pulse 2026 | India Votes Visually" description="Visual-first election dashboard for India's 2026 state elections. Stats, seats, parties — zero walls of text.">

  <!-- Hero Banner -->
  <section class="ep-hero">
    <div class="ep-hero-bg">
      <div class="ep-orb ep-orb-1"></div>
      <div class="ep-orb ep-orb-2"></div>
      <div class="ep-orb ep-orb-3"></div>
    </div>
    <div class="container ep-hero-content">
      <div class="ep-hero-badge">LIVE TRACKER</div>
      <h1 class="ep-hero-title">
        <span class="ep-title-line1">Election</span>
        <span class="ep-title-line2">Pulse <span class="ep-year">2026</span></span>
      </h1>
      <p class="ep-hero-tagline">{meta.tagline}</p>
      <div class="ep-hero-chips">
        <span class="ep-chip">{meta.totalStates} States</span>
        <span class="ep-chip">{meta.totalSeats} Seats</span>
        <span class="ep-chip">{meta.totalVoters} Voters</span>
        <span class="ep-chip ep-chip-genz">{meta.genZVoters} Gen Z</span>
      </div>
    </div>
  </section>

  <!-- Quick Facts — Big Number Cards -->
  <section class="ep-section">
    <div class="container">
      <div class="ep-facts-grid">
        {quickFacts.map((fact) => (
          <div class="ep-fact-card">
            <span class="ep-fact-icon">{fact.icon}</span>
            <span class="ep-fact-value">{fact.value}</span>
            <span class="ep-fact-label">{fact.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- State Election Cards -->
  <section class="ep-section">
    <div class="container">
      <h2 class="ep-section-title">States Going to Polls</h2>
      <p class="ep-section-sub">Tap a state to explore. Each card = one battleground.</p>
      <div class="ep-states-grid">
        {states.map((state) => (
          <div class="ep-state-card" style={`--state-color: ${state.color}`}>
            <div class="ep-state-header">
              <span class="ep-state-emoji">{state.mapEmoji}</span>
              <div>
                <h3 class="ep-state-name">{state.name}</h3>
                <span class="ep-state-ruling">Current: {state.currentRuling}</span>
              </div>
              <span class="ep-state-status">{state.status === 'upcoming' ? 'UPCOMING' : 'LIVE'}</span>
            </div>

            <div class="ep-state-stats">
              <div class="ep-stat-pill">
                <span class="ep-stat-num">{state.seats}</span>
                <span class="ep-stat-lbl">Seats</span>
              </div>
              <div class="ep-stat-pill">
                <span class="ep-stat-num">{state.voters}</span>
                <span class="ep-stat-lbl">Voters</span>
              </div>
              <div class="ep-stat-pill">
                <span class="ep-stat-num">{state.genZPercent}%</span>
                <span class="ep-stat-lbl">Gen Z</span>
              </div>
            </div>

            <div class="ep-state-issue">
              <span class="ep-issue-tag">Key Issue</span>
              <span class="ep-issue-text">{state.keyIssue}</span>
            </div>

            <div class="ep-state-date">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {state.electionDate}
            </div>

            <!-- Seat Distribution Visual Bar -->
            <div class="ep-seat-bar">
              {state.parties.map((party) => (
                <div
                  class="ep-seat-segment"
                  style={`width: ${(party.seats2021 / state.seats) * 100}%; background: ${party.color};`}
                  title={`${party.name}: ${party.seats2021} seats`}
                >
                  {(party.seats2021 / state.seats) * 100 > 12 && (
                    <span class="ep-seg-label">{party.name}</span>
                  )}
                </div>
              ))}
            </div>
            <div class="ep-seat-legend">
              {state.parties.map((party) => (
                <span class="ep-legend-item">
                  <span class="ep-legend-dot" style={`background: ${party.color}`}></span>
                  {party.icon} {party.name} <strong>{party.seats2021}</strong>
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Party Strength Overview -->
  <section class="ep-section ep-section-dark">
    <div class="container">
      <h2 class="ep-section-title">National Parties at a Glance</h2>
      <div class="ep-parties-grid">
        {nationalParties.map((party) => (
          <div class="ep-party-card" style={`--party-color: ${party.color}`}>
            <span class="ep-party-icon">{party.icon}</span>
            <h3 class="ep-party-name">{party.name}</h3>
            <p class="ep-party-full">{party.fullName}</p>
            <div class="ep-party-meta">
              <span class="ep-party-tag">{party.ideology}</span>
              <span class="ep-party-tag">Est. {party.founded}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gen Z Issues — What Matters Most -->
  <section class="ep-section">
    <div class="container">
      <h2 class="ep-section-title">What Gen Z Cares About</h2>
      <p class="ep-section-sub">Top issues driving 48M+ young voters to the polls</p>
      <div class="ep-issues-list">
        {genZIssues.map((item, idx) => (
          <div class="ep-issue-row">
            <span class="ep-issue-rank">#{idx + 1}</span>
            <span class="ep-issue-name">{item.issue}</span>
            <div class="ep-issue-bar-wrapper">
              <div class="ep-issue-bar" style={`width: ${item.percent}%; background: ${item.color};`}></div>
            </div>
            <span class="ep-issue-pct">{item.percent}%</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Election Timeline -->
  <section class="ep-section ep-section-dark">
    <div class="container">
      <h2 class="ep-section-title">Election Timeline</h2>
      <div class="ep-timeline">
        {timeline.map((item, idx) => (
          <div class="ep-timeline-item">
            <div class="ep-timeline-dot-wrap">
              <span class="ep-timeline-icon">{item.icon}</span>
              {idx < timeline.length - 1 && <div class="ep-timeline-line"></div>}
            </div>
            <div class="ep-timeline-content">
              <span class="ep-timeline-month">{item.month}</span>
              <span class="ep-timeline-event">{item.event}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="ep-cta">
    <div class="container">
      <div class="ep-cta-card">
        <h2>Your vote. Your voice. Your future.</h2>
        <p>48M+ Gen Z voters will shape India's next chapter. Stay informed, stay visual.</p>
        <div class="ep-cta-buttons">
          <a href="/" class="btn btn-primary btn-glow">Back to Home</a>
          <a href="/blog" class="btn btn-outline">Read Analysis</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ============================================
   ELECTION PULSE 2026 — GEN Z VISUAL DASHBOARD
   ============================================ */

/* Hero */
.ep-hero {
  position: relative;
  overflow: hidden;
  padding: 6rem 0 4rem;
  background: linear-gradient(135deg, #0f0f1a 0%, #1a1035 40%, #0d1b2a 100%);
  color: #fff;
  text-align: center;
}

.ep-hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.ep-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.4;
  animation: ep-float 8s ease-in-out infinite;
}

.ep-orb-1 {
  width: 400px; height: 400px;
  background: #ff6b35;
  top: -100px; left: -100px;
  animation-delay: 0s;
}

.ep-orb-2 {
  width: 350px; height: 350px;
  background: #138808;
  bottom: -80px; right: -80px;
  animation-delay: 2s;
}

.ep-orb-3 {
  width: 300px; height: 300px;
  background: #2563eb;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: 4s;
}

@keyframes ep-float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-30px) scale(1.05); }
}

.ep-hero-content {
  position: relative;
  z-index: 2;
}

.ep-hero-badge {
  display: inline-block;
  background: rgba(255, 107, 53, 0.2);
  border: 1px solid rgba(255, 107, 53, 0.4);
  color: #ff6b35;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 3px;
  padding: 0.4rem 1.2rem;
  border-radius: 50px;
  margin-bottom: 1.5rem;
  font-family: var(--font-body);
}

.ep-hero-title {
  font-family: var(--font-heading);
  font-size: clamp(3rem, 8vw, 6rem);
  font-weight: 800;
  line-height: 1.05;
  margin-bottom: 1rem;
}

.ep-title-line1 {
  display: block;
  color: rgba(255,255,255,0.9);
}

.ep-title-line2 {
  display: block;
}

.ep-year {
  background: linear-gradient(135deg, #ff6b35, #ff9f1c);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.ep-hero-tagline {
  font-size: 1.2rem;
  color: rgba(255,255,255,0.6);
  margin-bottom: 2rem;
  font-weight: 400;
}

.ep-hero-chips {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0.6rem;
}

.ep-chip {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.85);
  padding: 0.5rem 1.2rem;
  border-radius: 50px;
  font-size: 0.9rem;
  font-weight: 600;
  backdrop-filter: blur(10px);
}

.ep-chip-genz {
  background: linear-gradient(135deg, rgba(255,107,53,0.25), rgba(255,159,28,0.25));
  border-color: rgba(255,107,53,0.5);
  color: #ff9f1c;
}

/* Sections */
.ep-section {
  padding: 4rem 0;
}

.ep-section-dark {
  background: #0f0f1a;
  color: #fff;
}

.ep-section-title {
  font-family: var(--font-heading);
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  font-weight: 700;
  text-align: center;
  margin-bottom: 0.5rem;
}

.ep-section-dark .ep-section-title {
  color: #fff;
}

.ep-section-sub {
  text-align: center;
  color: var(--color-text-muted);
  font-size: 1rem;
  margin-bottom: 2.5rem;
}

.ep-section-dark .ep-section-sub {
  color: rgba(255,255,255,0.5);
}

/* Quick Facts Grid */
.ep-facts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
}

.ep-fact-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
  padding: 1.5rem 1rem;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: 16px;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s, box-shadow 0.2s;
}

.ep-fact-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.ep-fact-icon {
  font-size: 2rem;
}

.ep-fact-value {
  font-family: var(--font-heading);
  font-size: 1.8rem;
  font-weight: 800;
  color: var(--color-text);
}

.ep-fact-label {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* State Cards Grid */
.ep-states-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 1.5rem;
}

.ep-state-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: 20px;
  padding: 1.5rem;
  box-shadow: var(--shadow-md);
  transition: transform 0.2s, box-shadow 0.3s;
  border-top: 4px solid var(--state-color);
}

.ep-state-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}

.ep-state-header {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  margin-bottom: 1.2rem;
}

.ep-state-emoji {
  font-size: 2.5rem;
}

.ep-state-name {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
}

.ep-state-ruling {
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.ep-state-status {
  margin-left: auto;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--state-color);
  background: color-mix(in srgb, var(--state-color) 10%, transparent);
  padding: 0.3rem 0.8rem;
  border-radius: 50px;
  border: 1px solid color-mix(in srgb, var(--state-color) 30%, transparent);
}

.ep-state-stats {
  display: flex;
  gap: 0.8rem;
  margin-bottom: 1rem;
}

.ep-stat-pill {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0.7rem 0.5rem;
  background: var(--color-bg);
  border-radius: 12px;
}

.ep-stat-num {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--color-text);
}

.ep-stat-lbl {
  font-size: 0.7rem;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.ep-state-issue {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.8rem;
}

.ep-issue-tag {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--state-color);
  background: color-mix(in srgb, var(--state-color) 10%, transparent);
  padding: 0.2rem 0.6rem;
  border-radius: 6px;
}

.ep-issue-text {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.ep-state-date {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--color-text-muted);
  margin-bottom: 1.2rem;
}

/* Seat Distribution Bar */
.ep-seat-bar {
  display: flex;
  height: 28px;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 0.8rem;
  gap: 2px;
}

.ep-seat-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 4px;
  transition: opacity 0.2s;
  position: relative;
}

.ep-seat-segment:hover {
  opacity: 0.85;
}

.ep-seg-label {
  font-size: 0.65rem;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  letter-spacing: 0.5px;
}

.ep-seat-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
}

.ep-legend-item {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.8rem;
  color: var(--color-text-secondary);
}

.ep-legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
}

/* Party Cards */
.ep-parties-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
}

.ep-party-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 1.5rem;
  text-align: center;
  transition: transform 0.2s, background 0.2s;
  border-top: 3px solid var(--party-color);
}

.ep-party-card:hover {
  transform: translateY(-4px);
  background: rgba(255,255,255,0.08);
}

.ep-party-icon {
  font-size: 2.5rem;
  display: block;
  margin-bottom: 0.6rem;
}

.ep-party-name {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.2rem;
}

.ep-party-full {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  margin-bottom: 0.8rem;
  line-height: 1.4;
}

.ep-party-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  justify-content: center;
}

.ep-party-tag {
  font-size: 0.65rem;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.08);
  padding: 0.2rem 0.6rem;
  border-radius: 6px;
}

/* Gen Z Issues */
.ep-issues-list {
  max-width: 700px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.ep-issue-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: var(--color-bg-card);
  padding: 1rem 1.2rem;
  border-radius: 14px;
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}

.ep-issue-row:hover {
  transform: translateX(6px);
}

.ep-issue-rank {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--color-text-muted);
  min-width: 2rem;
}

.ep-issue-name {
  font-size: 0.95rem;
  font-weight: 600;
  min-width: 120px;
  color: var(--color-text);
}

.ep-issue-bar-wrapper {
  flex: 1;
  height: 10px;
  background: var(--color-border-light);
  border-radius: 10px;
  overflow: hidden;
}

.ep-issue-bar {
  height: 100%;
  border-radius: 10px;
  transition: width 1s ease-out;
}

.ep-issue-pct {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 700;
  min-width: 3rem;
  text-align: right;
  color: var(--color-text);
}

/* Timeline */
.ep-timeline {
  max-width: 600px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.ep-timeline-item {
  display: flex;
  gap: 1.2rem;
  align-items: flex-start;
}

.ep-timeline-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 48px;
}

.ep-timeline-icon {
  font-size: 1.8rem;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.15);
}

.ep-timeline-line {
  width: 2px;
  height: 40px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.2), rgba(255,255,255,0.05));
}

.ep-timeline-content {
  padding: 0.6rem 0 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.ep-timeline-month {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 700;
  color: #fff;
}

.ep-timeline-event {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.55);
}

/* CTA */
.ep-cta {
  padding: 4rem 0 5rem;
  background: linear-gradient(135deg, #0f0f1a 0%, #1a1035 100%);
}

.ep-cta-card {
  background: linear-gradient(135deg, rgba(255,107,53,0.1), rgba(37,99,235,0.1));
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
  padding: 3rem 2rem;
  text-align: center;
}

.ep-cta-card h2 {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.8rem;
}

.ep-cta-card p {
  color: rgba(255,255,255,0.55);
  font-size: 1rem;
  margin-bottom: 2rem;
}

.ep-cta-buttons {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 1rem;
}

/* Responsive */
@media (max-width: 768px) {
  .ep-hero {
    padding: 4rem 0 3rem;
  }
  .ep-states-grid {
    grid-template-columns: 1fr;
  }
  .ep-parties-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .ep-facts-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .ep-issue-row {
    flex-wrap: wrap;
  }
  .ep-issue-name {
    min-width: auto;
  }
  .ep-issue-bar-wrapper {
    flex-basis: 100%;
    order: 4;
  }
}

@media (max-width: 480px) {
  .ep-facts-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .ep-parties-grid {
    grid-template-columns: 1fr 1fr;
  }
  .ep-hero-chips {
    gap: 0.4rem;
  }
  .ep-chip {
    font-size: 0.8rem;
    padding: 0.4rem 0.8rem;
  }
}
</style>
