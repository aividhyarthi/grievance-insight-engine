---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Perimenopause Guide – hermidlife',
  description = 'Your trusted guide to perimenopause. Understand symptoms, changes, and how to navigate this stage of life — in plain language, with Australian context.',
} = Astro.props;

const currentPath = Astro.url.pathname;

const subnav = [
  { label: 'Overview',      href: '/perimenopause' },
  { label: 'Symptom Library', href: '/perimenopause/library' },
  { label: 'Topic Guides',  href: '/perimenopause/guides' },
  { label: 'FAQs',          href: '/perimenopause/faq' },
  { label: 'Talk to Your GP', href: '/perimenopause/talk-to-gp' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>

    <!-- Main navbar (same as site) -->
    <nav class="navbar">
      <div class="container navbar-inner">
        <a href="/" class="navbar-brand">
          Quit<span class="brand-dr">Dr</span>
        </a>
        <ul class="navbar-links" id="navbar-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/employers">For Employers</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="/perimenopause" style="color: #9D4E6E; font-weight: 600;">Perimenopause Guide</a></li>
        </ul>
        <a href="/book" class="btn btn-primary navbar-cta">Book $10 Consult</a>
        <button class="navbar-mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Perimenopause sub-navigation -->
    <div class="hml-subnav">
      <div class="container hml-subnav-inner">
        <a href="/perimenopause" class="hml-subnav-brand">
          <span class="hml-brand-her">her</span><span class="hml-brand-mid">mid</span><span class="hml-brand-life">life</span>
        </a>
        <ul class="hml-subnav-links" id="hml-subnav-links">
          {subnav.map(item => (
            <li>
              <a
                href={item.href}
                class:list={[{
                  'hml-active': item.href === '/perimenopause'
                    ? currentPath === '/perimenopause' || currentPath === '/perimenopause/'
                    : currentPath.startsWith(item.href)
                }]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <button class="hml-mobile-toggle" id="hml-mobile-toggle" aria-label="Toggle guide menu">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <div class="footer-brand-name"><span style="color:#C4798F;">her</span>mid<span style="color:#C4798F;">life</span></div>
            <p class="footer-tagline">A trusted information guide for women navigating perimenopause. Not a medical service — your GP is always your first port of call.</p>
            <div class="footer-disclaimer">
              This guide provides general health information only. It is not a substitute for professional medical advice, diagnosis, or treatment. Always consult your GP or a qualified healthcare professional about your symptoms and circumstances.
            </div>
          </div>
          <div class="footer-col">
            <h4>Guide</h4>
            <ul>
              <li><a href="/perimenopause">Overview</a></li>
              <li><a href="/perimenopause/library">Symptom Library</a></li>
              <li><a href="/perimenopause/guides">Topic Guides</a></li>
              <li><a href="/perimenopause/faq">FAQs</a></li>
              <li><a href="/perimenopause/talk-to-gp">Talk to Your GP</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Also from us</h4>
            <ul>
              <li><a href="/">QuitDr</a></li>
              <li><a href="/services">Quit Smoking Support</a></li>
              <li><a href="/employers">For Employers</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Legal</h4>
            <ul>
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms &amp; Conditions</a></li>
              <li><a href="/disclaimer">Medical Disclaimer</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} hermidlife. General health information only — not medical advice.</p>
          <div class="footer-legal-links">
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
            <a href="/disclaimer">Disclaimer</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Main navbar mobile toggle
      const toggle = document.getElementById('mobile-toggle');
      const links = document.getElementById('navbar-links');
      toggle?.addEventListener('click', () => links?.classList.toggle('open'));

      // Sub-nav mobile toggle
      const hmlToggle = document.getElementById('hml-mobile-toggle');
      const hmlLinks = document.getElementById('hml-subnav-links');
      hmlToggle?.addEventListener('click', () => hmlLinks?.classList.toggle('hml-open'));

      // FAQ accordion
      document.querySelectorAll('.faq-question').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item');
          const isOpen = item?.classList.contains('open');
          document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
          if (!isOpen) item?.classList.add('open');
        });
      });
    </script>

  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* ── hermidlife brand tokens ── */
  :root {
    --hml-primary:       #9D4E6E;
    --hml-primary-dark:  #7A3654;
    --hml-primary-light: #FCF0F5;
    --hml-accent:        #E07A5F;
    --hml-accent-light:  #FDF2EF;
    --hml-sage:          #6B8F6B;
    --hml-sage-light:    #F0F5F0;
    --hml-warm-bg:       #FDF8F9;
    --hml-border:        #F0DDE6;
  }

  /* ── Sub-navigation bar ── */
  .hml-subnav {
    background: var(--hml-primary-light);
    border-bottom: 2px solid var(--hml-border);
    position: sticky;
    top: 64px;
    z-index: 90;
  }
  .hml-subnav-inner {
    display: flex;
    align-items: center;
    height: 52px;
    gap: 1.5rem;
  }
  .hml-subnav-brand {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -.02em;
    text-decoration: none;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .hml-brand-her  { color: var(--hml-primary); }
  .hml-brand-mid  { color: var(--hml-primary-dark); }
  .hml-brand-life { color: var(--hml-accent); }

  .hml-subnav-links {
    display: flex;
    align-items: center;
    gap: .15rem;
    list-style: none;
    flex: 1;
  }
  .hml-subnav-links a {
    color: #5A3045;
    font-size: .88rem;
    font-weight: 500;
    padding: .35rem .8rem;
    border-radius: 6px;
    transition: all .18s;
    text-decoration: none;
    white-space: nowrap;
  }
  .hml-subnav-links a:hover,
  .hml-subnav-links a.hml-active {
    background: var(--hml-primary);
    color: #fff;
  }
  .hml-mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: .35rem;
    color: var(--hml-primary);
    margin-left: auto;
  }

  /* ── hermidlife page hero ── */
  .hml-hero {
    background: linear-gradient(145deg, #5A1D35 0%, #9D4E6E 55%, #C4798F 100%);
    color: #fff;
    padding: 5rem 0 4.5rem;
    position: relative;
    overflow: hidden;
  }
  .hml-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 50% at 85% 35%, rgba(224,122,95,.3) 0%, transparent 65%),
      radial-gradient(ellipse 40% 55% at 10% 75%, rgba(107,143,107,.15) 0%, transparent 60%);
  }
  .hml-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }
  .hml-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .76rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.75);
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    padding: .35rem .9rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }
  .hml-hero h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 900;
    line-height: 1.18;
    letter-spacing: -.03em;
    margin-bottom: 1.25rem;
    color: #fff;
  }
  .hml-hero h1 em { font-style: normal; color: #FBBF81; }
  .hml-hero-desc {
    font-size: 1.08rem;
    color: rgba(255,255,255,.85);
    line-height: 1.75;
    margin-bottom: 2rem;
    max-width: 520px;
  }
  .hml-disclaimer-strip {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: var(--radius-sm);
    padding: .65rem 1rem;
    font-size: .82rem;
    color: rgba(255,255,255,.8);
    line-height: 1.5;
    margin-top: 1.5rem;
  }

  /* ── Section label override for hermidlife ── */
  .hml-label {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--hml-primary);
    background: var(--hml-primary-light);
    padding: .35rem .85rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  /* ── Symptom cards (library) ── */
  .hml-symptoms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .hml-symptom-card {
    background: #fff;
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: all .22s;
    cursor: default;
  }
  .hml-symptom-card:hover {
    border-color: var(--hml-primary);
    box-shadow: 0 6px 24px rgba(157,78,110,.12);
    transform: translateY(-2px);
  }
  .hml-symptom-icon { font-size: 2rem; margin-bottom: .75rem; }
  .hml-symptom-name { font-size: 1.05rem; font-weight: 700; margin-bottom: .4rem; color: var(--clr-text); }
  .hml-symptom-why { font-size: .87rem; color: var(--clr-text-secondary); line-height: 1.6; margin-bottom: .75rem; }
  .hml-symptom-tag {
    display: inline-block;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: .2rem .65rem;
    border-radius: 100px;
    background: var(--hml-primary-light);
    color: var(--hml-primary);
  }
  .hml-symptom-tag.physical { background: #FDF2EF; color: var(--hml-accent); }
  .hml-symptom-tag.mental   { background: var(--hml-primary-light); color: var(--hml-primary); }
  .hml-symptom-tag.hormonal { background: var(--hml-sage-light); color: var(--hml-sage); }

  /* ── Guide cards ── */
  .hml-guides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 2.5rem;
  }
  .hml-guide-card {
    background: #fff;
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: all .22s;
  }
  .hml-guide-card:hover {
    border-color: var(--hml-primary);
    box-shadow: 0 8px 32px rgba(157,78,110,.12);
    transform: translateY(-2px);
  }
  .hml-guide-num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--hml-primary-light);
    color: var(--hml-primary);
    font-weight: 800;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .hml-guide-title { font-size: 1.1rem; font-weight: 700; margin-bottom: .5rem; color: var(--clr-text); }
  .hml-guide-desc  { font-size: .9rem; color: var(--clr-text-secondary); line-height: 1.65; margin-bottom: 1rem; }
  .hml-guide-topics { list-style: none; }
  .hml-guide-topics li {
    font-size: .85rem;
    color: var(--clr-text-secondary);
    padding: .35rem 0;
    border-bottom: 1px solid var(--hml-border);
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .hml-guide-topics li:last-child { border-bottom: none; }
  .hml-guide-topics li::before { content: '→'; color: var(--hml-primary); font-size: .85rem; flex-shrink: 0; }

  /* ── GP info card ── */
  .hml-gp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .hml-gp-card {
    background: #fff;
    border: 1.5px solid var(--hml-border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }
  .hml-gp-card-icon { font-size: 2rem; margin-bottom: .75rem; }
  .hml-gp-card-title { font-weight: 700; font-size: 1rem; margin-bottom: .4rem; }
  .hml-gp-card-desc  { font-size: .88rem; color: var(--clr-text-secondary); line-height: 1.65; }

  /* ── Info box ── */
  .hml-info-box {
    background: var(--hml-primary-light);
    border: 1.5px solid var(--hml-border);
    border-left: 4px solid var(--hml-primary);
    border-radius: var(--radius-sm);
    padding: 1.25rem 1.5rem;
    font-size: .92rem;
    color: #5A3045;
    line-height: 1.7;
    margin: 1.5rem 0;
  }
  .hml-info-box strong { color: var(--hml-primary); }

  /* ── Warm page background ── */
  .hml-page { background: var(--hml-warm-bg); min-height: 60vh; }

  /* ── Subnav responsive ── */
  @media (max-width: 800px) {
    .hml-subnav-links {
      display: none;
      flex-direction: column;
      position: absolute;
      top: calc(64px + 52px);
      left: 0;
      right: 0;
      background: var(--hml-primary-light);
      padding: .75rem 1.5rem 1.25rem;
      border-bottom: 2px solid var(--hml-border);
      box-shadow: 0 4px 16px rgba(0,0,0,.08);
      z-index: 89;
      align-items: flex-start;
      gap: .25rem;
    }
    .hml-subnav-links.hml-open { display: flex; }
    .hml-mobile-toggle { display: block; }
    .hml-subnav-brand { font-size: 1rem; }
  }

  @media (max-width: 640px) {
    .navbar-links { display: none; }
    .navbar-links.open {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: #fff;
      padding: 1rem 1.5rem 1.5rem;
      border-bottom: 1px solid var(--clr-border);
      box-shadow: 0 4px 16px rgba(0,0,0,.07);
      z-index: 99;
    }
    .navbar-mobile-toggle { display: block; }
    .navbar-cta { display: none; }
    .navbar-inner { position: relative; }
    .footer-grid { grid-template-columns: 1fr; }
    .section { padding: 3.5rem 0; }
    .hml-symptoms-grid { grid-template-columns: 1fr; }
    .hml-guides-grid { grid-template-columns: 1fr; }
    .hml-gp-grid { grid-template-columns: 1fr; }
  }
</style>
