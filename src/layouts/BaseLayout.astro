---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "DriveEase India - Premium Doorstep Car Servicing | Pickup, Service & Delivery Across India" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="navbar">
      <div class="container">
        <a href="/" class="navbar-brand">Drive<span>Ease</span></a>
        <ul class="navbar-links">
          <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a></li>
          <li><a href="/#services">Services</a></li>
          <li><a href="/#how-it-works">How It Works</a></li>
          <li><a href="/#pricing">Pricing</a></li>
          <li><a href="/#comparison">Why Us</a></li>
          <li><a href="/get-quote" class="cta-link">Get Free Quote</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <h4>DriveEase India</h4>
            <p>India's most trusted doorstep car servicing platform. We pick up your car, service it at certified garages, and deliver it back — spotless and on time.</p>
          </div>
          <div>
            <h4>Services</h4>
            <ul>
              <li><a href="/#services">Basic Service</a></li>
              <li><a href="/#services">Full Service</a></li>
              <li><a href="/#services">AC Service</a></li>
              <li><a href="/#services">Denting & Painting</a></li>
              <li><a href="/#services">Insurance Claims</a></li>
            </ul>
          </div>
          <div>
            <h4>Company</h4>
            <ul>
              <li><a href="/#how-it-works">How It Works</a></li>
              <li><a href="/#comparison">Why DriveEase</a></li>
              <li><a href="/get-quote">Get a Quote</a></li>
              <li><a href="/#testimonials">Reviews</a></li>
            </ul>
          </div>
          <div>
            <h4>Top Cities</h4>
            <ul>
              <li><a href="/#cities">Mumbai</a></li>
              <li><a href="/#cities">Delhi NCR</a></li>
              <li><a href="/#cities">Bangalore</a></li>
              <li><a href="/#cities">Hyderabad</a></li>
              <li><a href="/#cities">Chennai</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} DriveEase India. All rights reserved. | Trusted by 50,000+ car owners across India</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
