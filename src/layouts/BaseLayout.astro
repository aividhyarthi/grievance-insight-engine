---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'YouTube Metadata Optimizer – AI-Powered Title, Description & Hashtag Generator',
  description = 'Paste any YouTube video URL and get AI-optimized title, description, and hashtags to maximize views and ranking.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect width="24" height="24" rx="6" fill="#FF0000"/>
            <polygon points="10,7 17,12 10,17" fill="white"/>
          </svg>
          <span>TubeRank<strong>AI</strong></span>
        </a>
        <p class="header-tagline">AI-powered YouTube metadata optimizer</p>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>TubeRankAI &mdash; Powered by Claude AI &amp; YouTube Data API</p>
        <p class="footer-note">Paste any video URL to get optimized metadata for Shorts, Videos &amp; Lives.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
