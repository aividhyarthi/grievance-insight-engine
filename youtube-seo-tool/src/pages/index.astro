---
const title = 'YouTube SEO Generator — AI-Powered Titles, Descriptions & Hashtags';
const description = 'Paste any YouTube link and get AI-generated SEO-optimized titles, descriptions, hashtags, tags, and chapters in seconds.';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --yt-red: #FF0000;
      --yt-red-dark: #cc0000;
      --bg: #0f0f0f;
      --bg2: #1a1a1a;
      --bg3: #242424;
      --border: #333;
      --text: #f1f1f1;
      --text-muted: #aaa;
      --green: #00c853;
      --radius: 12px;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* ── Header ── */
    .header {
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .yt-logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.5px;
    }
    .yt-logo svg { flex-shrink: 0; }
    .yt-logo-sub {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 400;
      margin-left: 0.25rem;
    }

    /* ── Main layout ── */
    .main {
      max-width: 900px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .hero h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }
    .hero h1 span { color: var(--yt-red); }
    .hero p {
      color: var(--text-muted);
      font-size: 1rem;
      max-width: 520px;
      margin: 0 auto;
    }

    /* ── Input card ── */
    .input-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem;
      margin-bottom: 2rem;
    }
    .input-label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.6rem;
    }
    .url-row {
      display: flex;
      gap: 0.75rem;
    }
    .url-input {
      flex: 1;
      background: var(--bg3);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: inherit;
      font-size: 0.95rem;
      padding: 0.75rem 1rem;
      outline: none;
      transition: border-color 0.2s;
    }
    .url-input:focus { border-color: var(--yt-red); }
    .url-input::placeholder { color: #555; }

    .context-row {
      margin-top: 1rem;
    }
    .lang-select {
      width: 100%;
      background: var(--bg3);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: inherit;
      font-size: 0.9rem;
      padding: 0.65rem 1rem;
      outline: none;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .lang-select:focus { border-color: var(--yt-red); }
    .lang-select option { background: var(--bg2); }

    /* ── Audit toggle ── */
    .audit-toggle-row { margin-top: 1rem; }
    .audit-toggle-btn {
      background: transparent;
      border: 1.5px dashed var(--border);
      border-radius: 8px;
      color: var(--text-muted);
      font-family: inherit;
      font-size: 0.88rem;
      font-weight: 600;
      padding: 0.6rem 1rem;
      cursor: pointer;
      width: 100%;
      text-align: left;
      transition: border-color 0.2s, color 0.2s;
    }
    .audit-toggle-btn:hover { border-color: var(--yt-red); color: var(--text); }
    .audit-optional {
      font-size: 0.72rem;
      font-weight: 400;
      background: var(--bg3);
      border-radius: 99px;
      padding: 0.1rem 0.5rem;
      margin-left: 0.4rem;
      color: var(--text-muted);
    }
    .audit-inputs { margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .audit-hint { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.5rem; }

    /* ── Score card ── */
    .score-overall {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1.25rem 1.5rem;
      border-radius: 10px;
      margin-bottom: 1.25rem;
    }
    .score-big {
      font-size: 3rem;
      font-weight: 900;
      line-height: 1;
      flex-shrink: 0;
    }
    .score-label { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem; }
    .score-verdict { font-size: 1rem; font-weight: 700; }
    .score-verdict-sub { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem; }

    .score-rows { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.25rem; }
    .score-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--bg3);
      border-radius: 8px;
      padding: 0.75rem 1rem;
    }
    .score-row-icon { font-size: 1rem; flex-shrink: 0; width: 20px; text-align: center; }
    .score-row-label { font-size: 0.85rem; font-weight: 600; width: 110px; flex-shrink: 0; }
    .score-bar-wrap { flex: 1; background: var(--bg2); border-radius: 99px; height: 8px; overflow: hidden; }
    .score-bar-fill { height: 100%; border-radius: 99px; transition: width 0.6s ease; }
    .score-row-num { font-size: 0.85rem; font-weight: 700; width: 46px; text-align: right; flex-shrink: 0; }
    .score-row-feedback { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.25rem; width: 100%; padding-left: calc(20px + 110px + 0.75rem + 0.75rem); }

    .score-fixes {
      background: rgba(255,200,0,0.06);
      border: 1px solid rgba(255,200,0,0.2);
      border-radius: 8px;
      padding: 1rem 1.25rem;
    }
    .score-fixes-title { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #f1c40f; margin-bottom: 0.6rem; }
    .score-fix-item { display: flex; gap: 0.6rem; font-size: 0.87rem; color: var(--text); margin-bottom: 0.4rem; line-height: 1.5; }
    .score-fix-num { color: #f1c40f; font-weight: 700; flex-shrink: 0; }

    .btn-export {
      background: #1a5c2a;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: inherit;
      font-size: 0.88rem;
      font-weight: 700;
      padding: 0.6rem 1.25rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-export:hover { background: #145222; }

    .context-input {
      width: 100%;
      background: var(--bg3);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: inherit;
      font-size: 0.9rem;
      padding: 0.75rem 1rem;
      outline: none;
      resize: vertical;
      min-height: 70px;
      transition: border-color 0.2s;
    }
    .context-input:focus { border-color: var(--yt-red); }
    .context-input::placeholder { color: #555; }

    .btn-generate {
      background: var(--yt-red);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: inherit;
      font-size: 0.95rem;
      font-weight: 700;
      padding: 0.75rem 1.5rem;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s, transform 0.1s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-generate:hover { background: var(--yt-red-dark); }
    .btn-generate:active { transform: scale(0.97); }
    .btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Spinner ── */
    .spinner {
      width: 18px;
      height: 18px;
      border: 2.5px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      display: none;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Loading state ── */
    .loading-bar {
      display: none;
      margin-top: 1.25rem;
      background: var(--bg3);
      border-radius: 99px;
      height: 4px;
      overflow: hidden;
    }
    .loading-bar-inner {
      height: 100%;
      background: var(--yt-red);
      border-radius: 99px;
      animation: loading 1.8s ease-in-out infinite;
    }
    @keyframes loading {
      0% { width: 0%; margin-left: 0; }
      50% { width: 70%; margin-left: 15%; }
      100% { width: 0%; margin-left: 100%; }
    }
    .loading-text {
      display: none;
      text-align: center;
      margin-top: 0.75rem;
      color: var(--text-muted);
      font-size: 0.88rem;
    }

    /* ── Error ── */
    .error-box {
      display: none;
      background: rgba(255,0,0,0.1);
      border: 1px solid rgba(255,0,0,0.3);
      border-radius: 8px;
      color: #ff6b6b;
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      margin-top: 1rem;
    }

    /* ── Video preview ── */
    .video-preview {
      display: none;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      margin-bottom: 2rem;
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
    .video-preview img {
      width: 160px;
      height: 90px;
      object-fit: cover;
      border-radius: 8px;
      flex-shrink: 0;
      background: var(--bg3);
    }
    .video-preview-info h3 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }
    .video-preview-info p {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    /* ── Results ── */
    .results { display: none; }

    .section-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 1.25rem;
      overflow: hidden;
    }
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
      background: var(--bg3);
    }
    .section-title-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-weight: 700;
      font-size: 0.95rem;
    }
    .section-icon {
      font-size: 1.1rem;
    }
    .copy-btn {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-muted);
      font-family: inherit;
      font-size: 0.78rem;
      padding: 0.3rem 0.75rem;
      cursor: pointer;
      transition: all 0.15s;
      white-space: nowrap;
    }
    .copy-btn:hover { border-color: var(--yt-red); color: var(--yt-red); }
    .copy-btn.copied { border-color: var(--green); color: var(--green); }

    .section-body { padding: 1.25rem; }

    /* Titles */
    .title-option {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.9rem 1rem;
      background: var(--bg3);
      border-radius: 8px;
      margin-bottom: 0.6rem;
      cursor: pointer;
      border: 1.5px solid transparent;
      transition: border-color 0.15s;
    }
    .title-option:last-child { margin-bottom: 0; }
    .title-option:hover { border-color: var(--yt-red); }
    .title-num {
      background: var(--yt-red);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .title-text { font-size: 0.95rem; line-height: 1.4; }
    .title-len {
      margin-left: auto;
      font-size: 0.75rem;
      color: var(--text-muted);
      white-space: nowrap;
      padding-top: 2px;
    }

    /* Description */
    .desc-text {
      font-size: 0.9rem;
      line-height: 1.8;
      color: var(--text);
      white-space: pre-wrap;
    }

    /* Tags / hashtags */
    .tags-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .tag-chip {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 99px;
      font-size: 0.8rem;
      padding: 0.3rem 0.75rem;
      color: var(--text);
      cursor: pointer;
      transition: all 0.15s;
    }
    .tag-chip:hover { border-color: var(--yt-red); color: var(--yt-red); }
    .hashtag-chip { color: #3ea6ff; border-color: #1a3a5c; background: rgba(62,166,255,0.05); }

    /* Chapters */
    .chapters-text {
      font-family: 'Courier New', monospace;
      font-size: 0.88rem;
      line-height: 1.9;
      color: var(--text);
      white-space: pre-wrap;
    }

    /* Keywords */
    .keyword-chip {
      background: rgba(0,200,83,0.08);
      border: 1px solid rgba(0,200,83,0.25);
      border-radius: 99px;
      font-size: 0.8rem;
      padding: 0.3rem 0.75rem;
      color: var(--green);
    }

    /* Pinned comment / card text */
    .comment-text {
      font-size: 0.9rem;
      line-height: 1.7;
      color: var(--text);
      background: var(--bg3);
      border-radius: 8px;
      padding: 1rem;
      white-space: pre-wrap;
    }

    /* ── Thumbnail cards ── */
    .thumb-grid {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .thumb-card {
      background: var(--bg3);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .thumb-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
    }
    .thumb-concept {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--yt-red);
    }
    .thumb-num {
      background: var(--yt-red);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .thumb-body {
      padding: 1rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .thumb-preview {
      grid-column: 1 / -1;
      border-radius: 8px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100px;
      text-align: center;
      gap: 0.4rem;
    }
    .thumb-preview-headline {
      font-size: 1.3rem;
      font-weight: 900;
      letter-spacing: 0.02em;
      line-height: 1.2;
      text-transform: uppercase;
    }
    .thumb-preview-sub {
      font-size: 0.85rem;
      font-weight: 500;
      opacity: 0.9;
    }
    .thumb-field {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .thumb-field-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
    }
    .thumb-field-value {
      font-size: 0.88rem;
      color: var(--text);
      line-height: 1.5;
    }
    .thumb-colors {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .color-chip {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.25rem 0.5rem;
      font-size: 0.78rem;
    }
    .color-swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      border: 1px solid rgba(255,255,255,0.15);
      flex-shrink: 0;
    }
    .thumb-canva {
      grid-column: 1 / -1;
      background: rgba(62,166,255,0.07);
      border: 1px solid rgba(62,166,255,0.2);
      border-radius: 8px;
      padding: 0.65rem 0.9rem;
      font-size: 0.84rem;
      color: #3ea6ff;
    }
    .thumb-canva::before {
      content: '💡 Canva tip: ';
      font-weight: 700;
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .url-row { flex-direction: column; }
      .btn-generate { width: 100%; justify-content: center; }
      .video-preview { flex-direction: column; align-items: flex-start; }
      .video-preview img { width: 100%; height: auto; }
    }

    /* ── Footer ── */
    .footer {
      text-align: center;
      padding: 2rem;
      color: #444;
      font-size: 0.8rem;
      border-top: 1px solid var(--border);
      margin-top: 2rem;
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="yt-logo">
      <svg width="28" height="20" viewBox="0 0 28 20" fill="none">
        <rect width="28" height="20" rx="5" fill="#FF0000"/>
        <polygon points="11,5 22,10 11,15" fill="white"/>
      </svg>
      YouTube SEO Generator
      <span class="yt-logo-sub">by Pranita</span>
    </div>
  </header>

  <main class="main">
    <div class="hero">
      <h1>Generate <span>YouTube SEO</span> in Seconds</h1>
      <p>Paste any YouTube link and get AI-crafted titles, descriptions, hashtags, tags, and chapters — ready to copy.</p>
    </div>

    <!-- Input card -->
    <div class="input-card">
      <label class="input-label" for="yt-url">YouTube Video URL</label>
      <div class="url-row">
        <input
          id="yt-url"
          class="url-input"
          type="url"
          placeholder="https://www.youtube.com/watch?v=..."
          autocomplete="off"
          spellcheck="false"
        />
        <button class="btn-generate" id="generate-btn">
          <div class="spinner" id="spinner"></div>
          <span id="btn-label">Generate SEO</span>
        </button>
      </div>

      <div class="context-row">
        <label class="input-label" for="yt-language" style="margin-top:1rem;">
          Output Language
        </label>
        <select id="yt-language" class="lang-select">
          <option value="English">🇬🇧 English</option>
          <option value="Hindi">🇮🇳 Hindi</option>
          <option value="Tamil">🇮🇳 Tamil</option>
          <option value="Telugu">🇮🇳 Telugu</option>
          <option value="Kannada">🇮🇳 Kannada</option>
          <option value="Malayalam">🇮🇳 Malayalam</option>
          <option value="Bengali">🇮🇳 Bengali</option>
          <option value="Marathi">🇮🇳 Marathi</option>
          <option value="Gujarati">🇮🇳 Gujarati</option>
          <option value="Punjabi">🇮🇳 Punjabi</option>
        </select>
      </div>

      <div class="context-row">
        <label class="input-label" for="yt-context" style="margin-top:1rem;">
          Additional context <span style="color:#555;font-weight:400;text-transform:none;">(optional — describe your video topic, audience, or goals)</span>
        </label>
        <textarea
          id="yt-context"
          class="context-input"
          placeholder="e.g. Tutorial on how to bake sourdough bread for beginners. Target audience: home bakers aged 25-45."
        ></textarea>
      </div>

      <!-- Audit section -->
      <div class="audit-toggle-row">
        <button class="audit-toggle-btn" id="audit-toggle">
          <span id="audit-toggle-icon">＋</span> Audit my current SEO <span class="audit-optional">optional</span>
        </button>
      </div>
      <div class="audit-inputs" id="audit-inputs" style="display:none;">
        <p class="audit-hint">Paste your existing description and tags below — we'll score them and show exactly what to fix.</p>
        <label class="input-label" for="current-desc">Current Description</label>
        <textarea id="current-desc" class="context-input" style="min-height:100px;" placeholder="Paste your current YouTube description here..."></textarea>
        <label class="input-label" style="margin-top:.75rem;" for="current-tags">Current Tags <span style="color:#555;font-weight:400;text-transform:none;">(comma separated)</span></label>
        <textarea id="current-tags" class="context-input" style="min-height:55px;" placeholder="e.g. sourdough, bread recipe, beginner baking, homemade bread..."></textarea>
      </div>

      <div class="loading-bar" id="loading-bar"><div class="loading-bar-inner"></div></div>
      <div class="loading-text" id="loading-text">Analysing video and generating SEO content...</div>
      <div class="error-box" id="error-box"></div>
    </div>

    <!-- Video preview -->
    <div class="video-preview" id="video-preview">
      <img id="preview-thumb" src="" alt="thumbnail" />
      <div class="video-preview-info">
        <h3 id="preview-title">Loading...</h3>
        <p id="preview-author"></p>
      </div>
    </div>

    <!-- Results -->
    <div class="results" id="results">

      <!-- Export bar -->
      <div style="display:flex;justify-content:flex-end;margin-bottom:1rem;">
        <button class="btn-export" id="export-btn">⬇ Export to Excel</button>
      </div>

      <!-- SEO Audit Score -->
      <div class="section-card" id="audit-result-card" style="display:none;">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">📊</span> Your Current SEO Score</div>
        </div>
        <div class="section-body" id="audit-result-body"></div>
      </div>

      <!-- Titles -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">🎯</span> Title Options</div>
          <button class="copy-btn" data-copy="titles">Copy All</button>
        </div>
        <div class="section-body" id="titles-body"></div>
      </div>

      <!-- Description -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">📝</span> SEO Description</div>
          <button class="copy-btn" data-copy="description">Copy</button>
        </div>
        <div class="section-body">
          <div class="desc-text" id="description-body"></div>
        </div>
      </div>

      <!-- Hashtags -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">#</span> Hashtags</div>
          <button class="copy-btn" data-copy="hashtags">Copy All</button>
        </div>
        <div class="section-body">
          <div class="tags-wrap" id="hashtags-body"></div>
        </div>
      </div>

      <!-- Tags -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">🏷️</span> YouTube Tags</div>
          <button class="copy-btn" data-copy="tags">Copy All</button>
        </div>
        <div class="section-body">
          <div class="tags-wrap" id="tags-body"></div>
        </div>
      </div>

      <!-- Chapters -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">📖</span> Chapter Timestamps</div>
          <button class="copy-btn" data-copy="chapters">Copy</button>
        </div>
        <div class="section-body">
          <div class="chapters-text" id="chapters-body"></div>
        </div>
      </div>

      <!-- Keywords -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">🔑</span> Primary Keywords</div>
          <button class="copy-btn" data-copy="keywords">Copy All</button>
        </div>
        <div class="section-body">
          <div class="tags-wrap" id="keywords-body"></div>
        </div>
      </div>

      <!-- End screen card text -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">🃏</span> End Screen / Card Text</div>
          <button class="copy-btn" data-copy="cardText">Copy</button>
        </div>
        <div class="section-body">
          <div class="comment-text" id="cardText-body"></div>
        </div>
      </div>

      <!-- Pinned comment -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">📌</span> Pinned Comment</div>
          <button class="copy-btn" data-copy="pinnedComment">Copy</button>
        </div>
        <div class="section-body">
          <div class="comment-text" id="pinnedComment-body"></div>
        </div>
      </div>

      <!-- Thumbnail Recommendations -->
      <div class="section-card">
        <div class="section-header">
          <div class="section-title-row"><span class="section-icon">🖼️</span> Thumbnail Recommendations</div>
        </div>
        <div class="section-body" id="thumbnails-body"></div>
      </div>

    </div>
  </main>

  <footer class="footer">
    YouTube SEO Generator by Pranita &nbsp;|&nbsp; Paste a link, get ready-to-use SEO content
  </footer>

  <script src="https://unpkg.com/xlsx/dist/xlsx.full.min.js"></script>
  <script>
    let seoData = null;
    let videoTitle = '';

    const urlInput = document.getElementById('yt-url');
    const contextInput = document.getElementById('yt-context');
    const langSelect = document.getElementById('yt-language');
    const currentDescInput = document.getElementById('current-desc');
    const currentTagsInput = document.getElementById('current-tags');

    // Audit toggle
    document.getElementById('audit-toggle').addEventListener('click', () => {
      const panel = document.getElementById('audit-inputs');
      const icon = document.getElementById('audit-toggle-icon');
      const open = panel.style.display !== 'none';
      panel.style.display = open ? 'none' : 'flex';
      icon.textContent = open ? '＋' : '－';
    });
    const generateBtn = document.getElementById('generate-btn');
    const btnLabel = document.getElementById('btn-label');
    const spinner = document.getElementById('spinner');
    const loadingBar = document.getElementById('loading-bar');
    const loadingText = document.getElementById('loading-text');
    const errorBox = document.getElementById('error-box');
    const videoPreview = document.getElementById('video-preview');
    const results = document.getElementById('results');

    function setLoading(on) {
      generateBtn.disabled = on;
      spinner.style.display = on ? 'block' : 'none';
      btnLabel.textContent = on ? 'Generating…' : 'Generate SEO';
      loadingBar.style.display = on ? 'block' : 'none';
      loadingText.style.display = on ? 'block' : 'none';
    }

    function showError(msg) {
      errorBox.textContent = msg;
      errorBox.style.display = 'block';
    }

    function hideError() {
      errorBox.style.display = 'none';
    }

    function renderTitles(titles) {
      const body = document.getElementById('titles-body');
      body.innerHTML = titles.map((t, i) => `
        <div class="title-option" onclick="copyText(this.querySelector('.title-text').textContent)">
          <div class="title-num">${i + 1}</div>
          <div class="title-text">${escHtml(t)}</div>
          <div class="title-len">${t.length} chars</div>
        </div>
      `).join('');
    }

    function renderDescription(desc) {
      document.getElementById('description-body').textContent = desc;
    }

    function renderHashtags(hashtags) {
      const body = document.getElementById('hashtags-body');
      body.innerHTML = hashtags.map(h =>
        `<span class="tag-chip hashtag-chip" onclick="copyText('${escAttr(h)}')">${escHtml(h)}</span>`
      ).join('');
    }

    function renderTags(tags) {
      const body = document.getElementById('tags-body');
      body.innerHTML = tags.map(t =>
        `<span class="tag-chip" onclick="copyText('${escAttr(t)}')">${escHtml(t)}</span>`
      ).join('');
    }

    function renderChapters(chapters) {
      document.getElementById('chapters-body').textContent = chapters;
    }

    function renderKeywords(keywords) {
      const body = document.getElementById('keywords-body');
      body.innerHTML = keywords.map(k =>
        `<span class="keyword-chip">${escHtml(k)}</span>`
      ).join('');
    }

    function scoreColor(s) {
      if (s >= 75) return '#00c853';
      if (s >= 50) return '#f1c40f';
      return '#ff4444';
    }
    function scoreLabel(s) {
      if (s >= 75) return 'Good';
      if (s >= 50) return 'Needs Work';
      return 'Poor';
    }

    function renderAudit(audit) {
      const card = document.getElementById('audit-result-card');
      const body = document.getElementById('audit-result-body');
      if (!audit) { card.style.display = 'none'; return; }
      card.style.display = 'block';

      const overall = audit.overall || 0;
      const col = scoreColor(overall);
      const categories = [
        { icon: '📌', label: 'Title', key: 'title' },
        { icon: '📝', label: 'Description', key: 'description' },
        { icon: '🏷️', label: 'Tags', key: 'tags' },
        { icon: '#', label: 'Hashtags', key: 'hashtags' },
      ];

      const rowsHtml = categories.map(c => {
        const item = audit[c.key] || {};
        const s = item.score ?? null;
        const notProvided = s === null || s === undefined;
        const barColor = notProvided ? '#444' : scoreColor(s);
        const barWidth = notProvided ? 0 : s;
        const scoreText = notProvided ? 'N/A' : `${s}/100`;
        return `
          <div>
            <div class="score-row">
              <span class="score-row-icon">${c.icon}</span>
              <span class="score-row-label">${c.label}</span>
              <div class="score-bar-wrap"><div class="score-bar-fill" style="width:${barWidth}%;background:${barColor};"></div></div>
              <span class="score-row-num" style="color:${barColor};">${scoreText}</span>
            </div>
            ${item.feedback ? `<div class="score-row-feedback">${escHtml(item.feedback)}</div>` : ''}
          </div>`;
      }).join('');

      const fixesHtml = (audit.topFixes || []).map((f, i) =>
        `<div class="score-fix-item"><span class="score-fix-num">${i + 1}.</span><span>${escHtml(f)}</span></div>`
      ).join('');

      body.innerHTML = `
        <div class="score-overall" style="background:${col}18;border:1px solid ${col}33;">
          <div>
            <div class="score-big" style="color:${col};">${overall}</div>
            <div class="score-label">out of 100</div>
          </div>
          <div>
            <div class="score-verdict">${scoreLabel(overall)} SEO</div>
            <div class="score-verdict-sub">${audit.summary || 'See breakdown below for what to fix.'}</div>
          </div>
        </div>
        <div class="score-rows">${rowsHtml}</div>
        ${fixesHtml ? `<div class="score-fixes"><div class="score-fixes-title">⚡ Top Fixes — Do These First</div>${fixesHtml}</div>` : ''}
      `;
    }

    function renderText(id, text) {
      document.getElementById(id + '-body').textContent = text;
    }

    function extractHexColor(str) {
      const match = str.match(/#([0-9a-fA-F]{3,6})/);
      return match ? match[0] : null;
    }

    function renderThumbnails(thumbnails) {
      const body = document.getElementById('thumbnails-body');
      if (!thumbnails || !thumbnails.length) { body.innerHTML = '<p style="color:var(--text-muted);font-size:.9rem;">No thumbnail data returned.</p>'; return; }
      body.innerHTML = '<div class="thumb-grid">' + thumbnails.map((t, i) => {
        const bgHex = extractHexColor(t.colors?.background || '') || '#c0392b';
        const txtHex = extractHexColor(t.colors?.text || '') || '#ffffff';
        const accentHex = extractHexColor(t.colors?.accent || '') || '#f1c40f';
        return `
          <div class="thumb-card">
            <div class="thumb-card-header">
              <div style="display:flex;align-items:center;gap:.6rem;">
                <div class="thumb-num">${i + 1}</div>
                <span class="thumb-concept">${escHtml(t.concept || 'Concept ' + (i+1))}</span>
              </div>
            </div>
            <div class="thumb-body">
              <div class="thumb-preview" style="background:${bgHex};color:${txtHex};">
                <div class="thumb-preview-headline" style="color:${txtHex};">${escHtml(t.headline || '')}</div>
                ${t.subtext ? `<div class="thumb-preview-sub" style="color:${accentHex};">${escHtml(t.subtext)}</div>` : ''}
              </div>
              <div class="thumb-field">
                <div class="thumb-field-label">Colors</div>
                <div class="thumb-colors">
                  <div class="color-chip"><div class="color-swatch" style="background:${bgHex};"></div>${escHtml(t.colors?.background || '')}</div>
                  <div class="color-chip"><div class="color-swatch" style="background:${txtHex};"></div>${escHtml(t.colors?.text || '')}</div>
                  <div class="color-chip"><div class="color-swatch" style="background:${accentHex};"></div>${escHtml(t.colors?.accent || '')}</div>
                </div>
              </div>
              <div class="thumb-field">
                <div class="thumb-field-label">Composition</div>
                <div class="thumb-field-value">${escHtml(t.composition || '')}</div>
              </div>
              <div class="thumb-field">
                <div class="thumb-field-label">Expression / Body Language</div>
                <div class="thumb-field-value">${escHtml(t.expression || '')}</div>
              </div>
              <div class="thumb-canva">${escHtml(t.canvaTip || '')}</div>
            </div>
          </div>`;
      }).join('') + '</div>';
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escAttr(str) {
      return String(str).replace(/'/g,"\\'");
    }

    window.copyText = function(text) {
      navigator.clipboard.writeText(text).catch(() => {});
    };

    // Copy button handlers
    document.querySelectorAll('.copy-btn[data-copy]').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.copy;
        if (!seoData) return;
        let text = '';
        if (key === 'titles') text = seoData.titles.join('\n');
        else if (key === 'description') text = seoData.description;
        else if (key === 'hashtags') text = seoData.hashtags.join(' ');
        else if (key === 'tags') text = seoData.tags.join(', ');
        else if (key === 'chapters') text = seoData.chapters;
        else if (key === 'keywords') text = seoData.keywords.join(', ');
        else if (key === 'cardText') text = seoData.cardText;
        else if (key === 'pinnedComment') text = seoData.pinnedComment;
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          btn.classList.add('copied');
          setTimeout(() => { btn.textContent = key === 'description' || key === 'chapters' || key === 'cardText' || key === 'pinnedComment' ? 'Copy' : 'Copy All'; btn.classList.remove('copied'); }, 2000);
        });
      });
    });

    async function generate() {
      const url = urlInput.value.trim();
      if (!url) { showError('Please enter a YouTube URL.'); return; }

      hideError();
      results.style.display = 'none';
      videoPreview.style.display = 'none';
      setLoading(true);

      try {
        const res = await fetch('/api/youtube-seo', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            url,
            context: contextInput.value.trim(),
            language: langSelect.value,
            currentDescription: currentDescInput.value.trim(),
            currentTags: currentTagsInput.value.trim(),
          }),
        });

        let data;
        try {
          data = await res.json();
        } catch {
          showError(`Server error (status ${res.status}). The API key may not be configured correctly in Railway — check your ANTHROPIC_API_KEY variable.`);
          return;
        }

        if (!res.ok) {
          showError(data.error || `Server error (${res.status}). Please try again.`);
          return;
        }

        seoData = data.seo;

        // Show video preview
        if (data.videoInfo) {
          const info = data.videoInfo;
          document.getElementById('preview-thumb').src = info.thumbnail || `https://img.youtube.com/vi/${info.id}/hqdefault.jpg`;
          videoTitle = info.title || 'YouTube Video';
          document.getElementById('preview-title').textContent = videoTitle;
          document.getElementById('preview-author').textContent = info.author ? `by ${info.author}` : '';
          videoPreview.style.display = 'flex';
        }

        // Render results
        renderTitles(seoData.titles || []);
        renderDescription(seoData.description || '');
        renderHashtags(seoData.hashtags || []);
        renderTags(seoData.tags || []);
        renderChapters(seoData.chapters || '');
        renderKeywords(seoData.keywords || []);
        renderText('cardText', seoData.cardText || '');
        renderText('pinnedComment', seoData.pinnedComment || '');
        renderThumbnails(seoData.thumbnails || []);
        renderAudit(data.audit || null);

        results.style.display = 'block';
        results.scrollIntoView({ behavior: 'smooth', block: 'start' });

      } catch (err) {
        showError('Could not reach the server. Please refresh the page and try again.');
      } finally {
        setLoading(false);
      }
    }

    function exportToExcel() {
      if (!seoData) return;
      const wb = XLSX.utils.book_new();

      // Sheet 1 — SEO Content
      const seoRows = [
        ['YouTube SEO Generator by Pranita'],
        ['Video', videoTitle || urlInput.value],
        ['Language', langSelect.value],
        [''],
        ['TITLES'],
        ...(seoData.titles || []).map((t, i) => [`Option ${i + 1}`, t]),
        [''],
        ['DESCRIPTION'],
        [seoData.description || ''],
        [''],
        ['CHAPTERS'],
        [seoData.chapters || ''],
        [''],
        ['END SCREEN / CARD TEXT'],
        [seoData.cardText || ''],
        [''],
        ['PINNED COMMENT'],
        [seoData.pinnedComment || ''],
      ];
      const ws1 = XLSX.utils.aoa_to_sheet(seoRows);
      ws1['!cols'] = [{ wch: 20 }, { wch: 90 }];
      XLSX.utils.book_append_sheet(wb, ws1, 'SEO Content');

      // Sheet 2 — Hashtags & Tags
      const maxLen = Math.max((seoData.hashtags || []).length, (seoData.tags || []).length, (seoData.keywords || []).length);
      const tagRows = [['Hashtags', 'YouTube Tags', 'Keywords']];
      for (let i = 0; i < maxLen; i++) {
        tagRows.push([
          seoData.hashtags?.[i] || '',
          seoData.tags?.[i] || '',
          seoData.keywords?.[i] || '',
        ]);
      }
      const ws2 = XLSX.utils.aoa_to_sheet(tagRows);
      ws2['!cols'] = [{ wch: 30 }, { wch: 30 }, { wch: 30 }];
      XLSX.utils.book_append_sheet(wb, ws2, 'Hashtags & Tags');

      // Sheet 3 — Thumbnail Recommendations
      const thumbRows = [['Concept', 'Headline', 'Subtext', 'Background', 'Text Colour', 'Accent', 'Composition', 'Expression', 'Canva Tip']];
      (seoData.thumbnails || []).forEach(t => {
        thumbRows.push([
          t.concept || '', t.headline || '', t.subtext || '',
          t.colors?.background || '', t.colors?.text || '', t.colors?.accent || '',
          t.composition || '', t.expression || '', t.canvaTip || '',
        ]);
      });
      const ws3 = XLSX.utils.aoa_to_sheet(thumbRows);
      ws3['!cols'] = [{ wch: 22 }, { wch: 22 }, { wch: 22 }, { wch: 22 }, { wch: 16 }, { wch: 16 }, { wch: 40 }, { wch: 35 }, { wch: 40 }];
      XLSX.utils.book_append_sheet(wb, ws3, 'Thumbnails');

      const filename = `youtube-seo-${(videoTitle || 'video').replace(/[^a-z0-9]/gi, '-').toLowerCase().slice(0, 40)}.xlsx`;
      XLSX.writeFile(wb, filename);
    }

    document.getElementById('export-btn').addEventListener('click', exportToExcel);
    generateBtn.addEventListener('click', generate);
    urlInput.addEventListener('keydown', e => { if (e.key === 'Enter') generate(); });
  </script>

</body>
</html>
