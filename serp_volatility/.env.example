# SERP API Configuration
# Choose provider: serper, serpapi
SERP_PROVIDER=serper

# Serper.dev — cheapest at $0.30/1K queries
# Get key at: https://serper.dev
SERP_API_KEY=your_api_key_here

# DataForSEO (alternative provider)
# DATAFORSEO_LOGIN=your_login
# DATAFORSEO_PASSWORD=your_password

# Storage backend: sqlite (default) or bigquery
STORAGE_BACKEND=sqlite
SQLITE_PATH=serp_volatility/data/serp_data.db

# BigQuery (optional — for production)
# GCP_PROJECT=your-gcp-project
# BQ_DATASET=serp_volatility
