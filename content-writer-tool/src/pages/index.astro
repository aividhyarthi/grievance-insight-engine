---
// Content Writer Agent — full-width professional layout
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Writer Agent — SEO Content from SEMRush Data</title>
  <meta name="description" content="Generate unique, human-sounding SEO content from keywords, FAQs, and product details." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #0d1829;
      --bg2:     #132038;
      --bg3:     #1b2d4a;
      --bg4:     #243659;
      --border:  #2c4165;
      --accent:  #7b84f8;
      --accent-h:#5f68f0;
      --text:    #e0eaf8;
      --text-2:  #94adc8;
      --text-3:  #5b7594;
      --green:   #22d4a0;
      --amber:   #fbbf24;
      --red:     #f87171;
      --r:       12px;
    }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; line-height: 1.6; }

    /* ── Header ── */
    .header {
      background: var(--bg2); border-bottom: 1px solid var(--border);
      padding: 0.9rem 2rem; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 100;
    }
    .logo { display: flex; align-items: center; gap: 0.65rem; }
    .logo-icon { width: 36px; height: 36px; background: linear-gradient(135deg, var(--accent), #a78bfa); border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .logo-text { font-size: 1.1rem; font-weight: 800; letter-spacing: -0.3px; }
    .logo-tag { font-size: 0.65rem; font-weight: 600; background: rgba(123,132,248,0.15); color: var(--accent); border: 1px solid rgba(123,132,248,0.3); border-radius: 99px; padding: 0.15rem 0.6rem; margin-left: 0.3rem; }
    .header-right { display: flex; align-items: center; gap: 0.75rem; font-size: 0.8rem; color: var(--text-3); }
    .pill { background: rgba(34,212,160,0.1); border: 1px solid rgba(34,212,160,0.25); color: var(--green); border-radius: 99px; padding: 0.25rem 0.75rem; font-size: 0.72rem; font-weight: 600; }

    /* ── Main ── */
    .main { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    /* ── Card ── */
    .card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); margin-bottom: 1.5rem; overflow: hidden; }
    .card-header { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--bg3); display: flex; align-items: center; justify-content: space-between; }
    .card-title { font-size: 0.9rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; }
    .card-sub { font-size: 0.75rem; color: var(--text-3); }

    /* ── Inputs grid ── */
    .inputs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; padding: 1.5rem; }
    .input-group { display: flex; flex-direction: column; gap: 0.45rem; }
    .input-group.full { grid-column: 1 / -1; }

    .input-label { font-size: 0.8rem; font-weight: 700; color: var(--text-2); display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .input-hint { font-size: 0.72rem; color: var(--text-3); line-height: 1.5; }

    .num { width: 20px; height: 20px; border-radius: 50%; font-size: 0.68rem; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .n1 { background: rgba(123,132,248,0.2); color: var(--accent); }
    .n2 { background: rgba(34,212,160,0.15); color: var(--green); }
    .n3 { background: rgba(251,191,36,0.15); color: var(--amber); }
    .n4 { background: rgba(248,113,113,0.15); color: var(--red); }

    .badge { font-size: 0.62rem; font-weight: 600; border-radius: 99px; padding: 0.1rem 0.45rem; }
    .req { background: rgba(248,113,113,0.1); color: var(--red); border: 1px solid rgba(248,113,113,0.25); }
    .opt { background: rgba(255,255,255,0.04); color: var(--text-3); border: 1px solid var(--border); }

    .field {
      width: 100%; background: var(--bg3); border: 1.5px solid var(--border); border-radius: 9px;
      color: var(--text); font-family: 'Inter', sans-serif; font-size: 0.875rem;
      padding: 0.7rem 0.9rem; outline: none; transition: border-color 0.2s;
    }
    .field:focus { border-color: var(--accent); }
    .field::placeholder { color: var(--text-3); font-size: 0.8rem; line-height: 1.55; }
    textarea.field { resize: vertical; }

    /* URL row */
    .url-row { display: flex; gap: 0.5rem; }
    .url-row .field { flex: 1; }
    .fetch-btn {
      background: var(--bg4); border: 1.5px solid var(--border); border-radius: 9px;
      color: var(--text-2); font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 600;
      padding: 0 1.1rem; cursor: pointer; white-space: nowrap; transition: all 0.15s; flex-shrink: 0;
    }
    .fetch-btn:hover { border-color: var(--accent); color: var(--accent); }
    .fetch-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .url-status { font-size: 0.73rem; margin-top: 0.4rem; display: none; }
    .url-status.err { color: var(--red); display: block; }

    /* URL Preview card */
    .url-preview { display: none; margin-top: 0.75rem; background: var(--bg3); border: 1px solid var(--border); border-left: 3px solid var(--green); border-radius: 9px; padding: 0.85rem 1rem; }
    .url-preview-badge { font-size: 0.64rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--green); margin-bottom: 0.55rem; }
    .url-row-item { display: flex; gap: 0.6rem; margin-bottom: 0.35rem; align-items: baseline; }
    .url-row-key { font-size: 0.7rem; font-weight: 700; color: var(--accent); min-width: 95px; flex-shrink: 0; }
    .url-row-val { font-size: 0.75rem; color: var(--text-2); line-height: 1.45; }
    .url-divider { border: none; border-top: 1px solid var(--border); margin: 0.5rem 0; }
    .url-body-text { font-size: 0.71rem; color: var(--text-3); line-height: 1.6; }
    .url-tag { display: inline-block; background: rgba(123,132,248,0.1); border: 1px solid rgba(123,132,248,0.2); border-radius: 5px; padding: 0.1rem 0.45rem; font-size: 0.68rem; color: var(--accent); margin: 0.1rem 0.2rem 0.1rem 0; line-height: 1.6; }

    /* Footer */
    .inputs-footer { padding: 1.1rem 1.5rem; border-top: 1px solid var(--border); background: var(--bg3); display: flex; gap: 1rem; align-items: center; }
    .len-select {
      background: var(--bg2); border: 1.5px solid var(--border); border-radius: 9px;
      color: var(--text); font-family: 'Inter', sans-serif; font-size: 0.85rem;
      padding: 0.65rem 0.9rem; outline: none; cursor: pointer; transition: border-color 0.2s; flex-shrink: 0;
    }
    .len-select:focus { border-color: var(--accent); }
    .len-select option { background: var(--bg2); }

    .gen-btn {
      flex: 1; background: linear-gradient(135deg, #7b84f8, #a78bfa); color: #fff;
      border: none; border-radius: 9px; font-family: 'Inter', sans-serif;
      font-size: 1rem; font-weight: 700; padding: 0.75rem 2rem; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 0.6rem;
      transition: opacity 0.2s, transform 0.1s; letter-spacing: 0.01em;
    }
    .gen-btn:hover { opacity: 0.9; }
    .gen-btn:active { transform: scale(0.99); }
    .gen-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-spin { width: 17px; height: 17px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.65s linear infinite; display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .regen-btn {
      width: 100%; background: transparent; border: 1.5px dashed var(--border); border-radius: 9px;
      color: var(--text-2); font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 600;
      padding: 0.7rem; cursor: pointer; display: none; align-items: center; justify-content: center;
      gap: 0.5rem; transition: all 0.15s; margin-bottom: 1.5rem;
    }
    .regen-btn:hover { border-color: var(--accent); color: var(--accent); }

    .error-box { background: rgba(248,113,113,0.08); border: 1px solid rgba(248,113,113,0.3); border-radius: 9px; color: var(--red); padding: 0.8rem 1rem; font-size: 0.85rem; display: none; line-height: 1.5; margin: 0 1.5rem 1.25rem; }

    /* ── Output Card ── */
    .output-card { display: none; }

    /* Loading */
    .loading-state { display: none; padding: 3.5rem 2rem; text-align: center; }
    .loading-ring { width: 50px; height: 50px; border: 3px solid var(--bg4); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.9s linear infinite; margin: 0 auto 1.25rem; }
    .loading-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
    .loading-sub { font-size: 0.83rem; color: var(--text-3); max-width: 320px; margin: 0 auto; line-height: 1.65; }

    /* Stats bar */
    .stats-bar { background: var(--bg3); border-bottom: 1px solid var(--border); padding: 0.7rem 1.5rem; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .stat-chip { background: var(--bg2); border: 1px solid var(--border); border-radius: 99px; padding: 0.25rem 0.75rem; font-size: 0.72rem; color: var(--text-2); display: flex; align-items: center; gap: 0.3rem; }
    .stat-chip strong { color: var(--text); }
    .style-chip { background: rgba(123,132,248,0.08); border: 1px solid rgba(123,132,248,0.2); color: var(--accent); border-radius: 99px; padding: 0.25rem 0.75rem; font-size: 0.7rem; font-weight: 600; margin-left: auto; }

    /* Action bar */
    .action-bar { padding: 0.65rem 1.5rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .act-btn { background: var(--bg3); border: 1.5px solid var(--border); border-radius: 7px; color: var(--text-2); font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 600; padding: 0.4rem 0.9rem; cursor: pointer; display: flex; align-items: center; gap: 0.35rem; transition: all 0.15s; }
    .act-btn:hover { border-color: var(--accent); color: var(--accent); }
    .act-btn.copied { border-color: var(--green); color: var(--green); }
    .act-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
    .act-btn.primary:hover { background: var(--accent-h); border-color: var(--accent-h); color: #fff; }
    .meta-box { background: rgba(123,132,248,0.05); border: 1px solid rgba(123,132,248,0.15); border-radius: 7px; padding: 0.5rem 0.9rem; font-size: 0.76rem; color: var(--text-2); margin-left: auto; max-width: 460px; line-height: 1.5; }
    .meta-box strong { color: var(--text); }

    /* Tabs */
    .tab-row { border-bottom: 1px solid var(--border); padding: 0 1.5rem; display: flex; }
    .tab-btn { background: none; border: none; border-bottom: 2.5px solid transparent; color: var(--text-3); font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 600; padding: 0.65rem 0.9rem 0.6rem; cursor: pointer; transition: all 0.15s; }
    .tab-btn:hover { color: var(--text); }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* Content */
    .content-area { padding: 2rem 2.5rem 3rem; }
    .preview-html h1 { font-size: 1.7rem; font-weight: 800; line-height: 1.2; color: var(--text); margin: 0 0 1.25rem; }
    .preview-html h2 { font-size: 1.2rem; font-weight: 700; color: var(--text); margin: 2.25rem 0 0.8rem; padding-bottom: 0.45rem; border-bottom: 1px solid var(--border); }
    .preview-html h3 { font-size: 1rem; font-weight: 600; color: var(--accent); margin: 1.4rem 0 0.5rem; }
    .preview-html p { font-size: 0.95rem; line-height: 1.85; color: var(--text-2); margin: 0 0 0.95rem; }
    .preview-html ul, .preview-html ol { margin: 0.35rem 0 1rem 1.5rem; }
    .preview-html li { font-size: 0.95rem; line-height: 1.75; color: var(--text-2); margin-bottom: 0.3rem; }
    .preview-html table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
    .preview-html th { background: var(--bg4); padding: 0.7rem 1rem; font-weight: 700; color: var(--text); border: 1px solid var(--border); text-align: left; }
    .preview-html td { padding: 0.65rem 1rem; border: 1px solid var(--border); color: var(--text-2); }
    .preview-html tr:nth-child(even) td { background: var(--bg3); }
    .preview-html strong { color: var(--text); font-weight: 600; }
    .raw-area { display: none; width: 100%; min-height: 520px; background: var(--bg3); border: 1.5px solid var(--border); border-radius: 9px; color: var(--text-2); font-family: 'Courier New', monospace; font-size: 0.82rem; line-height: 1.7; padding: 1.25rem; resize: vertical; outline: none; }

    /* Responsive */
    @media (max-width: 768px) {
      .inputs-grid { grid-template-columns: 1fr; }
      .inputs-footer { flex-direction: column; }
      .gen-btn { width: 100%; }
      .header-right { display: none; }
      .content-area { padding: 1.25rem; }
      .main { padding: 1rem; }
    }
  </style>
</head>
<body>

<header class="header">
  <div class="logo">
    <div class="logo-icon">✍️</div>
    <span class="logo-text">Content Writer Agent</span>
    <span class="logo-tag">SEO</span>
  </div>
  <div class="header-right">
    <span class="pill">⚡ Unique style every generation</span>
    <span>Powered by Claude</span>
  </div>
</header>

<main class="main">

  <!-- ══ INPUT CARD ══════════════════════════════════════════════════════════ -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">
        📋 Enter Your Content Details
      </div>
      <span class="card-sub">Fill in the boxes below — every generation uses a different writing style so pages never sound the same</span>
    </div>

    <div class="inputs-grid">

      <!-- Box 1: URL — full width -->
      <div class="input-group full">
        <label class="input-label">
          <span class="num n1">1</span>
          Reference URL
          <span class="badge opt">Optional</span>
        </label>
        <p class="input-hint">Enter any product, category, or page URL — we will fetch the page content (including JavaScript-rendered pages) and use it as reference when writing.</p>
        <div class="url-row">
          <input id="inp-url" class="field" type="url" placeholder="https://www.nykaa.com/dot-key-watermelon-toner  or  https://yoursite.com/product-page" autocomplete="off" spellcheck="false" />
          <button class="fetch-btn" id="fetch-btn">Fetch Page</button>
        </div>
        <div class="url-status" id="url-status"></div>
        <div class="url-preview" id="url-preview">
          <div class="url-preview-badge">✓ Page content fetched — will be used as reference</div>
          <div id="url-preview-rows"></div>
          <hr class="url-divider" id="url-divider" style="display:none" />
          <div class="url-body-text" id="url-body-text"></div>
        </div>
      </div>

      <!-- Box 2: Keywords -->
      <div class="input-group">
        <label class="input-label">
          <span class="num n2">2</span>
          Keywords
          <span class="badge req">Required</span>
        </label>
        <p class="input-hint">Paste keywords from SEMRush or Search Console. Label by type for best output.</p>
        <textarea id="inp-keywords" class="field" rows="9"
          placeholder="Primary: buy watermelon face toner online
Secondary: best face toner for oily skin, hydrating toner India
LSI / Related: brightening toner, niacinamide toner, skin hydration
Long-tail: watermelon toner for acne-prone skin, alcohol free toner under 500"></textarea>
      </div>

      <!-- Box 3: SEMRush FAQs & LLM Prompts -->
      <div class="input-group">
        <label class="input-label">
          <span class="num n3">3</span>
          SEMRush — FAQs &amp; LLM Prompts
          <span class="badge opt">Optional</span>
        </label>
        <p class="input-hint">Paste FAQs, People Also Ask questions, and ChatGPT/LLM prompts from SEMRush Topic Research. These become the FAQ section at the bottom of the page.</p>
        <textarea id="inp-semrush" class="field" rows="9"
          placeholder="What does a face toner do for skin?
Is watermelon toner good for oily skin?
Can I use toner every day?
What is the difference between a toner and an essence?
How do I apply face toner correctly?
Which toner is best for acne-prone skin in India?
Does toner help with dark spots?"></textarea>
      </div>

      <!-- Box 4: Content Brief — full width -->
      <div class="input-group full">
        <label class="input-label">
          <span class="num n4">4</span>
          Content Brief — Product / Category Details
          <span class="badge req">Required</span>
        </label>
        <p class="input-hint">Product name, key features, ingredients, USPs, target audience, price, brand info — anything specific the content must cover or avoid.</p>
        <textarea id="inp-brief" class="field" rows="7"
          placeholder="Product: Dot &amp; Key Watermelon Brightening Face Toner 200ml
Brand: Dot &amp; Key
Price: ₹449
Key ingredients: Watermelon Extract, Niacinamide, Hyaluronic Acid, Vitamin C
Benefits: Hydrates, brightens, minimises pores, controls excess oil, alcohol-free
Skin type: Oily, combination, sensitive skin
USPs: Fragrance-free, dermatologist tested, cruelty-free, pH-balanced
Target audience: Women aged 18-35, skincare beginners to enthusiasts
Must mention: Available on Nykaa, suits Indian climate
Avoid: Comparing with competitor products"></textarea>
      </div>

    </div>

    <!-- Footer: settings + generate -->
    <div class="inputs-footer">
      <select id="inp-wordcount" class="len-select">
        <option value="400-600">Short — 400 to 600 words</option>
        <option value="600-900">Medium — 600 to 900 words</option>
        <option value="900-1200" selected>Standard — 900 to 1200 words</option>
        <option value="1200-1500">Long — 1200 to 1500 words</option>
        <option value="1500-2000">Extended — 1500 to 2000 words</option>
      </select>
      <button class="gen-btn" id="gen-btn">
        <div class="btn-spin" id="btn-spin"></div>
        <span id="btn-label">✦ Generate Content</span>
      </button>
    </div>

    <div class="error-box" id="error-box"></div>
  </div>

  <!-- Regenerate button -->
  <button class="regen-btn" id="regen-btn">↺ &nbsp;Regenerate with a different writing style</button>

  <!-- ══ OUTPUT CARD ══════════════════════════════════════════════════════════ -->
  <div class="card output-card" id="output-card">

    <!-- Loading -->
    <div class="loading-state" id="loading-state">
      <div class="loading-ring"></div>
      <div class="loading-title">Writing your content…</div>
      <div class="loading-sub">Claude is reading your inputs and crafting unique, human-sounding content with headings, tables, bullets, and FAQs. This takes about 20–30 seconds.</div>
    </div>

    <!-- Results (hidden until done) -->
    <div id="results-inner" style="display:none">
      <div class="stats-bar">
        <div class="stat-chip">📝 <strong id="stat-words">—</strong>&nbsp;words</div>
        <div class="stat-chip">🗂 <strong id="stat-h">—</strong>&nbsp;headings</div>
        <div class="stat-chip">❓ <strong id="stat-faq">—</strong>&nbsp;FAQs</div>
        <div class="stat-chip">⏱ <strong id="stat-read">—</strong>&nbsp;min read</div>
        <div class="style-chip" id="stat-style" title="Unique writing style fingerprint for this generation">—</div>
      </div>

      <div class="action-bar">
        <button class="act-btn primary" id="copy-html-btn">⎘&nbsp;Copy HTML</button>
        <button class="act-btn" id="copy-text-btn">⎘&nbsp;Copy Plain Text</button>
        <button class="act-btn" id="dl-btn">⬇&nbsp;Download .html</button>
        <div class="meta-box"><strong>Meta description:</strong>&nbsp;<span id="meta-out">—</span></div>
      </div>

      <div class="tab-row">
        <button class="tab-btn active" id="tab-preview">Preview</button>
        <button class="tab-btn" id="tab-raw">HTML Source</button>
      </div>

      <div class="content-area">
        <div class="preview-html" id="preview-out"></div>
        <textarea class="raw-area" id="raw-out" readonly spellcheck="false"></textarea>
      </div>
    </div>
  </div>

</main>

<script>
  let gHtml = '', gTitle = '', gMeta = '';
  let gFetchedData = null; // stores the structured product data from fetch

  // refs
  const inpUrl  = document.getElementById('inp-url');
  const inpKw   = document.getElementById('inp-keywords');
  const inpSem  = document.getElementById('inp-semrush');
  const inpBrief= document.getElementById('inp-brief');
  const inpWc   = document.getElementById('inp-wordcount');

  const fetchBtn     = document.getElementById('fetch-btn');
  const urlStatus    = document.getElementById('url-status');
  const urlPreview   = document.getElementById('url-preview');
  const urlPrevRows  = document.getElementById('url-preview-rows');
  const urlDivider   = document.getElementById('url-divider');
  const urlBodyText  = document.getElementById('url-body-text');

  const genBtn    = document.getElementById('gen-btn');
  const regenBtn  = document.getElementById('regen-btn');
  const btnSpin   = document.getElementById('btn-spin');
  const btnLabel  = document.getElementById('btn-label');
  const errorBox  = document.getElementById('error-box');

  const outputCard   = document.getElementById('output-card');
  const loadingState = document.getElementById('loading-state');
  const resultsInner = document.getElementById('results-inner');

  const statWords = document.getElementById('stat-words');
  const statH     = document.getElementById('stat-h');
  const statFaq   = document.getElementById('stat-faq');
  const statRead  = document.getElementById('stat-read');
  const statStyle = document.getElementById('stat-style');
  const metaOut   = document.getElementById('meta-out');
  const previewOut= document.getElementById('preview-out');
  const rawOut    = document.getElementById('raw-out');

  // ── Fetch URL ──────────────────────────────────────────────────────────────
  function row(key, val) {
    if (!val) return '';
    return `<div class="url-row-item"><span class="url-row-key">${key}</span><span class="url-row-val">${val}</span></div>`;
  }
  function listRow(key, items) {
    if (!items || !items.length) return '';
    return `<div class="url-row-item"><span class="url-row-key">${key}</span><span class="url-row-val">${items.map(i => `<span class="url-tag">${i}</span>`).join(' ')}</span></div>`;
  }

  fetchBtn.addEventListener('click', async () => {
    const url = inpUrl.value.trim();
    if (!url) { urlStatus.className='url-status err'; urlStatus.textContent='⚠ Enter a URL first.'; return; }
    urlStatus.style.display='none'; urlPreview.style.display='none';
    fetchBtn.textContent='Fetching…'; fetchBtn.disabled=true;
    try {
      const res = await fetch('/api/fetch-url', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({url}) });
      const d = await res.json();
      if (d.error) {
        urlStatus.className='url-status err'; urlStatus.textContent='⚠ '+d.error;
      } else {
        gFetchedData = d; // save for use in generate()
        let html = '';
        // Core product info
        html += row('Product',     d.title || '');
        html += row('Brand',       d.brand || '');
        if (d.price || d.mrp) html += row('Price', [d.price?`₹${d.price}`:'', d.mrp && d.mrp!==d.price?`MRP ₹${d.mrp}`:''].filter(Boolean).join('  |  '));
        html += row('Category',    d.category || '');
        if (d.reviewRating) html += row('Rating', `${d.reviewRating}★${d.reviewCount ? ` — ${d.reviewCount} reviews` : ''}`);
        // Description
        if (d.description) html += row('Description', d.description.slice(0,300)+(d.description.length>300?'…':''));
        // Highlights / benefits
        if (d.highlights?.length) html += listRow('Highlights', d.highlights.slice(0,8));
        // Key ingredients
        if (d.keyIngredients?.length) html += listRow('Key Ingredients', d.keyIngredients.slice(0,8));
        // Full ingredients
        if (d.ingredients) html += row('Ingredients', d.ingredients.slice(0,350)+(d.ingredients.length>350?'…':''));
        // How to use
        if (d.howToUse) html += row('How to Use', d.howToUse.slice(0,250)+(d.howToUse.length>250?'…':''));
        // Features / specs
        if (d.features?.length) html += listRow('Features/Specs', d.features.slice(0,6));
        // Page headings (non-product pages)
        if (!d.highlights?.length && d.headings?.length) html += row('Page sections', d.headings.slice(0,6).join(' · '));
        html += row('Keywords',    d.keywords || '');

        urlPrevRows.innerHTML = html || row('Note','Basic page info found — add product details in Box 4 for best results.');

        // Body text preview only for non-JSON sources and only if no structured data
        const hasStructured = d.highlights?.length || d.ingredients || d.keyIngredients?.length;
        if (d.bodyText && !hasStructured) {
          urlDivider.style.display='block';
          urlBodyText.textContent='Page text preview: '+d.bodyText.slice(0,300)+'…';
        } else {
          urlDivider.style.display='none'; urlBodyText.textContent='';
        }
        urlPreview.style.display='block';
        urlStatus.style.display='none';
      }
    } catch { urlStatus.className='url-status err'; urlStatus.textContent='⚠ Could not reach the server. Try again.'; }
    finally { fetchBtn.textContent='Fetch Page'; fetchBtn.disabled=false; }
  });

  // ── Generate ───────────────────────────────────────────────────────────────
  function setLoading(on) {
    genBtn.disabled=on; btnSpin.style.display=on?'block':'none';
    btnLabel.textContent=on?'Generating…':'✦ Generate Content';
    if (on) { errorBox.style.display='none'; outputCard.style.display='block'; loadingState.style.display='block'; resultsInner.style.display='none'; }
  }

  function showError(msg) {
    errorBox.textContent=msg; errorBox.style.display='block';
    outputCard.style.display='none'; loadingState.style.display='none';
  }

  function stripHtml(h) {
    return h.replace(/<br\s*\/?>/gi,'\n').replace(/<\/p>/gi,'\n\n').replace(/<\/h[1-6]>/gi,'\n\n')
      .replace(/<\/li>/gi,'\n').replace(/<td[^>]*>/gi,' | ').replace(/<[^>]+>/g,'').replace(/\n{3,}/g,'\n\n').trim();
  }

  function flash(btn, orig) { btn.textContent='✓ Copied!'; btn.classList.add('copied'); setTimeout(()=>{btn.innerHTML=orig;btn.classList.remove('copied');},2200); }

  async function generate() {
    const kw=inpKw.value.trim(), brief=inpBrief.value.trim();
    if (!kw && !brief) { showError('Please fill in at least Box 2 (Keywords) or Box 4 (Content Brief) before generating.'); return; }
    setLoading(true);

    // Build enriched content brief from fetched product data + user's Box 4
    let enrichedBrief = brief;
    if (gFetchedData && gFetchedData.success) {
      const fd = gFetchedData;
      const fetchedLines = [];
      if (fd.title)       fetchedLines.push(`Product: ${fd.title}`);
      if (fd.brand)       fetchedLines.push(`Brand: ${fd.brand}`);
      if (fd.price)       fetchedLines.push(`Price: ₹${fd.price}`);
      if (fd.mrp && fd.mrp !== fd.price) fetchedLines.push(`MRP: ₹${fd.mrp}`);
      if (fd.category)    fetchedLines.push(`Category: ${fd.category}`);
      if (fd.reviewRating) fetchedLines.push(`Rating: ${fd.reviewRating}★${fd.reviewCount ? ` from ${fd.reviewCount} reviews` : ''}`);
      if (fd.description) fetchedLines.push(`Description: ${fd.description}`);
      if (fd.keyIngredients?.length) fetchedLines.push(`Key Ingredients: ${fd.keyIngredients.join(', ')}`);
      if (fd.ingredients) fetchedLines.push(`Ingredients: ${fd.ingredients}`);
      if (fd.highlights?.length) fetchedLines.push(`Highlights:\n- ${fd.highlights.join('\n- ')}`);
      if (fd.features?.length)   fetchedLines.push(`Features:\n- ${fd.features.join('\n- ')}`);
      if (fd.howToUse)            fetchedLines.push(`How to Use: ${fd.howToUse}`);
      if (fetchedLines.length) {
        const fetchedBlock = '--- FROM FETCHED URL ---\n' + fetchedLines.join('\n');
        enrichedBrief = brief ? fetchedBlock + '\n\n--- USER ADDED ---\n' + brief : fetchedBlock;
      }
    }

    try {
      const res = await fetch('/api/content-writer', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ url:inpUrl.value.trim(), keywords:kw, semrushData:inpSem.value.trim(), contentBrief:enrichedBrief, wordCount:inpWc.value }),
      });
      let d; try { d=await res.json(); } catch { setLoading(false); showError(`Server error (${res.status}). Check ANTHROPIC_API_KEY is set in Railway Variables.`); return; }
      if (!res.ok||!d.success) { setLoading(false); showError(d.error||`Generation failed (${res.status}). Please try again.`); return; }

      const c=d.content||{};
      gHtml=c.html||''; gTitle=c.title||''; gMeta=c.metaDescription||'';
      const wc=c.wordCount||0;
      statWords.textContent=wc.toLocaleString(); statH.textContent=c.headingsCount||'—';
      statFaq.textContent=c.faqCount||'—'; statRead.textContent=Math.max(1,Math.round(wc/200));
      statStyle.textContent=d.styleId||'—'; metaOut.textContent=gMeta||'—';
      previewOut.innerHTML=gHtml; rawOut.value=gHtml;

      // Reset to preview tab
      document.getElementById('tab-preview').classList.add('active');
      document.getElementById('tab-raw').classList.remove('active');
      previewOut.style.display='block'; rawOut.style.display='none';

      loadingState.style.display='none'; resultsInner.style.display='block';
      regenBtn.style.display='flex';
      outputCard.scrollIntoView({behavior:'smooth',block:'start'});
    } catch { showError('Could not reach the server. Check your connection.'); }
    finally { setLoading(false); }
  }

  genBtn.addEventListener('click', generate);
  regenBtn.addEventListener('click', generate);

  // ── Tabs ───────────────────────────────────────────────────────────────────
  document.getElementById('tab-preview').addEventListener('click', () => {
    document.getElementById('tab-preview').classList.add('active');
    document.getElementById('tab-raw').classList.remove('active');
    previewOut.style.display='block'; rawOut.style.display='none';
  });
  document.getElementById('tab-raw').addEventListener('click', () => {
    document.getElementById('tab-raw').classList.add('active');
    document.getElementById('tab-preview').classList.remove('active');
    rawOut.style.display='block'; previewOut.style.display='none';
  });

  // ── Copy / Download ────────────────────────────────────────────────────────
  document.getElementById('copy-html-btn').addEventListener('click', () => {
    if (!gHtml) return;
    navigator.clipboard.writeText(gHtml).then(()=>flash(document.getElementById('copy-html-btn'),'⎘&nbsp;Copy HTML'));
  });
  document.getElementById('copy-text-btn').addEventListener('click', () => {
    if (!gHtml) return;
    navigator.clipboard.writeText(stripHtml(gHtml)).then(()=>flash(document.getElementById('copy-text-btn'),'⎘&nbsp;Copy Plain Text'));
  });
  document.getElementById('dl-btn').addEventListener('click', () => {
    if (!gHtml) return;
    const full=`<!doctype html><html lang="en"><head><meta charset="UTF-8"/><title>${gTitle.replace(/</g,'&lt;')}</title><meta name="description" content="${gMeta.replace(/"/g,'&quot;')}"/><style>body{font-family:Georgia,serif;max-width:780px;margin:2rem auto;padding:0 1rem;line-height:1.8;color:#222}h1{font-size:2rem;margin-bottom:1rem}h2{font-size:1.4rem;margin:2.5rem 0 .8rem;border-bottom:1px solid #e0e0e0;padding-bottom:.35rem}h3{font-size:1.05rem;margin:1.5rem 0 .5rem;color:#444}table{width:100%;border-collapse:collapse;margin:1.5rem 0}th,td{padding:.65rem 1rem;border:1px solid #ddd;text-align:left}th{background:#f5f5f5;font-weight:700}tr:nth-child(even) td{background:#fafafa}</style></head><body>${gHtml}</body></html>`;
    const a=document.createElement('a');
    a.href=URL.createObjectURL(new Blob([full],{type:'text/html'}));
    a.download=(gTitle||'content').replace(/[^a-z0-9]/gi,'-').toLowerCase().slice(0,50)+'.html';
    a.click(); URL.revokeObjectURL(a.href);
  });
</script>

</body>
</html>
