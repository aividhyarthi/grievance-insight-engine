# ============================================================
# Rudra Kasturi — blog.rudrakasturi.com
# Copy this to .env and fill in your values.
# NEVER share or commit the .env file.
# ============================================================

# ---- THE BRAIN (Required — nothing works without this) ------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Get it from: https://console.anthropic.com → API Keys

# ---- IMAGE GENERATION ---------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
# Get it from: https://platform.openai.com → API Keys
# Used for DALL-E 3 blog header + social images

# ---- WORDPRESS: blog.rudrakasturi.com -----------------------
WP_USERNAME=rudra                          # your WordPress login username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# How to get App Password:
#   1. Go to blog.rudrakasturi.com/wp-admin
#   2. Users → Your Profile
#   3. Scroll to "Application Passwords"
#   4. Type "Blog Automation" → click Add New
#   5. Copy the password it shows (only shown once!)

# ---- LINKEDIN: linkedin.com/in/rudrakasturi -----------------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXX
# How to get:
#   1. Go to https://developer.linkedin.com → Create App
#   2. Request permissions: r_liteprofile, w_member_social
#   3. Generate access token
#   4. Person URN: from LinkedIn API /me endpoint

# ---- INSTAGRAM: @kasturitagore -----------------------------
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# How to get:
#   1. You need a Facebook Business account linked to @kasturitagore
#   2. Go to https://developers.facebook.com → Create App
#   3. Add Instagram Graph API product
#   4. Get access token with instagram_basic + instagram_content_publish permissions
#   5. Business Account ID: from Graph API /me/accounts
