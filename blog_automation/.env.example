# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ---- Required -----------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- Image Generation (pick one) ----------------------------
OPENAI_API_KEY=your_openai_api_key_here        # For DALL-E 3
# STABILITY_API_KEY=your_stability_api_key      # For Stability AI

# ---- WordPress ----------------------------------------------
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx  # WordPress Application Password

# ---- Twitter / X --------------------------------------------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ---- LinkedIn -----------------------------------------------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXX     # From LinkedIn developer portal

# ---- Instagram (via Meta Graph API) -------------------------
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
