---
// Nykaa AEO Blog Topic Engine — single-page tool.
const brand = 'Nykaa';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AEO Blog Topic Engine — {brand}</title>
    <meta name="description" content="Turn category URLs, keywords and SEMrush prompts into blog topics built to rank in LLMs and answer engines." />
    <style>
      :root {
        --pink: #fc2779;
        --pink-dark: #d81b66;
        --ink: #1d1f2b;
        --muted: #6b6f80;
        --line: #e7e8ef;
        --bg: #f6f6fa;
        --card: #ffffff;
        --ok: #15a06a;
        --warn: #c98a00;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.5;
      }
      header {
        background: linear-gradient(120deg, #fc2779 0%, #ff6aa2 100%);
        color: #fff;
        padding: 30px 20px 34px;
      }
      .wrap { max-width: 1180px; margin: 0 auto; padding: 0 20px; }
      header h1 { margin: 0 0 6px; font-size: 26px; font-weight: 800; letter-spacing: -0.02em; }
      header p { margin: 0; opacity: 0.95; font-size: 15px; max-width: 760px; }
      .badge {
        display: inline-block; background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.35);
        padding: 3px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; margin-bottom: 12px;
      }
      main { padding: 26px 0 60px; }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
      @media (max-width: 880px) { .grid { grid-template-columns: 1fr; } }
      .card {
        background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 16px;
        box-shadow: 0 1px 2px rgba(20,20,40,0.04);
      }
      .card h3 { margin: 0 0 4px; font-size: 15px; display: flex; align-items: center; gap: 8px; }
      .card .hint { margin: 0 0 10px; font-size: 12.5px; color: var(--muted); }
      textarea {
        width: 100%; min-height: 190px; resize: vertical; border: 1px solid var(--line); border-radius: 10px;
        padding: 11px 12px; font-size: 13.5px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: var(--ink); background: #fcfcfe; outline: none;
      }
      textarea:focus { border-color: var(--pink); box-shadow: 0 0 0 3px rgba(252,39,121,0.12); }
      .count { font-size: 11.5px; color: var(--muted); margin-top: 6px; text-align: right; }
      .row { display: flex; align-items: center; gap: 14px; margin-top: 18px; flex-wrap: wrap; }
      .field { display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--muted); }
      .field input {
        border: 1px solid var(--line); border-radius: 8px; padding: 8px 10px; font-size: 13.5px; min-width: 160px;
      }
      button.primary {
        background: var(--pink); color: #fff; border: none; border-radius: 10px; padding: 12px 22px;
        font-size: 15px; font-weight: 700; cursor: pointer; transition: background 0.15s;
      }
      button.primary:hover { background: var(--pink-dark); }
      button.primary:disabled { opacity: 0.6; cursor: not-allowed; }
      button.ghost {
        background: #fff; color: var(--ink); border: 1px solid var(--line); border-radius: 9px;
        padding: 9px 14px; font-size: 13.5px; font-weight: 600; cursor: pointer;
      }
      button.ghost:hover { border-color: var(--pink); color: var(--pink); }
      .spinner {
        width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.5); border-top-color: #fff;
        border-radius: 50%; display: inline-block; vertical-align: -3px; margin-right: 8px; animation: spin 0.7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      .alert { margin-top: 16px; padding: 12px 14px; border-radius: 10px; font-size: 13.5px; display: none; }
      .alert.err { background: #fdecec; color: #b3261e; border: 1px solid #f6c9c6; }
      .alert.info { background: #fff6e6; color: #8a5d00; border: 1px solid #f3e0b0; }
      #results { margin-top: 26px; display: none; }
      .results-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
      .results-head h2 { margin: 0; font-size: 19px; }
      .actions { display: flex; gap: 8px; flex-wrap: wrap; }
      .table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 14px; background: #fff; }
      table { border-collapse: collapse; width: 100%; min-width: 920px; font-size: 13.5px; }
      th, td { text-align: left; padding: 11px 13px; vertical-align: top; border-bottom: 1px solid var(--line); }
      th { background: #fafafe; font-size: 12px; text-transform: uppercase; letter-spacing: 0.03em; color: var(--muted); position: sticky; top: 0; }
      tr:last-child td { border-bottom: none; }
      td.idx { color: var(--muted); font-variant-numeric: tabular-nums; width: 34px; }
      .pill {
        display: inline-block; padding: 2px 9px; border-radius: 999px; font-size: 11.5px; font-weight: 600;
        background: #f0eefc; color: #5b46c9; white-space: nowrap;
      }
      .ttl { font-weight: 600; }
      .kw { font-family: ui-monospace, monospace; font-size: 12.5px; color: var(--pink-dark); }
      .qp { color: var(--ink); }
      .why { color: var(--muted); font-size: 12.5px; }
      .crawlnote { font-size: 12px; color: var(--muted); margin-top: 8px; }
      .crawlnote .ok { color: var(--ok); }
      .crawlnote .bad { color: var(--warn); }
      footer { text-align: center; color: var(--muted); font-size: 12.5px; padding: 24px; }
      .toast {
        position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%); background: var(--ink); color: #fff;
        padding: 10px 18px; border-radius: 10px; font-size: 13.5px; opacity: 0; transition: opacity 0.2s; pointer-events: none;
      }
      .toast.show { opacity: 1; }
    </style>
  </head>
  <body>
    <header>
      <div class="wrap">
        <span class="badge">AEO &amp; LLM ranking · {brand}</span>
        <h1>Blog Topic Engine</h1>
        <p>
          Paste your category &amp; product page URLs, your seed keywords, and your SEMrush / LLM prompts.
          The tool reads the pages and generates blog topics built to be cited when people ask AI assistants and answer engines.
        </p>
      </div>
    </header>

    <main>
      <div class="wrap">
        <div class="grid">
          <div class="card">
            <h3>🔗 Category &amp; Product URLs</h3>
            <p class="hint">Category pages and PDPs you write content around. One URL per line.</p>
            <textarea id="urls" placeholder="https://www.nykaa.com/skin/sunscreen/c/8377
https://www.nykaa.com/brand-x-spf-50-sunscreen/p/123456"></textarea>
            <div class="count" id="urls-count">0 URLs</div>
          </div>

          <div class="card">
            <h3>🔑 Seed Keywords</h3>
            <p class="hint">From SEMrush or your research. One keyword per line.</p>
            <textarea id="keywords" placeholder="best sunscreen for oily skin
spf 50 sunscreen
sunscreen for dark spots"></textarea>
            <div class="count" id="keywords-count">0 keywords</div>
          </div>

          <div class="card">
            <h3>💬 SEMrush / LLM Prompts</h3>
            <p class="hint">The questions/prompts people ask. One per line.</p>
            <textarea id="prompts" placeholder="which sunscreen is best for acne-prone oily skin?
is spf 50 enough for indian summers?
how to choose a sunscreen that doesn't leave white cast"></textarea>
            <div class="count" id="prompts-count">0 prompts</div>
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label for="brand">Brand</label>
            <input id="brand" type="text" value="Nykaa" />
          </div>
          <div class="field">
            <label for="apikey">Anthropic API key</label>
            <input id="apikey" type="password" placeholder="sk-ant-..." autocomplete="off" style="min-width: 240px;" />
          </div>
          <button class="primary" id="go">Generate blog topics</button>
        </div>
        <p class="hint" style="margin: 8px 2px 0; font-size: 12px; color: var(--muted);">
          🔒 Your API key is stored only in this browser (never shared) and is used to talk to Claude. Leave it blank if your admin already set it on the server.
        </p>

        <div class="alert err" id="err"></div>
        <div class="alert info" id="info"></div>

        <section id="results">
          <div class="results-head">
            <h2 id="results-title">Blog topics</h2>
            <div class="actions">
              <button class="ghost" id="copy">📋 Copy table</button>
              <button class="ghost" id="csv">⬇️ Download Excel (CSV)</button>
            </div>
          </div>
          <div class="crawlnote" id="crawlnote"></div>
          <div class="table-wrap">
            <table id="table">
              <thead>
                <tr>
                  <th class="idx">#</th>
                  <th>Category</th>
                  <th>Blog Title</th>
                  <th>Focus Keyword</th>
                  <th>Target Prompt / Question</th>
                  <th>Intent</th>
                  <th>Why it ranks in LLMs</th>
                </tr>
              </thead>
              <tbody id="tbody"></tbody>
            </table>
          </div>
        </section>
      </div>
    </main>

    <footer>Built for {brand} content strategy · AEO + LLM citation planning</footer>
    <div class="toast" id="toast"></div>

    <script>
      const $ = (id) => document.getElementById(id);
      let lastTopics = [];

      function countLines(blob) {
        return blob.split(/[\n,]+/).map((s) => s.trim()).filter(Boolean).length;
      }
      function bindCount(id, label) {
        const el = $(id), out = $(id + '-count');
        const update = () => {
          const n = countLines(el.value);
          out.textContent = n + ' ' + label + (n === 1 ? '' : 's');
        };
        el.addEventListener('input', update);
        update();
      }
      bindCount('urls', 'URL');
      bindCount('keywords', 'keyword');
      bindCount('prompts', 'prompt');

      // Remember the API key in this browser only.
      const savedKey = localStorage.getItem('nykaa_anthropic_key');
      if (savedKey) $('apikey').value = savedKey;
      $('apikey').addEventListener('input', () => {
        localStorage.setItem('nykaa_anthropic_key', $('apikey').value.trim());
      });

      function showToast(msg) {
        const t = $('toast');
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 1800);
      }
      function hideAlerts() {
        $('err').style.display = 'none';
        $('info').style.display = 'none';
      }
      function showErr(msg) {
        const e = $('err');
        e.textContent = msg;
        e.style.display = 'block';
      }

      function esc(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      function render(data) {
        lastTopics = data.topics || [];
        $('results-title').textContent = lastTopics.length + ' blog topics for ' + (data.brand || 'your brand');

        const tbody = $('tbody');
        tbody.innerHTML = lastTopics.map((t, i) => `
          <tr>
            <td class="idx">${i + 1}</td>
            <td><span class="pill">${esc(t.category)}</span></td>
            <td class="ttl">${esc(t.blogTitle)}</td>
            <td class="kw">${esc(t.focusKeyword)}</td>
            <td class="qp">${esc(t.targetPrompt)}</td>
            <td>${esc(t.searchIntent)}</td>
            <td class="why">${esc(t.whyRanks)}</td>
          </tr>`).join('');

        // Crawl diagnostics
        const note = $('crawlnote');
        const crawls = (data.meta && data.meta.urlsCrawled) || [];
        if (crawls.length) {
          const okN = crawls.filter((c) => c.ok).length;
          const parts = [`Read ${okN}/${crawls.length} pages`];
          const failed = crawls.filter((c) => !c.ok);
          if (failed.length) {
            parts.push(`<span class="bad">${failed.length} page(s) returned little/no content (JS-rendered or bot-blocked) — topics for those were inferred from the URL & your keywords.</span>`);
          }
          note.innerHTML = parts.join(' · ');
        } else {
          note.innerHTML = '';
        }

        $('results').style.display = 'block';
        $('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      async function generate() {
        hideAlerts();
        const urls = $('urls').value;
        const keywords = $('keywords').value;
        const prompts = $('prompts').value;
        const brand = $('brand').value.trim() || 'Nykaa';
        const apiKey = $('apikey').value.trim();

        if (!countLines(urls) && !countLines(keywords) && !countLines(prompts)) {
          showErr('Add at least one URL, keyword, or prompt to get started.');
          return;
        }

        const btn = $('go');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>Reading pages & generating…';
        $('info').textContent = 'Crawling URLs and asking Claude for topics. This can take 20–40 seconds.';
        $('info').style.display = 'block';

        try {
          const res = await fetch('/api/blog-topics', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ urls, keywords, prompts, brand, apiKey }),
          });
          const data = await res.json();
          if (!res.ok) {
            showErr(data.error || 'Something went wrong. Please try again.');
          } else {
            render(data);
          }
        } catch (e) {
          showErr('Network error: ' + (e && e.message ? e.message : e));
        } finally {
          hideAlerts();
          btn.disabled = false;
          btn.textContent = 'Generate blog topics';
        }
      }

      $('go').addEventListener('click', generate);

      // ---- export helpers ----
      const HEADERS = ['#', 'Category', 'Blog Title', 'Focus Keyword', 'Target Prompt', 'Intent', 'Why it ranks in LLMs'];
      function rowsForExport() {
        return lastTopics.map((t, i) => [
          i + 1, t.category, t.blogTitle, t.focusKeyword, t.targetPrompt, t.searchIntent, t.whyRanks,
        ]);
      }
      function csvCell(v) {
        const s = String(v == null ? '' : v);
        return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
      }
      function downloadCsv() {
        if (!lastTopics.length) return;
        const lines = [HEADERS, ...rowsForExport()].map((r) => r.map(csvCell).join(','));
        // BOM so Excel opens UTF-8 correctly.
        const blob = new Blob(['﻿' + lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        const stamp = new Date().toISOString().slice(0, 10);
        a.download = `nykaa-blog-topics-${stamp}.csv`;
        a.click();
        URL.revokeObjectURL(a.href);
        showToast('CSV downloaded — open it in Excel');
      }
      async function copyTable() {
        if (!lastTopics.length) return;
        const tsv = [HEADERS, ...rowsForExport()]
          .map((r) => r.map((c) => String(c == null ? '' : c).replace(/\t|\n/g, ' ')).join('\t'))
          .join('\n');
        try {
          await navigator.clipboard.writeText(tsv);
          showToast('Copied — paste straight into Excel/Sheets');
        } catch {
          showToast('Copy failed — use the Download button instead');
        }
      }
      $('csv').addEventListener('click', downloadCsv);
      $('copy').addEventListener('click', copyTable);
    </script>
  </body>
</html>
