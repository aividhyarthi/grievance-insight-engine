    "nodemailer": "^8.0.1",
    "react-router-dom": "^7.13.0",
    "robots-parser": "^3.0.1",
    "stripe": "^20.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
