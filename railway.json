{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "streamlit run serp_volatility/dashboard/app.py --server.port=$PORT --server.headless=true --server.address=0.0.0.0 --server.enableCORS=false --server.enableXsrfProtection=false",
    "healthcheckPath": "/_stcore/health",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
