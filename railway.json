{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "streamlit run serp_volatility/dashboard/app.py --server.port=$PORT --server.headless=true --server.address=0.0.0.0",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
